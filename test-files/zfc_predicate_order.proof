include "zfc_in.proof"

definition predicate transrelon(X, template \psi[2]) as \forall x\forall y\forall z(in(x,X)\wedge in(y,X)\wedge in(z,X)\wedge\psi(x,y)\wedge\psi(y,z)\to\psi(x,z))

definition predicate antisymrelon(X, template \psi[2]) as \forall x\forall y(in(x,X)\wedge in(y,X)\wedge\psi(x,y)\wedge\psi(y,x)\to equal(x,y))

definition predicate orderon(X, template \psi[2]) as transrelon(X,\psi)\wedge antisymrelon(X,\psi)

definition predicate irrefrelon(X, template \psi[2]) as \forall x(in(x,X)\to\neg(\psi(x,x)))

definition predicate linorder_core(X, template \psi[2]) as \forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x))

definition predicate linorder(X, template \psi[2]) as orderon(X,\psi)\wedge linorder_core(X,\psi)

definition predicate minimal_core(X, template \psi[2], template \phi[1], a) as \forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\neg(\psi(x,a)))

definition predicate minimal(X, template \psi[2], template \phi[1], a) as in(a,X)\wedge\phi(a)\wedge minimal_core(X,\psi,\phi,a)

definition predicate minimum_core(X, template \psi[2], template \phi[1], a) as \forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\psi(a,x))

definition predicate minimum(X, template \psi[2], template \phi[1], a) as in(a,X)\wedge\phi(a)\wedge minimum_core(X,\psi,\phi,a)

theorem irrefrelon_and_transrelon_implies_antisymrelon \forall X\forall^T\psi[2](irrefrelon(X,\psi)\wedge transrelon(X,\psi)\to antisymrelon(X,\psi)) {
  any X, template \psi[2] {
    assume irrefrelon(X,\psi)\wedge transrelon(X,\psi) {
      any x,y {
        assume in(x,X)\wedge in(y,X)\wedge\psi(x,y)\wedge\psi(y,x) {
          split irrefrelon(X,\psi)\wedge transrelon(X,\psi)
          split in(x,X)\wedge in(y,X)\wedge\psi(x,y)\wedge\psi(y,x)
          connect in(x,X)\wedge in(y,X)\wedge in(x,X)\wedge\psi(x,y)\wedge\psi(y,x)
          apply invoke transrelon(X,\psi) for x,y,x
          apply invoke irrefrelon(X,\psi) for x
          contradict \psi(x,x)
          explode equal(x,y)
        }
      }
      fold for antisymrelon conclude antisymrelon(X,\psi)
    }
  }
}

theorem irrefrelon_and_transrelon_implies_orderon \forall X\forall^T\psi[2](irrefrelon(X,\psi)\wedge transrelon(X,\psi)\to orderon(X,\psi)) {
  any X, template \psi[2] {
    assume irrefrelon(X,\psi)\wedge transrelon(X,\psi) {
      split irrefrelon(X,\psi)\wedge transrelon(X,\psi)
      apply invoke irrefrelon_and_transrelon_implies_antisymrelon for X,\psi
      connect orderon(X,\psi)
    }
  }
}

theorem minimum_implies_minimal \forall X\forall^T\psi[2]\forall^T\phi[1]\forall a(antisymrelon(X,\psi)\wedge minimum(X,\psi,\phi,a)\to minimal(X,\psi,\phi,a)) {
  any X, template \psi[2], template \phi[1], a {
    assume antisymrelon(X,\psi)\wedge minimum(X,\psi,\phi,a) {
      split antisymrelon(X,\psi)\wedge minimum(X,\psi,\phi,a)
      split minimum(X,\psi,\phi,a)
      any x {
        assume in(x,X)\wedge\phi(x)\wedge neq(x,a) {
          split in(x,X)\wedge\phi(x)\wedge neq(x,a)
          deny \psi(x,a) {
            apply invoke minimum_core(X,\psi,\phi,a) for x
            connect in(a,X)\wedge in(x,X)\wedge\psi(a,x)\wedge\psi(x,a)
            apply invoke antisymrelon(X,\psi) for a,x
            contradict equal(a,x)
          }
        }
      }
      fold for minimal_core conclude minimal_core(X,\psi,\phi,a)
      connect minimal(X,\psi,\phi,a)
    }
  }
}

theorem linorder_and_minmal_implies_minimum \forall X\forall^T\psi[2]\forall^T\phi[1]\forall a(linorder(X,\psi)\wedge minimal(X,\psi,\phi,a)\to minimum(X,\psi,\phi,a)) {
  any X, template \psi[2], template \phi[1], a {
    assume linorder(X,\psi)\wedge minimal(X,\psi,\phi,a) {
      split linorder(X,\psi)\wedge minimal(X,\psi,\phi,a)
      split minimal(X,\psi,\phi,a)
      any x {
        assume in(x,X)\wedge\phi(x)\wedge neq(x,a) {
          apply invoke minimal_core(X,\psi,\phi,a) for x
          split in(x,X)\wedge\phi(x)\wedge neq(x,a)
          split 2 linorder(X,\psi)
          connect in(x,X)\wedge\phi(x)
          connect in(a,X)\wedge\phi(a)
          connect in(x,X)\wedge in(a,X)
          apply invoke linorder_core(X,\psi) for x,a
          divide \psi(x,a)\vee equal(x,a)\vee\psi(a,x)
            case \psi(x,a) {
              contradict \psi(x,a)
              explode \psi(a,x)
            }
            case equal(x,a) {
              contradict equal(x,a)
              explode \psi(a,x)
            }
            case \psi(a,x) {}
        }
      }
      fold for minimum_core conclude minimum_core(X,\psi,\phi,a)
      connect minimum(X,\psi,\phi,a)
    }
  }
}

definition predicate wellfounded(X, template \psi[2]) as \forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimal(X,\psi,\phi,a)))

definition predicate wellorder_core(X, template \psi[2]) as \forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimum(X,\psi,\phi,a)))

definition predicate wellorder(X, template \psi[2]) as orderon(X,\psi)\wedge wellorder_core(X,\psi)

theorem linorder_and_wellfounded_implies_wellorder \forall X\forall^T\psi[2](linorder(X,\psi)\wedge wellfounded(X,\psi)\to wellorder(X,\psi)) {
  any X, template \psi[2] {
    assume linorder(X,\psi)\wedge wellfounded(X,\psi) {
      split linorder(X,\psi)\wedge wellfounded(X,\psi)
      split linorder(X,\psi)
      any template \phi[1] {
        assume \exists z(in(z,X)\wedge\phi(z)) {
          apply invoke wellfounded(X,\psi) for \phi
          some a such \exists a(minimal(X,\psi,\phi,a)) {
            connect linorder(X,\psi)\wedge minimal(X,\psi,\phi,a)
            apply invoke linorder_and_minmal_implies_minimum for X,\psi,\phi,a
            lift for a conclude \exists a(minimum(X,\psi,\phi,a))
          }
        }
      }
      fold for wellorder_core conclude wellorder_core(X,\psi)
      connect wellorder(X,\psi)
    }
  }
}

theorem wellorder_implies_linorder \forall X\forall^T\psi[2](wellorder(X,\psi)\to linorder(X,\psi)) {
  any X, template \psi[2] {
    assume wellorder(X,\psi) {
      split wellorder(X,\psi)
      any x,y {
        assume in(x,X)\wedge in(y,X) {
          split in(x,X)\wedge in(y,X)
          pad equal(x,x) conclude equal(x,x)\vee equal(x,y)
          connect in(x,X)\wedge(equal(x,x)\vee equal(x,y))
          lift for x conclude \exists z(in(z,X)\wedge(equal(z,x)\vee equal(z,y)))
          apply invoke wellorder_core(X,\psi) for lambda z.equal(z,x)\vee equal(z,y)
          some a such \exists a(minimum(X,\psi,lambda z.equal(z,x)\vee equal(z,y),a)) {
            split minimum(X,\psi,lambda z.equal(z,x)\vee equal(z,y),a)
            apply law_of_excluded_middle for lambda.equal(x,y)
            divide equal(x,y)\vee neq(x,y)
              case equal(x,y) {
                pad equal(x,y) conclude \psi(x,y)\vee equal(x,y)\vee\psi(y,x)
              }
              case neq(x,y) {
                divide equal(a,x)\vee equal(a,y)
                  case equal(a,x) {
                    substitute minimum_core(X,\psi,lambda z.equal(z,x)\vee equal(z,y),a) for a:x
                    pad equal(y,y) conclude equal(y,x)\vee equal(y,y)
                    connect in(y,X)\wedge(equal(y,x)\vee equal(y,y))\wedge neq(y,x)
                    apply invoke minimum_core(X,\psi,lambda z.equal(z,x)\vee equal(z,y),x) for y
                    pad \psi(x,y) conclude \psi(x,y) \vee equal(x,y) \vee \psi(y,x)
                  }
                  case equal(a,y) {
                    substitute minimum_core(X,\psi,lambda z.equal(z,x)\vee equal(z,y),a) for a:y
                    pad equal(x,x) conclude equal(x,x)\vee equal(x,y)
                    connect in(x,X)\wedge(equal(x,x)\vee equal(x,y))\wedge neq(x,y)
                    apply invoke minimum_core(X,\psi,lambda z.equal(z,x)\vee equal(z,y),y) for x
                    pad \psi(y,x) conclude \psi(x,y)\vee equal(x,y)\vee\psi(y,x)
                  }
              }
          }
        }
      }
      fold for linorder_core conclude linorder_core(X,\psi)
      connect linorder(X,\psi)
    }
  }
}

theorem wellorder_implies_wellfounded \forall X\forall^T\psi[2](wellorder(X,\psi)\to wellfounded(X,\psi)) {
  any X, template \psi[2] {
    assume wellorder(X,\psi) {
      split wellorder(X,\psi)
      split 2 orderon(X,\psi)
      any template \phi[1] {
        assume \exists z(in(z,X)\wedge\phi(z)) {
          apply invoke wellorder_core(X,\psi) for \phi
          some a such \exists a(minimum(X,\psi,\phi,a)) {
            connect antisymrelon(X,\psi)\wedge minimum(X,\psi,\phi,a)
            apply invoke minimum_implies_minimal for X,\psi,\phi,a
            lift for a conclude \exists a(minimal(X,\psi,\phi,a))
          }
        }
      }
      fold for wellfounded conclude wellfounded(X,\psi)
    }
  }
}

theorem wellorder_equivalent_linorder_and_wellfounded \forall X\forall^T\psi[2](wellorder(X,\psi)\leftrightarrow linorder(X,\psi)\wedge wellfounded(X,\psi)) {
  any X, template \psi[2] {
    assume wellorder(X,\psi) {
      apply invoke wellorder_implies_linorder for X,\psi
      apply invoke wellorder_implies_wellfounded for X,\psi
      connect linorder(X,\psi)\wedge wellfounded(X,\psi)
    }
    assume linorder(X,\psi)\wedge wellfounded(X,\psi) {
      apply invoke linorder_and_wellfounded_implies_wellorder for X,\psi
    }
    connect wellorder(X,\psi)\leftrightarrow linorder(X,\psi)\wedge wellfounded(X,\psi)
  }
}

theorem transrelon_subset \forall X\forall^T\phi[2]\forall Y(transrelon(X,\phi)\wedge subset(Y,X)\to transrelon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume transrelon(X,\phi)\wedge subset(Y,X) {
      split transrelon(X,\phi)\wedge subset(Y,X)
      any x,y,z {
        assume in(x,Y)\wedge in(y,Y)\wedge in(z,Y)\wedge\phi(x,y)\wedge\phi(y,z) {
          split in(x,Y)\wedge in(y,Y)\wedge in(z,Y)\wedge\phi(x,y)\wedge\phi(y,z)
          connect in(x,Y)\wedge subset(Y,X)
          apply invoke subset(Y,X) for x
          connect in(y,Y)\wedge subset(Y,X)
          apply invoke subset(Y,X) for y
          connect in(z,Y)\wedge subset(Y,X)
          apply invoke subset(Y,X) for z
          connect in(x,X)\wedge in(y,X)\wedge in(z,X)\wedge\phi(x,y)\wedge\phi(y,z)
          apply invoke transrelon(X,\phi) for x,y,z
        }
      }
      fold for transrelon conclude transrelon(Y,\phi)
    }
  }
}

theorem antisymrelon_subset \forall X\forall^T\phi[2]\forall Y(antisymrelon(X,\phi)\wedge subset(Y,X)\to antisymrelon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume antisymrelon(X,\phi)\wedge subset(Y,X) {
      split antisymrelon(X,\phi)\wedge subset(Y,X)
      any x,y {
        assume in(x,Y)\wedge in(y,Y)\wedge\phi(x,y)\wedge\phi(y,x) {
          split in(x,Y)\wedge in(y,Y)\wedge\phi(x,y)\wedge\phi(y,x)
          apply invoke subset(Y,X) for x
          apply invoke subset(Y,X) for y
          connect in(x,X)\wedge in(y,X)\wedge\phi(x,y)\wedge\phi(y,x)
          apply invoke antisymrelon(X,\phi) for x,y
        }
      }
      fold for antisymrelon conclude antisymrelon(Y,\phi)
    }
  }
}

theorem orderon_subset \forall X\forall^T\phi[2]\forall Y(orderon(X,\phi)\wedge subset(Y,X)\to orderon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume orderon(X,\phi)\wedge subset(Y,X) {
      split orderon(X,\phi)\wedge subset(Y,X)
      split orderon(X,\phi)
      connect transrelon(X,\phi)\wedge subset(Y,X)
      apply invoke transrelon_subset for X,\phi,Y
      connect antisymrelon(X,\phi)\wedge subset(Y,X)
      apply invoke antisymrelon_subset for X,\phi,Y
      connect transrelon(Y,\phi)\wedge antisymrelon(Y,\phi)
      fold for orderon conclude orderon(Y,\phi)
    }
  }
}

theorem irrefrelon_subset \forall X\forall^T\phi[2]\forall Y(irrefrelon(X,\phi)\wedge subset(Y,X)\to irrefrelon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume irrefrelon(X,\phi)\wedge subset(Y,X) {
      split irrefrelon(X,\phi)\wedge subset(Y,X)
      any x {
        assume in(x,Y) {
          connect in(x,Y)\wedge subset(Y,X)
          apply invoke subset(Y,X) for x
          apply invoke irrefrelon(X,\phi) for x
        }
      }
      fold for irrefrelon conclude irrefrelon(Y,\phi)
    }
  }
}

theorem wellorder_subset \forall X\forall^T\psi[2]\forall Y(wellorder(X,\psi)\wedge subset(Y,X)\to wellorder(Y,\psi)) {
  any X, template \psi[2], Y {
    assume wellorder(X,\psi)\wedge subset(Y,X) {
      split wellorder(X,\psi)\wedge subset(Y,X)
      split wellorder(X,\psi)
      connect orderon(X,\psi)\wedge subset(Y,X)
      apply invoke orderon_subset for X,\psi,Y
      any template \chi[1] {
        assume \exists z(in(z,Y)\wedge\chi(z)) {
          some z such \exists z(in(z,Y)\wedge\chi(z)) {
            split in(z,Y)\wedge\chi(z)
            connect in(z,Y)\wedge subset(Y,X)
            apply invoke subset(Y,X) for z
            connect in(z,X)\wedge in(z,Y)\wedge\chi(z)
            lift for z conclude \exists z(in(z,X)\wedge in(z,Y)\wedge\chi(z))
          }
          apply invoke wellorder_core(X,\psi) for lambda w.in(w,Y)\wedge\chi(w)
          some a such \exists a(minimum(X,\psi,lambda w.in(w,Y)\wedge\chi(w),a)) {
            split minimum(X,\psi,lambda w.in(w,Y)\wedge\chi(w),a)
            any x {
              assume in(x,Y)\wedge\chi(x)\wedge neq(x,a) {
                split in(x,Y)\wedge\chi(x)\wedge neq(x,a)
                connect in(x,Y)\wedge subset(Y,X)
                apply invoke subset(Y,X) for x
                connect in(x,X)\wedge in(x,Y)\wedge\chi(x)\wedge neq(x,a)
                apply invoke minimum_core(X,\psi,lambda w.in(w,Y)\wedge\chi(w),a) for x
              }
            }
            fold for minimum_core conclude minimum_core(Y,\psi,\chi,a)
            connect minimum(Y,\psi,\chi,a)
            lift for a conclude \exists a(minimum(Y,\psi,\chi,a))
          }
        }
      }
      fold for wellorder_core conclude wellorder_core(Y,\psi)
      connect wellorder(Y,\psi)
    }
  }
}
