include "zfc_in.proof"

definition predicate transrelon(X, template \psi[2]) as \forall x\forall y\forall z(in(x,X)\wedge in(y,X)\wedge in(z,X)\to(\psi(x,y)\wedge\psi(y,z)\to\psi(x,z)))

definition predicate antisymrelon(X, template \psi[2]) as \forall x\forall y(in(x,X)\wedge in(y,X)\to(\psi(x,y)\wedge\psi(y,x)\to equal(x,y)))

definition predicate orderon(X, template \psi[2]) as transrelon(X,\psi)\wedge antisymrelon(X,\psi)

definition predicate irrefrelon(X, template \psi[2]) as \forall x(in(x,X)\to\neg(\psi(x,x)))

definition predicate linorder(X, template \psi[2]) as orderon(X,\psi)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x))

definition predicate minimal(X, template \psi[2], template \phi[1], a) as in(a,X)\wedge\phi(a)\wedge\forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\neg(\psi(x,a)))

definition predicate minimum(X, template \psi[2], template \phi[1], a) as in(a,X)\wedge\phi(a)\wedge\forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\psi(a,x))

theorem minimum_implies_minimal \forall X\forall^T\psi[2]\forall^T\phi[1]\forall a(antisymrelon(X,\psi)\wedge minimum(X,\psi,\phi,a)\to minimal(X,\psi,\phi,a)) {
  any X, template \psi[2], template \phi[1], a {
    assume antisymrelon(X,\psi)\wedge minimum(X,\psi,\phi,a) {
      split antisymrelon(X,\psi)\wedge minimum(X,\psi,\phi,a)
      expand minimum(X,\psi,\phi,a) for minimum
      split in(a,X)\wedge\phi(a)\wedge\forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\psi(a,x))
      any x {
        assume in(x,X)\wedge\phi(x)\wedge neq(x,a) {
          split in(x,X)\wedge\phi(x)\wedge neq(x,a)
          deny \psi(x,a) {
            apply invoke \forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\psi(a,x)) for x:x
            connect \psi(a,x)\wedge\psi(x,a)
            expand antisymrelon(X,\psi) for antisymrelon
            connect \phi(a)\wedge in(a,X)
            connect \phi(x)\wedge in(x,X)
            connect in(a,X)\wedge in(x,X)
            apply invoke \forall x\forall y(in(x,X)\wedge in(y,X)\to(\psi(x,y)\wedge\psi(y,x)\to equal(x,y))) for x:a,y:x
            invoke \psi(a,x)\wedge\psi(x,a)\to equal(a,x)
            contradict equal(a,x)
          }
        }
      }
      connect in(a,X)\wedge\phi(a)\wedge\forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\neg(\psi(x,a)))
      fold for minimal conclude minimal(X,\psi,\phi,a)
    }
  }
}

theorem linorder_and_minmal_implies_minimum \forall X\forall^T\psi[2]\forall^T\phi[1]\forall a(linorder(X,\psi)\wedge minimal(X,\psi,\phi,a)\to minimum(X,\psi,\phi,a)) {
  any X, template \psi[2], template \phi[1], a {
    assume linorder(X,\psi)\wedge minimal(X,\psi,\phi,a) {
      split linorder(X,\psi)\wedge minimal(X,\psi,\phi,a)
      expand minimal(X,\psi,\phi,a) for minimal
      split in(a,X)\wedge\phi(a)\wedge\forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\neg(\psi(x,a)))
      any x {
        assume in(x,X)\wedge\phi(x)\wedge neq(x,a) {
          apply invoke \forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\neg(\psi(x,a))) for x:x
          split in(x,X)\wedge\phi(x)\wedge neq(x,a)
          expand linorder(X,\psi) for linorder
          split 2 orderon(X,\psi)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x))
          connect in(x,X)\wedge\phi(x)
          connect in(a,X)\wedge\phi(a)
          connect in(x,X)\wedge in(a,X)
          apply invoke \forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x)) for x:x,y:a
          divide \psi(x,a)\vee equal(x,a)\vee\psi(a,x)
            case \psi(x,a) {
              contradict \psi(x,a)
              explode \psi(a,x)
            }
            case equal(x,a) {
              contradict equal(x,a)
              explode \psi(a,x)
            }
            case \psi(a,x) {}
        }
      }
      connect in(a,X)\wedge\phi(a)\wedge\forall x(in(x,X)\wedge\phi(x)\wedge neq(x,a)\to\psi(a,x))
      fold for minimum conclude minimum(X,\psi,\phi,a)
    }
  }
}

definition predicate wellfounded(X, template \psi[2]) as \forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimal(X,\psi,\phi,a)))

definition predicate wellorder(X, template \psi[2]) as orderon(X,\psi)\wedge\forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimum(X,\psi,\phi,a)))

theorem linorder_and_wellfounded_implies_wellorder \forall X\forall^T\psi[2](linorder(X,\psi)\wedge wellfounded(X,\psi)\to wellorder(X,\psi)) {
  any X, template \psi[2] {
    assume linorder(X,\psi)\wedge wellfounded(X,\psi) {
      split linorder(X,\psi)\wedge wellfounded(X,\psi)
      expand linorder(X,\psi) for linorder
      split orderon(X,\psi)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x))
      any template \phi[1] {
        assume \exists z(in(z,X)\wedge\phi(z)) {
          expand wellfounded(X,\psi) for wellfounded
          apply invoke \forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimal(X,\psi,\phi,a))) for \phi:\phi
          some a:a such \exists a(minimal(X,\psi,\phi,a)) {
            connect linorder(X,\psi)\wedge minimal(X,\psi,\phi,a)
            apply invoke linorder_and_minmal_implies_minimum for X:X,\psi:\psi,\phi:\phi,a:a
            lift for a:a conclude \exists a(minimum(X,\psi,\phi,a))
          }
        }
      }
      connect orderon(X,\psi)\wedge\forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimum(X,\psi,\phi,a)))
      fold for wellorder conclude wellorder(X,\psi)
    }
  }
}

theorem wellorder_implies_linorder \forall X\forall^T\psi[2](wellorder(X,\psi)\to linorder(X,\psi)) {
  any X, template \psi[2] {
    assume wellorder(X,\psi) {
      expand wellorder(X,\psi) for wellorder
      split orderon(X,\psi)\wedge\forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimum(X,\psi,\phi,a)))
      any x,y {
        assume in(x,X)\wedge in(y,X) {
          split in(x,X)\wedge in(y,X)
          pad equal(x,x) conclude equal(x,x)\vee equal(x,y)
          connect in(x,X)\wedge(equal(x,x)\vee equal(x,y))
          lift for z:x conclude \exists z(in(z,X)\wedge(equal(z,x)\vee equal(z,y)))
          apply invoke \forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimum(X,\psi,\phi,a))) for \phi:lambda z.equal(z,x)\vee equal(z,y)
          some a:a such \exists a(minimum(X,\psi,lambda z.equal(z,x)\vee equal(z,y),a)) {
            expand minimum(X,\psi,lambda z.equal(z,x)\vee equal(z,y),a) for minimum
            split in(a,X)\wedge(equal(a,x)\vee equal(a,y))\wedge\forall z(in(z,X)\wedge(equal(z,x)\vee equal(z,y))\wedge neq(z,a)\to\psi(a,z))
            apply law_of_excluded_middle for \phi:lambda.equal(x,y)
            divide equal(x,y)\vee neq(x,y)
              case equal(x,y) {
                pad equal(x,y) conclude \psi(x,y)\vee equal(x,y)\vee\psi(y,x)
              }
              case neq(x,y) {
                divide equal(a,x)\vee equal(a,y)
                  case equal(a,x) {
                    substitute \forall z(in(z,X)\wedge(equal(z,x)\vee equal(z,y))\wedge neq(z,a)\to\psi(a,z)) for a:x
                    pad equal(y,y) conclude equal(y,x)\vee equal(y,y)
                    connect in(y,X)\wedge(equal(y,x)\vee equal(y,y))\wedge neq(y,x)
                    apply invoke \forall z(in(z,X)\wedge(equal(z,x)\vee equal(z,y))\wedge neq(z,x)\to\psi(x,z)) for z:y
                    pad \psi(x,y) conclude \psi(x,y) \vee equal(x,y) \vee \psi(y,x)
                  }                                
                  case equal(a,y) {
                    substitute \forall z(in(z,X)\wedge(equal(z,x)\vee equal(z,y))\wedge neq(z,a)\to\psi(a,z)) for a:y
                    pad equal(x,x) conclude equal(x,x)\vee equal(x,y)
                    connect in(x,X)\wedge(equal(x,x)\vee equal(x,y))\wedge neq(x,y)
                    apply invoke \forall z(in(z,X)\wedge(equal(z,x)\vee equal(z,y))\wedge neq(z,y)\to\psi(y,z)) for z:x
                    pad \psi(y,x) conclude \psi(x,y)\vee equal(x,y)\vee\psi(y,x)
                  }
              }
          }
        }
      }
      connect orderon(X,\psi)\wedge\forall x\forall y(in(x,X)\wedge in(y,X)\to\psi(x,y)\vee equal(x,y)\vee\psi(y,x))
      fold for linorder conclude linorder(X,\psi)
    }
  }
}

theorem wellorder_implies_wellfounded \forall X\forall^T\psi[2](wellorder(X,\psi)\to wellfounded(X,\psi)) {
  any X, template \psi[2] {
    assume wellorder(X,\psi) {
      expand wellorder(X,\psi) for wellorder
      split orderon(X,\psi)\wedge\forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimum(X,\psi,\phi,a)))
      expand orderon(X,\psi) for orderon
      split 2 transrelon(X,\psi)\wedge antisymrelon(X,\psi)
      any template \phi[1] {
        assume \exists z(in(z,X)\wedge\phi(z)) {
          apply invoke \forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimum(X,\psi,\phi,a))) for \phi:\phi
          some a:a such \exists a(minimum(X,\psi,\phi,a)) {
            connect antisymrelon(X,\psi)\wedge minimum(X,\psi,\phi,a)
            apply invoke minimum_implies_minimal for X:X,\psi:\psi,\phi:\phi,a:a
            lift for a:a conclude \exists a(minimal(X,\psi,\phi,a))
          }
        }
      }
      fold for wellfounded conclude wellfounded(X,\psi)
    }
  }
}

theorem wellorder_equivalent_linorder_and_wellfounded \forall X\forall^T\psi[2](wellorder(X,\psi)\leftrightarrow linorder(X,\psi)\wedge wellfounded(X,\psi)) {
  any X, template \psi[2] {
    assume wellorder(X,\psi) {
      apply invoke wellorder_implies_linorder for X:X,\psi:\psi
      apply invoke wellorder_implies_wellfounded for X:X,\psi:\psi
      connect linorder(X,\psi)\wedge wellfounded(X,\psi)
    }
    assume linorder(X,\psi)\wedge wellfounded(X,\psi) {
      apply invoke linorder_and_wellfounded_implies_wellorder for X:X,\psi:\psi
    }
    connect wellorder(X,\psi)\leftrightarrow linorder(X,\psi)\wedge wellfounded(X,\psi)
  }
}

theorem transrelon_subset \forall X\forall^T\phi[2]\forall Y(transrelon(X,\phi)\wedge subset(Y,X)\to transrelon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume transrelon(X,\phi)\wedge subset(Y,X) {
      split transrelon(X,\phi)\wedge subset(Y,X)
      any x,y,z {
        assume in(x,Y)\wedge in(y,Y)\wedge in(z,Y) {
          split in(x,Y)\wedge in(y,Y)\wedge in(z,Y)
          connect in(x,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:x,x:Y,y:X
          connect in(y,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:y,x:Y,y:X
          connect in(z,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:z,x:Y,y:X
          connect in(x,X)\wedge in(y,X)\wedge in(z,X)
          expand transrelon(X,\phi) for transrelon
          apply invoke \forall x\forall y\forall z(in(x,X)\wedge in(y,X)\wedge in(z,X)\to(\phi(x,y)\wedge\phi(y,z)\to\phi(x,z))) for x:x,y:y,z:z
        }
      }
      fold for transrelon conclude transrelon(Y,\phi)
    }
  }
}

theorem antisymrelon_subset \forall X\forall^T\phi[2]\forall Y(antisymrelon(X,\phi)\wedge subset(Y,X)\to antisymrelon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume antisymrelon(X,\phi)\wedge subset(Y,X) {
      split antisymrelon(X,\phi)\wedge subset(Y,X)
      any x,y {
        assume in(x,Y)\wedge in(y,Y) {
          split in(x,Y)\wedge in(y,Y)
          connect in(x,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:x,x:Y,y:X
          connect in(y,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:y,x:Y,y:X
          connect in(x,X)\wedge in(y,X)
          expand antisymrelon(X,\phi) for antisymrelon
          apply invoke \forall x\forall y(in(x,X)\wedge in(y,X)\to(\phi(x,y)\wedge\phi(y,x)\to equal(x,y))) for x:x,y:y
        }
      }
      fold for antisymrelon conclude antisymrelon(Y,\phi)
    }
  }
}

theorem orderon_subset \forall X\forall^T\phi[2]\forall Y(orderon(X,\phi)\wedge subset(Y,X)\to orderon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume orderon(X,\phi)\wedge subset(Y,X) {
      split orderon(X,\phi)\wedge subset(Y,X)
      expand orderon(X,\phi) for orderon
      split transrelon(X,\phi)\wedge antisymrelon(X,\phi)
      connect transrelon(X,\phi)\wedge subset(Y,X)
      apply invoke transrelon_subset for X:X,\phi:\phi,Y:Y
      connect antisymrelon(X,\phi)\wedge subset(Y,X)
      apply invoke antisymrelon_subset for X:X,\phi:\phi,Y:Y
      connect transrelon(Y,\phi)\wedge antisymrelon(Y,\phi)
      fold for orderon conclude orderon(Y,\phi)
    }
  }
}

theorem irrefrelon_subset \forall X\forall^T\phi[2]\forall Y(irrefrelon(X,\phi)\wedge subset(Y,X)\to irrefrelon(Y,\phi)) {
  any X, template \phi[2], Y {
    assume irrefrelon(X,\phi)\wedge subset(Y,X) {
      split irrefrelon(X,\phi)\wedge subset(Y,X)
      any x {
        assume in(x,Y) {
          connect in(x,Y)\wedge subset(Y,X)
          apply invoke subset_cor1 for z:x,x:Y,y:X
          expand irrefrelon(X,\phi) for irrefrelon
          apply invoke \forall x(in(x,X)\to\neg(\phi(x,x))) for x:x
        }
      }
      fold for irrefrelon conclude irrefrelon(Y,\phi)
    }
  }
}

theorem wellorder_subset \forall X\forall^T\psi[2]\forall Y(wellorder(X,\psi)\wedge subset(Y,X)\to wellorder(Y,\psi)) {
  any X, template \psi[2], Y {
    assume wellorder(X,\psi)\wedge subset(Y,X) {
      split wellorder(X,\psi)\wedge subset(Y,X)
      expand wellorder(X,\psi) for wellorder
      split orderon(X,\psi)\wedge\forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimum(X,\psi,\phi,a)))
      connect orderon(X,\psi)\wedge subset(Y,X)
      apply invoke orderon_subset for X:X,\phi:\psi,Y:Y
      any template \chi[1] {
        assume \exists z(in(z,Y)\wedge\chi(z)) {
          some z:z such \exists z(in(z,Y)\wedge\chi(z)) {
            split in(z,Y)\wedge\chi(z)
            connect in(z,Y)\wedge subset(Y,X)
            apply invoke subset_cor1 for z:z,x:Y,y:X
            connect in(z,X)\wedge in(z,Y)\wedge\chi(z)
            lift for z:z conclude \exists z(in(z,X)\wedge in(z,Y)\wedge\chi(z))
          }
          apply invoke \forall^T\phi[1](\exists z(in(z,X)\wedge\phi(z))\to\exists a(minimum(X,\psi,\phi,a))) for \phi:lambda w.in(w,Y)\wedge\chi(w)
          some a:a such \exists a(minimum(X,\psi,lambda w.in(w,Y)\wedge\chi(w),a)) {
            expand minimum(X,\psi,lambda w.in(w,Y)\wedge\chi(w),a) for minimum
            split in(a,X)\wedge in(a,Y)\wedge\chi(a)\wedge\forall x(in(x,X)\wedge in(x,Y)\wedge\chi(x)\wedge neq(x,a)\to\psi(a,x))
            any x {
              assume in(x,Y)\wedge\chi(x)\wedge neq(x,a) {
                split in(x,Y)\wedge\chi(x)\wedge neq(x,a)
                connect in(x,Y)\wedge subset(Y,X)
                apply invoke subset_cor1 for z:x,x:Y,y:X
                connect in(x,X)\wedge in(x,Y)\wedge\chi(x)\wedge neq(x,a)
                apply invoke \forall x(in(x,X)\wedge in(x,Y)\wedge\chi(x)\wedge neq(x,a)\to\psi(a,x)) for x:x
              }
            }
            connect in(a,Y)\wedge\chi(a)\wedge\forall x(in(x,Y)\wedge\chi(x)\wedge neq(x,a)\to\psi(a,x))
            fold for minimum conclude minimum(Y,\psi,\chi,a)
            lift for a:a conclude \exists a(minimum(Y,\psi,\chi,a))
          }
        }
      }
      connect orderon(Y,\psi)\wedge\forall^T\phi[1](\exists z(in(z,Y)\wedge\phi(z))\to\exists a(minimum(Y,\psi,\phi,a)))
      fold for wellorder conclude wellorder(Y,\psi)
    }
  }
}

definition predicate trans(x) as \forall y\forall z(in(z,y)\wedge in(y,x)\to in(z,x))

definition predicate ordinal(\alpha) as trans(\alpha)\wedge irrefrelon(\alpha,lambda x,y.in(x,y))\wedge wellorder(\alpha,lambda x,y.in(x,y))

definition predicate sucordinal(\alpha) as ordinal(\alpha)\wedge\exists\beta(ordinal(\beta)\wedge\forall\gamma(in(\gamma,\alpha)\leftrightarrow in(\gamma,\beta)\vee equal(\gamma,\beta)))

definition predicate natural(n) as (\forall x(notin(x,n))\vee(sucordinal(n)))\wedge\forall m(in(m,n)\to\forall x(notin(x,m))\vee sucordinal(m))

/*definition predicate finite(x) as \exists n\exists^T\psi[2](natural(n)\wedge\forall m(in(m,n)\to\exists!a(in(a,x)\wedge\psi(m,a)))\wedge\forall a(in(a,x)\to\exists!a(in(a,n)\wedge\psi(a,m))))*/
