include "zfc_finite_removal.proof"

definition predicate rel(R) as \forall z (in(z, R) \to \exists x \exists y (equal(z, op(x, y))))

definition predicate dom(R, X) as \forall x (in(x, X) \leftrightarrow \exists y (in(op(x, y), R)))

definition predicate ran(R, Y) as \forall y (in(y, Y) \leftrightarrow \exists x (in(op(x, y), R)))

definition predicate fun(f) as rel(f) \wedge \forall x \forall y \forall y' (in(op(x, y), f) \wedge in(op(x, y'), f) \to equal(y, y'))

definition predicate inj(f) as fun(f) \wedge \forall x \forall x' \forall y (in(op(x, y), f) \wedge in(op(x', y), f) \to equal(x, x'))

definition predicate surj(f, X, Y) as fun(f) \wedge dom(f, X) \wedge ran(f, Y)

definition predicate bij(f, X, Y) as inj(f) \wedge surj(f, X, Y)

definition predicate equipotent(X, Y) as \exists f (bij(f, X, Y))

definition predicate size(X, n) as natural(n) \wedge equipotent(n, X)

definition predicate finite(X) as \exists n (size(X, n))

theorem singleton_op_is_rel \forall x \forall y (rel(singleton(op(x, y)))) {
  any x, y {
    any z {
      assume in(z, singleton(op(x, y))) {
        apply invoke rightward singleton_characterization for op(x, y), z
        lift for x, y conclude \exists x \exists y (equal(z, op(x, y)))
      }
    }
    fold for rel conclude rel(singleton(op(x, y)))
  }
}

theorem singleton_op_dom \forall x \forall y (dom(singleton(op(x, y)), singleton(x))) {
  any x, y {
    any p {
      assume in(p, singleton(x)) {
        apply invoke rightward singleton_characterization for x, p
        substitute equal(op(x, y), op(x, y)) for x[1]: p
        apply invoke leftward singleton_characterization for op(x, y), op(p, y)
        lift for y conclude \exists q (in(op(p, q), singleton(op(x, y))))
      }
      assume \exists q (in(op(p, q), singleton(op(x, y)))) {
        some q such \exists q (in(op(p, q), singleton(op(x, y)))) {
          apply invoke rightward singleton_characterization for op(x, y), op(p, q)
          apply invoke op_characterization for p, q, x, y
          split 1 equal(p, x) \wedge equal(q, y)
          apply invoke leftward singleton_characterization for x, p
        }
      }
      connect in(p, singleton(x)) \leftrightarrow \exists q (in(op(p, q), singleton(op(x, y))))
    }
    fold for dom conclude dom(singleton(op(x, y)), singleton(x))
  }
}

theorem singleton_op_is_fun \forall x \forall y (fun(singleton(op(x, y)))) {
  any x, y {
    apply singleton_op_is_rel for x, y
    any p, q, q' {
      assume in(op(p, q), singleton(op(x, y))) \wedge in(op(p, q'), singleton(op(x, y))) {
        split in(op(p, q), singleton(op(x, y))) \wedge in(op(p, q'), singleton(op(x, y)))
        apply invoke rightward singleton_characterization for op(x, y), op(p, q)
        apply invoke rightward singleton_characterization for op(x, y), op(p, q')
        substitute equal(op(x, y), op(p, q)) for op(x, y): op(p, q')
        apply invoke op_characterization for p, q', p, q
        split 2 equal(p, p) \wedge equal(q', q)
      }
    }
    connect fun(singleton(op(x, y)))
  }
}

theorem adding_op_rel \forall R \forall x \forall y (rel(R) \to rel(adj(R, op(x, y)))) {
  any R, x, y {
    assume rel(R) {
      any z {
        assume in(z, adj(R, op(x, y))) {
          apply invoke rightward adj_existence for R, op(x, y), z
          divide in(z, R) \vee equal(z, op(x, y))
            case in(z, R) {
              apply invoke rel(R) for z
            }
            case equal(z, op(x, y)) {
              lift for x, y conclude \exists x \exists y (equal(z, op(x, y)))
            }
        }
      }
      fold for rel conclude rel(adj(R, op(x, y)))
    }
  }
}

theorem adding_op_dom \forall R \forall X \forall x \forall y (dom(R, X) \to dom(adj(R, op(x, y)), adj(X, x))) {
  any R, X, x, y {
    assume dom(R, X) {
      any p {
        assume in(p, adj(X, x)) {
          apply invoke rightward adj_existence for X, x, p
          divide in(p, X) \vee equal(p, x)
            case in(p, X) {
              apply invoke rightward dom(R, X) for p
              some q such \exists q (in(op(p, q), R)) {
                pad in(op(p, q), R) conclude in(op(p, q), R) \vee equal(op(p, q), op(x, y))
                apply invoke leftward adj_existence for R, op(x, y), op(p, q)
                lift for q conclude \exists q (in(op(p, q), adj(R, op(x, y))))
              }
            }
            case equal(p, x) {
              substitute equal(op(x, y), op(x, y)) for x[1]: p
              pad equal(op(p, y), op(x, y)) conclude in(op(p, y), R) \vee equal(op(p, y), op(x, y))
              apply invoke leftward adj_existence for R, op(x, y), op(p, y)
              lift for y conclude \exists q (in(op(p, q), adj(R, op(x, y))))
            }
        }
        assume \exists q (in(op(p, q), adj(R, op(x, y)))) {
          some q such \exists q (in(op(p, q), adj(R, op(x, y)))) {
            apply invoke rightward adj_existence for R, op(x, y), op(p, q)
            divide in(op(p, q), R) \vee equal(op(p, q), op(x, y))
              case in(op(p, q), R) {
                lift for q conclude \exists q (in(op(p, q), R))
                apply invoke leftward dom(R, X) for p
                pad in(p, X) conclude in(p, X) \vee equal(p, x)
                apply invoke leftward adj_existence for X, x, p
              }
              case equal(op(p, q), op(x, y)) {
                apply invoke op_characterization for p, q, x, y
                split 1 equal(p, x) \wedge equal(q, y)
                pad equal(p, x) conclude in(p, X) \vee equal(p, x)
                apply invoke leftward adj_existence for X, x, p
              }
          }
        }
        connect in(p, adj(X, x)) \leftrightarrow \exists q (in(op(p, q), adj(R, op(x, y))))
      }
      fold for dom conclude dom(adj(R, op(x, y)), adj(X, x))
    }
  }
}

theorem adding_op_ran \forall R \forall Y \forall x \forall y (ran(R, Y) \to ran(adj(R, op(x, y)), adj(Y, y))) {
  any R, Y, x, y {
    assume ran(R, Y) {
      any q {
        assume in(q, adj(Y, y)) {
          apply invoke rightward adj_existence for Y, y, q
          divide in(q, Y) \vee equal(q, y)
            case in(q, Y) {
              apply invoke rightward ran(R, Y) for q
              some p such \exists p (in(op(p, q), R)) {
                pad in(op(p, q), R) conclude in(op(p, q), R) \vee equal(op(p, q), op(x, y))
                apply invoke leftward adj_existence for R, op(x, y), op(p, q)
                lift for p conclude \exists p (in(op(p, q), adj(R, op(x, y))))
              }
            }
            case equal(q, y) {
              substitute equal(op(x, y), op(x, y)) for y[1]: q
              pad equal(op(x, q), op(x, y)) conclude in(op(x, q), R) \vee equal(op(x, q), op(x, y))
              apply invoke leftward adj_existence for R, op(x, y), op(x, q)
              lift for x conclude \exists p (in(op(p, q), adj(R, op(x, y))))
            }
        }
        assume \exists p (in(op(p, q), adj(R, op(x, y)))) {
          some p such \exists p (in(op(p, q), adj(R, op(x, y)))) {
            apply invoke rightward adj_existence for R, op(x, y), op(p, q)
            divide in(op(p, q), R) \vee equal(op(p, q), op(x, y))
              case in(op(p, q), R) {
                lift for p conclude \exists p (in(op(p, q), R))
                apply invoke leftward ran(R, Y) for q
                pad in(q, Y) conclude in(q, Y) \vee equal(q, y)
                apply invoke leftward adj_existence for Y, y, q
              }
              case equal(op(p, q), op(x, y)) {
                apply invoke op_characterization for p, q, x, y
                split 2 equal(p, x) \wedge equal(q, y)
                pad equal(q, y) conclude in(q, Y) \vee equal(q, y)
                apply invoke leftward adj_existence for Y, y, q
              }
          }
        }
        connect in(q, adj(Y, y)) \leftrightarrow \exists p (in(op(p, q), adj(R, op(x, y))))
      }
      fold for ran conclude ran(adj(R, op(x, y)), adj(Y, y))
    }
  }
}

theorem adding_op_fun \forall f \forall x \forall y (fun(f) \wedge \neg(\exists q (in(op(x, q), f))) \to fun(adj(f, op(x, y)))) {
  any f, x, y {
    assume fun(f) \wedge \neg(\exists q (in(op(x, q), f))) {
      split fun(f) \wedge \neg(\exists q (in(op(x, q), f)))
      split fun(f)
      apply invoke adding_op_rel for f, x, y
      any p, q, q' {
        assume in(op(p, q), adj(f, op(x, y))) \wedge in(op(p, q'), adj(f, op(x, y))) {
          split in(op(p, q), adj(f, op(x, y))) \wedge in(op(p, q'), adj(f, op(x, y)))
          apply invoke rightward adj_existence for f, op(x, y), op(p, q)
          apply invoke rightward adj_existence for f, op(x, y), op(p, q')
          divide in(op(p, q), f) \vee equal(op(p, q), op(x, y))
            case in(op(p, q), f) {
              divide in(op(p, q'), f) \vee equal(op(p, q'), op(x, y))
                case in(op(p, q'), f) {
                  connect in(op(p, q), f) \wedge in(op(p, q'), f)
                  apply invoke \forall x \forall y \forall y' (in(op(x, y), f) \wedge in(op(x, y'), f) \to equal(y, y')) for p, q, q'
                }
                case equal(op(p, q'), op(x, y)) {
                  apply invoke op_characterization for p, q', x, y
                  split 1 equal(p, x) \wedge equal(q', y)
                  substitute \neg(\exists q (in(op(x, q), f))) for x: p
                  lift for q conclude \exists q (in(op(p, q), f))
                  contradict \exists q (in(op(p, q), f))
                  explode equal(q, q')
                }
            }
            case equal(op(p, q), op(x, y)) {
              divide in(op(p, q'), f) \vee equal(op(p, q'), op(x, y))
                case in(op(p, q'), f) {
                  apply invoke op_characterization for p, q, x, y
                  split 1 equal(p, x) \wedge equal(q, y)
                  substitute \neg(\exists q (in(op(x, q), f))) for x: p
                  lift for q' conclude \exists q' (in(op(p, q'), f))
                  contradict \exists q (in(op(p, q), f))
                  explode equal(q, q')
                }
                case equal(op(p, q'), op(x, y)) {
                  apply invoke op_characterization for p, q, x, y
                  split 2 equal(p, x) \wedge equal(q, y)
                  apply invoke op_characterization for p, q', x, y
                  split 2 equal(p, x) \wedge equal(q', y)
                  substitute equal(q, y) for y: q'
                }
            }
        }
      }
      connect fun(adj(f, op(x, y)))
    }
  }
}

theorem adding_op_inj \forall f \forall x \forall y (inj(f) \wedge \neg(\exists q (in(op(x, q), f))) \wedge \neg(\exists p(in(op(p, y), f))) \to inj(adj(f, op(x, y)))) {
  any f, x, y {
    assume inj(f) \wedge \neg(\exists q (in(op(x, q), f))) \wedge \neg(\exists p (in(op(p, y), f))) {
      split inj(f) \wedge \neg(\exists q (in(op(x, q), f))) \wedge \neg(\exists p(in(op(p, y), f)))
      split inj(f)
      connect fun(f) \wedge \neg(\exists q(in(op(x, q), f)))
      apply invoke adding_op_fun for f, x, y
      any p, p', q {
        assume in(op(p, q), adj(f, op(x, y))) \wedge in(op(p', q), adj(f, op(x, y))) {
          split in(op(p, q), adj(f, op(x, y))) \wedge in(op(p', q), adj(f, op(x, y)))
          apply invoke rightward adj_existence for f, op(x, y), op(p, q)
          apply invoke rightward adj_existence for f, op(x, y), op(p', q)
          divide in(op(p, q), f) \vee equal(op(p, q), op(x, y))
            case in(op(p, q), f) {
              divide in(op(p', q), f) \vee equal(op(p', q), op(x, y))
                case in(op(p', q), f) {
                  connect in(op(p, q), f) \wedge in(op(p', q), f)
                  apply invoke \forall x \forall x' \forall y (in(op(x, y), f) \wedge in(op(x', y), f) \to equal(x, x')) for p, p', q
                }
                case equal(op(p', q), op(x, y)) {
                  apply invoke op_characterization for p', q, x, y
                  split 2 equal(p', x) \wedge equal(q, y)
                  substitute \neg(\exists p (in(op(p, y), f))) for y: q
                  lift for p conclude \exists p (in(op(p, q), f))
                  contradict \exists p (in(op(p, q), f))
                  explode equal(p, p')
                }
            }
            case equal(op(p, q), op(x, y)) {
              divide in(op(p', q), f) \vee equal(op(p', q), op(x, y))
                case in(op(p', q), f) {
                  apply invoke op_characterization for p, q, x, y
                  split 2 equal(p, x) \wedge equal(q, y)
                  substitute \neg(\exists p (in(op(p, y), f))) for y: q
                  lift for p' conclude \exists p' (in(op(p', q), f))
                  contradict \exists p (in(op(p, q), f))
                  explode equal(p, p')
                }
                case equal(op(p', q), op(x, y)) {
                  apply invoke op_characterization for p, q, x, y
                  split 1 equal(p, x) \wedge equal(q, y)
                  apply invoke op_characterization for p', q, x, y
                  split 1 equal(p', x) \wedge equal(q, y)
                  substitute equal(p, x) for x: p'
                }
            }
        }
      }
      connect inj(adj(f, op(x, y)))
    }
  }
}

theorem adding_op_bij \forall f \forall X \forall Y \forall x \forall y (bij(f, X, Y) \wedge \neg(\exists q (in(op(x, q), f))) \wedge \neg(\exists p(in(op(p, y), f))) \to bij(adj(f, op(x, y)), adj(X, x), adj(Y, y))) {
  any f, X, Y, x, y {
    assume bij(f, X, Y) \wedge \neg(\exists q (in(op(x, q), f))) \wedge \neg(\exists p(in(op(p, y), f))) {
      split bij(f, X, Y) \wedge \neg(\exists q (in(op(x, q), f))) \wedge \neg(\exists p(in(op(p, y), f)))
      split bij(f, X, Y)
      split inj(f)
      connect inj(f) \wedge \neg(\exists q(in(op(x, q), f))) \wedge \neg(\exists p(in(op(p, y), f)))
      apply invoke adding_op_inj for f, x, y
      split inj(adj(f, op(x, y)))
      split surj(f, X, Y)
      apply invoke adding_op_dom for f, X, x, y
      apply invoke adding_op_ran for f, Y, x, y
      connect surj(adj(f, op(x, y)), adj(X, x), adj(Y, y))
      connect bij(adj(f, op(x, y)), adj(X, x), adj(Y, y))
    }
  }
}

theorem finite_adj \forall Y \forall y (finite(Y) \to finite(adj(Y, y))) {
  any Y, y {
    assume finite(Y) {
      apply law_of_excluded_middle for \lambda^P. in(y, Y)
      divide in(y, Y) \vee notin(y, Y)
        case in(y, Y) {
          any z {
            assume in(z, adj(Y, y)) {
              apply invoke rightward adj_existence for Y, y, z
              divide in(z, Y) \vee equal(z, y)
                case in(z, Y) {}
                case equal(z, y) {
                  substitute in(y, Y) for y: z
                }
            }
            assume in(z, Y) {
              pad in(z, Y) conclude in(z, Y) \vee equal(z, y)
              apply invoke leftward adj_existence for Y, y, z
            }
            connect in(z, adj(Y, y)) \leftrightarrow in(z, Y)
          }
          fold for equal conclude equal(adj(Y, y), Y)
          substitute finite(Y) for Y: adj(Y, y)
        }
        case notin(y, Y) {
          some n such finite(Y) {
            split size(Y, n)
            some f such equipotent(n, Y) {
              split bij(f, n, Y)
              split surj(f, n, Y)
              deny \exists q (in(op(n, q), f)) {
                apply invoke leftward dom(f, n) for n
                apply invoke natural_is_irrefrelon for n
                contradict in(n, n)
              }
              deny \exists p (in(op(p, y), f)) {
                apply invoke leftward ran(f, Y) for y
                contradict in(y, Y)
              }
              connect bij(f, n, Y) \wedge \neg(\exists q (in(op(n, q), f))) \wedge \neg(\exists p (in(op(p, y), f)))
              apply invoke adding_op_bij for f, n, Y, n, y
              fold for suc conclude bij(adj(f, op(n, y)), suc(n), adj(Y, y))
              lift for adj(f, op(n, y)) conclude \exists f' (bij(f', suc(n), adj(Y, y)))
              fold for equipotent conclude equipotent(suc(n), adj(Y, y))
              apply invoke rightward suc_of_natural_is_natural_and_vice_versa for n
              connect size(adj(Y, y), suc(n))
              lift for suc(n) conclude \exists n' (size(adj(Y, y), n'))
              fold for finite conclude finite(adj(Y, y))
            }
          }
        }
    }
  }
}

theorem removing_op_rel \forall R \forall x \forall y (rel(R) \to rel(rem(R, op(x, y)))) {
  any R, x, y {
    assume rel(R) {
      any z {
        assume in(z, rem(R, op(x, y))) {
          apply invoke rightward rem_existence for R, op(x, y), z
          split 1 in(z, R) \wedge neq(z, op(x, y))
          apply invoke rel(R) for z
        }
      }
      fold for rel conclude rel(rem(R, op(x, y)))
    }
  }
}

theorem removing_op_dom \forall f \forall X \forall x \forall y (fun(f) \wedge dom(f, X) \wedge in(op(x, y), f) \to dom(rem(f, op(x, y)), rem(X, x))) {
  any f, X, x, y {
    assume fun(f) \wedge dom(f, X) \wedge in(op(x, y), f) {
      split fun(f) \wedge dom(f, X) \wedge in(op(x, y), f)
      split fun(f)
      any p {
        assume in(p, rem(X, x)) {
          apply invoke rightward rem_existence for X, x, p
          split in(p, X) \wedge neq(p, x)
          apply invoke rightward dom(f, X) for p
          some q such \exists q (in(op(p, q), f)) {
            deny equal(op(p, q), op(x, y)) {
              apply invoke op_characterization for p, q, x, y
              split 1 equal(p, x) \wedge equal(q, y)
              contradict equal(p, x)
            }
            connect in(op(p, q), f) \wedge neq(op(p, q), op(x, y))
            apply invoke leftward rem_existence for f, op(x, y), op(p, q)
            lift for q conclude \exists q (in(op(p, q), rem(f, op(x, y))))
          }
        }
        assume \exists q (in(op(p, q), rem(f, op(x, y)))) {
          some q such \exists q (in(op(p, q), rem(f, op(x, y)))) {
            apply invoke rightward rem_existence for f, op(x, y), op(p, q)
            split in(op(p, q), f) \wedge neq(op(p, q), op(x, y))
            lift for q conclude \exists q (in(op(p, q), f))
            apply invoke leftward dom(f, X) for p
            apply law_of_excluded_middle for \lambda^P. in(op(x, y), f)
            deny equal(p, x) {
              substitute in(op(x, y), f) for x: p
              connect in(op(p, q), f) \wedge in(op(p, y), f)
              apply invoke \forall x \forall y \forall y' (in(op(x, y), f) \wedge in(op(x, y'), f) \to equal(y, y')) for p, q, y
              substitute neq(op(p, q), op(x, y)) for x: p, y: q
              contradict equal(op(p, q), op(p, q))
            }
            connect in(p, X) \wedge neq(p, x)
            apply invoke leftward rem_existence for X, x, p
          }
        }
        connect in(p, rem(X, x)) \leftrightarrow \exists q (in(op(p, q), rem(f, op(x, y))))
      }
      fold for dom conclude dom(rem(f, op(x, y)), rem(X, x))
    }
  }
}

theorem removing_op_ran \forall f \forall Y \forall x \forall y (inj(f) \wedge ran(f, Y) \wedge in(op(x, y), f) \to ran(rem(f, op(x, y)), rem(Y, y))) {
  any f, Y, x, y {
    assume inj(f) \wedge ran(f, Y) \wedge in(op(x, y), f) {
      split inj(f) \wedge ran(f, Y) \wedge in(op(x, y), f)
      split inj(f)
      split fun(f)
      any q {
        assume in(q, rem(Y, y)) {
          apply invoke rightward rem_existence for Y, y, q
          split in(q, Y) \wedge neq(q, y)
          apply invoke rightward ran(f, Y) for q
          some p such \exists p (in(op(p, q), f)) {
            deny equal(op(p, q), op(x, y)) {
              apply invoke op_characterization for p, q, x, y
              split 2 equal(p, x) \wedge equal(q, y)
              contradict equal(q, y)
            }
            connect in(op(p, q), f) \wedge neq(op(p, q), op(x, y))
            apply invoke leftward rem_existence for f, op(x, y), op(p, q)
            lift for p conclude \exists p (in(op(p, q), rem(f, op(x, y))))
          }
        }
        assume \exists p (in(op(p, q), rem(f, op(x, y)))) {
          some p such \exists p (in(op(p, q), rem(f, op(x, y)))) {
            apply invoke rightward rem_existence for f, op(x, y), op(p, q)
            split in(op(p, q), f) \wedge neq(op(p, q), op(x, y))
            lift for p conclude \exists p (in(op(p, q), f))
            apply invoke leftward ran(f, Y) for q
            apply law_of_excluded_middle for \lambda^P. in(op(x, y), f)
            deny equal(q, y) {
              substitute in(op(x, y), f) for y: q
              connect in(op(p, q), f) \wedge in(op(x, q), f)
              apply invoke \forall x \forall x' \forall y (in(op(x, y), f) \wedge in(op(x', y), f) \to equal(x, x')) for p, x, q
              substitute neq(op(p, q), op(x, y)) for x: p, y: q
              contradict equal(op(p, q), op(p, q))
            }
            connect in(q, Y) \wedge neq(q, y)
            apply invoke leftward rem_existence for Y, y, q
          }
        }
        connect in(q, rem(Y, y)) \leftrightarrow \exists p (in(op(p, q), rem(f, op(x, y))))
      }
      fold for ran conclude ran(rem(f, op(x, y)), rem(Y, y))
    }
  }
}

theorem removing_op_fun \forall f \forall x \forall y (fun(f) \to fun(rem(f, op(x, y)))) {
  any f, x, y {
    assume fun(f) {
      split fun(f)
      apply invoke removing_op_rel for f, x, y
      any p, q, q' {
        assume in(op(p, q), rem(f, op(x, y))) \wedge in(op(p, q'), rem(f, op(x, y))) {
          split in(op(p, q), rem(f, op(x, y))) \wedge in(op(p, q'), rem(f, op(x, y)))
          apply invoke rightward rem_existence for f, op(x, y), op(p, q)
          apply invoke rightward rem_existence for f, op(x, y), op(p, q')
          split 1 in(op(p, q), f) \wedge neq(op(p, q), op(x, y))
          split 1 in(op(p, q'), f) \wedge neq(op(p, q'), op(x, y))
          connect in(op(p, q), f) \wedge in(op(p, q'), f)
          apply invoke \forall x \forall y \forall y' (in(op(x, y), f) \wedge in(op(x, y'), f) \to equal(y, y')) for p, q, q'
        }
      }
      connect fun(rem(f, op(x, y)))
    }
  }
}

theorem removing_op_inj \forall f \forall x \forall y (inj(f) \to inj(rem(f, op(x, y)))) {
  any f, x, y {
    assume inj(f) {
      split inj(f)
      apply invoke removing_op_fun for f, x, y
      any p, p', q {
        assume in(op(p, q), rem(f, op(x, y))) \wedge in(op(p', q), rem(f, op(x, y))) {
          split in(op(p, q), rem(f, op(x, y))) \wedge in(op(p', q), rem(f, op(x, y)))
          apply invoke rightward rem_existence for f, op(x, y), op(p, q)
          apply invoke rightward rem_existence for f, op(x, y), op(p', q)
          split 1 in (op(p, q), f) \wedge neq(op(p, q), op(x, y))
          split 1 in (op(p', q), f) \wedge neq(op(p', q), op(x, y))
          connect in(op(p, q), f) \wedge in(op(p', q), f)
          apply invoke \forall x \forall x' \forall y (in(op(x, y), f) \wedge in(op(x', y), f) \to equal(x, x')) for p, p', q
        }
      }
      connect inj(rem(f, op(x, y)))
    }
  }
}

theorem removing_op_bij \forall f \forall X \forall Y \forall x \forall y (bij(f, X, Y) \wedge in(op(x, y), f) \to bij(rem(f, op(x, y)), rem(X, x), rem(Y, y))) {
  any f, X, Y, x, y {
    assume bij(f, X, Y) \wedge in(op(x, y), f) {
      split bij(f, X, Y) \wedge in(op(x, y), f)
      split bij(f, X, Y)
      split inj(f)
      apply invoke removing_op_inj for f, x, y
      split inj(rem(f, op(x, y)))
      split surj(f, X, Y)
      connect fun(f) \wedge dom(f, X) \wedge in(op(x, y), f)
      apply invoke removing_op_dom for f, X, x, y
      connect inj(f) \wedge ran(f, Y) \wedge in(op(x, y), f)
      apply invoke removing_op_ran for f, Y, x, y
      connect surj(rem(f, op(x, y)), rem(X, x), rem(Y, y))
      connect bij(rem(f, op(x, y)), rem(X, x), rem(Y, y))
    }
  }
}

theorem dom_is_unique \forall R \forall X \forall X' (dom(R, X) \wedge dom(R, X') \to equal(X, X')) {
  any R, X, X' {
    assume dom(R, X) \wedge dom(R, X') {
      split dom(R, X) \wedge dom(R, X')
      expand dom(R, X) for dom
      expand dom(R, X') for dom
      connect \forall x (in(x, X) \leftrightarrow \exists y (in(op(x, y), R))) \wedge \forall x (in(x, X') \leftrightarrow \exists y (in(op(x, y), R)))
      apply invoke set_is_unique_for_each_predicate for \lambda^P x. \exists y (in(op(x, y), R)), X, X'
    }
  }
}

theorem ran_is_unique \forall R \forall Y \forall Y' (ran(R, Y) \wedge ran(R, Y') \to equal(Y, Y')) {
  any R, Y, Y' {
    assume ran(R, Y) \wedge ran(R, Y') {
      split ran(R, Y) \wedge ran(R, Y')
      expand ran(R, Y) for ran
      expand ran(R, Y') for ran
      connect \forall y (in(y, Y) \leftrightarrow \exists x (in(op(x, y), R))) \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(op(x, y), R)))
      apply invoke set_is_unique_for_each_predicate for \lambda^P y. \exists x (in(op(x, y), R)), Y, Y'
    }
  }
}

theorem emptyset_is_rel rel(emptyset) {
  any z {
    assume in(z, emptyset) {
      apply emptyset_existence for z
      contradict in(z, emptyset)
      explode \exists x \exists y (equal(z, op(x, y)))
    }
  }
  fold for rel conclude rel(emptyset)
}

theorem emptyset_is_fun fun(emptyset) {
  assert emptyset_is_rel
  any x, y, y' {
    assume in(op(x, y), emptyset) \wedge in(op(x, y'), emptyset) {
      split 1 in(op(x, y), emptyset) \wedge in(op(x, y'), emptyset)
      apply emptyset_existence for op(x, y)
      contradict in(op(x, y), emptyset)
      explode equal(y, y')
    }
  }
  connect fun(emptyset)
}

theorem emptyset_is_inj inj(emptyset) {
  assert emptyset_is_fun
  any x, x', y {
    assume in(op(x, y), emptyset) \wedge in(op(x', y), emptyset) {
      split 1 in(op(x, y), emptyset) \wedge in(op(x', y), emptyset)
      apply emptyset_existence for op(x, y)
      contradict in(op(x, y), emptyset)
      explode equal(x, x')
    }
  }
  connect inj(emptyset)
}

theorem dom_of_emptyset_is_emptyset dom(emptyset, emptyset) {
  any x {
    assume in(x, emptyset) {
      apply emptyset_existence for x
      contradict in(x, emptyset)
      explode \exists y (in(op(x, y), emptyset))
    }
    assume \exists y (in(op(x, y), emptyset)) {
      some y such \exists y (in(op(x, y), emptyset)) {
        apply emptyset_existence for op(x, y)
        contradict in(op(x, y), emptyset)
        explode in(x, emptyset)
      }
    }
    connect in(x, emptyset) \leftrightarrow \exists y (in(op(x, y), emptyset))
  }
  fold for dom conclude dom(emptyset, emptyset)
}

theorem ran_of_emptyset_is_emptyset ran(emptyset, emptyset) {
  any y {
    assume in(y, emptyset) {
      apply emptyset_existence for y
      contradict in(y, emptyset)
      explode \exists x (in(op(x, y), emptyset))
    }
    assume \exists x (in(op(x, y), emptyset)) {
      some x such \exists x (in(op(x, y), emptyset)) {
        apply emptyset_existence for op(x, y)
        contradict in(op(x, y), emptyset)
        explode in(y, emptyset)
      }
    }
    connect in(y, emptyset) \leftrightarrow \exists x (in(op(x, y), emptyset))
  }
  fold for ran conclude ran(emptyset, emptyset)
}

theorem emptyset_is_surj_from_emptyset_to_emptyset surj(emptyset, emptyset, emptyset) {
  assert emptyset_is_fun
  assert dom_of_emptyset_is_emptyset
  assert ran_of_emptyset_is_emptyset
  connect surj(emptyset, emptyset, emptyset)
}

theorem emptyset_is_bij_from_emptyset_to_emptyset bij(emptyset, emptyset, emptyset) {
  assert emptyset_is_inj
  assert emptyset_is_surj_from_emptyset_to_emptyset
  connect bij(emptyset, emptyset, emptyset)
}

theorem emptyset_is_equipotent_to_emptyset equipotent(emptyset, emptyset) {
  assert emptyset_is_bij_from_emptyset_to_emptyset
  lift for emptyset conclude \exists f (bij(f, emptyset, emptyset))
  fold for equipotent conclude equipotent(emptyset, emptyset)
}

theorem size_of_emptyset_is_emptyset size(emptyset, emptyset) {
  assert emptyset_is_natural
  assert emptyset_is_equipotent_to_emptyset
  connect size(emptyset, emptyset)
}

theorem emptyset_is_finite finite(emptyset) {
  assert size_of_emptyset_is_emptyset
  lift for emptyset conclude \exists n (size(emptyset, n))
  fold for finite conclude finite(emptyset)
}

theorem rel_with_dom_emptyset_is_emptyset \forall R (rel(R) \wedge dom(R, emptyset) \to equal(R, emptyset)) {
  any R {
    assume rel(R) \wedge dom(R, emptyset) {
      split rel(R) \wedge dom(R, emptyset)
      any z {
        deny in(z, R) {
          apply invoke rel(R) for z
          some x, y such \exists x \exists y (equal(z, op(x, y))) {
            substitute in(z, R) for z: op(x, y)
            lift for y conclude \exists y (in(op(x, y), R))
            apply invoke leftward dom(R, emptyset) for x
            apply emptyset_existence for x
            contradict in(x, emptyset)
          }
        }
      }
      apply invoke emptyset_uniqueness for R
    }
  }
}

theorem rel_with_ran_emptyset_is_emptyset \forall R (rel(R) \wedge ran(R, emptyset) \to equal(R, emptyset)) {
  any R {
    assume rel(R) \wedge ran(R, emptyset) {
      split rel(R) \wedge ran(R, emptyset)
      any z {
        deny in(z, R) {
          apply invoke rel(R) for z
          some x, y such \exists x \exists y (equal(z, op(x, y))) {
            substitute in(z, R) for z: op(x, y)
            lift for x conclude \exists x (in(op(x, y), R))
            apply invoke leftward ran(R, emptyset) for y
            apply emptyset_existence for y
            contradict in(y, emptyset)
          }
        }
      }
      apply invoke emptyset_uniqueness for R
    }
  }
}

theorem dom_emptyset_implies_ran_emptyset \forall R (rel(R) \wedge dom(R, emptyset) \to ran(R, emptyset)) {
  any R {
    assume rel(R) \wedge dom(R, emptyset) {
      apply invoke rel_with_dom_emptyset_is_emptyset for R
      substitute ran_of_emptyset_is_emptyset for emptyset[1]: R
    }
  }
}

theorem ran_emptyset_implies_dom_emptyset \forall R (rel(R) \wedge ran(R, emptyset) \to dom(R, emptyset)) {
  any R {
    assume rel(R) \wedge ran(R, emptyset) {
      apply invoke rel_with_ran_emptyset_is_emptyset for R
      substitute dom_of_emptyset_is_emptyset for emptyset[1]: R
    }
  }
}

theorem surj_with_dom_emptyset_implies_ran_emptyset \forall f \forall X (surj(f, emptyset, X) \to equal(X, emptyset)) {
  any f, X {
    assume surj(f, emptyset, X) {
      split surj(f, emptyset, X)
      split fun(f)
      connect rel(f) \wedge dom(f, emptyset)
      apply invoke dom_emptyset_implies_ran_emptyset for f
      connect ran(f, X) \wedge ran(f, emptyset)
      apply invoke ran_is_unique for f, X, emptyset
    }
  }
}

theorem surj_with_ran_emptyset_implies_dom_emptyset \forall f \forall X (surj(f, X, emptyset) \to equal(X, emptyset)) {
  any f, X {
    assume surj(f, X, emptyset) {
      split surj(f, X, emptyset)
      split fun(f)
      connect rel(f) \wedge ran(f, emptyset)
      apply invoke ran_emptyset_implies_dom_emptyset for f
      connect dom(f, X) \wedge dom(f, emptyset)
      apply invoke dom_is_unique for f, X, emptyset
    }
  }
}

theorem size_emptyset_implies_set_emptyset \forall X (size(X, emptyset) \to equal(X, emptyset)) {
  any X {
    assume size(X, emptyset) {
      split size(X, emptyset)
      some f such equipotent(emptyset, X) {
        split bij(f, emptyset, X)
        apply invoke surj_with_dom_emptyset_implies_ran_emptyset for f, X
      }
    }
  }
}

theorem size_is_unique_for_emptyset \forall n (size(emptyset, n) \to equal(n, emptyset)) {
  any n {
    assume size(emptyset, n) {
      split size(emptyset, n)
      some f such equipotent(n, emptyset) {
        split bij(f, n, emptyset)
        apply invoke surj_with_ran_emptyset_implies_dom_emptyset for f, n
      }
    }
  }
}

theorem size_is_unique \forall X \forall n \forall m (size(X, n) \wedge size(X, m) \to equal(n, m)) {
  any X, m {
    assume size(X, emptyset) \wedge size(X, m) {
      split size(X, emptyset) \wedge size(X, m)
      apply invoke size_emptyset_implies_set_emptyset for X
      substitute size(X, m) for X: emptyset
      apply invoke size_is_unique_for_emptyset for m
    }
  }
  any n {
    assume \forall X \forall m (size(X, n) \wedge size(X, m) \to equal(n, m)) {
      any X, m {
        assume size(X, suc(n)) \wedge size(X, m) {
          split size(X, suc(n)) \wedge size(X, m)
          split size(X, suc(n))
          apply invoke leftward suc_of_natural_is_natural_and_vice_versa for n
          some f such equipotent(suc(n), X) {
            split bij(f, suc(n), X)
            split surj(f, suc(n), X)
            apply suc_implies_in for n
            apply invoke rightward dom(f, suc(n)) for n
            some x such \exists x (in(op(n, x), f)) {
              connect bij(f, suc(n), X) \wedge in(op(n, x), f)
              apply invoke removing_op_bij for f, suc(n), X, n, x
              apply invoke natural_is_irrefrelon for n
              apply invoke rem_suc for n
              substitute bij(rem(f, op(n, x)), rem(suc(n), n), rem(X, x)) for rem(suc(n), n): n
              lift for n conclude \exists n (in(op(n, x), f))
              apply invoke leftward ran(f, X) for x
              split size(X, m)
              some g such equipotent(m, X) {
                split bij(g, m, X)
                split surj(g, m, X)
                apply invoke rightward ran(g, X) for x
                some l such \exists l (in(op(l, x), g)) {
                  connect bij(g, m, X) \wedge in(op(l, x), g)
                  apply invoke removing_op_bij for g, m, X, l, x
                  deny equal(m, emptyset) {
                    substitute dom(g, m) for m: emptyset
                    split fun(g)
                    connect rel(g) \wedge dom(g, emptyset)
                    apply invoke rel_with_dom_emptyset_is_emptyset for g
                    substitute in(op(l, x), g) for g: emptyset
                    apply emptyset_existence for op(l, x)
                    contradict in(op(l, x), emptyset)
                  }
                  divide natural(m)
                    case equal(m, emptyset) {
                      contradict equal(m, emptyset)
                      explode equal(m, suc(n))
                    }
                    case sucordinal(m) \wedge \forall k (in(k, m) \to equal(k, emptyset) \vee sucordinal(k)) {
                      split 1 sucordinal(m) \wedge \forall k (in(k, m) \to equal(k, emptyset) \vee sucordinal(k))
                      split 2 sucordinal(m)
                      some k such \exists k (equal(m, suc(k))) {
                        substitute natural(m) for m: suc(k)
                        apply invoke leftward suc_of_natural_is_natural_and_vice_versa for k
                        apply invoke natural_is_irrefrelon for k
                        apply invoke rem_suc for k
                        apply law_of_excluded_middle for \lambda^P. equal(l, k)
                        divide equal(l, k) \vee neq(l, k)
                          case equal(l, k) {
                            substitute bij(rem(g, op(l, x)), rem(m, l), rem(X, x)) for m: suc(k), l: k
                            substitute bij(rem(g, op(k, x)), rem(suc(k), k), rem(X, x)) for rem(suc(k), k): k
                            lift for rem(f, op(n, x)) conclude \exists f' (bij(f', n, rem(X, x)))
                            fold for equipotent conclude equipotent(n, rem(X, x))
                            connect size(rem(X, x), n)
                            lift for rem(g, op(k, x)) conclude \exists g' (bij(g', k, rem(X, x)))
                            fold for equipotent conclude equipotent(k, rem(X, x))
                            connect size(rem(X, x), k)
                            connect size(rem(X, x), n) \wedge size(rem(X, x), k)
                            connect natural(n) \wedge bij(rem(f, op(n, x)), n, rem(X, x)) \wedge natural(k) \wedge bij(rem(g, op(k, x)), k, rem(X, x))
                            apply invoke \forall X \forall m (size(X, n) \wedge size(X, m) \to equal(n, m)) for rem(X, x), k
                            substitute equal(m, suc(k)) for k: n
                          }
                          case neq(l, k) {
                            apply suc_implies_in for k
                            substitute dom(g, m) for m: suc(k)
                            apply invoke rightward dom(g, suc(k)) for k
                            some y such \exists y (in(op(k, y), g)) {
                              connect in(op(k, y), g) \wedge neq(k, l)
                              apply invoke removing_op_lem1 for g, k, y, l, x
                              connect bij(rem(g, op(l, x)), rem(m, l), rem(X, x)) \wedge in(op(k, y), rem(g, op(l, x)))
                              apply invoke removing_op_bij for rem(g, op(l, x)), rem(m, l), rem(X, x), k, y
                              deny \exists q (in(op(l, q), rem(rem(g, op(l, x)), op(k, y)))) {
                                some q such \exists q (in(op(l, q), rem(rem(g, op(l, x)), op(k, y)))) {
                                  apply invoke rightward rem_existence for rem(g, op(l, x)), op(k, y), op(l, q)
                                  split 1 in(op(l, q), rem(g, op(l, x))) \wedge neq(op(l, q), op(k, y))
                                  lift for q conclude \exists q (in(op(l, q), rem(g, op(l, x))))
                                  split bij(rem(g, op(l, x)), rem(m, l), rem(X, x))
                                  split surj(rem(g, op(l, x)), rem(m, l), rem(X, x))
                                  apply invoke leftward dom(rem(g, op(l, x)), rem(m, l)) for l
                                  apply invoke rightward rem_existence for m, l, l
                                  split 2 in(l, m) \wedge neq(l, l)
                                  contradict equal(l, l)
                                }
                              }
                              deny \exists p (in(op(p, y), rem(rem(g, op(l, x)), op(k, y)))) {
                                split bij(rem(rem(g, op(l, x)), op(k, y)), rem(rem(m, l), k), rem(rem(X, x), y))
                                split surj(rem(rem(g, op(l, x)), op(k, y)), rem(rem(m, l), k), rem(rem(X, x), y))
                                apply invoke leftward ran(rem(rem(g, op(l, x)), op(k, y)), rem(rem(X, x), y)) for y
                                apply invoke rightward rem_existence for rem(X, x), y, y
                                split 2 in(y, rem(X, x)) \wedge neq(y, y)
                                contradict equal(y, y)
                              }
                              connect bij(rem(rem(g, op(l, x)), op(k, y)), rem(rem(m, l), k), rem(rem(X, x), y)) \wedge \neg(\exists q (in(op(l, q), rem(rem(g, op(l, x)), op(k, y))))) \wedge \neg(\exists p (in(op(p, y), rem(rem(g, op(l, x)), op(k, y)))))
                              apply invoke adding_op_bij for rem(rem(g, op(l, x)), op(k, y)), rem(rem(m, l), k), rem(rem(X, x), y), l, y
                              any j {
                                assume in(j, adj(rem(rem(m, l), k), l)) {
                                  apply invoke rightward adj_existence for rem(rem(m, l), k), l, j
                                  divide in(j, rem(rem(m, l), k)) \vee equal(j, l)
                                    case in(j, rem(rem(m, l), k)) {
                                      apply invoke rightward rem_existence for rem(m, l), k, j
                                      split in(j, rem(m, l)) \wedge neq(j, k)
                                      apply invoke rightward rem_existence for m, l, j
                                      split in(j, m) \wedge neq(j, l)
                                      connect in(j, m) \wedge neq(j, k)
                                    }
                                    case equal(j, l) {
                                      lift for x conclude \exists x (in(op(l, x), g))
                                      apply invoke leftward dom(g, m) for l
                                      connect in(l, m) \wedge neq(l, k)
                                      substitute in(l, m) \wedge neq(l, k) for l: j
                                    }
                                  apply invoke leftward rem_existence for m, k, j
                                }
                                assume in(j, rem(m, k)) {
                                  apply law_of_excluded_middle for \lambda^P. equal(j, l)
                                  divide equal(j, l) \vee neq(j, l)
                                    case equal(j, l) {
                                      pad equal(j, l) conclude in(j, rem(rem(m, l), k)) \vee equal(j, l)
                                    }
                                    case neq(j, l) {
                                      apply invoke rightward rem_existence for m, k, j
                                      split in(j, m) \wedge neq(j, k)
                                      connect in(j, m) \wedge neq(j, l)
                                      apply invoke leftward rem_existence for m, l, j
                                      connect in(j, rem(m, l)) \wedge neq(j, k)
                                      apply invoke leftward rem_existence for rem(m, l), k, j
                                      pad in(j, rem(rem(m, l), k)) conclude in(j, rem(rem(m, l), k)) \vee equal(j, l)
                                    }
                                    apply invoke leftward adj_existence for rem(rem(m, l), k), l, j
                                }
                                connect in(j, adj(rem(rem(m, l), k), l)) \leftrightarrow in(j, rem(m, k))
                              }
                              fold for equal conclude equal(adj(rem(rem(m, l), k), l), rem(m, k))
                              substitute equal(adj(rem(rem(m, l), k), l), rem(m, k)) for m[2]: suc(k)
                              substitute equal(adj(rem(rem(m, l), k), l), rem(suc(k), k)) for rem(suc(k), k): k
                              any z {
                                assume in(z, adj(rem(rem(X, x), y), y)) {
                                  apply invoke rightward adj_existence for rem(rem(X, x), y), y, z
                                  divide in(z, rem(rem(X, x), y)) \vee equal(z, y)
                                    case in(z, rem(rem(X, x), y)) {
                                      apply invoke rightward rem_existence for rem(X, x), y, z
                                      split 1 in(z, rem(X, x)) \wedge neq(z, y)
                                    }
                                    case equal(z, y) {
                                      lift for k conclude \exists k (in(op(k, y), g))
                                      apply invoke leftward ran(g, X) for y
                                      deny equal(y, x) {
                                        substitute in(op(k, y), g) for y: x
                                        connect in(op(l, x), g) \wedge in(op(k, x), g)
                                        split inj(g)
                                        apply invoke \forall x \forall x' \forall y (in(op(x, y), g) \wedge in(op(x', y), g) \to equal(x, x')) for l, k, x
                                        contradict equal(l, k)
                                      }
                                      connect in(y, X) \wedge neq(y, x)
                                      substitute in(y, X) \wedge neq(y, x) for y: z
                                      apply invoke leftward rem_existence for X, x, z
                                    }
                                }
                                assume in(z, rem(X, x)) {
                                  apply law_of_excluded_middle for \lambda^P. equal(z, y)
                                  divide equal(z, y) \vee neq(z, y)
                                    case equal(z, y) {
                                      pad equal(z, y) conclude in(z, rem(rem(X, x), y)) \vee equal(z, y)
                                    }
                                    case neq(z, y) {
                                      apply invoke rightward rem_existence for X, x, z
                                      split in(z, X) \wedge neq(z, x)
                                      connect in(z, rem(X, x)) \wedge neq(z, y)
                                      apply invoke leftward rem_existence for rem(X, x), y, z
                                      pad in(z, rem(rem(X, x), y)) conclude in(z, rem(rem(X, x), y)) \vee equal(z, y)
                                    }
                                  apply invoke leftward adj_existence for rem(rem(X, x), y), y, z
                                }
                                connect in(z, adj(rem(rem(X, x), y), y)) \leftrightarrow in(z, rem(X, x))
                              }
                              fold for equal conclude equal(adj(rem(rem(X, x), y), y), rem(X, x))
                              substitute bij(adj(rem(rem(g, op(l, x)), op(k, y)), op(l, y)), adj(rem(rem(m, l), k), l), adj(rem(rem(X, x), y), y)) for adj(rem(rem(m, l), k), l): k, adj(rem(rem(X, x), y), y): rem(X, x)
                              lift for rem(f, op(n, x)) conclude \exists f' (bij(f', n, rem(X, x)))
                              fold for equipotent conclude equipotent(n, rem(X, x))
                              connect size(rem(X, x), n)
                              lift for adj(rem(rem(g, op(l, x)), op(k, y)), op(l, y)) conclude \exists g' (bij(g', k, rem(X, x)))
                              fold for equipotent conclude equipotent(k, rem(X, x))
                              connect size(rem(X, x), k)
                              connect size(rem(X, x), n) \wedge size(rem(X, x), k)
                              apply invoke \forall X \forall m (size(X, n) \wedge size(X, m) \to equal(n, m)) for rem(X, x), k
                              substitute equal(m, suc(k)) for k: n
                            }
                          }
                      }
                    }
                }
              }
            }
          }
        }
      }
    }
  }
  connect inductive(\lambda^P n. \forall X \forall m (size(X, n) \wedge size(X, m) \to equal(m, n)))
  apply invoke natural_induction for \lambda^P n. \forall X \forall m (size(X, n) \wedge size(X, m) \to equal(m, n))
  any X, n, m {
    assume size(X, n) \wedge size(X, m) {
      split size(X, n) \wedge size(X, m)
      split 1 size(X, n)
      apply invoke subset(natural, \lambda^P n. \forall X \forall m (size(X, n) \wedge size(X, m) \to equal(m, n))) for n
      apply invoke \forall X \forall m (size(X, n) \wedge size(X, m) \to equal(m, n)) for X, m
    }
  }
}

theorem finite_set_has_unique_size \forall x (finite(x) \to \exists! n (size(x, n))) {
  any x {
    assume finite(x) {
      some n such finite(x) {
        any n' {
          assume size(x, n') {
            connect size(x, n) \wedge size(x, n')
            apply invoke size_is_unique for x, n, n'
          }
        }
        connect size(x, n) \wedge \forall n' (size(x, n') \to equal(n', n))
        characterize for n conclude \exists! n (size(x, n))
      }
    }
  }
}
