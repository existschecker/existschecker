include "zfc_union.proof"

axiom axiom_of_powerset \forall x\exists y\forall z(in(z,y)\leftrightarrow subset(z,x))

theorem powerset_exists_uniquely \forall x\exists!y\forall z(in(z,y)\leftrightarrow subset(z,x)) {
  any x {
    apply axiom_of_powerset for x:x
    some y:y such \exists y\forall z(in(z,y)\leftrightarrow subset(z,x)) {
      any y' {
        assume \forall z(in(z,y')\leftrightarrow subset(z,x)) {
          any z {
            assume in(z,y') {
              apply \forall z(in(z,y')\leftrightarrow subset(z,x)) for z:z
              invoke rightward in(z,y')\leftrightarrow subset(z,x)
              apply \forall z(in(z,y)\leftrightarrow subset(z,x)) for z:z
              invoke leftward in(z,y)\leftrightarrow subset(z,x)
            }
            assume in(z,y) {
              apply \forall z(in(z,y)\leftrightarrow subset(z,x)) for z:z
              invoke rightward in(z,y)\leftrightarrow subset(z,x)
              apply \forall z(in(z,y')\leftrightarrow subset(z,x)) for z:z
              invoke leftward in(z,y')\leftrightarrow subset(z,x)
            }
            connect in(z,y')\leftrightarrow in(z,y)
          }
          expand \forall z(in(z,y')\leftrightarrow in(z,y)) for equal conclude equal(y',y)
        }
      }
      connect \forall z(in(z,y)\leftrightarrow subset(z,x))\wedge\forall y'(\forall z(in(z,y')\leftrightarrow subset(z,x))\to equal(y',y))
      characterize for y:y conclude \exists!y\forall z(in(z,y)\leftrightarrow subset(z,x))
    }
  }
}

definition function powerset by powerset_exists_uniquely tex "\mathcal{P}(",")"
existence powerset_existence \forall x\forall z(in(z,powerset(x))\leftrightarrow subset(z,x)) by powerset
uniqueness powerset_uniqueness \forall x\forall y(\forall z(in(z,y)\leftrightarrow subset(z,x))\to equal(y,powerset(x))) by powerset

theorem powerset_cor1 \forall x(in(x,powerset(x))) {
  any x {
    apply subset_reflection for x:x
    apply powerset_existence for x:x,z:x
    invoke leftward in(x,powerset(x))\leftrightarrow subset(x,x)
  }
}

theorem powerset_cor2 equal(powerset(emptyset),singleton(emptyset)) {
  any x {
    assume in(x,powerset(emptyset)) {
      apply powerset_existence for x:emptyset,z:x
      invoke rightward in(x,powerset(emptyset))\leftrightarrow subset(x,emptyset)
      apply emptyset_subset_cor1 for x:x
      invoke subset(x,emptyset)\to equal(x,emptyset)
      apply singleton_cor1 for x:emptyset
      substitute in(emptyset,singleton(emptyset)) for emptyset@1:x conclude in(x,singleton(emptyset))
    }
    assume in(x,singleton(emptyset)) {
      apply singleton_characterization for x:emptyset,y:x
      invoke rightward in(x,singleton(emptyset))\leftrightarrow equal(x,emptyset)
      apply powerset_cor1 for x:emptyset
      substitute in(emptyset,powerset(emptyset)) for emptyset@1:x conclude in(x,powerset(emptyset))
    }
    connect in(x,powerset(emptyset))\leftrightarrow in(x,singleton(emptyset))
  }
  expand \forall x(in(x,powerset(emptyset))\leftrightarrow in(x,singleton(emptyset))) for equal conclude equal(powerset(emptyset),singleton(emptyset))
}
