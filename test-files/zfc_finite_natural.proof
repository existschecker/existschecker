include "zfc_finite_suc.proof"

definition predicate sucordinal(\alpha) as ordinal(\alpha) \wedge \exists \beta (equal(\alpha, suc(\beta)))

definition predicate natural(n) as equal(n, emptyset) \vee (sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)))

theorem subset_natural_ordinal subset_predicate(natural, ordinal) {
  any n {
    assume natural(n) {
      divide natural(n)
        case equal(n, emptyset) {
          substitute emptyset_is_ordinal for emptyset: n
        }
        case sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)) {
          split 1 sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m))
          split 1 sucordinal(n)
        }
    }
  }
  fold for subset_predicate conclude subset_predicate(natural, ordinal)
}

theorem emptyset_is_natural natural(emptyset) {
  pad equal(emptyset, emptyset) conclude equal(emptyset, emptyset) \vee (sucordinal(emptyset) \wedge \forall m (in(m, emptyset) \to equal(m, emptyset) \vee sucordinal(m)))
  fold for natural conclude natural(emptyset)
}

theorem natural_is_trans trans_predicate(natural) {
  any n, m {
    assume in(m, n) \wedge natural(n) {
      split in(m, n) \wedge natural(n)
      divide natural(n)
        case equal(n, emptyset) {
          apply emptyset_existence for m
          substitute notin(m, emptyset) for emptyset: n
          contradict in(m, n)
          explode natural(m)
        }
        case sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)) {
          split sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m))
          apply invoke \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)) for m
          divide equal(m, emptyset) \vee sucordinal(m)
            case equal(m, emptyset) {
              substitute emptyset_is_natural for emptyset: m
            }
            case sucordinal(m) {
              any l {
                assume in (l, m) {
                  connect in(l, m) \wedge in(m, n)
                  apply invoke subset_natural_ordinal for n
                  split 1 ordinal(n)
                  apply invoke trans(n) for m, l
                  apply invoke \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)) for l
                }
              }
              connect sucordinal(m) \wedge \forall l (in(l, m) \to equal(l, emptyset) \vee sucordinal(l))
              pad sucordinal(m) \wedge \forall l (in(l, m) \to equal(l, emptyset) \vee sucordinal(l)) conclude equal(m, emptyset) \vee (sucordinal(m) \wedge \forall l (in(l, m) \to equal(l, emptyset) \vee sucordinal(l)))
              fold for natural conclude natural(m)
            }
        }
    }
  }
  fold for trans_predicate conclude trans_predicate(natural)
}

theorem natural_is_irrefrelon irrefrelon_predicate(natural, in) {
  assert ordinal_is_irrefrelon
  assert subset_natural_ordinal
  connect irrefrelon_predicate(ordinal, in) \wedge subset_predicate(natural, ordinal)
  apply invoke irrefrelon_subset_predicate for ordinal, in, natural
}

theorem natural_is_wellorder wellorder_predicate(natural, in) {
  assert ordinal_is_wellorder
  assert subset_natural_ordinal
  connect wellorder_predicate(ordinal, in) \wedge subset_predicate(natural, ordinal)
  apply invoke wellorder_subset_predicate for ordinal, in, natural
}

theorem natural_is_wellfounded wellfounded_predicate(natural, in) {
  assert natural_is_wellorder
  apply invoke wellorder_implies_wellfounded_predicate for natural, in
}

theorem natural_is_ordinal ordinal_predicate(natural) {
  assert natural_is_trans
  assert natural_is_irrefrelon
  assert natural_is_wellorder
  connect trans_predicate(natural) \wedge irrefrelon_predicate(natural, in) \wedge wellorder_predicate(natural, in)
  fold for ordinal_predicate conclude ordinal_predicate(natural)
}

theorem suc_of_natural_is_natural_and_vice_versa \forall n (natural(n) \leftrightarrow natural(suc(n))) {
  any n {
    assume natural(n) {
      apply invoke subset_natural_ordinal for n
      apply invoke rightward suc_of_ordinal_is_ordinal_and_vice_versa for n
      lift for n conclude \exists n (equal(suc(n), suc(n)))
      connect sucordinal(suc(n))
      any m {
        assume in(m, suc(n)) {
          apply invoke rightward suc_characterization for n, m
          divide in(m, n) \vee equal(m, n)
            case in(m, n) {
              divide natural(n)
                case equal(n, emptyset) {
                  apply emptyset_existence for m
                  substitute in(m, n) for n: emptyset
                  contradict in(m, emptyset)
                  explode equal(m, emptyset) \vee sucordinal(m)
                }
                case sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)) {
                  split 2 sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m))
                  apply invoke \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)) for m
                }
            }
            case equal(m, n) {
              substitute natural(n) for n: m
              divide natural(m)
                case equal(m, emptyset) {
                  pad equal(m, emptyset) conclude equal(m, emptyset) \vee sucordinal(m)
                }
                case sucordinal(m) \wedge \forall l (in(l, m) \to equal(l, emptyset) \vee sucordinal(l)) {
                  split 1 sucordinal(m) \wedge \forall l (in(l, m) \to equal(l, emptyset) \vee sucordinal(l))
                  pad sucordinal(m) conclude equal(m, emptyset) \vee sucordinal(m)
                }
            }
        }
      }
      connect sucordinal(suc(n)) \wedge \forall m (in(m, suc(n)) \to equal(m, emptyset) \vee sucordinal(m))
      pad sucordinal(suc(n)) \wedge \forall m (in(m, suc(n)) \to equal(m, emptyset) \vee sucordinal(m)) conclude equal(suc(n), emptyset) \vee (sucordinal(suc(n)) \wedge \forall m (in(m, suc(n)) \to equal(m, emptyset) \vee sucordinal(m)))
      fold for natural conclude natural(suc(n))
    }
    assume natural(suc(n)) {
      apply suc_implies_in for n
      divide natural(suc(n))
        case equal(suc(n), emptyset) {
          substitute in(n, suc(n)) for suc(n): emptyset
          apply emptyset_existence for n
          contradict in(n, emptyset)
          explode natural(n)
        }
        case sucordinal(suc(n)) \wedge \forall m (in(m, suc(n)) \to equal(m, emptyset) \vee sucordinal(m)) {
          split sucordinal(suc(n)) \wedge \forall m (in(m, suc(n)) \to equal(m, emptyset) \vee sucordinal(m))
          apply invoke \forall m (in(m, suc(n)) \to equal(m, emptyset) \vee sucordinal(m)) for n
          divide equal(n, emptyset) \vee sucordinal(n)
            case equal(n, emptyset) {
              pad equal(n, emptyset) conclude equal(n, emptyset) \vee (sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)))
              fold for natural conclude natural(n)
            }
            case sucordinal(n) {
              any m {
                assume in(m, n) {
                  pad in(m, n) conclude in(m, n) \vee equal(m, n)
                  apply invoke leftward suc_characterization for n, m
                  apply invoke \forall m (in(m, suc(n)) \to equal(m, emptyset) \vee sucordinal(m)) for m
                }
              }
              connect sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m))
              pad sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)) conclude equal(n, emptyset) \vee (sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)))
              fold for natural conclude natural(n)
            }
        }
    }
    connect natural(n) \leftrightarrow natural(suc(n))
  }
}

theorem suc_is_injection \forall n \forall m (natural(n) \wedge natural(m) \wedge equal(suc(n), suc(m)) \to equal(n, m)) {
  any n, m {
    assume natural(n) \wedge natural(m) \wedge equal(suc(n), suc(m)) {
      split natural(n) \wedge natural(m) \wedge equal(suc(n), suc(m))
      apply suc_implies_in for n
      substitute in(n, suc(n)) for suc(n): suc(m)
      apply invoke rightward suc_characterization for m, n
      apply suc_implies_in for m
      substitute in(m, suc(m)) for suc(m): suc(n)
      apply invoke rightward suc_characterization for n, m
      divide in(n, m) \vee equal(n, m)
        case in(n, m) {
          divide in(m, n) \vee equal(m, n)
            case in(m, n) {
              connect natural(n) \wedge natural(m) \wedge in(n, m) \wedge in(m, n)
              split 1 natural_is_wellorder
              split 2 orderon_predicate(natural, in)
              apply invoke antisymrelon_predicate(natural, in) for m, n
            }
            case equal(m, n) {}
        }
        case equal(n, m) {}
    }
  }
}

theorem suc_is_injection_cor1 \forall n \forall m (natural(n) \wedge natural(m) \wedge neq(n, m) \to neq(suc(n), suc(m))) {
  any n, m {
    assume natural(n) \wedge natural(m) \wedge neq(n, m) {
      split natural(n) \wedge natural(m) \wedge neq(n, m)
      deny equal(suc(n), suc(m)) {
        connect natural(n) \wedge natural(m) \wedge equal(suc(n), suc(m))
        apply invoke suc_is_injection for n, m
        contradict equal(n, m)
      }
    }
  }
}

definition predicate inductive(predicate \phi[1]) as \phi(emptyset) \wedge \forall x (\phi(x) \to \phi(suc(x)))

theorem natural_induction \forall^P \phi[1] (inductive(\phi) \to subset_predicate(natural, \phi)) {
  any predicate \phi[1] {
    assume inductive(\phi) {
      deny \neg(subset_predicate(natural, \phi)) {
        apply invoke rightward neg_subset_predicate for natural, \phi
        apply invoke natural_is_wellfounded for \lambda^P n. \neg(\phi(n))
        some n such \exists n (minimal_predicate(natural, in, \lambda^P m. \neg(\phi(m)), n)) {
          split minimal_predicate(natural, in, \lambda^P m. \neg(\phi(m)), n)
          divide natural(n)
            case equal(n, emptyset) {
              split 1 inductive(\phi)
              substitute \phi(emptyset) for emptyset: n
              contradict \phi(n)
            }
            case sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m)) {
              split sucordinal(n) \wedge \forall m (in(m, n) \to equal(m, emptyset) \vee sucordinal(m))
              split sucordinal(n)
              some m such \exists m (equal(n, suc(m))) {
                apply suc_implies_in for m
                substitute natural(n) for n: suc(m)
                connect in(m, suc(m)) \wedge natural(suc(m))
                apply invoke natural_is_trans for suc(m), m
                deny equal(m, suc(m)) {
                  substitute in(m, suc(m)) for m[1]: suc(m)
                  apply invoke natural_is_irrefrelon for suc(m)
                  contradict in(suc(m), suc(m))
                }
                deny \neg(\phi(m)) {
                  connect natural(m) \wedge \neg(\phi(m)) \wedge neq(m, suc(m))
                  substitute minimal_core_predicate(natural, in, \lambda^P l. \neg(\phi(l)), n) for n: suc(m)
                  apply invoke minimal_core_predicate(natural, in, \lambda^P l. \neg(\phi(l)), suc(m)) for m
                  contradict in(m, suc(m))
                }
                split 2 inductive(\phi)
                apply invoke \forall x (\phi(x) \to \phi(suc(x))) for m
                substitute \neg(\phi(n)) for n: suc(m)
                contradict \phi(suc(m))
              }
            }
        }
      }
    }
  }
}
