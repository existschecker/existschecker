include "zfc_finite_pair.proof"

definition predicate rel(R) as \forall z (in(z, R) \to \exists x \exists y (equal(z, op(x, y))))

definition predicate dom(R, predicate \phi[1]) as \forall x (\phi(x) \leftrightarrow \exists y (in(op(x, y), R)))

definition predicate ran(R, predicate \phi[1]) as \forall y (\phi(y) \leftrightarrow \exists x (in(op(x, y), R)))

definition predicate fun(f) as rel(f) \wedge \forall x \forall y \forall y' (in(op(x, y), f) \wedge in(op(x, y'), f) \to equal(y, y'))

definition predicate inj(f) as fun(f) \wedge \forall x \forall x' \forall y (in(op(x, y), f) \wedge in(op(x', y), f) \to equal(x, x'))

definition predicate equipotent(predicate \phi[1], predicate \chi[1]) as \exists f (inj(f) \wedge dom(f, \phi) \wedge ran(f, \chi))

definition predicate finite(predicate \phi[1]) as \exists n (natural(n) \wedge equipotent(n, \phi))

theorem singleton_op_is_rel \forall x \forall y (rel(singleton(op(x, y)))) {
  any x, y {
    any z {
      assume in(z, singleton(op(x, y))) {
        apply invoke rightward singleton_characterization for op(x, y), z
        lift for x, y conclude \exists x \exists y (equal(z, op(x, y)))
      }
    }
    fold for rel conclude rel(singleton(op(x, y)))
  }
}

theorem singleton_op_dom \forall x \forall y (dom(singleton(op(x, y)), singleton(x))) {
  any x, y {
    any p {
      assume in(p, singleton(x)) {
        apply invoke rightward singleton_characterization for x, p
        substitute equal(op(x, y), op(x, y)) for x[1]: p
        apply invoke leftward singleton_characterization for op(x, y), op(p, y)
        lift for y conclude \exists q (in(op(p, q), singleton(op(x, y))))
      }
      assume \exists q (in(op(p, q), singleton(op(x, y)))) {
        some q such \exists q (in(op(p, q), singleton(op(x, y)))) {
          apply invoke rightward singleton_characterization for op(x, y), op(p, q)
          apply invoke op_characterization for p, q, x, y
          split 1 equal(p, x) \wedge equal(q, y)
          apply invoke leftward singleton_characterization for x, p
        }
      }
      connect in(p, singleton(x)) \leftrightarrow \exists q (in(op(p, q), singleton(op(x, y))))
    }
    fold for dom conclude dom(singleton(op(x, y)), singleton(x))
  }
}

theorem singleton_op_is_fun \forall x \forall y (fun(singleton(op(x, y)))) {
  any x, y {
    apply singleton_op_is_rel for x, y
    any p, q, q' {
      assume in(op(p, q), singleton(op(x, y))) \wedge in(op(p, q'), singleton(op(x, y))) {
        split in(op(p, q), singleton(op(x, y))) \wedge in(op(p, q'), singleton(op(x, y)))
        apply invoke rightward singleton_characterization for op(x, y), op(p, q)
        apply invoke rightward singleton_characterization for op(x, y), op(p, q')
        substitute equal(op(x, y), op(p, q)) for op(x, y): op(p, q')
        apply invoke op_characterization for p, q', p, q
        split 2 equal(p, p) \wedge equal(q', q)
      }
    }
    connect fun(singleton(op(x, y)))
  }
}

theorem adding_op_rel \forall R \forall x \forall y (rel(R) \to rel(adj(R, op(x, y)))) {
  any R, x, y {
    assume rel(R) {
      any z {
        assume in(z, adj(R, op(x, y))) {
          apply invoke rightward adj_existence for R, op(x, y), z
          divide in(z, R) \vee equal(z, op(x, y))
            case in(z, R) {
              apply invoke rel(R) for z
            }
            case equal(z, op(x, y)) {
              lift for x, y conclude \exists x \exists y (equal(z, op(x, y)))
            }
        }
      }
      fold for rel conclude rel(adj(R, op(x, y)))
    }
  }
}

theorem adding_op_dom \forall R \forall X \forall x \forall y (dom(R, X) \to dom(adj(R, op(x, y)), adj(X, x))) {
  any R, X, x, y {
    assume dom(R, X) {
      any p {
        assume in(p, adj(X, x)) {
          apply invoke rightward adj_existence for X, x, p
          divide in(p, X) \vee equal(p, x)
            case in(p, X) {
              apply invoke rightward dom(R, X) for p
              some q such \exists q (in(op(p, q), R)) {
                pad in(op(p, q), R) conclude in(op(p, q), R) \vee equal(op(p, q), op(x, y))
                apply invoke leftward adj_existence for R, op(x, y), op(p, q)
                lift for q conclude \exists q (in(op(p, q), adj(R, op(x, y))))
              }
            }
            case equal(p, x) {
              substitute equal(op(x, y), op(x, y)) for x[1]: p
              pad equal(op(p, y), op(x, y)) conclude in(op(p, y), R) \vee equal(op(p, y), op(x, y))
              apply invoke leftward adj_existence for R, op(x, y), op(p, y)
              lift for y conclude \exists q (in(op(p, q), adj(R, op(x, y))))
            }
        }
        assume \exists q (in(op(p, q), adj(R, op(x, y)))) {
          some q such \exists q (in(op(p, q), adj(R, op(x, y)))) {
            apply invoke rightward adj_existence for R, op(x, y), op(p, q)
            divide in(op(p, q), R) \vee equal(op(p, q), op(x, y))
              case in(op(p, q), R) {
                lift for q conclude \exists q (in(op(p, q), R))
                apply invoke leftward dom(R, X) for p
                pad in(p, X) conclude in(p, X) \vee equal(p, x)
                apply invoke leftward adj_existence for X, x, p
              }
              case equal(op(p, q), op(x, y)) {
                apply invoke op_characterization for p, q, x, y
                split 1 equal(p, x) \wedge equal(q, y)
                pad equal(p, x) conclude in(p, X) \vee equal(p, x)
                apply invoke leftward adj_existence for X, x, p
              }
          }
        }
        connect in(p, adj(X, x)) \leftrightarrow \exists q (in(op(p, q), adj(R, op(x, y))))
      }
      fold for dom conclude dom(adj(R, op(x, y)), adj(X, x))
    }
  }
}

theorem adding_op_fun \forall f \forall x \forall y (fun(f) \wedge \neg(\exists q (in(op(x, q), f))) \to fun(adj(f, op(x, y)))) {
  any f, x, y {
    assume fun(f) \wedge \neg(\exists q (in(op(x, q), f))) {
      split fun(f) \wedge \neg(\exists q (in(op(x, q), f)))
      split fun(f)
      apply invoke adding_op_rel for f, x, y
      any p, q, q' {
        assume in(op(p, q), adj(f, op(x, y))) \wedge in(op(p, q'), adj(f, op(x, y))) {
          split in(op(p, q), adj(f, op(x, y))) \wedge in(op(p, q'), adj(f, op(x, y)))
          apply invoke rightward adj_existence for f, op(x, y), op(p, q)
          apply invoke rightward adj_existence for f, op(x, y), op(p, q')
          divide in(op(p, q), f) \vee equal(op(p, q), op(x, y))
            case in(op(p, q), f) {
              divide in(op(p, q'), f) \vee equal(op(p, q'), op(x, y))
                case in(op(p, q'), f) {
                  connect in(op(p, q), f) \wedge in(op(p, q'), f)
                  apply invoke \forall x \forall y \forall y' (in(op(x, y), f) \wedge in(op(x, y'), f) \to equal(y, y')) for p, q, q'
                }
                case equal(op(p, q'), op(x, y)) {
                  apply invoke op_characterization for p, q', x, y
                  split 1 equal(p, x) \wedge equal(q', y)
                  substitute \neg(\exists q (in(op(x, q), f))) for x: p
                  lift for q conclude \exists q (in(op(p, q), f))
                  contradict \exists q (in(op(p, q), f))
                  explode equal(q, q')
                }
            }
            case equal(op(p, q), op(x, y)) {
              divide in(op(p, q'), f) \vee equal(op(p, q'), op(x, y))
                case in(op(p, q'), f) {
                  apply invoke op_characterization for p, q, x, y
                  split 1 equal(p, x) \wedge equal(q, y)
                  substitute \neg(\exists q (in(op(x, q), f))) for x: p
                  lift for q' conclude \exists q' (in(op(p, q'), f))
                  contradict \exists q (in(op(p, q), f))
                  explode equal(q, q')
                }
                case equal(op(p, q'), op(x, y)) {
                  apply invoke op_characterization for p, q, x, y
                  split 2 equal(p, x) \wedge equal(q, y)
                  apply invoke op_characterization for p, q', x, y
                  split 2 equal(p, x) \wedge equal(q', y)
                  substitute equal(q, y) for y: q'
                }
            }
        }
      }
      connect fun(adj(f, op(x, y)))
    }
  }
}

/* theorem finite_separation \forall x \forall^P \phi[1] (finite(x) \to \exists y \forall z (in(z, y) \leftrightarrow in(z, x) \wedge \phi(z))) */

definition predicate approx(g, n, predicate \phi[1], predicate \psi[2]) as fun(g) \wedge dom(g, suc(n)) \wedge \exists a (in(op(emptyset, a), g) \wedge \phi(a)) \wedge \forall k (in(k, n) \to \exists p \exists q (in(op(k, p), g) \wedge in(op(suc(k), q), g) \wedge \psi(p, q)))

definition function predicate[2] recursion(predicate \phi[1], predicate \psi[2]) as \lambda^P n, x. natural(n) \wedge \exists g (approx(g, n, \phi, \psi) \wedge in(op(n, x), g))

definition function predicate[1] tc(predicate \phi[1], predicate \psi[2]) as \lambda^P e. \exists n \exists s (recursion(\phi, \psi)(n, s) \wedge in(e, s))
