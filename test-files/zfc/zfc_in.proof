include "..\logic\logic.proof"

primitive predicate in arity 2 tex infix "\in"

equality equal tex infix "="

axiom axiom_of_extensionality \forall x \forall y (\forall z (in(z, x) \leftrightarrow in(z, y)) \to equal(x, y))

theorem set_is_unique_for_each_predicate \forall^P\phi[1]\forall x\forall x'(\forall y(in(y,x)\leftrightarrow\phi(y))\wedge\forall y(in(y,x')\leftrightarrow\phi(y))\to equal(x,x')) {
  any predicate \phi[1], x, x' {
    assume \forall y(in(y,x)\leftrightarrow\phi(y))\wedge\forall y(in(y,x')\leftrightarrow\phi(y)) {
      split \forall y(in(y,x)\leftrightarrow\phi(y))\wedge\forall y(in(y,x')\leftrightarrow\phi(y))
      any y {
        assume in(y,x) {
          apply invoke rightward \forall y(in(y,x)\leftrightarrow\phi(y)) for y
          apply invoke leftward \forall y(in(y,x')\leftrightarrow\phi(y)) for y
        }
        assume in(y,x') {
          apply invoke rightward \forall y(in(y,x')\leftrightarrow\phi(y)) for y
          apply invoke leftward \forall y(in(y,x)\leftrightarrow\phi(y)) for y
        }
        connect in(y,x)\leftrightarrow in(y,x')
      }
      apply invoke axiom_of_extensionality for x, x'
    }
  }
}

definition predicate autoexpand notin(x,y) as \neg(in(x,y)) tex infix "\notin"

definition predicate autoexpand neq(x,y) as \neg(equal(x,y)) tex infix "\neq"

theorem neq_cor1 \forall x\forall y(neq(x,y)\leftrightarrow\exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)))) {
  any x, y {
    assume neq(x,y) {
      deny \forall z(in(z,x)\leftrightarrow in(z,y)) {
        apply invoke axiom_of_extensionality for x, y
        contradict equal(x,y)
      }
      deny \neg(\exists z(\neg(in(z,x)\leftrightarrow in(z,y)))) {
        any z {
          deny \neg(in(z,x)\leftrightarrow in(z,y)) {
            lift for z conclude \exists z(\neg(in(z,x)\leftrightarrow in(z,y)))
            contradict \exists z(\neg(in(z,x)\leftrightarrow in(z,y)))
          }
        }
        contradict \forall z(in(z,x)\leftrightarrow in(z,y))
      }
      some z such \exists z(\neg(in(z,x)\leftrightarrow in(z,y))) {
        deny (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x)) {
          split (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x))
          connect in(z,x)\leftrightarrow in(z,y)
          contradict in(z,x)\leftrightarrow in(z,y)
        }
        deny \neg(\neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))) {
          deny \neg(in(z,x)\to in(z,y)) {
            pad \neg(in(z,x)\to in(z,y)) conclude \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
            contradict \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
          }
          deny \neg(in(z,y)\to in(z,x)) {
            pad \neg(in(z,y)\to in(z,x)) conclude \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
            contradict \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
          }
          connect (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x))
          contradict (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x))
        }
        divide \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
          case \neg(in(z,x)\to in(z,y)) {
            deny \neg(in(z,x)\wedge notin(z,y)) {
              assume in(z,x) {
                deny notin(z,y) {
                  connect in(z,x)\wedge notin(z,y)
                  contradict in(z,x)\wedge notin(z,y)
                }
              }
              contradict in(z,x)\to in(z,y)
            }
            pad in(z,x)\wedge notin(z,y) conclude (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
          }
          case \neg(in(z,y)\to in(z,x)) {
            deny \neg(notin(z,x)\wedge in(z,y)) {
              assume in(z,y) {
                deny notin(z,x) {
                  connect notin(z,x)\wedge in(z,y)
                  contradict notin(z,x)\wedge in(z,y)
                }
              }
              contradict in(z,y)\to in(z,x)
            }
            pad notin(z,x)\wedge in(z,y) conclude (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
          }
        lift for z conclude \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)))
      }
    }
    assume \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) {
      some z such \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) {
        deny equal(x,y) {
          divide (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
            case in(z,x)\wedge notin(z,y) {
              split in(z,x)\wedge notin(z,y)
              substitute in(z, x) for x: y
              contradict in(z,y)
            }
            case notin(z,x)\wedge in(z,y) {
              split notin(z,x)\wedge in(z,y)
              substitute in(z, y) for y: x
              contradict in(z,x)
            }
        }
      }
    }
    connect neq(x,y)\leftrightarrow\exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)))
  }
}

definition predicate subset(x,y) as \forall z(in(z,x)\to in(z,y)) tex infix "\subset"

theorem subset_reflection \forall x(subset(x,x)) {
  any x {
    any y {
      assume in(y,x) {}
    }
    fold for subset conclude subset(x,x)
  }
}

theorem subset_antisymmetry \forall x\forall y(subset(x,y)\wedge subset(y,x)\leftrightarrow equal(x,y)) {
  any x,y {
    assume subset(x,y)\wedge subset(y,x) {
      any z {
        assume in(z,x) {
          split subset(x,y)\wedge subset(y,x)
          connect in(z,x)\wedge subset(x,y)
          apply invoke subset(x,y) for z
        }
        assume in(z,y) {
          split subset(x,y)\wedge subset(y,x)
          connect in(z,y)\wedge subset(y,x)
          apply invoke subset(y,x) for z
        }
        connect in(z,x)\leftrightarrow in(z,y)
      }
      apply invoke axiom_of_extensionality for x, y
    }
    assume equal(x,y) {
      any z {
        assume in(z,x) {
          substitute in(z, x) for x: y
        }
      }
      fold for subset conclude subset(x,y)
      any z {
        assume in(z,y) {
          substitute in(z, y) for y: x
        }
      }
      fold for subset conclude subset(y,x)
      connect subset(x,y)\wedge subset(y,x)
    }
    connect subset(x,y)\wedge subset(y,x)\leftrightarrow equal(x,y)
  }
}

theorem subset_trans \forall x\forall y\forall z(subset(x,y)\wedge subset(y,z)\to subset(x,z)) {
  any x,y,z {
    assume subset(x,y)\wedge subset(y,z) {
      any w {
        assume in(w,x) {
          split subset(x,y)\wedge subset(y,z)
          connect in(w,x)\wedge subset(x,y)
          apply invoke subset(x,y) for w
          connect in(w,y)\wedge subset(y,z)
          apply invoke subset(y,z) for w
        }
      }
      fold for subset conclude subset(x,z)
    }
  }
}

theorem neg_subset \forall x\forall y(\neg(subset(x,y))\leftrightarrow\exists z(in(z,x)\wedge notin(z,y))) {
  any x,y {
    assume \neg(subset(x,y)) {
      expand \neg(subset(x,y)) for subset
      apply invoke leftward exist_neg_leftrightarrow_neg_forall for \lambda^P z.in(z,x)\to in(z,y)
      some z such \exists z(\neg(in(z,x)\to in(z,y))) {
        apply invoke rightward neg_implication for \lambda^P.in(z,x),\lambda^P.in(z,y)
        lift for z conclude \exists z(in(z,x)\wedge notin(z,y))
      }
    }
    assume \exists z(in(z,x)\wedge notin(z,y)) {
      some z such \exists z(in(z,x)\wedge notin(z,y)) {
        apply invoke leftward neg_implication for \lambda^P.in(z,x),\lambda^P.in(z,y)
        lift for z conclude \exists z(\neg(in(z,x)\to in(z,y)))
      }
      apply invoke rightward exist_neg_leftrightarrow_neg_forall for \lambda^P z.in(z,x)\to in(z,y)
      fold for subset conclude \neg(subset(x,y))
    }
    connect \neg(subset(x,y))\leftrightarrow\exists z(in(z,x)\wedge notin(z,y))
  }
}

theorem neq_iff_subset \forall x\forall y(neq(x,y)\leftrightarrow\neg(subset(x,y))\vee\neg(subset(y,x))) {
  any x,y {
    apply subset_antisymmetry for x,y
    apply invoke neg_iff for \lambda^P.subset(x,y)\wedge subset(y,x),\lambda^P.equal(x,y)
    assume neq(x,y) {
      invoke leftward \neg(subset(x,y)\wedge subset(y,x))\leftrightarrow neq(x,y)
      apply invoke rightward neg_and for \lambda^P.subset(x,y),\lambda^P.subset(y,x)
    }
    assume \neg(subset(x,y))\vee\neg(subset(y,x)) {
      apply invoke leftward neg_and for \lambda^P.subset(x,y),\lambda^P.subset(y,x)
      invoke rightward \neg(subset(x,y)\wedge subset(y,x))\leftrightarrow neq(x,y)
    }
    connect neq(x,y)\leftrightarrow\neg(subset(x,y))\vee\neg(subset(y,x))
  }
}

definition predicate subsetneq(x,y) as subset(x,y)\wedge neq(x,y) tex infix "\subsetneq"

theorem subsetneq_implies_exist \forall x\forall y(subsetneq(x,y)\to\exists z(in(z,y)\wedge notin(z,x))) {
  any x,y {
    assume subsetneq(x,y) {
      split subsetneq(x,y)
      apply invoke rightward neq_cor1 for x,y
      some z such \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) {
        divide (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
          case in(z,x)\wedge notin(z,y) {
            split in(z,x)\wedge notin(z,y)
            connect in(z,x)\wedge subset(x,y)
            apply invoke subset(x,y) for z
            contradict in(z,y)
            explode notin(z,x)\wedge in(z,y)
          }
          case notin(z,x)\wedge in(z,y) {}
        lift for z conclude \exists z(in(z,y)\wedge notin(z,x))
      }
    }
  }
}

theorem subset_subsetneq \forall x\forall y(subset(x,y)\leftrightarrow subsetneq(x,y)\vee equal(x,y)) {
  any x,y {
    assume subset(x,y) {
      apply law_of_excluded_middle for \lambda^P.equal(x,y)
      divide equal(x,y)\vee neq(x,y)
        case equal(x,y) {
          pad equal(x,y) conclude subsetneq(x,y)\vee equal(x,y)
        }
        case neq(x,y) {
          connect subset(x,y)\wedge neq(x,y)
          fold for subsetneq conclude subsetneq(x,y)
          pad subsetneq(x,y) conclude subsetneq(x,y)\vee equal(x,y)
        }
    }
    assume subsetneq(x,y)\vee equal(x,y) {
      divide subsetneq(x,y)\vee equal(x,y)
        case subsetneq(x,y) {
          split 1 subsetneq(x,y)
        }
        case equal(x,y) {
          apply invoke leftward subset_antisymmetry for x,y
          split 1 subset(x,y)\wedge subset(y,x)
        }
    }
    connect subset(x,y)\leftrightarrow subsetneq(x,y)\vee equal(x,y)
  }
}
