include "zfc_pair.proof"

axiom axiom_of_union \forall x\exists y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))

theorem union_exists_uniquely \forall x\exists!y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) {
  any x {
    apply axiom_of_union for x
    some y such \exists y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) {
      any y' {
        assume \forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) {
          any z {
            assume in(z,y') {
              apply invoke rightward \forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z
              apply invoke leftward \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z
            }
            assume in(z,y) {
              apply invoke rightward \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z
              apply invoke leftward \forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z
            }
            connect in(z,y')\leftrightarrow in(z,y)
          }
          apply invoke axiom_of_extensionality for y', y
        }
      }
      connect \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\wedge\forall y'(\forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\to equal(y',y))
      characterize for y conclude \exists!y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))
    }
  }
}

definition function bigcup by union_exists_uniquely tex "\bigcup",""
existence bigcup_existence \forall x\forall z(in(z,bigcup(x))\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) by bigcup
uniqueness bigcup_uniqueness \forall x(\forall y(\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\to equal(y,bigcup(x)))) by bigcup

theorem bigcup_cor1 \forall x\forall y(in(y,x)\to subset(y,bigcup(x))) {
  any x,y {
    assume in(y,x) {
      any z {
        assume in(z,y) {
          connect in(z,y)\wedge in(y,x)
          lift for y conclude \exists y(in(z,y)\wedge in(y,x))
          apply invoke leftward bigcup_existence for x,z
        }
      }
      fold for subset conclude subset(y,bigcup(x))
    }
  }
}

theorem bigcup_cor2 equal(bigcup(emptyset),emptyset) {
  any x {
    deny in(x,bigcup(emptyset)) {
      apply invoke rightward bigcup_existence for emptyset,x
      some w such \exists w(in(x,w)\wedge in(w,emptyset)) {
        split in(x,w)\wedge in(w,emptyset)
        apply emptyset_existence for w
        contradict in(w,emptyset)
      }
    }
  }
  apply invoke emptyset_uniqueness for bigcup(emptyset)
}

definition function cup(x,y) as bigcup(pair(x,y)) tex infix "\cup"

theorem cup_characterization \forall x\forall y\forall z(in(z,cup(x,y))\leftrightarrow in(z,x)\vee in(z,y)) {
  any x,y,z {
    assume in(z,cup(x,y)) {
      show \exists w(in(z,w)\wedge in(w,pair(x,y))) {
        expand in(z,cup(x,y)) for cup
        apply invoke rightward bigcup_existence for pair(x,y),z
      }
      some w such \exists w(in(z,w)\wedge in(w,pair(x,y))) {
        split in(z,w)\wedge in(w,pair(x,y))
        show equal(w,x)\vee equal(w,y) {
          apply invoke rightward pair_existence for x,y,w
        }
        divide equal(w,x)\vee equal(w,y)
          case equal(w,x) {
            substitute in(z,w) for w:x
            pad in(z,x) conclude in(z,x)\vee in(z,y)
          }
          case equal(w,y) {
            substitute in(z,w) for w:y
            pad in(z,y) conclude in(z,x)\vee in(z,y)
          }
      }
    }
    assume in(z,x)\vee in(z,y) {
      divide in(z,x)\vee in(z,y)
        case in(z,x) {
          show \exists w(in(z,w)\wedge in(w,pair(x,y))) {
            apply pair_cor1 for x,y
            connect in(z,x)\wedge in(x,pair(x,y))
            lift for x conclude \exists w(in(z,w)\wedge in(w,pair(x,y)))
          }
          show in(z,cup(x,y)) {
            apply invoke leftward bigcup_existence for pair(x,y),z
            fold for cup conclude in(z,cup(x,y))
          }
        }
        case in(z,y) {
          show \exists w(in(z,w)\wedge in(w,pair(x,y))) {
            apply pair_cor2 for x,y
            connect in(z,y)\wedge in(y,pair(x,y))
            lift for y conclude \exists w(in(z,w)\wedge in(w,pair(x,y)))
          }
          show in(z,cup(x,y)) {
            apply invoke leftward bigcup_existence for pair(x,y),z
            fold for cup conclude in(z,cup(x,y))
          }
        }
    }
    connect in(z,cup(x,y))\leftrightarrow in(z,x)\vee in(z,y)
  }
}

theorem cup_commutativity \forall x\forall y(equal(cup(x,y),cup(y,x))) {
  any x,y {
    expand equal(cup(x,y),cup(x,y)) for cup[2]
    apply pair_commutativity for x,y
    substitute equal(cup(x,y),bigcup(pair(x,y))) for pair(x,y):pair(y,x)
    fold for cup[2] conclude equal(cup(x,y),cup(y,x))
  }
}

theorem cup_cor1 \forall x(equal(cup(x,emptyset),x)) {
  any x {
    any y {
      assume in(y,cup(x,emptyset)) {
        apply invoke rightward cup_characterization for x,emptyset,y
        divide in(y,x)\vee in(y,emptyset)
          case in(y,x) {}
          case in(y,emptyset) {
            apply emptyset_existence for y
            contradict in(y,emptyset)
            explode in(y,x)
          }
      }
      assume in(y,x) {
        pad in(y,x) conclude in(y,x)\vee in(y,emptyset)
        apply invoke leftward cup_characterization for x,emptyset,y
      }
      connect in(y,cup(x,emptyset))\leftrightarrow in(y,x)
    }
    apply invoke axiom_of_extensionality for cup(x, emptyset), x
  }
}

theorem cup_cor2 \forall x(equal(cup(emptyset,x),x)) {
  any x {
    apply cup_commutativity for x,emptyset
    apply cup_cor1 for x
    substitute equal(cup(x,emptyset),x) for cup(x,emptyset):cup(emptyset,x)
  }
}

theorem cup_cor3 \forall x\forall y(subset(x,cup(x,y))) {
  any x,y {
    any z {
      assume in(z,x) {
        pad in(z,x) conclude in(z,x)\vee in(z,y)
        apply invoke leftward cup_characterization for x,y,z
      }
    }
    fold for subset conclude subset(x,cup(x,y))
  }
}

theorem cup_cor4 \forall x\forall y(subset(y,cup(x,y))) {
  any x,y {
    apply cup_commutativity for x,y
    apply cup_cor3 for y,x
    substitute subset(y,cup(y,x)) for cup(y,x):cup(x,y)
  }
}

theorem cup_cor5 \forall x\forall y\forall X\forall Y(in(x,X)\wedge in(y,Y)\to subset(pair(x,y),cup(X,Y))) {
  any x,y,X,Y {
    assume in(x,X)\wedge in(y,Y) {
      split in(x,X)\wedge in(y,Y)
      any z {
        assume in(z,pair(x,y)) {
          apply invoke rightward pair_existence for x,y,z
          divide equal(z,x)\vee equal(z,y)
            case equal(z,x) {
              substitute in(x,X) for x:z
              apply cup_cor3 for X,Y
              connect in(z,X)\wedge subset(X,cup(X,Y))
              apply invoke subset(X,cup(X,Y)) for z
            }
            case equal(z,y) {
              substitute in(y,Y) for y:z
              apply cup_cor4 for X,Y
              connect in(z,Y)\wedge subset(Y,cup(X,Y))
              apply invoke subset(Y,cup(X,Y)) for z
            }
        }
      }
      fold for subset conclude subset(pair(x,y),cup(X,Y))
    }
  }
}
