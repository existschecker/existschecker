include "zfc_cartprod.proof"

definition predicate rel(R) as \forall z(in(z,R)\to\exists x\exists y(equal(z,op(x,y))))

theorem emptyset_is_relation rel(emptyset) {
  any z {
    assume in(z,emptyset) {
      apply emptyset_existence for z
      contradict in(z,emptyset)
      explode \exists x\exists y(equal(z,op(x,y)))
    }
  }
  fold for rel conclude rel(emptyset)
}

theorem cartprod_is_relation \forall X\forall Y(rel(cartprod(X,Y))) {
  any X,Y {
    any z {
      assume in(z,cartprod(X,Y)) {
        apply invoke rightward cartprod_characterization for X,Y,z
        some x,y such \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y))) {
          split 3 in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y))
          lift for x,y conclude \exists x\exists y(equal(z,op(x,y)))
        }
      }
    }
    fold for rel conclude rel(cartprod(X,Y))
  }
}

definition predicate relon(X,R) as \forall z(in(z,R)\to\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))))

theorem emptyset_is_relon_emptyset relon(emptyset,emptyset) {
  any z {
    assume in(z,emptyset) {
      apply emptyset_existence for z
      contradict in(z,emptyset)
      explode \exists x\exists y(in(x,emptyset)\wedge in(y,emptyset)\wedge equal(z,op(x,y)))
    }
  }
  fold for relon conclude relon(emptyset,emptyset)
}

definition function res(R,X) as cap(R,cartprod(X,X))

theorem res_characterization \forall R\forall X\forall z(in(z,res(R,X))\leftrightarrow in(z,R)\wedge in(z,cartprod(X,X))) {
  any R,X,z {
    assume in(z,res(R,X)) {
      expand in(z,res(R,X)) for res
      apply invoke rightward cap_characterization for R,cartprod(X,X),z
    }
    assume in(z,R)\wedge in(z,cartprod(X,X)) {
      apply invoke leftward cap_characterization for R,cartprod(X,X),z
      fold for res conclude in(z,res(R,X))
    }
    connect in(z,res(R,X))\leftrightarrow in(z,R)\wedge in(z,cartprod(X,X))
  }
}

theorem res_characterization_op \forall R\forall X\forall x\forall y(in(op(x,y),res(R,X))\leftrightarrow in(op(x,y),R)\wedge in(x,X)\wedge in(y,X)) {
  any R,X,x,y {
    assume in(op(x,y),res(R,X)) {
      apply invoke rightward res_characterization for R,X,op(x,y)
      split in(op(x,y),R)\wedge in(op(x,y),cartprod(X,X))
      apply invoke leftward cartprod_cor1 for X,X,x,y
      split in(x,X)\wedge in(y,X)
      connect in(op(x,y),R)\wedge in(x,X)\wedge in(y,X)
    }
    assume in(op(x,y),R)\wedge in(x,X)\wedge in(y,X) {
      split in(op(x,y),R)\wedge in(x,X)\wedge in(y,X)
      connect in(x,X)\wedge in(y,X)
      apply invoke rightward cartprod_cor1 for X,X,x,y
      connect in(op(x,y),R)\wedge in(op(x,y),cartprod(X,X))
      apply invoke leftward res_characterization for R,X,op(x,y)
    }
    connect in(op(x,y),res(R,X))\leftrightarrow in(op(x,y),R)\wedge in(x,X)\wedge in(y,X)
  }
}

theorem res_is_relon \forall X\forall R(relon(X,res(R,X))) {
  any X,R {
    any z {
      assume in(z,res(R,X)) {
        expand in(z,res(R,X)) for res
        apply invoke rightward cap_characterization for R,cartprod(X,X),z
        split 2 in(z,R)\wedge in(z,cartprod(X,X))
        apply invoke rightward cartprod_characterization for X,X,z
      }
    }
    fold for relon conclude relon(X,res(R,X))
  }
}

definition function dom(R) as sep(bigcup(bigcup(R)),\lambda^P x.\exists y(in(op(x,y),R)))

theorem dom_lem1 \forall R\forall x(\exists y(in(op(x,y),R))\to in(x,bigcup(bigcup(R)))) {
  any R,x {
    assume \exists y(in(op(x,y),R)) {
      some y such \exists y(in(op(x,y),R)) {
        expand in(op(x,y),R) for op
        apply pair_cor1 for singleton(x),pair(x,y)
        connect in(singleton(x),pair(singleton(x),pair(x,y)))\wedge in(pair(singleton(x),pair(x,y)),R)
        lift for pair(singleton(x),pair(x,y)) conclude \exists z(in(singleton(x),z)\wedge in(z,R))
      }
      apply invoke leftward bigcup_existence for R,singleton(x)
      apply singleton_cor1 for x
      connect in(x,singleton(x))\wedge in(singleton(x),bigcup(R))
      lift for singleton(x) conclude \exists z(in(x,z)\wedge in(z,bigcup(R)))
      apply invoke leftward bigcup_existence for bigcup(R),x
    }
  }
}

theorem dom_characterization \forall R\forall x(in(x,dom(R))\leftrightarrow\exists y(in(op(x,y),R))) {
  any R,x {
    assume in(x,dom(R)) {
      expand in(x,dom(R)) for dom
      apply invoke sep_cor2 for bigcup(bigcup(R)),\lambda^P x.\exists y(in(op(x,y),R)),x
    }
    assume \exists y(in(op(x,y),R)) {
      apply invoke dom_lem1 for R,x
      connect in(x,bigcup(bigcup(R)))\wedge\exists y(in(op(x,y),R))
      apply invoke leftward sep_existence for bigcup(bigcup(R)),\lambda^P x.\exists y(in(op(x,y),R)),x
      fold for dom conclude in(x,dom(R))
    }
    connect in(x,dom(R))\leftrightarrow\exists y(in(op(x,y),R))
  }
}

theorem dom_cor1 \forall R\forall x\forall y(in(op(x,y),R)\to in(x,dom(R))) {
  any R,x,y {
    assume in(op(x,y),R) {
      lift for y conclude \exists y(in(op(x,y),R))
      apply invoke leftward dom_characterization for R,x
    }
  }
}

theorem domain_of_emptyset equal(dom(emptyset),emptyset) {
  any x {
    deny in(x,dom(emptyset)) {
      apply invoke rightward dom_characterization for emptyset,x
      some y such \exists y(in(op(x,y),emptyset)) {
        apply emptyset_existence for op(x,y)
        contradict in(op(x,y),emptyset)
      }
    }
  }
  apply invoke emptyset_uniqueness for dom(emptyset)
}

theorem domain_of_cartprod \forall X\forall Y(neq(Y,emptyset)\to equal(dom(cartprod(X,Y)),X)) {
  any X,Y {
    assume neq(Y,emptyset) {
      any x {
        assume in(x,dom(cartprod(X,Y))) {
          apply invoke rightward dom_characterization for cartprod(X,Y),x
          some y such \exists y(in(op(x,y),cartprod(X,Y))) {
            apply invoke leftward cartprod_cor1 for X,Y,x,y
            split 1 in(x,X)\wedge in(y,Y)
          }
        }
        assume in(x,X) {
          apply invoke not_emptyset_has_a_member for Y
          some y such \exists y(in(y,Y)) {
            connect in(x,X)\wedge in(y,Y)
            apply invoke rightward cartprod_cor1 for X,Y,x,y
            lift for y conclude \exists y(in(op(x,y),cartprod(X,Y)))
            apply invoke leftward dom_characterization for cartprod(X,Y),x
          }
        }
        connect in(x,dom(cartprod(X,Y)))\leftrightarrow in(x,X)
      }
      apply invoke axiom_of_extensionality for dom(cartprod(X, Y)), X
    }
  }
}

definition function ran(R) as sep(bigcup(bigcup(R)),\lambda^P y.\exists x(in(op(x,y),R)))

theorem ran_lem1 \forall R\forall y(\exists x(in(op(x,y),R))\to in(y,bigcup(bigcup(R)))) {
  any R,y {
    assume \exists x(in(op(x,y),R)) {
      some x such \exists x(in(op(x,y),R)) {
        expand in(op(x,y),R) for op
        apply pair_cor2 for singleton(x),pair(x,y)
        connect in(pair(x,y),pair(singleton(x),pair(x,y)))\wedge in(pair(singleton(x),pair(x,y)),R)
        lift for pair(singleton(x),pair(x,y)) conclude \exists z(in(pair(x,y),z)\wedge in(z,R))
        apply invoke leftward bigcup_existence for R,pair(x,y)
        apply pair_cor2 for x,y
        connect in(y,pair(x,y))\wedge in(pair(x,y),bigcup(R))
        lift for pair(x,y) conclude \exists z(in(y,z)\wedge in(z,bigcup(R)))
      }
      apply invoke leftward bigcup_existence for bigcup(R),y
    }
  }
}

theorem ran_characterization \forall R\forall y(in(y,ran(R))\leftrightarrow\exists x(in(op(x,y),R))) {
  any R,y {
    assume in(y,ran(R)) {
      expand in(y,ran(R)) for ran
      apply invoke sep_cor2 for bigcup(bigcup(R)),\lambda^P y.\exists x(in(op(x,y),R)),y
    }
    assume \exists x(in(op(x,y),R)) {
      apply invoke ran_lem1 for R,y
      connect in(y,bigcup(bigcup(R)))\wedge\exists x(in(op(x,y),R))
      apply invoke leftward sep_existence for bigcup(bigcup(R)),\lambda^P y.\exists x(in(op(x,y),R)),y
      fold for ran conclude in(y,ran(R))
    }
    connect in(y,ran(R))\leftrightarrow\exists x(in(op(x,y),R))
  }
}

theorem ran_cor1 \forall R\forall x\forall y(in(op(x,y),R)\to in(y,ran(R))) {
  any R,x,y {
    assume in(op(x,y),R) {
      lift for x conclude \exists x(in(op(x,y),R))
      apply invoke leftward ran_characterization for R,y
    }
  }
}

theorem range_of_empyset equal(ran(emptyset),emptyset) {
  any y {
    deny in(y,ran(emptyset)) {
      apply invoke rightward ran_characterization for emptyset,y
      some x such \exists x(in(op(x,y),emptyset)) {
        apply emptyset_existence for op(x,y)
        contradict in(op(x,y),emptyset)
      }
    }
  }
  apply invoke emptyset_uniqueness for ran(emptyset)
}

theorem range_of_cartprod \forall X\forall Y(neq(X,emptyset)\to equal(ran(cartprod(X,Y)),Y)) {
  any X,Y {
    assume neq(X,emptyset) {
      any y {
        assume in(y,ran(cartprod(X,Y))) {
          apply invoke rightward ran_characterization for cartprod(X,Y),y
          some x such \exists x(in(op(x,y),cartprod(X,Y))) {
            apply invoke leftward cartprod_cor1 for X,Y,x,y
            split 2 in(x,X)\wedge in(y,Y)
          }
        }
        assume in(y,Y) {
          apply invoke not_emptyset_has_a_member for X
          some x such \exists x(in(x,X)) {
            connect in(x,X)\wedge in(y,Y)
            apply invoke rightward cartprod_cor1 for X,Y,x,y
            lift for x conclude \exists x(in(op(x,y),cartprod(X,Y)))
            apply invoke leftward ran_characterization for cartprod(X,Y),y
          }
        }
        connect in(y,ran(cartprod(X,Y)))\leftrightarrow in(y,Y)
      }
      apply invoke axiom_of_extensionality for ran(cartprod(X, Y)), Y
    }
  }
}

definition function relsep(X, predicate \phi[2]) as sep(cartprod(X,X),\lambda^P z.\exists x\exists y(equal(z,op(x,y))\wedge\phi(x,y)))

theorem relsep_characterization \forall X\forall^P\phi[2]\forall z(in(z,relsep(X,\phi))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y))) {
  any X, predicate \phi[2], z {
    assume in(z,relsep(X,\phi)) {
      expand in(z,relsep(X,\phi)) for relsep
      apply invoke rightward sep_existence for cartprod(X,X),\lambda^P z.\exists x\exists y(equal(z,op(x,y))\wedge\phi(x,y)),z
      split in(z,cartprod(X,X))\wedge\exists x\exists y(equal(z,op(x,y))\wedge\phi(x,y))
      some x,y such \exists x\exists y(equal(z,op(x,y))\wedge\phi(x,y)) {
        split equal(z,op(x,y))\wedge\phi(x,y)
        substitute in(z,cartprod(X,X)) for z:op(x,y)
        apply invoke leftward cartprod_cor1 for X,X,x,y
        split in(x,X)\wedge in(y,X)
        connect in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y)
        lift for x,y conclude \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y))
      }
    }
    assume \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y)) {
      some x,y such \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y)) {
        split in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y)
        connect in(x,X)\wedge in(y,X)
        apply invoke rightward cartprod_cor1 for X,X,x,y
        substitute in(op(x,y),cartprod(X,X)) for op(x,y):z
        connect equal(z,op(x,y))\wedge\phi(x,y)
        lift for x,y conclude \exists x\exists y(equal(z,op(x,y))\wedge\phi(x,y))
        connect in(z,cartprod(X,X))\wedge\exists x\exists y(equal(z,op(x,y))\wedge\phi(x,y))
      }
      apply invoke leftward sep_existence for cartprod(X,X),\lambda^P z.\exists x\exists y(equal(z,op(x,y))\wedge\phi(x,y)),z
      fold for relsep conclude in(z,relsep(X,\phi))
    }
    connect in(z,relsep(X,\phi))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y))
  }
}

theorem relsep_relon \forall X\forall^P\phi[2](relon(X,relsep(X,\phi))) {
  any X, predicate \phi[2] {
    any z {
      assume in(z,relsep(X,\phi)) {
        apply invoke rightward relsep_characterization for X,\phi,z
        some x,y such \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y)) {
          split in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y)
          connect in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))
          lift for x,y conclude \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y)))
        }
      }
    }
    fold for relon conclude relon(X,relsep(X,\phi))
  }
}

theorem relsep_res \forall X\forall^P\phi[2]\forall Y(subset(Y,X)\to equal(res(relsep(X,\phi),Y),relsep(Y,\phi))) {
  any X, predicate \phi[2], Y {
    assume subset(Y,X) {
      any z {
        assume in(z,res(relsep(X,\phi),Y)) {
          expand in(z,res(relsep(X,\phi),Y)) for res
          apply invoke rightward cap_characterization for relsep(X,\phi),cartprod(Y,Y),z
          split in(z,relsep(X,\phi))\wedge in(z,cartprod(Y,Y))
          apply invoke rightward relsep_characterization for X,\phi,z
          some x,y such \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y)) {
            split in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y)
            substitute in(z,cartprod(Y,Y)) for z:op(x,y)
            apply invoke leftward cartprod_cor1 for Y,Y,x,y
            split in(x,Y)\wedge in(y,Y)
            connect in(x,Y)\wedge in(y,Y)\wedge equal(z,op(x,y))\wedge\phi(x,y)
            lift for x,y conclude \exists x\exists y(in(x,Y)\wedge in(y,Y)\wedge equal(z,op(x,y))\wedge\phi(x,y))
          }
          apply invoke leftward relsep_characterization for Y,\phi,z
        }
        assume in(z,relsep(Y,\phi)) {
          apply invoke rightward relsep_characterization for Y,\phi,z
          some x,y such \exists x\exists y(in(x,Y)\wedge in(y,Y)\wedge equal(z,op(x,y))\wedge\phi(x,y)) {
            split in(x,Y)\wedge in(y,Y)\wedge equal(z,op(x,y))\wedge\phi(x,y)
            connect in(x,Y)\wedge subset(Y,X)
            apply invoke subset(Y,X) for x
            connect in(y,Y)\wedge subset(Y,X)
            apply invoke subset(Y,X) for y
            connect in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y)
            lift for x,y conclude \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge\phi(x,y))
            apply invoke leftward relsep_characterization for X,\phi,z
            connect in(x,Y)\wedge in(y,Y)
            apply invoke rightward cartprod_cor1 for Y,Y,x,y
            substitute in(op(x,y),cartprod(Y,Y)) for op(x,y):z
            connect in(z,relsep(X,\phi))\wedge in(z,cartprod(Y,Y))
          }
          apply invoke leftward cap_characterization for relsep(X,\phi),cartprod(Y,Y),z
          fold for res conclude in(z,res(relsep(X,\phi),Y))
        }
        connect in(z,res(relsep(X,\phi),Y))\leftrightarrow in(z,relsep(Y,\phi))
      }
      apply invoke axiom_of_extensionality for res(relsep(X, \phi), Y), relsep(Y, \phi)
    }
  }
}

definition function id(X) as relsep(X,\lambda^P x,y.equal(x,y))

theorem id_characterization \forall X\forall z(in(z,id(X))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge equal(x,y))) {
  any X,z {
    assume in(z,id(X)) {
      expand in(z,id(X)) for id
      apply invoke rightward relsep_characterization for X,\lambda^P x,y.equal(x,y),z
    }
    assume \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge equal(x,y)) {
      apply invoke leftward relsep_characterization for X,\lambda^P x,y.equal(x,y),z
      fold for id conclude in(z,id(X))
    }
    connect in(z,id(X))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge equal(x,y))
  }
}

theorem id_cor1 \forall X\forall z(in(z,id(X))\leftrightarrow\exists x(in(x,X)\wedge equal(z,op(x,x)))) {
  any X,z {
    assume in(z,id(X)) {
      apply invoke rightward id_characterization for X,z
      some x,y such \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge equal(x,y)) {
        split in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge equal(x,y)
        substitute equal(z,op(x,y)) for y:x
        connect in(x,X)\wedge equal(z,op(x,x))
        lift for x conclude \exists x(in(x,X)\wedge equal(z,op(x,x)))
      }
    }
    assume \exists x(in(x,X)\wedge equal(z,op(x,x))) {
      some x such \exists x(in(x,X)\wedge equal(z,op(x,x))) {
        split in(x,X)\wedge equal(z,op(x,x))
        connect in(x,X)\wedge in(x,X)\wedge equal(z,op(x,x))\wedge equal(x,x)
        lift for x,x conclude \exists x\exists y(in(x,X)\wedge in(y,X)\wedge equal(z,op(x,y))\wedge equal(x,y))
        apply invoke leftward id_characterization for X,z
      }
    }
    connect in(z,id(X))\leftrightarrow\exists x(in(x,X)\wedge equal(z,op(x,x)))
  }
}

theorem id_cor2 \forall X\forall x\forall y(in(op(x,y),id(X))\leftrightarrow in(x,X)\wedge in(y,X)\wedge equal(x,y)) {
  any X,x,y {
    assume in(op(x,y),id(X)) {
      apply invoke rightward id_cor1 for X,op(x,y)
      some x' such \exists x'(in(x',X)\wedge equal(op(x,y),op(x',x'))) {
        split in(x',X)\wedge equal(op(x,y),op(x',x'))
        apply invoke op_characterization for x,y,x',x'
        split equal(x,x')\wedge equal(y,x')
        substitute in(x',X) for x':x
        substitute in(x',X) for x':y
        substitute equal(x,x') for x':y
        connect in(x,X)\wedge in(y,X)\wedge equal(x,y)
      }
    }
    assume in(x,X)\wedge in(y,X)\wedge equal(x,y) {
      split in(x,X)\wedge in(y,X)\wedge equal(x,y)
      substitute equal(op(x,y),op(x,y)) for y[2]:x
      connect in(x,X)\wedge equal(op(x,y),op(x,x))
      lift for x conclude \exists x'(in(x',X)\wedge equal(op(x,y),op(x',x')))
      apply invoke leftward id_cor1 for X,op(x,y)
    }
    connect in(op(x,y),id(X))\leftrightarrow in(x,X)\wedge in(y,X)\wedge equal(x,y)
  }
}

theorem id_cor3 \forall X\forall x(in(op(x,x),id(X))\leftrightarrow in(x,X)) {
  any X,x {
    assume in(op(x,x),id(X)) {
      apply invoke rightward id_cor2 for X,x,x
      split 1 in(x,X)\wedge in(x,X)\wedge equal(x,x)
    }
    assume in(x,X) {
      connect in(x,X)\wedge in(x,X)\wedge equal(x,x)
      apply invoke leftward id_cor2 for X,x,x
    }
    connect in(op(x,x),id(X))\leftrightarrow in(x,X)
  }
}

theorem id_is_relation \forall X(rel(id(X))) {
  any X {
    any z {
      assume in(z,id(X)) {
        apply invoke rightward id_cor1 for X,z
        some x such \exists x(in(x,X)\wedge equal(z,op(x,x))) {
          split 2 in(x,X)\wedge equal(z,op(x,x))
          lift for x,x conclude \exists x\exists y(equal(z,op(x,y)))
        }
      }
    }
    fold for rel conclude rel(id(X))
  }
}

theorem id_relon \forall X(relon(X,id(X))) {
  any X {
    apply relsep_relon for X,\lambda^P x,y.equal(x,y)
    fold for id conclude relon(X,id(X))
  }
}

theorem id_res \forall X\forall Y(subset(Y,X)\to equal(id(Y),res(id(X),Y))) {
  any X,Y {
    assume subset(Y,X) {
      apply invoke relsep_res for X,\lambda^P x,y.equal(x,y),Y
      fold for id conclude equal(id(Y),res(id(X),Y))
    }
  }
}

theorem dom_of_id \forall X(equal(dom(id(X)),X)) {
  any X {
    any x {
      assume in(x,dom(id(X))) {
        apply invoke rightward dom_characterization for id(X),x
        some y such \exists y(in(op(x,y),id(X))) {
          apply invoke rightward id_cor2 for X,x,y
          split 1 in(x,X)\wedge in(y,X)\wedge equal(x,y)
        }
      }
      assume in(x,X) {
        apply invoke leftward id_cor3 for X,x
        lift for x conclude \exists y(in(op(x,y),id(X)))
        apply invoke leftward dom_characterization for id(X),x
      }
      connect in(x,dom(id(X)))\leftrightarrow in(x,X)
    }
    apply invoke axiom_of_extensionality for dom(id(X)), X
  }
}

theorem ran_of_id \forall X(equal(ran(id(X)),X)) {
  any X {
    any x {
      assume in(x,ran(id(X))) {
        apply invoke rightward ran_characterization for id(X),x
        some y such \exists y(in(op(y,x),id(X))) {
          apply invoke rightward id_cor2 for X,y,x
          split 2 in(y,X)\wedge in(x,X)\wedge equal(y,x)
        }
      }
      assume in(x,X) {
        apply invoke leftward id_cor3 for X,x
        lift for x conclude \exists y(in(op(y,x),id(X)))
        apply invoke leftward ran_characterization for id(X),x
      }
      connect in(x,ran(id(X)))\leftrightarrow in(x,X)
    }
    apply invoke axiom_of_extensionality for ran(id(X)), X
  }
}

definition function invrel(R) as sep(cartprod(ran(R),dom(R)),\lambda^P z.\exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R))) tex "","^{-1}"

theorem invrel_lem1 \forall R\forall z(\exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R))\to in(z,cartprod(ran(R),dom(R)))) {
  any R,z {
    assume \exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R)) {
      some y,x such \exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R)) {
        split equal(z,op(y,x))\wedge in(op(x,y),R)
        lift for y conclude \exists y(in(op(x,y),R))
        apply invoke leftward dom_characterization for R,x
        lift for x conclude \exists x(in(op(x,y),R))
        apply invoke leftward ran_characterization for R,y
        connect in(y,ran(R))\wedge in(x,dom(R))
        apply invoke rightward cartprod_cor1 for ran(R),dom(R),y,x
        substitute in(op(y,x),cartprod(ran(R),dom(R))) for op(y,x):z
      }
    }
  }
}

theorem invrel_characterization \forall R\forall z(in(z,invrel(R))\leftrightarrow\exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R))) {
  any R,z {
    assume in(z,invrel(R)) {
      expand in(z,invrel(R)) for invrel
      apply invoke sep_cor2 for cartprod(ran(R),dom(R)),\lambda^P z.\exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R)),z
    }
    assume \exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R)) {
      apply invoke invrel_lem1 for R,z
      connect in(z,cartprod(ran(R),dom(R)))\wedge\exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R))
      apply invoke leftward sep_existence for cartprod(ran(R),dom(R)),\lambda^P z.\exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R)),z
      fold for invrel conclude in(z,invrel(R))
    }
    connect in(z,invrel(R))\leftrightarrow\exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R))
  }
}

theorem invrel_cor1 \forall R\forall x\forall y(in(op(y,x),invrel(R))\leftrightarrow in(op(x,y),R)) {
  any R,x,y {
    assume in(op(y,x),invrel(R)) {
      apply invoke rightward invrel_characterization for R,op(y,x)
      some y',x' such \exists y'\exists x'(equal(op(y,x),op(y',x'))\wedge in(op(x',y'),R)) {
        split equal(op(y,x),op(y',x'))\wedge in(op(x',y'),R)
        apply invoke op_characterization for y,x,y',x'
        split equal(y,y')\wedge equal(x,x')
        substitute in(op(x',y'),R) for x':x,y':y
      }
    }
    assume in(op(x,y),R) {
      connect equal(op(y,x),op(y,x))\wedge in(op(x,y),R)
      lift for y,x conclude \exists y'\exists x'(equal(op(y,x),op(y',x'))\wedge in(op(x',y'),R))
      apply invoke leftward invrel_characterization for R,op(y,x)
    }
    connect in(op(y,x),invrel(R))\leftrightarrow in(op(x,y),R)
  }
}

theorem invrel_is_rel \forall R(rel(invrel(R))) {
  any R {
    any z {
      assume in(z,invrel(R)) {
        apply invoke rightward invrel_characterization for R,z
        some y,x such \exists y\exists x(equal(z,op(y,x))\wedge in(op(x,y),R)) {
          split 1 equal(z,op(y,x))\wedge in(op(x,y),R)
          lift for y,x conclude \exists y\exists x(equal(z,op(y,x)))
        }
      }
    }
    fold for rel conclude rel(invrel(R))
  }
}

theorem invrel_of_invrel_is_itself \forall R(rel(R)\leftrightarrow equal(invrel(invrel(R)),R)) {
  any R {
    assume rel(R) {
      any z {
        assume in(z,invrel(invrel(R))) {
          apply invoke rightward invrel_characterization for invrel(R),z
          some x,y such \exists x\exists y(equal(z,op(x,y))\wedge in(op(y,x),invrel(R))) {
            split equal(z,op(x,y))\wedge in(op(y,x),invrel(R))
            apply invoke rightward invrel_cor1 for R,x,y
            substitute in(op(x,y),R) for op(x,y):z
          }
        }
        assume in(z,R) {
          expand rel(R) for rel
          apply invoke \forall z(in(z,R)\to\exists x\exists y(equal(z,op(x,y)))) for z
          some x,y such \exists x\exists y(equal(z,op(x,y))) {
            substitute in(z,R) for z:op(x,y)
            apply invoke leftward invrel_cor1 for R,x,y
            apply invoke leftward invrel_cor1 for invrel(R),y,x
            substitute in(op(x,y),invrel(invrel(R))) for op(x,y):z
          }
        }
        connect in(z,invrel(invrel(R)))\leftrightarrow in(z,R)
      }
      apply invoke axiom_of_extensionality for invrel(invrel(R)), R
    }
    assume equal(invrel(invrel(R)),R) {
      apply invrel_is_rel for invrel(R)
      substitute rel(invrel(invrel(R))) for invrel(invrel(R)):R
    }
    connect rel(R)\leftrightarrow equal(invrel(invrel(R)),R)
  }
}

theorem dom_of_invrel_is_ran \forall R(equal(dom(invrel(R)),ran(R))) {
  any R {
    any y {
      assume in(y,dom(invrel(R))) {
        apply invoke rightward dom_characterization for invrel(R),y
        some x such \exists x(in(op(y,x),invrel(R))) {
          apply invoke rightward invrel_cor1 for R,x,y
          apply invoke ran_cor1 for R,x,y
        }
      }
      assume in(y,ran(R)) {
        apply invoke rightward ran_characterization for R,y
        some x such \exists x(in(op(x,y),R)) {
          apply invoke leftward invrel_cor1 for R,x,y
          apply invoke dom_cor1 for invrel(R),y,x
        }
      }
      connect in(y,dom(invrel(R)))\leftrightarrow in(y,ran(R))
    }
    apply invoke axiom_of_extensionality for dom(invrel(R)), ran(R)
  }
}

theorem ran_of_invrel_is_dom \forall R(equal(ran(invrel(R)),dom(R))) {
  any R {
    any x {
      assume in(x,ran(invrel(R))) {
        apply invoke rightward ran_characterization for invrel(R),x
        some y such \exists y(in(op(y,x),invrel(R))) {
          apply invoke rightward invrel_cor1 for R,x,y
          apply invoke dom_cor1 for R,x,y
        }
      }
      assume in(x,dom(R)) {
        apply invoke rightward dom_characterization for R,x
        some y such \exists y(in(op(x,y),R)) {
          apply invoke leftward invrel_cor1 for R,x,y
          apply invoke ran_cor1 for invrel(R),y,x
        }
      }
      connect in(x,ran(invrel(R)))\leftrightarrow in(x,dom(R))
    }
    apply invoke axiom_of_extensionality for ran(invrel(R)), dom(R)
  }
}

definition function comprel(R,S) as sep(cartprod(dom(R),ran(S)),\lambda^P z.\exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S)))) tex infix "\circ"

theorem comprel_lem1 \forall R\forall S\forall z(\exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S)))\to in(z,cartprod(dom(R),ran(S)))) {
  any R,S,z {
    assume \exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S))) {
      some x,y such \exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S))) {
        split equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S))
        some w such \exists w(in(op(x,w),R)\wedge in(op(w,y),S)) {
          split in(op(x,w),R)\wedge in(op(w,y),S)
          apply invoke dom_cor1 for R,x,w
          apply invoke ran_cor1 for S,w,y
          connect in(x,dom(R))\wedge in(y,ran(S))
          apply invoke rightward cartprod_cor1 for dom(R),ran(S),x,y
          substitute in(op(x,y),cartprod(dom(R),ran(S))) for op(x,y):z
        }
      }
    }
  }
}

theorem comprel_characterization \forall R\forall S\forall z(in(z,comprel(R,S))\leftrightarrow\exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S)))) {
  any R,S,z {
    assume in(z,comprel(R,S)) {
      expand in(z,comprel(R,S)) for comprel
      apply invoke sep_cor2 for cartprod(dom(R),ran(S)),\lambda^P z.\exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S))),z
    }
    assume \exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S))) {
      apply invoke comprel_lem1 for R,S,z
      connect in(z,cartprod(dom(R),ran(S)))\wedge\exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S)))
      apply invoke leftward sep_existence for cartprod(dom(R),ran(S)),\lambda^P z.\exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S))),z
      fold for comprel conclude in(z,comprel(R,S))
    }
    connect in(z,comprel(R,S))\leftrightarrow\exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S)))
  }
}

theorem comprel_is_rel \forall R\forall S(rel(comprel(R,S))) {
  any R,S {
    any z {
      assume in(z,comprel(R,S)) {
        apply invoke rightward comprel_characterization for R,S,z
        some x,y such \exists x\exists y(equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S))) {
          split 1 equal(z,op(x,y))\wedge\exists w(in(op(x,w),R)\wedge in(op(w,y),S))
          lift for x,y conclude \exists x\exists y(equal(z,op(x,y)))
        }
      }
    }
    fold for rel conclude rel(comprel(R,S))
  }
}
