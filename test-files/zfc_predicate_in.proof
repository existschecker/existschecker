include "logic.proof"

primitive predicate in arity 2 tex "","\in",""

equality equal tex "", "=", ""

axiom axiom_of_extensionality \forall x \forall y (\forall z (in(z, x) \leftrightarrow in(z, y)) \to equal(x, y))

definition predicate equal_predicate(predicate \phi[1], predicate \chi[1]) as \forall x (\phi(x) \leftrightarrow \chi(x)) tex "","=",""

theorem equal_lambda \forall X \forall Y (equal(X, Y) \leftrightarrow equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))) {
  any X, Y {
    assume equal(X, Y) {
      any x {
        assume in(x, X) {
          substitute in(x, X) for X: Y
        }
        assume in(x, Y) {
          substitute in(x, Y) for Y: X
        }
        connect in(x, X) \leftrightarrow in(x, Y)
      }
      fold for equal_predicate conclude equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
    }
    assume equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) {
      expand equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) for equal_predicate
      apply invoke axiom_of_extensionality for X, Y
    }
    connect equal(X, Y) \leftrightarrow equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
  }
}

theorem set_is_unique \forall x \exists! y (equal(y, x)) {
  any x {
    any y {
      assume equal(y, x) {}
    }
    connect equal(x, x) \wedge \forall y (equal(y, x) \to equal(y, x))
    characterize for x conclude \exists! y (equal(y, x))
  }
}

theorem set_is_unique_for_each_predicate \forall^P\phi[1]\forall x\forall x'(\forall y(in(y,x)\leftrightarrow\phi(y))\wedge\forall y(in(y,x')\leftrightarrow\phi(y))\to equal(x,x')) {
  any predicate \phi[1], x, x' {
    assume \forall y(in(y,x)\leftrightarrow\phi(y))\wedge\forall y(in(y,x')\leftrightarrow\phi(y)) {
      split \forall y(in(y,x)\leftrightarrow\phi(y))\wedge\forall y(in(y,x')\leftrightarrow\phi(y))
      any y {
        assume in(y,x) {
          apply invoke rightward \forall y(in(y,x)\leftrightarrow\phi(y)) for y
          apply invoke leftward \forall y(in(y,x')\leftrightarrow\phi(y)) for y
        }
        assume in(y,x') {
          apply invoke rightward \forall y(in(y,x')\leftrightarrow\phi(y)) for y
          apply invoke leftward \forall y(in(y,x)\leftrightarrow\phi(y)) for y
        }
        connect in(y,x)\leftrightarrow in(y,x')
      }
      apply invoke axiom_of_extensionality for x, x'
    }
  }
}

definition predicate autoexpand notin(x,y) as \neg(in(x,y)) tex "","\notin",""

definition predicate autoexpand neq(x, y) as \neg(equal(x, y)) tex "", "\neq", ""

definition predicate autoexpand neq_predicate(predicate \phi[1], predicate \chi[1]) as \neg(equal_predicate(\phi, \chi)) tex "", "\neq", ""

theorem neq_lambda \forall X \forall Y (neq(X, Y) \leftrightarrow neq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))) {
  any X, Y {
    assume neq(X, Y) {
      deny equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) {
        apply invoke leftward equal_lambda for X, Y
        contradict equal(X, Y)
      }
    }
    assume neq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) {
      deny equal(X, Y) {
        apply invoke rightward equal_lambda for X, Y
        contradict equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
      }
    }
    connect neq(X, Y) \leftrightarrow neq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
  }
}

theorem neq_cor1_predicate \forall^P \phi[1] \forall^P \chi[1] (neq_predicate(\phi, \chi) \leftrightarrow \exists x ((\phi(x) \wedge \neg(\chi(x))) \vee (\neg(\phi(x)) \wedge \chi(x)))) {
  any predicate \phi[1], predicate \chi[1] {
    assume neq_predicate(\phi, \chi) {
      expand neq_predicate(\phi, \chi) for neq_predicate, equal_predicate
      apply invoke leftward exist_neg_leftrightarrow_neg_forall for \lambda^P x. \phi(x) \leftrightarrow \chi(x)
      some x such \exists x (\neg(\phi(x) \leftrightarrow \chi(x))) {
        apply invoke rightward neg_iff_iff for \lambda^P. \phi(x), \lambda^P. \chi(x)
        lift for x conclude \exists x ((\phi(x) \wedge \neg(\chi(x))) \vee (\neg(\phi(x)) \wedge \chi(x)))
      }
    }
    assume \exists x ((\phi(x) \wedge \neg(\chi(x))) \vee (\neg(\phi(x)) \wedge \chi(x))) {
      some x such \exists x ((\phi(x) \wedge \neg(\chi(x))) \vee (\neg(\phi(x)) \wedge \chi(x))) {
        apply invoke leftward neg_iff_iff for \lambda^P. \phi(x), \lambda^P. \chi(x)
        lift for x conclude \exists x (\neg(\phi(x) \leftrightarrow \chi(x)))
      }
      apply invoke rightward exist_neg_leftrightarrow_neg_forall for \lambda^P x. \phi(x) \leftrightarrow \chi(x)
      fold for neq_predicate, equal_predicate conclude neq_predicate(\phi, \chi)
    }
    connect neq_predicate(\phi, \chi) \leftrightarrow \exists x ((\phi(x) \wedge \neg(\chi(x))) \vee (\neg(\phi(x)) \wedge \chi(x)))
  }
}

theorem neq_cor1 \forall X \forall Y (neq(X, Y) \leftrightarrow \exists z ((in(z, X) \wedge notin(z, Y)) \vee (notin(z, X) \wedge in(z, Y)))) {
  any X, Y {
    assume neq(X, Y) {
      apply invoke rightward neq_lambda for X, Y
      apply invoke rightward neq_cor1_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y)
    }
    assume \exists z ((in(z, X) \wedge notin(z, Y)) \vee (notin(z, X) \wedge in(z, Y))) {
      apply invoke leftward neq_cor1_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y)
      apply invoke leftward neq_lambda for X, Y
    }
    connect neq(X, Y) \leftrightarrow \exists z ((in(z, X) \wedge notin(z, Y)) \vee (notin(z, X) \wedge in(z, Y)))
  }
}

definition predicate subset(x, y) as \forall z (in(z, x) \to in(z, y)) tex "", "\subset", ""

definition predicate subset_predicate(predicate \phi[1], predicate \chi[1]) as \forall x (\phi(x) \to \chi(x)) tex "", "\subset", ""

theorem subset_lambda \forall X \forall Y (subset(X, Y) \leftrightarrow subset_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))) {
  any X, Y {
    assume subset(X, Y) {
      expand subset(X, Y) for subset
      fold for subset_predicate conclude subset_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
    }
    assume subset_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) {
      expand subset_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) for subset_predicate
      fold for subset conclude subset(X, Y)
    }
    connect subset(X, Y) \leftrightarrow subset_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
  }
}

theorem subset_reflection_predicate \forall^P \phi[1] (subset_predicate(\phi, \phi)) {
  any predicate \phi[1] {
    any x {
      assume \phi(x) {}
    }
    fold for subset_predicate conclude subset_predicate(\phi, \phi)
  }
}

theorem subset_reflection \forall X (subset(X, X)) {
  any X {
    apply subset_reflection_predicate for \lambda^P x. in(x, X)
    apply invoke leftward subset_lambda for X, X
  }
}

theorem subset_antisymmetry_predicate \forall^P \phi[1] \forall^P \chi[1] (subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \phi) \leftrightarrow equal_predicate(\phi, \chi)) {
  any predicate \phi[1], predicate \chi[1] {
    assume subset_predicate(\phi, \chi)\wedge subset_predicate(\chi, \phi) {
      split subset_predicate(\phi, \chi)\wedge subset_predicate(\chi, \phi)
      any x {
        assume \phi(x) {
          apply invoke subset_predicate(\phi, \chi) for x
        }
        assume \chi(x) {
          apply invoke subset_predicate(\chi, \phi) for x
        }
        connect \phi(x) \leftrightarrow \chi(x)
      }
      fold for equal_predicate conclude equal_predicate(\phi, \chi)
    }
    assume equal_predicate(\phi, \chi) {
      any x {
        assume \phi(x) {
          apply invoke rightward equal_predicate(\phi, \chi) for x
        }
      }
      fold for subset_predicate conclude subset_predicate(\phi, \chi)
      any x {
        assume \chi(x) {
          apply invoke leftward equal_predicate(\phi, \chi) for x
        }
      }
      fold for subset_predicate conclude subset_predicate(\chi, \phi)
      connect subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \phi)
    }
    connect subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \phi) \leftrightarrow equal_predicate(\phi, \chi)
  }
}

theorem subset_antisymmetry \forall X \forall Y (subset(X, Y) \wedge subset(Y, X) \leftrightarrow equal(X, Y)) {
  any X, Y {
    assume subset(X, Y) \wedge subset(Y, X) {
      split subset(X, Y) \wedge subset(Y, X)
      apply invoke rightward subset_lambda for X, Y
      apply invoke rightward subset_lambda for Y, X
      connect subset_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) \wedge subset_predicate(\lambda^P y. in(y, Y), \lambda^P x. in(x, X))
      apply invoke rightward subset_antisymmetry_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y)
      apply invoke leftward equal_lambda for X, Y
    }
    assume equal(X, Y) {
      apply subset_reflection for X
      substitute subset(X, X) for X[2]: Y
      substitute subset(X, X) for X[1]: Y
      connect subset(X, Y) \wedge subset(Y, X)
    }
    connect subset(X, Y) \wedge subset(Y, X) \leftrightarrow equal(X, Y)
  }
}

theorem subset_trans_predicate \forall^P \phi[1] \forall^P \chi[1] \forall^P \rho[1] (subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \rho) \to subset_predicate(\phi, \rho)) {
  any predicate \phi[1], predicate \chi[1], predicate \rho[1] {
    assume subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \rho) {
      split subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \rho)
      any x {
        assume \phi(x) {
          apply invoke subset_predicate(\phi, \chi) for x
          apply invoke subset_predicate(\chi, \rho) for x
        }
      }
      fold for subset_predicate conclude subset_predicate(\phi, \rho)
    }
  }
}

theorem subset_trans \forall X \forall Y \forall Z (subset(X, Y) \wedge subset(Y, Z) \to subset(X, Z)) {
  any X, Y, Z {
    assume subset(X, Y) \wedge subset(Y, Z) {
      split subset(X, Y) \wedge subset(Y, Z)
      apply invoke rightward subset_lambda for X, Y
      apply invoke rightward subset_lambda for Y, Z
      connect subset_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) \wedge subset_predicate(\lambda^P y. in(y, Y), \lambda^P z. in(z, Z))
      apply invoke subset_trans_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y), \lambda^P z. in(z, Z)
      apply invoke leftward subset_lambda for X, Z
    }
  }
}

theorem neg_subset_predicate \forall^P \phi[1] \forall^P \chi[1] (\neg(subset_predicate(\phi, \chi)) \leftrightarrow \exists x (\phi(x) \wedge \neg(\chi(x)))) {
  any predicate \phi[1], predicate \chi[1] {
    assume \neg(subset_predicate(\phi, \chi)) {
      expand \neg(subset_predicate(\phi, \chi)) for subset_predicate
      apply invoke leftward exist_neg_leftrightarrow_neg_forall for \lambda^P x. \phi(x) \to \chi(x)
      some x such \exists x (\neg(\phi(x) \to \chi(x))) {
        apply invoke rightward neg_implication for \lambda^P. \phi(x), \lambda^P. \chi(x)
        lift for x conclude \exists x (\phi(x) \wedge \neg(\chi(x)))
      }
    }
    assume \exists x (\phi(x) \wedge \neg(\chi(x))) {
      some x such \exists x (\phi(x) \wedge \neg(\chi(x))) {
        apply invoke leftward neg_implication for \lambda^P. \phi(x), \lambda^P. \chi(x)
        lift for x conclude \exists x (\neg(\phi(x) \to \chi(x)))
      }
      apply invoke rightward exist_neg_leftrightarrow_neg_forall for \lambda^P x. \phi(x) \to \chi(x)
      fold for subset_predicate conclude \neg(subset_predicate(\phi, \chi))
    }
    connect \neg(subset_predicate(\phi, \chi)) \leftrightarrow \exists x (\phi(x) \wedge \neg(\chi(x)))
  }
}

theorem neg_subset \forall X \forall Y (\neg(subset(X, Y)) \leftrightarrow \exists z (in(z, X) \wedge notin(z, Y))) {
  any X, Y {
    assume \neg(subset(X, Y)) {
      deny subset_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) {
        apply invoke leftward subset_lambda for X, Y
        contradict subset(X, Y)
      }
      apply invoke rightward neg_subset_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y)
    }
    assume \exists z (in(z, X) \wedge notin(z, Y)) {
      apply invoke leftward neg_subset_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y)
      deny subset(X, Y) {
        apply invoke rightward subset_lambda for X, Y
        contradict subset_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
      }
    }
    connect \neg(subset(X, Y)) \leftrightarrow \exists z (in(z, X) \wedge notin(z, Y))
  }
}

theorem neq_iff_subset_predicate \forall^P \phi[1] \forall^P \chi[1] (neq_predicate(\phi, \chi) \leftrightarrow \neg(subset_predicate(\phi, \chi)) \vee \neg(subset_predicate(\chi, \phi))) {
  any predicate \phi[1], predicate \chi[1] {
    apply subset_antisymmetry_predicate for \phi, \chi
    apply invoke neg_iff for \lambda^P. subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \phi), \lambda^P.equal_predicate(\phi, \chi)
    assume neq_predicate(\phi, \chi) {
      invoke leftward \neg(subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \phi)) \leftrightarrow neq_predicate(\phi, \chi)
      apply invoke rightward neg_and for \lambda^P. subset_predicate(\phi, \chi), \lambda^P. subset_predicate(\chi, \phi)
    }
    assume \neg(subset_predicate(\phi, \chi)) \vee \neg(subset_predicate(\chi, \phi)) {
      apply invoke leftward neg_and for \lambda^P. subset_predicate(\phi, \chi), \lambda^P. subset_predicate(\chi, \phi)
      invoke rightward \neg(subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \phi)) \leftrightarrow neq_predicate(\phi, \chi)
    }
    connect neq_predicate(\phi, \chi) \leftrightarrow \neg(subset_predicate(\phi, \chi)) \vee \neg(subset_predicate(\chi, \phi))
  }
}

definition predicate subsetneq(x, y) as subset(x, y) \wedge neq(x, y) tex "", "\subsetneq", ""

definition predicate subsetneq_predicate(predicate \phi[1], predicate \chi[1]) as subset_predicate(\phi, \chi) \wedge neq_predicate(\phi, \chi) tex "", "\subsetneq", ""

theorem subsetneq_lambda \forall X \forall Y (subsetneq(X, Y) \leftrightarrow subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))) {
  any X, Y {
    assume subsetneq(X, Y) {
      split subsetneq(X, Y)
      apply invoke rightward subset_lambda for X, Y
      apply invoke rightward neq_lambda for X, Y
      connect subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
    }
    assume subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) {
      split subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
      apply invoke leftward subset_lambda for X, Y
      apply invoke leftward neq_lambda for X, Y
      connect subsetneq(X, Y)
    }
    connect subsetneq(X, Y) \leftrightarrow subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
  }
}

theorem subsetneq_implies_exist_predicate \forall^P \phi[1] \forall^P \chi[1] (subsetneq_predicate(\phi, \chi) \to \exists x(\neg(\phi(x)) \wedge \chi(x))) {
  any predicate \phi[1], predicate \chi[1] {
    assume subsetneq_predicate(\phi, \chi) {
      split subsetneq_predicate(\phi, \chi)
      apply invoke rightward neq_cor1_predicate for \phi, \chi
      some x such \exists x ((\phi(x) \wedge \neg(\chi(x))) \vee (\neg(\phi(x)) \wedge \chi(x))) {
        divide (\phi(x) \wedge \neg(\chi(x))) \vee (\neg(\phi(x)) \wedge \chi(x))
          case \phi(x) \wedge \neg(\chi(x)) {
            split \phi(x) \wedge \neg(\chi(x))
            apply invoke subset_predicate(\phi, \chi) for x
            contradict \chi(x)
            explode \neg(\phi(x)) \wedge \chi(x)
          }
          case \neg(\phi(x)) \wedge \chi(x) {}
        lift for x conclude \exists x (\neg(\phi(x)) \wedge \chi(x))
      }
    }
  }
}

theorem subsetneq_implies_exist \forall X \forall Y (subsetneq(X, Y) \to \exists z (notin(z, X) \wedge in(z, Y))) {
  any X, Y {
    assume subsetneq(X, Y) {
      apply invoke rightward subsetneq_lambda for X, Y
      apply invoke subsetneq_implies_exist_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y)
    }
  }
}

theorem subset_subsetneq_predicate \forall^P \phi[1] \forall^P \chi[1] (subset_predicate(\phi, \chi) \leftrightarrow subsetneq_predicate(\phi, \chi) \vee equal_predicate(\phi, \chi)) {
  any predicate \phi[1], predicate \chi[1] {
    assume subset_predicate(\phi, \chi) {
      apply law_of_excluded_middle for \lambda^P. equal_predicate(\phi, \chi)
      divide equal_predicate(\phi, \chi) \vee neq_predicate(\phi, \chi)
        case equal_predicate(\phi, \chi) {
          pad equal_predicate(\phi, \chi) conclude subsetneq_predicate(\phi, \chi) \vee equal_predicate(\phi, \chi)
        }
        case neq_predicate(\phi, \chi) {
          connect subset_predicate(\phi, \chi) \wedge neq_predicate(\phi, \chi)
          fold for subsetneq_predicate conclude subsetneq_predicate(\phi, \chi)
          pad subsetneq_predicate(\phi, \chi) conclude subsetneq_predicate(\phi, \chi) \vee equal_predicate(\phi, \chi)
        }
    }
    assume subsetneq_predicate(\phi, \chi) \vee equal_predicate(\phi, \chi) {
      divide subsetneq_predicate(\phi, \chi) \vee equal_predicate(\phi, \chi)
        case subsetneq_predicate(\phi, \chi) {
          split 1 subsetneq_predicate(\phi, \chi)
        }
        case equal_predicate(\phi, \chi) {
          apply invoke leftward subset_antisymmetry_predicate for \phi, \chi
          split 1 subset_predicate(\phi, \chi) \wedge subset_predicate(\chi, \phi)
        }
    }
    connect subset_predicate(\phi, \chi)\leftrightarrow subsetneq_predicate(\phi, \chi)\vee equal_predicate(\phi, \chi)
  }
}

theorem subset_subsetneq \forall X \forall Y (subset(X, Y) \leftrightarrow subsetneq(X, Y) \vee equal(X, Y)) {
  any X, Y {
    assume subset(X, Y) {
      apply invoke rightward subset_lambda for X, Y
      apply invoke rightward subset_subsetneq_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y)
      divide subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) \vee equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
        case subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) {
          apply invoke leftward subsetneq_lambda for X, Y
          pad subsetneq(X, Y) conclude subsetneq(X, Y) \vee equal(X, Y)
        }
        case equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) {
          apply invoke leftward equal_lambda for X, Y
          pad equal(X, Y) conclude subsetneq(X, Y) \vee equal(X, Y)
        }
    }
    assume subsetneq(X, Y) \vee equal(X, Y) {
      divide subsetneq(X, Y) \vee equal(X, Y)
        case subsetneq(X, Y) {
          apply invoke rightward subsetneq_lambda for X, Y
          pad subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) conclude subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) \vee equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
        }
        case equal(X, Y) {
          apply invoke rightward equal_lambda for X, Y
          pad equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) conclude subsetneq_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y)) \vee equal_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y))
        }
      apply invoke leftward subset_subsetneq_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y)
      apply invoke leftward subset_lambda for X, Y
    }
    connect subset(X, Y) \leftrightarrow subsetneq(X, Y) \vee equal(X, Y)
  }
}
