primitive predicate in arity 2 tex "","\in",""

definition predicate equal(x,y) as \forall z(in(z,x)\leftrightarrow in(z,y)) tex "","=",""

theorem equal_reflection \forall x(equal(x,x)) {
  any x {
    any y {
      assume in(y,x) {}
      connect in(y,x)\leftrightarrow in(y,x)
    }
    expand \forall y(in(y,x)\leftrightarrow in(y,x)) for equal conclude equal(x,x)
  }
}

theorem equal_replacement \forall x\forall y\forall u\forall v(equal(x,y)\wedge equal(u,v)\to(equal(x,u)\to equal(y,v))) {
  any x,y,u,v {
    assume equal(x,y)\wedge equal(u,v) {
      assume equal(x,u) {
        any p {
          assume in(p,y) {
            split equal(x,y)\wedge equal(u,v)
            expand equal(x,y) for equal conclude \forall z(in(z,x)\leftrightarrow in(z,y))
            apply \forall z(in(z,x)\leftrightarrow in(z,y)) for z:p
            invoke leftward in(p,x)\leftrightarrow in(p,y)
            expand equal(x,u) for equal conclude \forall z(in(z,x)\leftrightarrow in(z,u))
            apply \forall z(in(z,x)\leftrightarrow in(z,u)) for z:p
            invoke rightward in(p,x)\leftrightarrow in(p,u)
            expand equal(u,v) for equal conclude \forall z(in(z,u)\leftrightarrow in(z,v))
            apply \forall z(in(z,u)\leftrightarrow in(z,v)) for z:p
            invoke rightward in(p,u)\leftrightarrow in(p,v)
          }
          assume in(p,v) {
            split equal(x,y)\wedge equal(u,v)
            expand equal(u,v) for equal conclude \forall z(in(z,u)\leftrightarrow in(z,v))
            apply \forall z(in(z,u)\leftrightarrow in(z,v)) for z:p
            invoke leftward in(p,u)\leftrightarrow in(p,v)
            expand equal(x,u) for equal conclude \forall z(in(z,x)\leftrightarrow in(z,u))
            apply \forall z(in(z,x)\leftrightarrow in(z,u)) for z:p
            invoke leftward in(p,x)\leftrightarrow in(p,u)
            expand equal(x,y) for equal conclude \forall z(in(z,x)\leftrightarrow in(z,y))
            apply \forall z(in(z,x)\leftrightarrow in(z,y)) for z:p
            invoke rightward in(p,x)\leftrightarrow in(p,y)
          }
          connect in(p,y)\leftrightarrow in(p,v)
        }
        expand \forall p(in(p,y)\leftrightarrow in(p,v)) for equal conclude equal(y,v)
      }
    }
  }
}

axiom axiom_of_equal \forall x\forall y(equal(x,y)\to\forall z(in(x,z)\to in(y,z)))

theorem in_replacement \forall x\forall y\forall u\forall v(equal(x,y)\wedge equal(u,v)\to(in(x,u)\to in(y,v))) {
  any x,y,u,v {
    assume equal(x,y)\wedge equal(u,v) {
      assume in(x,u) {
        apply axiom_of_equal for x:x,y:y
        split equal(x,y)\wedge equal(u,v)
        invoke equal(x,y)\to\forall z(in(x,z)\to in(y,z))
        apply \forall z(in(x,z)\to in(y,z)) for z:u
        invoke in(x,u)\to in(y,u)
        expand equal(u,v) for equal conclude \forall z(in(z,u)\leftrightarrow in(z,v))
        apply \forall z(in(z,u)\leftrightarrow in(z,v)) for z:y
        invoke rightward in(y,u)\leftrightarrow in(y,v)
      }
    }
  }
}

equality equal
  reflection equal_reflection
  replacement equal: equal_replacement, in: in_replacement

definition predicate autoexpand notin(x,y) as \neg(in(x,y)) tex "","\notin",""

definition predicate autoexpand neq(x,y) as \neg(equal(x,y)) tex "","\neq",""

theorem neq_cor1 \forall x\forall y(neq(x,y)\leftrightarrow\exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)))) {
  any x, y {
    assume neq(x,y) {
      deny \forall z(in(z,x)\leftrightarrow in(z,y)) {
        expand \forall z(in(z,x)\leftrightarrow in(z,y)) for equal conclude equal(x,y)
        contradict equal(x,y)
      }
      deny \neg(\exists z(\neg(in(z,x)\leftrightarrow in(z,y)))) {
        any z {
          deny \neg(in(z,x)\leftrightarrow in(z,y)) {
            lift for z:z conclude \exists z(\neg(in(z,x)\leftrightarrow in(z,y)))
            contradict \exists z(\neg(in(z,x)\leftrightarrow in(z,y)))
          }
        }
        contradict \forall z(in(z,x)\leftrightarrow in(z,y))
      }
      some z:z such \exists z(\neg(in(z,x)\leftrightarrow in(z,y))) {
        deny (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x)) {
          split (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x))
          connect in(z,x)\leftrightarrow in(z,y)
          contradict in(z,x)\leftrightarrow in(z,y)
        }
        deny \neg(\neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))) {
          deny \neg(in(z,x)\to in(z,y)) {
            pad \neg(in(z,x)\to in(z,y)) conclude \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
            contradict \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
          }
          deny \neg(in(z,y)\to in(z,x)) {
            pad \neg(in(z,y)\to in(z,x)) conclude \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
            contradict \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
          }
          connect (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x))
          contradict (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x))
        }
        divide \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
          case \neg(in(z,x)\to in(z,y)) {
            deny \neg(in(z,x)\wedge notin(z,y)) {
              assume in(z,x) {
                deny notin(z,y) {
                  connect in(z,x)\wedge notin(z,y)
                  contradict in(z,x)\wedge notin(z,y)
                }
              }
              contradict in(z,x)\to in(z,y)
            }
            pad in(z,x)\wedge notin(z,y) conclude (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
          }
          case \neg(in(z,y)\to in(z,x)) {
            deny \neg(notin(z,x)\wedge in(z,y)) {
              assume in(z,y) {
                deny notin(z,x) {
                  connect notin(z,x)\wedge in(z,y)
                  contradict notin(z,x)\wedge in(z,y)
                }
              }
              contradict in(z,y)\to in(z,x)
            }
            pad notin(z,x)\wedge in(z,y) conclude (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
          }
        lift for z:z conclude \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)))
      }
    }
    assume \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) {
      some z:z such \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) {
        deny equal(x,y) {
          expand equal(x,y) for equal conclude \forall z(in(z,x)\leftrightarrow in(z,y))
          apply \forall z(in(z,x)\leftrightarrow in(z,y)) for z:z
          divide (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
            case in(z,x)\wedge notin(z,y) {
              split in(z,x)\wedge notin(z,y)
              invoke rightward in(z,x)\leftrightarrow in(z,y)
              contradict in(z,y)
            }
            case notin(z,x)\wedge in(z,y) {
              split notin(z,x)\wedge in(z,y)
              invoke leftward in(z,x)\leftrightarrow in(z,y)
              contradict in(z,x)
            }
        }
      }
    }
    connect neq(x,y)\leftrightarrow\exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)))
  }
}

definition predicate subset(x,y) as \forall z(in(z,x)\to in(z,y)) tex "","\subset",""

theorem subset_cor1 \forall z\forall x\forall y(in(z,x)\wedge subset(x,y)\to in(z,y)) {
  any x,y,z {
    assume in(z,x)\wedge subset(x,y) {
      split in(z,x)\wedge subset(x,y)
      expand subset(x,y) for subset conclude \forall z(in(z,x)\to in(z,y))
      apply \forall z(in(z,x)\to in(z,y)) for z:z
      invoke in(z,x)\to in(z,y)
    }
  }
}

theorem subset_reflection \forall x(subset(x,x)) {
  any x {
    any y {
      assume in(y,x) {}
    }
    expand \forall y(in(y,x)\to in(y,x)) for subset conclude subset(x,x)
  }
}

theorem subset_antisymmetry \forall x\forall y(subset(x,y)\wedge subset(y,x)\to equal(x,y)) {
  any x,y {
    assume subset(x,y)\wedge subset(y,x) {
      any z {
        assume in(z,x) {
          apply subset_cor1 for z:z,x:x,y:y
          split subset(x,y)\wedge subset(y,x)
          connect in(z,x)\wedge subset(x,y)
          invoke in(z,x)\wedge subset(x,y)\to in(z,y)
        }
        assume in(z,y) {
          apply subset_cor1 for z:z,x:y,y:x
          split subset(x,y)\wedge subset(y,x)
          connect in(z,y)\wedge subset(y,x)
          invoke in(z,y)\wedge subset(y,x)\to in(z,x)
        }
        connect in(z,x)\leftrightarrow in(z,y)
      }
      expand \forall z(in(z,x)\leftrightarrow in(z,y)) for equal conclude equal(x,y)
    }
  }
}

theorem subset_trans \forall x\forall y\forall z(subset(x,y)\wedge subset(y,z)\to subset(x,z)) {
  any x,y,z {
    assume subset(x,y)\wedge subset(y,z) {
      any w {
        assume in(w,x) {
          apply subset_cor1 for z:w,x:x,y:y
          split subset(x,y)\wedge subset(y,z)
          connect in(w,x)\wedge subset(x,y)
          invoke in(w,x)\wedge subset(x,y)\to in(w,y)
          apply subset_cor1 for z:w,x:y,y:z
          connect in(w,y)\wedge subset(y,z)
          invoke in(w,y)\wedge subset(y,z)\to in(w,z)
        }
      }
      expand \forall w(in(w,x)\to in(w,z)) for subset conclude subset(x,z)
    }
  }
}

axiom axiom_of_emptyset \exists x\forall y(notin(y,x))

theorem emptyset_exists_uniquely \exists!x\forall y(notin(y,x)) {
  some x:x such axiom_of_emptyset {
    any x' {
      assume \forall y(notin(y,x')) {
        any y {
          assume in(y,x') {
            apply \forall y(notin(y,x')) for y:y
            contradict in(y,x')
            explode in(y,x)
          }
          assume in(y,x) {
            apply \forall y(notin(y,x)) for y:y
            contradict in(y,x)
            explode in(y,x')
          }
          connect in(y,x')\leftrightarrow in(y,x)
        }
        expand \forall y(in(y,x')\leftrightarrow in(y,x)) for equal conclude equal(x',x)
      }
    }
    connect \forall y(notin(y,x))\wedge\forall x'(\forall y(notin(y,x'))\to equal(x',x))
    characterize for x:x conclude \exists!x\forall y(notin(y,x))
  }
}

definition constant emptyset by emptyset_exists_uniquely tex "\emptyset"
  existence emptyset_existence \forall y(notin(y,emptyset))
  uniqueness emptyset_uniqueness \forall x(\forall y(notin(y,x))\to equal(x,emptyset))

theorem not_emptyset_has_a_member \forall x(neq(x, emptyset)\to\exists y(in(y,x))) {
  any x {
    assume neq(x,emptyset) {
      deny \neg(\exists y(in(y,x))) {
        any y {
          deny in(y,x) {
            lift for y:y conclude \exists y(in(y,x))
            contradict \exists y(in(y,x))
          }
        }
        apply emptyset_uniqueness for x:x
        invoke \forall y(notin(y,x))\to equal(x,emptyset)
        contradict equal(x,emptyset)
      }
    }
  }
}

theorem has_a_member_not_emptyset \forall x(\exists y(in(y,x))\to neq(x,emptyset)) {
  any x {
    assume \exists y(in(y,x)) {
      deny equal(x,emptyset) {
        substitute \exists y(in(y,x)) for x:emptyset conclude \exists y(in(y,emptyset))
        some y:y such \exists y(in(y,emptyset)) {
          apply emptyset_existence for y:y
          contradict in(y,emptyset)
        }
      }
    }
  }
}

theorem emptyset_subset_cor1 \forall x(subset(x,emptyset)\to equal(x,emptyset)) {
  any x {
    assume subset(x,emptyset) {
      expand subset(x,emptyset) for subset conclude \forall z(in(z,x)\to in(z,emptyset))
      any y {
        deny in(y,x) {
          apply \forall z(in(z,x)\to in(z,emptyset)) for z:y
          invoke in(y,x)\to in(y,emptyset)
          apply emptyset_existence for y:y
          contradict in(y,emptyset)
        }
      }
      apply emptyset_uniqueness for x:x
      invoke \forall y(notin(y,x))\to equal(x,emptyset)
    }
  }
}

axiom axiom_of_pair \forall x\forall y\exists z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))

theorem pair_exists_uniquely \forall x\forall y\exists!z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) {
  any x, y {
    apply axiom_of_pair for x:x, y:y
    some z:z such \exists z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) {
      any z' {
        assume \forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)) {
          any w {
            assume in(w,z') {
              apply \forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)) for w:w
              invoke rightward in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)
              apply \forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) for w:w
              invoke leftward in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)
            }
            assume in(w,z) {
              apply \forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) for w:w
              invoke rightward in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)
              apply \forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)) for w:w
              invoke leftward in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)
            }
            connect in(w,z')\leftrightarrow in(w,z)
          }
          expand \forall w(in(w,z')\leftrightarrow in(w,z)) for equal conclude equal(z',z)
        }
      }
      connect \forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))\wedge\forall z'(\forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y))\to equal(z',z))
      characterize for z:z conclude \exists!z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))
    }
  }
}

definition function pair by pair_exists_uniquely tex "\{",",","\}"
  existence pair_existence \forall x\forall y\forall w(in(w,pair(x,y))\leftrightarrow equal(w,x)\vee equal(w,y))
  uniqueness pair_uniqueness \forall x\forall y\forall z(\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))\to equal(z,pair(x,y)))

theorem pair_cor1 \forall x\forall y(in(x,pair(x,y))) {
  any x,y {
    apply pair_existence for x:x,y:y,w:x
    pad equal(x,x) conclude equal(x,x)\vee equal(x,y)
    invoke leftward in(x,pair(x,y))\leftrightarrow equal(x,x)\vee equal(x,y)
  }
}

theorem pair_cor2 \forall x\forall y(in(y,pair(x,y))) {
  any x,y {
    apply pair_existence for x:x,y:y,w:y
    pad equal(y,y) conclude equal(y,x)\vee equal(y,y)
    invoke leftward in(y,pair(x,y))\leftrightarrow equal(y,x)\vee equal(y,y)
  }
}

theorem pair_cor3 \forall x\forall y(subset(pair(x,y),pair(y,x))) {
  any x,y {
    any z {
      assume in(z,pair(x,y)) {
        apply pair_existence for x:x,y:y,w:z
        invoke rightward in(z,pair(x,y))\leftrightarrow equal(z,x)\vee equal(z,y)
        apply pair_existence for x:y,y:x,w:z
        invoke leftward in(z,pair(y,x))\leftrightarrow equal(z,y)\vee equal(z,x)
      }
    }
    expand \forall z(in(z,pair(x,y))\to in(z,pair(y,x))) for subset conclude subset(pair(x,y),pair(y,x))
  }
}

theorem pair_commutativity \forall x\forall y(equal(pair(x,y),pair(y,x))) {
  any x,y {
    apply pair_cor3 for x:x,y:y
    apply pair_cor3 for x:y,y:x
    connect subset(pair(x,y),pair(y,x))\wedge subset(pair(y,x),pair(x,y))
    apply subset_antisymmetry for x:pair(x,y),y:pair(y,x)
    invoke subset(pair(x,y),pair(y,x))\wedge subset(pair(y,x),pair(x,y))\to equal(pair(x,y),pair(y,x))
  }
}

theorem pair_cor4 \forall x\forall y\forall z\forall w(equal(pair(x,y),pair(z,w))\to equal(x,z)\vee equal(x,w)) {
  any x,y,z,w {
    assume equal(pair(x,y),pair(z,w)) {
      apply pair_cor1 for x:x,y:y
      substitute in(x,pair(x,y)) for pair(x,y):pair(z,w) conclude in(x,pair(z,w))
      apply pair_existence for x:z,y:w,w:x
      invoke rightward in(x,pair(z,w))\leftrightarrow equal(x,z)\vee equal(x,w)
    }
  }
}

theorem pair_cor5 \forall x\forall y\forall z\forall w(equal(pair(x,y),pair(z,w))\to equal(y,z)\vee equal(y,w)) {
  any x,y,z,w {
    assume equal(pair(x,y),pair(z,w)) {
      apply pair_cor2 for x:x,y:y
      substitute in(y,pair(x,y)) for pair(x,y):pair(z,w) conclude in(y,pair(z,w))
      apply pair_existence for x:z,y:w,w:y
      invoke rightward in(y,pair(z,w))\leftrightarrow equal(y,z)\vee equal(y,w)
    }
  }
}

theorem pair_cor6 \forall x\forall y\forall z(equal(pair(x,x),pair(y,z))\to equal(x,y)) {
  any x,y,z {
    assume equal(pair(x,x),pair(y,z)) {
      apply pair_cor4 for x:y,y:z,z:x,w:x
      invoke equal(pair(y,z),pair(x,x))\to equal(y,x)\vee equal(y,x)
      divide equal(y,x)\vee equal(y,x)
        case equal(y,x) {}
        case equal(y,x) {}
    }
  }
}

theorem pair_cor7 \forall x\forall y\forall z(equal(pair(x,x),pair(y,z))\to equal(x,z)) {
  any x,y,z {
    assume equal(pair(x,x),pair(y,z)) {
      apply pair_cor5 for x:y,y:z,z:x,w:x
      invoke equal(pair(y,z),pair(x,x))\to equal(z,x)\vee equal(z,x)
      divide equal(z,x)\vee equal(z,x)
        case equal(z,x) {}
        case equal(z,x) {}
    }
  }
}

theorem pair_cor8 \forall x\forall y\forall z(equal(pair(x,y),pair(x,z))\to equal(y,z)) {
  any x,y,z {
    assume equal(pair(x,y),pair(x,z)) {
      apply pair_cor5 for x:x,y:y,z:x,w:z
      invoke equal(pair(x,y),pair(x,z))\to equal(y,x)\vee equal(y,z)
      divide equal(y,x)\vee equal(y,z)
        case equal(y,x) {
          substitute equal(pair(x,y),pair(x,z)) for y:x conclude equal(pair(x,x),pair(x,z))
          apply pair_cor7 for x:x,y:x,z:z
          invoke equal(pair(x,x),pair(x,z))\to equal(x,z)
          substitute equal(y,x) for x:z conclude equal(y,z)
        }
        case equal(y,z) {}
    }
  }
}

theorem pair_cor9 \forall x\forall y(neq(pair(x,y),emptyset)) {
  any x, y {
    apply pair_cor1 for x:x,y:y
    lift for z:x conclude \exists z(in(z,pair(x,y)))
    apply has_a_member_not_emptyset for x:pair(x,y)
    invoke \exists z(in(z,pair(x,y)))\to neq(pair(x,y),emptyset)
  }
}

theorem pair_cor10 \forall x\forall y\forall z(in(x,z)\wedge in(y,z)\to subset(pair(x,y),z)) {
  any x,y,z {
    assume in(x,z)\wedge in(y,z) {
      split in(x,z)\wedge in(y,z)
      any w {
        assume in(w,pair(x,y)) {
          apply pair_existence for x:x,y:y,w:w
          invoke rightward in(w,pair(x,y))\leftrightarrow equal(w,x)\vee equal(w,y)
          divide equal(w,x)\vee equal(w,y)
            case equal(w,x) {
              substitute in(x,z) for x:w conclude in(w,z)
            }
            case equal(w,y) {
              substitute in(y,z) for y:w conclude in(w,z)
            }
        }
      }
      expand \forall w(in(w,pair(x,y))\to in(w,z)) for subset conclude subset(pair(x,y),z)
    }
  }
}

definition function singleton(x) as pair(x,x) tex "\{","\}"

theorem singleton_characterization \forall x\forall y(in(y,singleton(x))\leftrightarrow equal(y,x)) {
  any x,y {
    assume in(y,singleton(x)) {
      expand in(y,singleton(x)) for singleton conclude in(y,pair(x,x))
      apply pair_existence for x:x,y:x,w:y
      invoke rightward in(y,pair(x,x))\leftrightarrow equal(y,x)\vee equal(y,x)
      divide equal(y,x)\vee equal(y,x)
        case equal(y,x) {}
        case equal(y,x) {}
    }
    assume equal(y,x) {
      apply pair_existence for x:x,y:x,w:y
      pad equal(y,x) conclude equal(y,x)\vee equal(y,x)
      invoke leftward in(y,pair(x,x))\leftrightarrow equal(y,x)\vee equal(y,x)
      expand in(y,pair(x,x)) for singleton conclude in(y,singleton(x))
    }
    connect in(y,singleton(x))\leftrightarrow equal(y,x)
  }
}

theorem singleton_cor1 \forall x(in(x,singleton(x))) {
  any x {
    apply singleton_characterization for x:x,y:x
    invoke leftward in(x,singleton(x))\leftrightarrow equal(x,x)
  }
}

theorem singleton_cor2 \forall x\forall y(equal(singleton(x),singleton(y))\to equal(x,y)) {
  any x,y {
    assume equal(singleton(x),singleton(y)) {
      apply singleton_cor1 for x:x
      substitute in(x,singleton(x)) for singleton(x):singleton(y) conclude in(x,singleton(y))
      apply singleton_characterization for x:y,y:x
      invoke rightward in(x,singleton(y))\leftrightarrow equal(x,y)
    }
  }
}

theorem singleton_cor3 \forall x\forall y(in(x,y)\to subset(singleton(x),y)) {
  any x,y {
    assume in(x,y) {
      any z {
        assume in(z,singleton(x)) {
          apply singleton_characterization for x:x,y:z
          invoke rightward in(z,singleton(x))\leftrightarrow equal(z,x)
          substitute in(x,y) for x:z conclude in(z,y)
        }
      }
      expand \forall z(in(z,singleton(x))\to in(z,y)) for subset conclude subset(singleton(x),y)
    }
  }
}

theorem pair_singleton_cor1 \forall x\forall y\forall z(equal(singleton(x),pair(y,z))\to equal(x,y)) {
  any x,y,z {
    assume equal(singleton(x),pair(y,z)) {
      expand equal(singleton(x),pair(y,z)) for singleton conclude equal(pair(x,x),pair(y,z))
      apply pair_cor6 for x:x,y:y,z:z
      invoke equal(pair(x,x),pair(y,z))\to equal(x,y)
    }
  }
}

theorem pair_singleton_cor2 \forall x\forall y\forall z(equal(singleton(x),pair(y,z))\to equal(x,z)) {
  any x,y,z {
    assume equal(singleton(x),pair(y,z)) {
      expand equal(singleton(x),pair(y,z)) for singleton conclude equal(pair(x,x),pair(y,z))
      apply pair_cor7 for x:x,y:y,z:z
      invoke equal(pair(x,x),pair(y,z))\to equal(x,z)
    }
  }
}

definition function op(x,y) as pair(singleton(x),pair(x,y)) tex "(",",",")"

theorem op_characterization \forall x\forall y\forall x'\forall y'(equal(op(x,y),op(x',y'))\to equal(x,x')\wedge equal(y,y')) {
  any x,y,x',y' {
    assume equal(op(x,y),op(x',y')) {
      expand equal(op(x,y),op(x',y')) for op conclude equal(pair(singleton(x),pair(x,y)),pair(singleton(x'),pair(x',y')))
      apply pair_cor4 for x:singleton(x),y:pair(x,y),z:singleton(x'),w:pair(x',y')
      invoke equal(pair(singleton(x),pair(x,y)),pair(singleton(x'),pair(x',y')))\to equal(singleton(x),singleton(x'))\vee equal(singleton(x),pair(x',y'))
      divide equal(singleton(x),singleton(x'))\vee equal(singleton(x),pair(x',y'))
        case equal(singleton(x),singleton(x')) {
          apply singleton_cor2 for x:x,y:x'
          invoke equal(singleton(x),singleton(x'))\to equal(x,x')
        }
        case equal(singleton(x),pair(x',y')) {
          apply pair_singleton_cor1 for x:x,y:x',z:y'
          invoke equal(singleton(x),pair(x',y'))\to equal(x,x')
        }
      substitute equal(pair(singleton(x),pair(x,y)),pair(singleton(x'),pair(x',y'))) for x':x conclude equal(pair(singleton(x),pair(x,y)),pair(singleton(x),pair(x,y')))
      apply pair_cor8 for x:singleton(x),y:pair(x,y),z:pair(x,y')
      invoke equal(pair(singleton(x),pair(x,y)),pair(singleton(x),pair(x,y')))\to equal(pair(x,y),pair(x,y'))
      apply pair_cor8 for x:x,y:y,z:y'
      invoke equal(pair(x,y),pair(x,y'))\to equal(y,y')
      connect equal(x,x')\wedge equal(y,y')
    }
  }
}

axiom axiom_of_union \forall x\exists y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))

theorem union_exists_uniquely \forall x\exists!y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) {
  any x {
    apply axiom_of_union for x:x
    some y:y such \exists y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) {
      any y' {
        assume \forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) {
          any z {
            assume in(z,y') {
              apply \forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z:z
              invoke rightward in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))
              apply \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z:z
              invoke leftward in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))
            }
            assume in(z,y) {
              apply \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z:z
              invoke rightward in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))
              apply \forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z:z
              invoke leftward in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))
            }
            connect in(z,y')\leftrightarrow in(z,y)
          }
          expand \forall z(in(z,y')\leftrightarrow in(z,y)) for equal conclude equal(y',y)
        }
      }
      connect \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\wedge\forall y'(\forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\to equal(y',y))
      characterize for y:y conclude \exists!y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))
    }
  }
}

definition function bigcup by union_exists_uniquely tex "\bigcup",""
  existence bigcup_existence \forall x\forall z(in(z,bigcup(x))\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))
  uniqueness bigcup_uniqueness \forall x(\forall y(\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\to equal(y,bigcup(x))))

theorem bigcup_cor1 \forall x\forall y(in(y,x)\to subset(y,bigcup(x))) {
  any x,y {
    assume in(y,x) {
      any z {
        assume in(z,y) {
          connect in(z,y)\wedge in(y,x)
          lift for y:y conclude \exists y(in(z,y)\wedge in(y,x))
          apply bigcup_existence for x:x,z:z
          invoke leftward in(z,bigcup(x))\leftrightarrow\exists w(in(z,w)\wedge in(w,x))
        }
      }
      expand \forall z(in(z,y)\to in(z,bigcup(x))) for subset conclude subset(y,bigcup(x))
    }
  }
}

theorem bigcup_cor2 equal(bigcup(emptyset),emptyset) {
  any x {
    deny in(x,bigcup(emptyset)) {
      apply bigcup_existence for x:emptyset,z:x
      invoke rightward in(x,bigcup(emptyset))\leftrightarrow\exists w(in(x,w)\wedge in(w,emptyset))
      some w:w such \exists w(in(x,w)\wedge in(w,emptyset)) {
        split in(x,w)\wedge in(w,emptyset)
        apply emptyset_existence for y:w
        contradict in(w,emptyset)
      }
    }
  }
  apply emptyset_uniqueness for x:bigcup(emptyset)
  invoke \forall y(notin(y,bigcup(emptyset)))\to equal(bigcup(emptyset),emptyset)
}

definition function cup(x,y) as bigcup(pair(x,y)) tex "","\cup",""

theorem cup_characterization \forall x\forall y\forall z(in(z,cup(x,y))\leftrightarrow in(z,x)\vee in(z,y)) {
  any x,y,z {
    assume in(z,cup(x,y)) {
      show \exists w(in(z,w)\wedge in(w,pair(x,y))) {
        expand in(z,cup(x,y)) for cup conclude in(z,bigcup(pair(x,y)))
        apply bigcup_existence for x:pair(x,y),z:z
        invoke rightward in(z,bigcup(pair(x,y)))\leftrightarrow\exists w(in(z,w)\wedge in(w,pair(x,y)))
      }
      some w:w such \exists w(in(z,w)\wedge in(w,pair(x,y))) {
        split in(z,w)\wedge in(w,pair(x,y))
        show equal(w,x)\vee equal(w,y) {
          apply pair_existence for x:x,y:y,w:w
          invoke rightward in(w,pair(x,y))\leftrightarrow equal(w,x)\vee equal(w,y)
        }
        divide equal(w,x)\vee equal(w,y)
          case equal(w,x) {
            substitute in(z,w) for w:x conclude in(z,x)
            pad in(z,x) conclude in(z,x)\vee in(z,y)
          }
          case equal(w,y) {
            substitute in(z,w) for w:y conclude in(z,y)
            pad in(z,y) conclude in(z,x)\vee in(z,y)
          }
      }
    }
    assume in(z,x)\vee in(z,y) {
      divide in(z,x)\vee in(z,y)
        case in(z,x) {
          show \exists w(in(z,w)\wedge in(w,pair(x,y))) {
            apply pair_cor1 for x:x,y:y
            connect in(z,x)\wedge in(x,pair(x,y))
            lift for w:x conclude \exists w(in(z,w)\wedge in(w,pair(x,y)))
          }
          show in(z,cup(x,y)) {
            apply bigcup_existence for x:pair(x,y),z:z
            invoke leftward in(z,bigcup(pair(x,y)))\leftrightarrow\exists w(in(z,w)\wedge in(w,pair(x,y)))
            expand in(z,bigcup(pair(x,y))) for cup conclude in(z,cup(x,y))
          }
        }
        case in(z,y) {
          show \exists w(in(z,w)\wedge in(w,pair(x,y))) {
            apply pair_cor2 for x:x,y:y
            connect in(z,y)\wedge in(y,pair(x,y))
            lift for w:y conclude \exists w(in(z,w)\wedge in(w,pair(x,y)))
          }
          show in(z,cup(x,y)) {
            apply bigcup_existence for x:pair(x,y),z:z
            invoke leftward in(z,bigcup(pair(x,y)))\leftrightarrow\exists w(in(z,w)\wedge in(w,pair(x,y)))
            expand in(z,bigcup(pair(x,y))) for cup conclude in(z,cup(x,y))
          }
        }
    }
    connect in(z,cup(x,y))\leftrightarrow in(z,x)\vee in(z,y)
  }
}

theorem cup_commutativity \forall x\forall y(equal(cup(x,y),cup(y,x))) {
  any x,y {
    expand equal(cup(x,y),cup(x,y)) for cup conclude equal(cup(x,y),bigcup(pair(x,y)))
    apply pair_commutativity for x:x,y:y
    substitute equal(cup(x,y),bigcup(pair(x,y))) for pair(x,y):pair(y,x) conclude equal(cup(x,y),bigcup(pair(y,x)))
    expand equal(cup(x,y),bigcup(pair(y,x))) for cup conclude equal(cup(x,y),cup(y,x))
  }
}

theorem cup_cor1 \forall x(equal(cup(x,emptyset),x)) {
  any x {
    any y {
      assume in(y,cup(x,emptyset)) {
        apply cup_characterization for x:x,y:emptyset,z:y
        invoke rightward in(y,cup(x,emptyset))\leftrightarrow in(y,x)\vee in(y,emptyset)
        divide in(y,x)\vee in(y,emptyset)
          case in(y,x) {}
          case in(y,emptyset) {
            apply emptyset_existence for y:y
            contradict in(y,emptyset)
            explode in(y,x)
          }
      }
      assume in(y,x) {
        pad in(y,x) conclude in(y,x)\vee in(y,emptyset)
        apply cup_characterization for x:x,y:emptyset,z:y
        invoke leftward in(y,cup(x,emptyset))\leftrightarrow in(y,x)\vee in(y,emptyset)
      }
      connect in(y,cup(x,emptyset))\leftrightarrow in(y,x)
    }
    expand \forall y(in(y,cup(x,emptyset))\leftrightarrow in(y,x)) for equal conclude equal(cup(x,emptyset),x)
  }
}

theorem cup_cor2 \forall x(equal(cup(emptyset,x),x)) {
  any x {
    apply cup_commutativity for x:x,y:emptyset
    apply cup_cor1 for x:x
    substitute equal(cup(x,emptyset),x) for cup(x,emptyset):cup(emptyset,x) conclude equal(cup(emptyset,x),x)
  }
}

theorem cup_cor3 \forall x\forall y(subset(x,cup(x,y))) {
  any x,y {
    any z {
      assume in(z,x) {
        pad in(z,x) conclude in(z,x)\vee in(z,y)
        apply cup_characterization for x:x,y:y,z:z
        invoke leftward in(z,cup(x,y))\leftrightarrow in(z,x)\vee in(z,y)
      }
    }
    expand \forall z(in(z,x)\to in(z,cup(x,y))) for subset conclude subset(x,cup(x,y))
  }
}

theorem cup_cor4 \forall x\forall y(subset(y,cup(x,y))) {
  any x,y {
    apply cup_commutativity for x:x,y:y
    apply cup_cor3 for x:y,y:x
    substitute subset(y,cup(y,x)) for cup(y,x):cup(x,y) conclude subset(y,cup(x,y))
  }
}

theorem cup_cor5 \forall x\forall y\forall X\forall Y(in(x,X)\wedge in(y,Y)\to subset(pair(x,y),cup(X,Y))) {
  any x,y,X,Y {
    assume in(x,X)\wedge in(y,Y) {
      split in(x,X)\wedge in(y,Y)
      any z {
        assume in(z,pair(x,y)) {
          apply pair_existence for x:x,y:y,w:z
          invoke rightward in(z,pair(x,y))\leftrightarrow equal(z,x)\vee equal(z,y)
          divide equal(z,x)\vee equal(z,y)
            case equal(z,x) {
              substitute in(x,X) for x:z conclude in(z,X)
              apply cup_cor3 for x:X,y:Y
              connect in(z,X)\wedge subset(X,cup(X,Y))
              apply subset_cor1 for z:z,x:X,y:cup(X,Y)
              invoke in(z,X)\wedge subset(X,cup(X,Y))\to in(z,cup(X,Y))
            }
            case equal(z,y) {
              substitute in(y,Y) for y:z conclude in(z,Y)
              apply cup_cor4 for x:X,y:Y
              connect in(z,Y)\wedge subset(Y,cup(X,Y))
              apply subset_cor1 for z:z,x:Y,y:cup(X,Y)
              invoke in(z,Y)\wedge subset(Y,cup(X,Y))\to in(z,cup(X,Y))
            }
        }
      }
      expand \forall z(in(z,pair(x,y))\to in(z,cup(X,Y))) for subset conclude subset(pair(x,y),cup(X,Y))
    }
  }
}

axiom axiom_of_powerset \forall x\exists y\forall z(in(z,y)\leftrightarrow subset(z,x))

theorem powerset_exists_uniquely \forall x\exists!y\forall z(in(z,y)\leftrightarrow subset(z,x)) {
  any x {
    apply axiom_of_powerset for x:x
    some y:y such \exists y\forall z(in(z,y)\leftrightarrow subset(z,x)) {
      any y' {
        assume \forall z(in(z,y')\leftrightarrow subset(z,x)) {
          any z {
            assume in(z,y') {
              apply \forall z(in(z,y')\leftrightarrow subset(z,x)) for z:z
              invoke rightward in(z,y')\leftrightarrow subset(z,x)
              apply \forall z(in(z,y)\leftrightarrow subset(z,x)) for z:z
              invoke leftward in(z,y)\leftrightarrow subset(z,x)
            }
            assume in(z,y) {
              apply \forall z(in(z,y)\leftrightarrow subset(z,x)) for z:z
              invoke rightward in(z,y)\leftrightarrow subset(z,x)
              apply \forall z(in(z,y')\leftrightarrow subset(z,x)) for z:z
              invoke leftward in(z,y')\leftrightarrow subset(z,x)
            }
            connect in(z,y')\leftrightarrow in(z,y)
          }
          expand \forall z(in(z,y')\leftrightarrow in(z,y)) for equal conclude equal(y',y)
        }
      }
      connect \forall z(in(z,y)\leftrightarrow subset(z,x))\wedge\forall y'(\forall z(in(z,y')\leftrightarrow subset(z,x))\to equal(y',y))
      characterize for y:y conclude \exists!y\forall z(in(z,y)\leftrightarrow subset(z,x))
    }
  }
}

definition function powerset by powerset_exists_uniquely tex "\mathcal{P}(",")"
  existence powerset_existence \forall x\forall z(in(z,powerset(x))\leftrightarrow subset(z,x))
  uniqueness powerset_uniqueness \forall x\forall y(\forall z(in(z,y)\leftrightarrow subset(z,x))\to equal(y,powerset(x)))

theorem powerset_cor1 \forall x(in(x,powerset(x))) {
  any x {
    apply subset_reflection for x:x
    apply powerset_existence for x:x,z:x
    invoke leftward in(x,powerset(x))\leftrightarrow subset(x,x)
  }
}

theorem powerset_cor2 equal(powerset(emptyset),singleton(emptyset)) {
  any x {
    assume in(x,powerset(emptyset)) {
      apply powerset_existence for x:emptyset,z:x
      invoke rightward in(x,powerset(emptyset))\leftrightarrow subset(x,emptyset)
      apply emptyset_subset_cor1 for x:x
      invoke subset(x,emptyset)\to equal(x,emptyset)
      apply singleton_cor1 for x:emptyset
      substitute in(emptyset,singleton(emptyset)) for emptyset:x conclude in(x,singleton(emptyset))
    }
    assume in(x,singleton(emptyset)) {
      apply singleton_characterization for x:emptyset,y:x
      invoke rightward in(x,singleton(emptyset))\leftrightarrow equal(x,emptyset)
      apply powerset_cor1 for x:emptyset
      substitute in(emptyset,powerset(emptyset)) for emptyset:x conclude in(x,powerset(emptyset))
    }
    connect in(x,powerset(emptyset))\leftrightarrow in(x,singleton(emptyset))
  }
  expand \forall x(in(x,powerset(emptyset))\leftrightarrow in(x,singleton(emptyset))) for equal conclude equal(powerset(emptyset),singleton(emptyset))
}

axiom axiom_schema_of_separation \forall x\forall^T\phi[1]\exists y\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z))

theorem separation_is_unique \forall x\forall^T\phi[1]\exists!y\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z)) {
  any x, template \phi[1] {
    apply axiom_schema_of_separation for x:x, \phi:\phi
    some y:y such \exists y\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z)) {
      any y' {
        assume \forall z(in(z,y')\leftrightarrow in(z,x)\wedge\phi(z)) {
          any z {
            apply \forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z)) for z:z
            apply \forall z(in(z,y')\leftrightarrow in(z,x)\wedge\phi(z)) for z:z
            assume in(z,y') {
              invoke rightward in(z,y')\leftrightarrow in(z,x)\wedge\phi(z)
              invoke leftward in(z,y)\leftrightarrow in(z,x)\wedge\phi(z)
            }
            assume in(z,y) {
              invoke rightward in(z,y)\leftrightarrow in(z,x)\wedge\phi(z)
              invoke leftward in(z,y')\leftrightarrow in(z,x)\wedge\phi(z)
            }
            connect in(z,y')\leftrightarrow in(z,y)
          }
          expand \forall z(in(z,y')\leftrightarrow in(z,y)) for equal conclude equal(y',y)
        }
      }
      connect \forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z))\wedge\forall y'(\forall z(in(z,y')\leftrightarrow in(z,x)\wedge\phi(z))\to equal(y',y))
      characterize for y:y conclude \exists!y\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z))
    }
  }
}

definition function sep by separation_is_unique tex "\mathrm{sep}(",",",")"
  existence sep_existence \forall x\forall^T\phi[1]\forall z(in(z,sep(x,\phi))\leftrightarrow in(z,x)\wedge\phi(z))
  uniqueness sep_uniqueness \forall x\forall^T\phi[1]\forall y(\forall z(in(z,y)\leftrightarrow in(z,x)\wedge\phi(z))\to equal(y,sep(x,\phi)))

theorem sep_cor1 \forall x\forall^T\phi[1](subset(sep(x,\phi),x)) {
  any x, template \phi[1] {
    any z {
      assume in(z,sep(x,\phi)) {
        apply sep_existence for x:x, \phi:\phi, z:z
        invoke rightward in(z,sep(x,\phi))\leftrightarrow in(z,x)\wedge\phi(z)
        split 1 in(z,x)\wedge\phi(z)
      }
    }
    expand \forall z(in(z,sep(x,\phi))\to in(z,x)) for subset conclude subset(sep(x,\phi),x)
  }
}

definition function bigcap(u) as sep(bigcup(u), lambda z. \forall w(in(w,u)\to in(z,w))) tex "\bigcap",""

theorem bigcap_characterization \forall u\forall z(in(z,bigcap(u))\leftrightarrow in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))) {
  any u, z {
    assume in(z,bigcap(u)) {
      expand in(z,bigcap(u)) for bigcap conclude in(z,sep(bigcup(u), lambda z'. \forall w(in(w,u)\to in(z',w))))
      apply sep_existence for x:bigcup(u),\phi: lambda z'. \forall w(in(w,u)\to in(z',w)),z:z
      invoke rightward in(z,sep(bigcup(u), lambda z'. \forall w(in(w,u)\to in(z',w))))\leftrightarrow in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
    }
    assume in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w)) {
      apply sep_existence for x:bigcup(u),\phi: lambda z'. \forall w(in(w,u)\to in(z',w)),z:z
      invoke leftward in(z,sep(bigcup(u), lambda z'. \forall w(in(w,u)\to in(z',w))))\leftrightarrow in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
      expand in(z,sep(bigcup(u), lambda z'. \forall w(in(w,u)\to in(z',w)))) for bigcap conclude in(z,bigcap(u))
    }
    connect in(z,bigcap(u))\leftrightarrow in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
  }
}

theorem bigcap_cor1 equal(bigcap(emptyset),emptyset) {
  apply sep_cor1 for x:bigcup(emptyset), \phi: lambda z. \forall w(in(w,emptyset)\to in(z,w))
  expand subset(sep(bigcup(emptyset), lambda z. \forall w(in(w,emptyset)\to in(z,w))),bigcup(emptyset)) for bigcap conclude subset(bigcap(emptyset),bigcup(emptyset))
  substitute subset(bigcap(emptyset),bigcup(emptyset)) for bigcup(emptyset):emptyset by bigcup_cor2 conclude subset(bigcap(emptyset),emptyset)
  apply emptyset_subset_cor1 for x:bigcap(emptyset)
  invoke subset(bigcap(emptyset),emptyset)\to equal(bigcap(emptyset),emptyset)
}

theorem bigcap_cor2 \forall u(neq(u,emptyset)\to\forall z(in(z,bigcap(u))\leftrightarrow\forall w(in(w,u)\to in(z,w)))) {
  any u {
    assume neq(u,emptyset) {
      any z {
        assume in(z,bigcap(u)) {
          apply bigcap_characterization for u:u,z:z
          invoke rightward in(z,bigcap(u))\leftrightarrow in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
          split 2 in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
        }
        assume \forall w(in(w,u)\to in(z,w)) {
          apply not_emptyset_has_a_member for x:u
          invoke neq(u,emptyset)\to\exists y(in(y,u))
          some y:y such \exists y(in(y,u)) {
            apply \forall w(in(w,u)\to in(z,w)) for w:y
            invoke in(y,u)\to in(z,y)
            connect in(z,y)\wedge in(y,u)
            lift for y:y conclude \exists y(in(z,y)\wedge in(y,u))
          }
          apply bigcup_existence for x:u,z:z
          invoke leftward in(z,bigcup(u))\leftrightarrow\exists y(in(z,y)\wedge in(y,u))
          connect in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
          apply bigcap_characterization for u:u,z:z
          invoke leftward in(z,bigcap(u))\leftrightarrow in(z,bigcup(u))\wedge\forall w(in(w,u)\to in(z,w))
        }
        connect in(z,bigcap(u))\leftrightarrow\forall w(in(w,u)\to in(z,w))
      }
    }
  }
}

theorem bigcap_cor3 \forall x\forall y(in(y,x)\to subset(bigcap(x),y)) {
  any x, y {
    assume in(y,x) {
      any z {
        assume in(z,bigcap(x)) {
          apply bigcap_characterization for z:z,u:x
          invoke rightward in(z,bigcap(x))\leftrightarrow in(z,bigcup(x))\wedge\forall w(in(w,x)\to in(z,w))
          split in(z,bigcup(x))\wedge\forall w(in(w,x)\to in(z,w))
          apply \forall w(in(w,x)\to in(z,w)) for w:y
          invoke in(y,x)\to in(z,y)
        }
      }
      expand \forall z(in(z,bigcap(x))\to in(z,y)) for subset conclude subset(bigcap(x),y)
    }
  }
}

definition function cap(x,y) as bigcap(pair(x,y)) tex "","\cap",""

theorem cap_characterization \forall x\forall y\forall z(in(z,cap(x,y))\leftrightarrow in(z,x)\wedge in(z,y)) {
  any x, y, z {
    apply bigcap_cor2 for u:pair(x,y)
    apply pair_cor9 for x:x,y:y
    invoke neq(pair(x,y),emptyset)\to\forall z(in(z,bigcap(pair(x,y)))\leftrightarrow\forall w(in(w,pair(x,y))\to in(z,w)))
    apply \forall z(in(z,bigcap(pair(x,y)))\leftrightarrow\forall w(in(w,pair(x,y))\to in(z,w))) for z:z
    assume in(z,cap(x,y)) {
      expand in(z,cap(x,y)) for cap conclude in(z,bigcap(pair(x,y)))
      invoke rightward in(z,bigcap(pair(x,y)))\leftrightarrow\forall w(in(w,pair(x,y))\to in(z,w))
      apply \forall w(in(w,pair(x,y))\to in(z,w)) for w:x
      apply pair_cor1 for x:x,y:y
      invoke in(x,pair(x,y))\to in(z,x)
      apply \forall w(in(w,pair(x,y))\to in(z,w)) for w:y
      apply pair_cor2 for x:x,y:y
      invoke in(y,pair(x,y))\to in(z,y)
      connect in(z,x)\wedge in(z,y)
    }
    assume in(z,x)\wedge in(z,y) {
      split in(z,x)\wedge in(z,y)
      any w {
        assume in(w,pair(x,y)) {
          apply pair_existence for x:x,y:y,w:w
          invoke rightward in(w,pair(x,y))\leftrightarrow equal(w,x)\vee equal(w,y)
          divide equal(w,x)\vee equal(w,y)
            case equal(w,x) {
              substitute in(z,x) for x:w conclude in(z,w)
            }
            case equal(w,y) {
              substitute in(z,y) for y:w conclude in(z,w)
            }
        }
      }
      invoke leftward in(z,bigcap(pair(x,y)))\leftrightarrow\forall w(in(w,pair(x,y))\to in(z,w))
      expand in(z,bigcap(pair(x,y))) for cap conclude in(z,cap(x,y))
    }
    connect in(z,cap(x,y))\leftrightarrow in(z,x)\wedge in(z,y)
  }
}

definition function cartprod(X,Y) as sep(powerset(powerset(cup(X,Y))), lambda z. \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))) tex "","\times",""

theorem cartprod_lem1 \forall X\forall Y\forall x\forall y(in(x,X)\wedge in(y,Y)\to in(op(x,y),powerset(powerset(cup(X,Y))))) {
  any X,Y,x,y {
    assume in(x,X)\wedge in(y,Y) {
      split in(x,X)\wedge in(y,Y)
      apply singleton_cor3 for x:x,y:X
      invoke in(x,X)\to subset(singleton(x),X)
      apply cup_cor3 for x:X,y:Y
      connect subset(singleton(x),X)\wedge subset(X,cup(X,Y))
      apply subset_trans for x:singleton(x),y:X,z:cup(X,Y)
      invoke subset(singleton(x),X)\wedge subset(X,cup(X,Y))\to subset(singleton(x),cup(X,Y))
      apply powerset_existence for x:cup(X,Y),z:singleton(x)
      invoke leftward in(singleton(x),powerset(cup(X,Y)))\leftrightarrow subset(singleton(x),cup(X,Y))
      apply cup_cor5 for x:x,y:y,X:X,Y:Y
      invoke in(x,X)\wedge in(y,Y)\to subset(pair(x,y),cup(X,Y))
      apply powerset_existence for x:cup(X,Y),z:pair(x,y)
      invoke leftward in(pair(x,y),powerset(cup(X,Y)))\leftrightarrow subset(pair(x,y),cup(X,Y))
      connect in(singleton(x),powerset(cup(X,Y)))\wedge in(pair(x,y),powerset(cup(X,Y)))
      apply pair_cor10 for x:singleton(x),y:pair(x,y),z:powerset(cup(X,Y))
      invoke in(singleton(x),powerset(cup(X,Y)))\wedge in(pair(x,y),powerset(cup(X,Y)))\to subset(pair(singleton(x),pair(x,y)),powerset(cup(X,Y)))
      expand subset(pair(singleton(x),pair(x,y)),powerset(cup(X,Y))) for op conclude subset(op(x,y),powerset(cup(X,Y)))
      apply powerset_existence for x:powerset(cup(X,Y)),z:op(x,y)
      invoke leftward in(op(x,y),powerset(powerset(cup(X,Y))))\leftrightarrow subset(op(x,y),powerset(cup(X,Y)))
    }
  }
}

theorem cartprod_characterization \forall X\forall Y\forall z(in(z,cartprod(X,Y))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))) {
  any X,Y,z {
    apply sep_existence for x:powerset(powerset(cup(X,Y))),\phi:lambda z'. \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z',op(x,y))),z:z
    assume in(z,cartprod(X,Y)) {
      expand in(z,cartprod(X,Y)) for cartprod conclude in(z,sep(powerset(powerset(cup(X,Y))), lambda z'. \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z',op(x,y)))))
      invoke rightward in(z,sep(powerset(powerset(cup(X,Y))),lambda z'.\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z',op(x,y)))))\leftrightarrow in(z,powerset(powerset(cup(X,Y))))\wedge\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))
      split in(z,powerset(powerset(cup(X,Y))))\wedge\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))
    }
    assume \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y))) {
      some x:x,y:y such \exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y))) {
        split in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y))
        connect in(x,X)\wedge in(y,Y)
        apply cartprod_lem1 for X:X,Y:Y,x:x,y:y
        invoke in(x,X)\wedge in(y,Y)\to in(op(x,y),powerset(powerset(cup(X,Y))))
        substitute in(op(x,y),powerset(powerset(cup(X,Y)))) for op(x,y):z conclude in(z,powerset(powerset(cup(X,Y))))
        connect in(z,powerset(powerset(cup(X,Y))))\wedge\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))
        invoke leftward in(z,sep(powerset(powerset(cup(X,Y))),lambda z'.\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z',op(x,y)))))\leftrightarrow in(z,powerset(powerset(cup(X,Y))))\wedge\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))
        expand in(z,sep(powerset(powerset(cup(X,Y))),lambda z'.\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z',op(x,y))))) for cartprod conclude in(z,cartprod(X,Y))
      }
    }
    connect in(z,cartprod(X,Y))\leftrightarrow\exists x\exists y(in(x,X)\wedge in(y,Y)\wedge equal(z,op(x,y)))
  }
}
