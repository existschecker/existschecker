atom predicate in arity 2

definition predicate equal(x,y) \forall z(in(z,x)\leftrightarrow in(z,y))

theorem equal_reflection \forall x(equal(x,x)) {
  any x conclude equal(x,x) {
    any y conclude in(y,x)\leftrightarrow in(y,x) {
      assume in(y,x) conclude in(y,x) {}
      connect in(y,x)\leftrightarrow in(y,x)
    }
    fold \forall y(in(y,x)\leftrightarrow in(y,x)) conclude equal(x,x)
  }
}

theorem equal_replacement \forall x\forall y\forall u\forall v(equal(x,y)\wedge equal(u,v)\to(equal(x,u)\to equal(y,v))) {
  any x,y,u,v conclude equal(x,y)\wedge equal(u,v)\to(equal(x,u)\to equal(y,v)) {
    assume equal(x,y)\wedge equal(u,v) conclude equal(x,u)\to equal(y,v) {
      assume equal(x,u) conclude equal(y,v) {
        any p conclude in(p,y)\leftrightarrow in(p,v) {
          assume in(p,y) conclude in(p,v) {
            split equal(x,y)\wedge equal(u,v)
            expand equal(x,y) conclude \forall z(in(z,x)\leftrightarrow in(z,y))
            apply \forall z(in(z,x)\leftrightarrow in(z,y)) for z:p conclude in(p,x)\leftrightarrow in(p,y)
            split in(p,x)\leftrightarrow in(p,y)
            invoke in(p,y)\to in(p,x) conclude in(p,x)
            expand equal(x,u) conclude \forall z(in(z,x)\leftrightarrow in(z,u))
            apply \forall z(in(z,x)\leftrightarrow in(z,u)) for z:p conclude in(p,x)\leftrightarrow in(p,u)
            split in(p,x)\leftrightarrow in(p,u)
            invoke in(p,x)\to in(p,u) conclude in(p,u)
            expand equal(u,v) conclude \forall z(in(z,u)\leftrightarrow in(z,v))
            apply \forall z(in(z,u)\leftrightarrow in(z,v)) for z:p conclude in(p,u)\leftrightarrow in(p,v)
            split in(p,u)\leftrightarrow in(p,v)
            invoke in(p,u)\to in(p,v) conclude in(p,v)
          }
          assume in(p,v) conclude in(p,y) {
            split equal(x,y)\wedge equal(u,v)
            expand equal(u,v) conclude \forall z(in(z,u)\leftrightarrow in(z,v))
            apply \forall z(in(z,u)\leftrightarrow in(z,v)) for z:p conclude in(p,u)\leftrightarrow in(p,v)
            split in(p,u)\leftrightarrow in(p,v)
            invoke in(p,v)\to in(p,u) conclude in(p,u)
            expand equal(x,u) conclude \forall z(in(z,x)\leftrightarrow in(z,u))
            apply \forall z(in(z,x)\leftrightarrow in(z,u)) for z:p conclude in(p,x)\leftrightarrow in(p,u)
            split in(p,x)\leftrightarrow in(p,u)
            invoke in(p,u)\to in(p,x) conclude in(p,x)
            expand equal(x,y) conclude \forall z(in(z,x)\leftrightarrow in(z,y))
            apply \forall z(in(z,x)\leftrightarrow in(z,y)) for z:p conclude in(p,x)\leftrightarrow in(p,y)
            split in(p,x)\leftrightarrow in(p,y)
            invoke in(p,x)\to in(p,y) conclude in(p,y)
          }
          connect in(p,y)\leftrightarrow in(p,v)
        }
        fold \forall p(in(p,y)\leftrightarrow in(p,v)) conclude equal(y,v)
      }
    }
  }
}

axiom axiom_of_equal \forall x\forall y(equal(x,y)\to\forall z(in(x,z)\to in(y,z)))

theorem in_replacement \forall x\forall y\forall u\forall v(equal(x,y)\wedge equal(u,v)\to(in(x,u)\to in(y,v))) {
  any x,y,u,v conclude equal(x,y)\wedge equal(u,v)\to(in(x,u)\to in(y,v)) {
    assume equal(x,y)\wedge equal(u,v) conclude in(x,u)\to in(y,v) {
      assume in(x,u) conclude in(y,v) {
        apply axiom_of_equal for x:x,y:y conclude equal(x,y)\to\forall z(in(x,z)\to in(y,z))
        split equal(x,y)\wedge equal(u,v)
        invoke equal(x,y)\to\forall z(in(x,z)\to in(y,z)) conclude \forall z(in(x,z)\to in(y,z))
        apply \forall z(in(x,z)\to in(y,z)) for z:u conclude in(x,u)\to in(y,u)
        invoke in(x,u)\to in(y,u) conclude in(y,u)
        expand equal(u,v) conclude \forall z(in(z,u)\leftrightarrow in(z,v))
        apply \forall z(in(z,u)\leftrightarrow in(z,v)) for z:y conclude in(y,u)\leftrightarrow in(y,v)
        split in(y,u)\leftrightarrow in(y,v)
        invoke in(y,u)\to in(y,v) conclude in(y,v)
      }
    }
  }
}

equality equal
  reflection equal_reflection
  replacement equal: equal_replacement, in: in_replacement

definition predicate autoexpand notin(x,y) \neg(in(x,y))

definition predicate autoexpand neq(x,y) \neg(equal(x,y))

theorem neq_cor1 \forall x\forall y(neq(x,y)\leftrightarrow\exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)))) {
  any x, y conclude neq(x,y)\leftrightarrow\exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) {
    assume neq(x,y) conclude \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) {
      deny \forall z(in(z,x)\leftrightarrow in(z,y)) {
        fold \forall z(in(z,x)\leftrightarrow in(z,y)) conclude equal(x,y)
        contradict equal(x,y)
      }
      deny \neg(\exists z(\neg(in(z,x)\leftrightarrow in(z,y)))) {
        any z conclude in(z,x)\leftrightarrow in(z,y) {
          deny \neg(in(z,x)\leftrightarrow in(z,y)) {
            lift \neg(in(z,x)\leftrightarrow in(z,y)) for z:z conclude \exists z(\neg(in(z,x)\leftrightarrow in(z,y)))
            contradict \exists z(\neg(in(z,x)\leftrightarrow in(z,y)))
          }
        }
        contradict \forall z(in(z,x)\leftrightarrow in(z,y))
      }
      some z:z such \exists z(\neg(in(z,x)\leftrightarrow in(z,y))) conclude \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) {
        deny (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x)) {
          contradict in(z,x)\leftrightarrow in(z,y)
        }
        deny \neg(\neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))) {
          deny \neg(in(z,x)\to in(z,y)) {
            contradict \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
          }
          deny \neg(in(z,y)\to in(z,x)) {
            contradict \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x))
          }
          contradict (in(z,x)\to in(z,y))\wedge(in(z,y)\to in(z,x))
        }
        divide \neg(in(z,x)\to in(z,y))\vee\neg(in(z,y)\to in(z,x)) conclude (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
          case \neg(in(z,x)\to in(z,y)) {
            deny \neg(in(z,x)\wedge notin(z,y)) {
              assume in(z,x) conclude in(z,y) {
                deny notin(z,y) {
                  connect in(z,x)\wedge notin(z,y)
                  contradict in(z,x)\wedge notin(z,y)
                }
              }
              contradict in(z,x)\to in(z,y)
            }
            pad in(z,x)\wedge notin(z,y) conclude (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
          }
          case \neg(in(z,y)\to in(z,x)) {
            deny \neg(notin(z,x)\wedge in(z,y)) {
              assume in(z,y) conclude in(z,x) {
                deny notin(z,x) {
                  connect notin(z,x)\wedge in(z,y)
                  contradict notin(z,x)\wedge in(z,y)
                }
              }
              contradict in(z,y)\to in(z,x)
            }
            pad notin(z,x)\wedge in(z,y) conclude (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))
          }
        lift (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)) for z:z conclude \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)))
      }
    }
    assume \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) conclude neq(x,y) {
      some z:z such \exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y))) conclude neq(x,y) {
        deny equal(x,y) {
          expand equal(x,y) conclude \forall z(in(z,x)\leftrightarrow in(z,y))
          apply \forall z(in(z,x)\leftrightarrow in(z,y)) for z:z conclude in(z,x)\leftrightarrow in(z,y)
          split in(z,x)\leftrightarrow in(z,y)
          divide (in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)) conclude \bot
            case in(z,x)\wedge notin(z,y) {
              split in(z,x)\wedge notin(z,y)
              invoke in(z,x)\to in(z,y) conclude in(z,y)
              contradict in(z,y)
            }
            case notin(z,x)\wedge in(z,y) {
              split notin(z,x)\wedge in(z,y)
              invoke in(z,y)\to in(z,x) conclude in(z,x)
              contradict in(z,x)
            }
        }
      }
    }
    connect neq(x,y)\leftrightarrow\exists z((in(z,x)\wedge notin(z,y))\vee(notin(z,x)\wedge in(z,y)))
  }
}

axiom axiom_of_emptyset \exists x\forall y(notin(y,x))

theorem emptyset_exists_uniquely \exists!x\forall y(notin(y,x)) {
  some x:x such axiom_of_emptyset conclude \exists!x\forall y(notin(y,x)) {
    any x' conclude \forall y(notin(y,x'))\to equal(x',x) {
      assume \forall y(notin(y,x')) conclude equal(x',x) {
        any y conclude in(y,x')\leftrightarrow in(y,x) {
          assume in(y,x') conclude in(y,x) {
            apply \forall y(notin(y,x')) for y:y conclude notin(y,x')
            contradict in(y,x')
            explode in(y,x)
          }
          assume in(y,x) conclude in(y,x') {
            apply \forall y(notin(y,x)) for y:y conclude notin(y,x)
            contradict in(y,x)
            explode in(y,x')
          }
          connect in(y,x')\leftrightarrow in(y,x)
        }
        fold \forall y(in(y,x')\leftrightarrow in(y,x)) conclude equal(x',x)
      }
    }
    connect \forall y(notin(y,x))\wedge\forall x'(\forall y(notin(y,x'))\to equal(x',x))
    lift \forall y(notin(y,x))\wedge\forall x'(\forall y(notin(y,x'))\to equal(x',x)) for x:x conclude \exists!x\forall y(notin(y,x))
  }
}

definition constant emptyset by emptyset_exists_uniquely
  existence emptyset_existence \forall y(notin(y,emptyset))
  uniqueness emptyset_uniqueness \forall x(\forall y(notin(y,x))\to equal(x,emptyset))

theorem not_emptyset_has_a_member \forall x(\neg(equal(x, emptyset))\to\exists y(in(y,x))) {
    any x conclude \neg(equal(x,emptyset))\to\exists y(in(y,x)) {
        assume \neg(equal(x,emptyset)) conclude \exists y(in(y,x)) {
            deny \neg(\exists y(in(y,x))) {
                any y conclude notin(y,x) {
                    deny in(y,x) {
                        lift in(y,x) for y:y conclude \exists y(in(y,x))
                        contradict \exists y(in(y,x))
                    }
                }
                apply emptyset_uniqueness for x:x with \forall y(notin(y,x)) conclude equal(x,emptyset)
                contradict equal(x,emptyset)
            }
        }
    }
}

definition predicate subset(x,y) \forall z(in(z,x)\to in(z,y))

theorem subset_cor1 \forall z\forall x\forall y(in(z,x)\wedge subset(x,y)\to in(z,y)) {
  any x,y,z conclude in(z,x)\wedge subset(x,y)\to in(z,y) {
    assume in(z,x)\wedge subset(x,y) conclude in(z,y) {
      split in(z,x)\wedge subset(x,y)
      expand subset(x,y) conclude \forall z(in(z,x)\to in(z,y))
      apply \forall z(in(z,x)\to in(z,y)) for z:z conclude in(z,x)\to in(z,y)
      invoke in(z,x)\to in(z,y) conclude in(z,y)
    }
  }
}

theorem subset_reflection \forall x(subset(x,x)) {
  any x conclude subset(x,x) {
    any y conclude in(y,x)\to in(y,x) {
      assume in(y,x) conclude in(y,x) {}
    }
    fold \forall y(in(y,x)\to in(y,x)) conclude subset(x,x)
  }
}

theorem subset_antisymmetry \forall x\forall y(subset(x,y)\wedge subset(y,x)\to equal(x,y)) {
  any x,y conclude subset(x,y)\wedge subset(y,x)\to equal(x,y) {
    assume subset(x,y)\wedge subset(y,x) conclude equal(x,y) {
      any z conclude in(z,x)\leftrightarrow in(z,y) {
        assume in(z,x) conclude in(z,y) {
          apply subset_cor1 for z:z,x:x,y:y conclude in(z,x)\wedge subset(x,y)\to in(z,y)
          split subset(x,y)\wedge subset(y,x)
          connect in(z,x)\wedge subset(x,y)
          invoke in(z,x)\wedge subset(x,y)\to in(z,y) conclude in(z,y)
        }
        assume in(z,y) conclude in(z,x) {
          apply subset_cor1 for z:z,x:y,y:x conclude in(z,y)\wedge subset(y,x)\to in(z,x)
          split subset(x,y)\wedge subset(y,x)
          connect in(z,y)\wedge subset(y,x)
          invoke in(z,y)\wedge subset(y,x)\to in(z,x) conclude in(z,x)
        }
        connect in(z,x)\leftrightarrow in(z,y)
      }
      fold \forall z(in(z,x)\leftrightarrow in(z,y)) conclude equal(x,y)
    }
  }
}

theorem subset_trans \forall x\forall y\forall z(subset(x,y)\wedge subset(y,z)\to subset(x,z)) {
  any x,y,z conclude subset(x,y)\wedge subset(y,z)\to subset(x,z) {
    assume subset(x,y)\wedge subset(y,z) conclude subset(x,z) {
      any w conclude in(w,x)\to in(w,z) {
        assume in(w,x) conclude in(w,z) {
          apply subset_cor1 for z:w,x:x,y:y conclude in(w,x)\wedge subset(x,y)\to in(w,y)
          split subset(x,y)\wedge subset(y,z)
          connect in(w,x)\wedge subset(x,y)
          invoke in(w,x)\wedge subset(x,y)\to in(w,y) conclude in(w,y)
          apply subset_cor1 for z:w,x:y,y:z conclude in(w,y)\wedge subset(y,z)\to in(w,z)
          connect in(w,y)\wedge subset(y,z)
          invoke in(w,y)\wedge subset(y,z)\to in(w,z) conclude in(w,z)
        }
      }
      fold \forall w(in(w,x)\to in(w,z)) conclude subset(x,z)
    }
  }
}

axiom axiom_of_pair \forall x\forall y\exists z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))

theorem pair_exists_uniquely \forall x\forall y\exists!z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) {
  any x, y conclude \exists!z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) {
    apply axiom_of_pair for x:x, y:y conclude \exists z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))
    some z:z such \exists z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) conclude \exists!z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) {
      any z' conclude \forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y))\to equal(z',z) {
        assume \forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)) conclude equal(z',z) {
          any w conclude in(w,z')\leftrightarrow in(w,z) {
            assume in(w,z') conclude in(w,z) {
              apply \forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)) for w:w conclude in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)
              split in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)
              invoke in(w,z')\to equal(w,x)\vee equal(w,y) conclude equal(w,x)\vee equal(w,y)
              apply \forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) for w:w conclude in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)
              split in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)
              invoke equal(w,x)\vee equal(w,y)\to in(w,z) conclude in(w,z)
            }
            assume in(w,z) conclude in(w,z') {
              apply \forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)) for w:w conclude in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)
              split in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y)
              invoke in(w,z)\to equal(w,x)\vee equal(w,y) conclude equal(w,x)\vee equal(w,y)
              apply \forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)) for w:w conclude in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)
              split in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y)
              invoke equal(w,x)\vee equal(w,y)\to in(w,z') conclude in(w,z')
            }
            connect in(w,z')\leftrightarrow in(w,z)
          }
          fold \forall w(in(w,z')\leftrightarrow in(w,z)) conclude equal(z',z)
        }
      }
      connect \forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))\wedge\forall z'(\forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y))\to equal(z',z))
      lift \forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))\wedge\forall z'(\forall w(in(w,z')\leftrightarrow equal(w,x)\vee equal(w,y))\to equal(z',z)) for z:z conclude \exists!z\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))
    }
  }
}

definition function pair by pair_exists_uniquely
  existence pair_existence \forall x\forall y\forall w(in(w,pair(x,y))\leftrightarrow equal(w,x)\vee equal(w,y))
  uniqueness pair_uniqueness \forall x\forall y\forall z(\forall w(in(w,z)\leftrightarrow equal(w,x)\vee equal(w,y))\to equal(z,pair(x,y)))

theorem pair_cor1 \forall x\forall y(in(x,pair(x,y))) {
  any x,y conclude in(x,pair(x,y)) {
    apply pair_existence for x:x,y:y,w:x conclude in(x,pair(x,y))\leftrightarrow equal(x,x)\vee equal(x,y)
    split in(x,pair(x,y))\leftrightarrow equal(x,x)\vee equal(x,y)
    apply equal_reflection for x:x conclude equal(x,x)
    pad equal(x,x) conclude equal(x,x)\vee equal(x,y)
    invoke equal(x,x)\vee equal(x,y)\to in(x,pair(x,y)) conclude in(x,pair(x,y))
  }
}

theorem pair_cor2 \forall x\forall y(in(y,pair(x,y))) {
  any x,y conclude in(y,pair(x,y)) {
    apply pair_existence for x:x,y:y,w:y conclude in(y,pair(x,y))\leftrightarrow equal(y,x)\vee equal(y,y)
    split in(y,pair(x,y))\leftrightarrow equal(y,x)\vee equal(y,y)
    apply equal_reflection for x:y conclude equal(y,y)
    pad equal(y,y) conclude equal(y,x)\vee equal(y,y)
    invoke equal(y,x)\vee equal(y,y)\to in(y,pair(x,y)) conclude in(y,pair(x,y))
  }
}

theorem pair_cor3 \forall x\forall y(subset(pair(x,y),pair(y,x))) {
  any x,y conclude subset(pair(x,y),pair(y,x)) {
    any z conclude in(z,pair(x,y))\to in(z,pair(y,x)) {
      assume in(z,pair(x,y)) conclude in(z,pair(y,x)) {
        apply pair_existence for x:x,y:y,w:z conclude in(z,pair(x,y))\leftrightarrow equal(z,x)\vee equal(z,y)
        split in(z,pair(x,y))\leftrightarrow equal(z,x)\vee equal(z,y)
        invoke in(z,pair(x,y))\to equal(z,x)\vee equal(z,y) conclude equal(z,x)\vee equal(z,y)
        apply pair_existence for x:y,y:x,w:z conclude in(z,pair(y,x))\leftrightarrow equal(z,y)\vee equal(z,x)
        split in(z,pair(y,x))\leftrightarrow equal(z,y)\vee equal(z,x)
        invoke equal(z,y)\vee equal(z,x)\to in(z,pair(y,x)) conclude in(z,pair(y,x))
      }
    }
    fold \forall z(in(z,pair(x,y))\to in(z,pair(y,x))) conclude subset(pair(x,y),pair(y,x))
  }
}

theorem pair_commutativity \forall x\forall y(equal(pair(x,y),pair(y,x))) {
  any x,y conclude equal(pair(x,y),pair(y,x)) {
    apply pair_cor3 for x:x,y:y conclude subset(pair(x,y),pair(y,x))
    apply pair_cor3 for x:y,y:x conclude subset(pair(y,x),pair(x,y))
    connect subset(pair(x,y),pair(y,x))\wedge subset(pair(y,x),pair(x,y))
    apply subset_antisymmetry for x:pair(x,y),y:pair(y,x) conclude subset(pair(x,y),pair(y,x))\wedge subset(pair(y,x),pair(x,y))\to equal(pair(x,y),pair(y,x))
    invoke subset(pair(x,y),pair(y,x))\wedge subset(pair(y,x),pair(x,y))\to equal(pair(x,y),pair(y,x)) conclude equal(pair(x,y),pair(y,x))
  }
}

theorem pair_cor4 \forall x\forall y\forall z\forall w(equal(pair(x,y),pair(z,w))\to equal(x,z)\vee equal(x,w)) {
  any x,y,z,w conclude equal(pair(x,y),pair(z,w))\to equal(x,z)\vee equal(x,w) {
    assume equal(pair(x,y),pair(z,w)) conclude equal(x,z)\vee equal(x,w) {
      apply pair_cor1 for x:x,y:y conclude in(x,pair(x,y))
      substitute in(x,pair(x,y)) conclude in(x,pair(z,w))
      apply pair_existence for x:z,y:w,w:x conclude in(x,pair(z,w))\leftrightarrow equal(x,z)\vee equal(x,w)
      split in(x,pair(z,w))\leftrightarrow equal(x,z)\vee equal(x,w)
      invoke in(x,pair(z,w))\to equal(x,z)\vee equal(x,w) conclude equal(x,z)\vee equal(x,w)
    }
  }
}

theorem pair_cor5 \forall x\forall y\forall z\forall w(equal(pair(x,y),pair(z,w))\to equal(y,z)\vee equal(y,w)) {
  any x,y,z,w conclude equal(pair(x,y),pair(z,w))\to equal(y,z)\vee equal(y,w) {
    assume equal(pair(x,y),pair(z,w)) conclude equal(y,z)\vee equal(y,w) {
      apply pair_cor2 for x:x,y:y conclude in(y,pair(x,y))
      substitute in(y,pair(x,y)) conclude in(y,pair(z,w))
      apply pair_existence for x:z,y:w,w:y conclude in(y,pair(z,w))\leftrightarrow equal(y,z)\vee equal(y,w)
      split in(y,pair(z,w))\leftrightarrow equal(y,z)\vee equal(y,w)
      invoke in(y,pair(z,w))\to equal(y,z)\vee equal(y,w) conclude equal(y,z)\vee equal(y,w)
    }
  }
}

theorem pair_cor6 \forall x\forall y\forall z(equal(pair(x,x),pair(y,z))\to equal(x,y)) {
  any x,y,z conclude equal(pair(x,x),pair(y,z))\to equal(x,y) {
    assume equal(pair(x,x),pair(y,z)) conclude equal(x,y) {
      apply pair_cor4 for x:y,y:z,z:x,w:x conclude equal(pair(y,z),pair(x,x))\to equal(y,x)\vee equal(y,x)
      invoke equal(pair(y,z),pair(x,x))\to equal(y,x)\vee equal(y,x) conclude equal(y,x)\vee equal(y,x)
      divide equal(y,x)\vee equal(y,x) conclude equal(y,x)
        case equal(y,x) {}
        case equal(y,x) {}
      substitute equal(y,x) conclude equal(x,y)
    }
  }
}

theorem pair_cor7 \forall x\forall y\forall z(equal(pair(x,x),pair(y,z))\to equal(x,z)) {
  any x,y,z conclude equal(pair(x,x),pair(y,z))\to equal(x,z) {
    assume equal(pair(x,x),pair(y,z)) conclude equal(x,z) {
      apply pair_cor5 for x:y,y:z,z:x,w:x conclude equal(pair(y,z),pair(x,x))\to equal(z,x)\vee equal(z,x)
      invoke equal(pair(y,z),pair(x,x))\to equal(z,x)\vee equal(z,x) conclude equal(z,x)\vee equal(z,x)
      divide equal(z,x)\vee equal(z,x) conclude equal(z,x)
        case equal(z,x) {}
        case equal(z,x) {}
      substitute equal(z,x) conclude equal(x,z)
    }
  }
}

theorem pair_cor8 \forall x\forall y\forall z(equal(pair(x,y),pair(x,z))\to equal(y,z)) {
  any x,y,z conclude equal(pair(x,y),pair(x,z))\to equal(y,z) {
    assume equal(pair(x,y),pair(x,z)) conclude equal(y,z) {
      apply pair_cor5 for x:x,y:y,z:x,w:z conclude equal(pair(x,y),pair(x,z))\to equal(y,x)\vee equal(y,z)
      invoke equal(pair(x,y),pair(x,z))\to equal(y,x)\vee equal(y,z) conclude equal(y,x)\vee equal(y,z)
      divide equal(y,x)\vee equal(y,z) conclude equal(y,z)
        case equal(y,x) {
          substitute equal(pair(x,y),pair(x,z)) conclude equal(pair(x,x),pair(x,z))
          apply pair_cor7 for x:x,y:x,z:z conclude equal(pair(x,x),pair(x,z))\to equal(x,z)
          invoke equal(pair(x,x),pair(x,z))\to equal(x,z) conclude equal(x,z)
          substitute equal(y,x) conclude equal(y,z)
        }
        case equal(y,z) {}
    }
  }
}

definition function singleton(x) pair(x,x)

theorem singleton_characterization \forall x\forall y(in(y,singleton(x))\leftrightarrow equal(y,x)) {
  any x,y conclude in(y,singleton(x))\leftrightarrow equal(y,x) {
    assume in(y,singleton(x)) conclude equal(y,x) {
      expand in(y,singleton(x)) conclude in(y,pair(x,x))
      apply pair_existence for x:x,y:x,w:y conclude in(y,pair(x,x))\leftrightarrow equal(y,x)\vee equal(y,x)
      split in(y,pair(x,x))\leftrightarrow equal(y,x)\vee equal(y,x)
      invoke in(y,pair(x,x))\to equal(y,x)\vee equal(y,x) conclude equal(y,x)\vee equal(y,x)
      divide equal(y,x)\vee equal(y,x) conclude equal(y,x)
        case equal(y,x) {}
        case equal(y,x) {}
    }
    assume equal(y,x) conclude in(y,singleton(x)) {
      apply pair_existence for x:x,y:x,w:y conclude in(y,pair(x,x))\leftrightarrow equal(y,x)\vee equal(y,x)
      split in(y,pair(x,x))\leftrightarrow equal(y,x)\vee equal(y,x)
      invoke equal(y,x)\vee equal(y,x)\to in(y,pair(x,x)) conclude in(y,pair(x,x))
      expand in(y,pair(x,x)) conclude in(y,singleton(x))
    }
    connect in(y,singleton(x))\leftrightarrow equal(y,x)
  }
}

theorem singleton_cor1 \forall x(in(x,singleton(x))) {
  any x conclude in(x,singleton(x)) {
    apply singleton_characterization for x:x,y:x conclude in(x,singleton(x))\leftrightarrow equal(x,x)
    split in(x,singleton(x))\leftrightarrow equal(x,x)
    invoke equal(x,x)\to in(x,singleton(x)) conclude in(x,singleton(x))
  }
}

theorem singleton_cor2 \forall x\forall y(equal(singleton(x),singleton(y))\to equal(x,y)) {
  any x,y conclude equal(singleton(x),singleton(y))\to equal(x,y) {
    assume equal(singleton(x),singleton(y)) conclude equal(x,y) {
      apply singleton_cor1 for x:x conclude in(x,singleton(x))
      substitute in(x,singleton(x)) conclude in(x,singleton(y))
      apply singleton_characterization for x:y,y:x conclude in(x,singleton(y))\leftrightarrow equal(x,y)
      split in(x,singleton(y))\leftrightarrow equal(x,y)
      invoke in(x,singleton(y))\to equal(x,y) conclude equal(x,y)
    }
  }
}

theorem pair_singleton_cor1 \forall x\forall y\forall z(equal(singleton(x),pair(y,z))\to equal(x,y)) {
  any x,y,z conclude equal(singleton(x),pair(y,z))\to equal(x,y) {
    assume equal(singleton(x),pair(y,z)) conclude equal(x,y) {
      expand equal(singleton(x),pair(y,z)) conclude equal(pair(x,x),pair(y,z))
      apply pair_cor6 for x:x,y:y,z:z conclude equal(pair(x,x),pair(y,z))\to equal(x,y)
      invoke equal(pair(x,x),pair(y,z))\to equal(x,y) conclude equal(x,y)
    }
  }
}

theorem pair_singleton_cor2 \forall x\forall y\forall z(equal(singleton(x),pair(y,z))\to equal(x,z)) {
  any x,y,z conclude equal(singleton(x),pair(y,z))\to equal(x,z) {
    assume equal(singleton(x),pair(y,z)) conclude equal(x,z) {
      expand equal(singleton(x),pair(y,z)) conclude equal(pair(x,x),pair(y,z))
      apply pair_cor7 for x:x,y:y,z:z conclude equal(pair(x,x),pair(y,z))\to equal(x,z)
      invoke equal(pair(x,x),pair(y,z))\to equal(x,z) conclude equal(x,z)
    }
  }
}

definition function op(x,y) pair(singleton(x),pair(x,y))

theorem op_characterization \forall x\forall y\forall x'\forall y'(equal(op(x,y),op(x',y'))\to equal(x,x')\wedge equal(y,y')) {
  any x,y,x',y' {
    assume equal(op(x,y),op(x',y')) {
      expand equal(op(x,y),op(x',y')) conclude equal(pair(singleton(x),pair(x,y)),pair(singleton(x'),pair(x',y')))
      apply pair_cor4 for x:singleton(x),y:pair(x,y),z:singleton(x'),w:pair(x',y')
      invoke equal(pair(singleton(x),pair(x,y)),pair(singleton(x'),pair(x',y')))\to equal(singleton(x),singleton(x'))\vee equal(singleton(x),pair(x',y'))
      divide equal(singleton(x),singleton(x'))\vee equal(singleton(x),pair(x',y'))
        case equal(singleton(x),singleton(x')) {
          apply singleton_cor2 for x:x,y:x'
          invoke equal(singleton(x),singleton(x'))\to equal(x,x')
        }
        case equal(singleton(x),pair(x',y')) {
          apply pair_singleton_cor1 for x:x,y:x',z:y'
          invoke equal(singleton(x),pair(x',y'))\to equal(x,x')
        }
      substitute equal(pair(singleton(x),pair(x,y)),pair(singleton(x'),pair(x',y'))) conclude equal(pair(singleton(x),pair(x,y)),pair(singleton(x),pair(x,y')))
      apply pair_cor8 for x:singleton(x),y:pair(x,y),z:pair(x,y')
      invoke equal(pair(singleton(x),pair(x,y)),pair(singleton(x),pair(x,y')))\to equal(pair(x,y),pair(x,y'))
      apply pair_cor8 for x:x,y:y,z:y'
      invoke equal(pair(x,y),pair(x,y'))\to equal(y,y')
      connect equal(x,x')\wedge equal(y,y')
    }
  }
}

axiom axiom_of_union \forall x\exists y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))

theorem union_exists_uniquely \forall x\exists!y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) {
  any x {
    apply axiom_of_union for x:x
    some y:y such \exists y\forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) {
      any y' {
        assume \forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) {
          any z {
            assume in(z,y') {
              apply \forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z:z
              split in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))
              invoke in(z,y')\to\exists w(in(z,w)\wedge in(w,x))
              apply \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z:z
              split in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))
              invoke \exists w(in(z,w)\wedge in(w,x))\to in(z,y)
            }
            assume in(z,y) {
              apply \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z:z
              split in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x))
              invoke in(z,y)\to\exists w(in(z,w)\wedge in(w,x))
              apply \forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))) for z:z
              split in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x))
              invoke \exists w(in(z,w)\wedge in(w,x))\to in(z,y')
            }
            connect in(z,y')\leftrightarrow in(z,y)
          }
          expand \forall z(in(z,y')\leftrightarrow in(z,y)) conclude equal(y',y)
        }
      }
      connect \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\wedge\forall y'(\forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\to equal(y',y))
      characterize \forall z(in(z,y)\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\wedge\forall y'(\forall z(in(z,y')\leftrightarrow\exists w(in(z,w)\wedge in(w,x)))\to equal(y',y)) for y:y
    }
  }
}
