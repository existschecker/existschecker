atom predicate in arity 2

theorem test01 \forall x\forall y(in(x,y)\to in(x,y)) {
  any x, y conclude in(x,y)\to in(x,y) {
    assume in(x,y) conclude in(x,y) {}
  }
}

theorem test02 \forall x\forall y(in(x,y)\to in(x,y)\wedge in(x,y)) {
  any x, y conclude in(x,y)\to in(x,y)\wedge in(x,y) {
    assume in(x,y) conclude in(x,y)\wedge in(x,y) {
      connect in(x,y)\wedge in(x,y)
    }
  }
}

theorem test03 \forall x\forall y((in(x,y)\to in(x,y))\wedge(in(x,y)\to in(x,y))) {
  any x, y conclude (in(x,y)\to in(x,y))\wedge(in(x,y)\to in(x,y)) {
    assume in(x,y) conclude in(x,y) {}
    connect (in(x,y)\to in(x,y))\wedge(in(x,y)\to in(x,y))
  }
}

theorem test04 (\forall x\forall y(in(x,y)\to in(x,y)))\wedge(\forall z\forall w(in(z,w)\to in(z,w))) {
  any x, y conclude in(x,y)\to in(x,y) {
    assume in(x,y) conclude in(x,y) {}
  }
  connect (\forall x\forall y(in(x,y)\to in(x,y)))\wedge(\forall z\forall w(in(z,w)\to in(z,w)))
}

theorem test05 \forall x\forall y((in(x,y)\to in(x,y))\wedge(in(x,y)\to in(x,y)\wedge in(x,y))) {
  any x, y conclude (in(x,y)\to in(x,y))\wedge(in(x,y)\to in(x,y)\wedge in(x,y)) {
    assume in(x,y) conclude in(x,y) {}
    assume in(x,y) conclude in(x,y)\wedge in(x,y) {
      connect in(x,y)\wedge in(x,y)
    }
    connect (in(x,y)\to in(x,y))\wedge(in(x,y)\to in(x,y)\wedge in(x,y))
  }
}

theorem test06 (\forall x\forall y(in(x,y)\to in(x,y)))\wedge(\forall x\forall y(in(x,y)\to in(x,y)\wedge in(x,y))) {
  any x, y conclude in(x,y)\to in(x,y) {
    assume in(x,y) conclude in(x,y) {}
  }
  any x, y conclude in(x,y)\to in(x,y)\wedge in(x,y) {
    assume in(x,y) conclude in(x,y)\wedge in(x,y) {
      connect in(x,y)\wedge in(x,y)
    }
  }
  connect (\forall x\forall y(in(x,y)\to in(x,y)))\wedge(\forall x\forall y(in(x,y)\to in(x,y)\wedge in(x,y)))
}

theorem test07 \forall x\forall y(in(x,y)\to in(x,y)\wedge\forall z(in(z,x)\to in(z,x))) {
  any x, y conclude in(x,y)\to in(x,y)\wedge\forall z(in(z,x)\to in(z,x)) {
    assume in(x,y) conclude in(x,y)\wedge\forall z(in(z,x)\to in(z,x)) {
      any z conclude in(z,x)\to in(z,x) {
        assume in(z,x) conclude in(z,x) {} 
      }
      connect in(x,y)\wedge\forall z(in(z,x)\to in(z,x))
    } 
  }
}

theorem test08 \forall v\forall u(in(u,v)\to in(u,v)) {
  any x, y conclude in(x,y)\to in(x,y) {
    assume in(x,y) conclude in(x,y) {}
  }
}

theorem test09 \forall v\forall u(in(u,v)\to in(u,v)) {
  any x, y conclude in(x,y)\to in(x,y) {
    assume in(x,y) conclude in(x,y) {}
    check in(x,y)\to in(x,y)
  }
}

theorem test10 \forall v\forall u(in(u,v)\to in(u,v)) {
  any x, y conclude in(x,y)\to in(x,y) {
    assume in(x,y) conclude in(x,y) {}
  }
  check \forall x\forall y(in(x,y)\to in(x,y))
}

theorem test11 \forall u\forall v(in(u,v)\to in(u,v)\vee in(v,u)) {
  any x, y conclude in(x,y)\to(in(x,y)\vee in(y,x)) {
    assume in(x,y) conclude in(x,y)\vee in(y,x) {
      pad in(x,y) conclude in(x,y)\vee in(y,x)
    }
  }
}

theorem test12 \forall u\forall v(in(u,v)\vee in(v,u)\to in(v,u)\vee in(u,v)) {
  any x, y conclude in(x,y)\vee in(y,x)\to in(y,x)\vee in(x,y) {
    assume in(x,y)\vee in(y,x) conclude in(y,x)\vee in(x,y) {}
  }
}

theorem test13 \forall x\forall y(in(x,y)\vee in(y,x)\to(in(x,y)\wedge in(x,y))\vee(in(y,x)\wedge in(y,x))) {
  any x, y conclude in(x,y)\vee in(y,x)\to(in(x,y)\wedge in(x,y))\vee(in(y,x)\wedge in(y,x)) {
    assume in(x,y)\vee in(y,x) conclude (in(x,y)\wedge in(x,y))\vee(in(y,x)\wedge in(y,x)) {
      divide in(x,y)\vee in(y,x) conclude (in(x,y)\wedge in(x,y))\vee(in(y,x)\wedge in(y,x))
        case in(x,y) {
          connect in(x,y)\wedge in(x,y)
          pad in(x,y)\wedge in(x,y) conclude (in(x,y)\wedge in(x,y))\vee(in(y,x)\wedge in(y,x))
        }
        case in(y,x) {
          connect in(y,x)\wedge in(y,x)
          pad in(y,x)\wedge in(y,x) conclude (in(x,y)\wedge in(x,y))\vee(in(y,x)\wedge in(y,x))
        }
    }
  }
}

theorem test14 \forall x\forall y(in(x,x)\vee in(x,y)\vee in(y,x)\to in(x,x)\vee in(x,y)\vee in(y,x)) {
  any x, y conclude in(x,x)\vee in(x,y)\vee in(y,x)\to in(x,x)\vee in(x,y)\vee in(y,x) {
    assume in(x,x)\vee in(x,y)\vee in(y,x) conclude in(x,x)\vee in(x,y)\vee in(y,x) {
      divide in(x,x)\vee in(x,y)\vee in(y,x) conclude in(x,x)\vee in(x,y)\vee in(y,x)
        case in(x,x) {}
        case in(y,x) {}
        case in(x,y) {}
    }
  }
}

theorem test15 \exists x\exists y(in(x,y))\to\exists x\exists y(in(x,y)\wedge in(x,y)) {
  assume \exists x\exists y(in(x,y)) conclude \exists x\exists y(in(x,y)\wedge in(x,y)) {
    some x:x, y:y such \exists x\exists y(in(x,y)) conclude \exists x\exists y(in(x,y)\wedge in(x,y)) {
      connect in(x,y)\wedge in(x,y)
      lift in(x,y)\wedge in(x,y) for x: x, y: y conclude \exists x\exists y(in(x,y)\wedge in(x,y))
    }
  }
}

theorem test16 \forall x\forall y(in(x,y))\to\forall x\forall y(in(x,y)) {
  assume \forall x\forall y(in(x,y)) conclude \forall x\forall y(in(x,y)) {}
}

theorem test17 \exists x(in(x,x))\to\exists x(in(x,x)) {
  assume \exists x(in(x,x)) conclude \exists x(in(x,x)) {
    some x:x such \exists x(in(x,x)) conclude \exists x(in(x,x)) {
      lift in(x,x) for x: x conclude \exists x(in(x,x))
    }
  }
}

theorem test18 \exists x\exists y(in(x,y)\vee in(y,x))\to\exists x\exists y(\neg(\neg(in(x,y))\wedge\neg(in(y,x)))) {
  assume \exists x\exists y(in(x,y)\vee in(y,x)) conclude \exists x\exists y(\neg(\neg(in(x,y))\wedge\neg(in(y,x)))) {
    some x:x, y:y such \exists x\exists y(in(x,y)\vee in(y,x)) conclude \exists x\exists y(\neg(\neg(in(x,y))\wedge\neg(in(y,x)))) {
      divide in(x,y)\vee in(y,x) conclude \neg(\neg(in(x,y))\wedge\neg(in(y,x)))
        case in(x,y) {
          deny \neg(in(x,y))\wedge\neg(in(y,x)) {
            split \neg(in(x,y))\wedge\neg(in(y,x))
            contradict in(x,y)
          }
        }
        case in(y,x) {
          deny \neg(in(x,y))\wedge\neg(in(y,x)) {
            split \neg(in(x,y))\wedge\neg(in(y,x))
            contradict in(y,x)
          }
        }
      lift \neg(\neg(in(x,y))\wedge\neg(in(y,x))) for x: x, y: y conclude \exists x\exists y(\neg(\neg(in(x,y))\wedge\neg(in(y,x))))
    }
  }
}

theorem test19 \exists x\exists y((in(x,y)\vee in(y,x))\wedge\neg(in(y,x)))\to\exists x\exists y(in(x,y)) {
  assume \exists x\exists y((in(x,y)\vee in(y,x))\wedge\neg(in(y,x))) conclude \exists x\exists y(in(x,y)) {
    some x:x, y:y such \exists x\exists y((in(x,y)\vee in(y,x))\wedge\neg(in(y,x))) conclude \exists x\exists y(in(x,y)) {
      split (in(x,y)\vee in(y,x))\wedge\neg(in(y,x))
      divide in(x,y)\vee in(y,x) conclude in(x,y)
        case in(x,y) {}
        case in(y,x) {
          contradict in(y,x)
          explode in(x,y)
        }
      lift in(x,y) for x: x, y: y conclude \exists x\exists y(in(x,y))
    }
  }
}

theorem test20 \forall x\forall y(in(x,y)\to\forall z(in(z,x)))\wedge\exists x\exists y(in(x,y))\to\exists x\exists y(in(x,y)\wedge in(y,x)) {
  assume \forall x\forall y(in(x,y)\to\forall z(in(z,x)))\wedge\exists x\exists y(in(x,y)) conclude \exists x\exists y(in(x,y)\wedge in(y,x)) {
    split \forall x\forall y(in(x,y)\to\forall z(in(z,x)))\wedge\exists x\exists y(in(x,y))
    some x:x, y:y such \exists x\exists y(in(x,y)) conclude \exists x\exists y(in(x,y)\wedge in(y,x)) {
      apply \forall x\forall y(in(x,y)\to\forall z(in(z,x))) for x: x, y: y with in(x,y) conclude \forall z(in(z,x))
      apply \forall z(in(z,x)) for z: y conclude in(y,x)
      connect in(x,y)\wedge in(y,x)
      lift in(x,y)\wedge in(y,x) for x: x, y: y conclude \exists x\exists y(in(x,y)\wedge in(y,x))
    }
  }
}

theorem test21 \forall x\forall y(in(x,y))\to\neg(\exists x\exists y(\neg(in(x,y)))) {
  assume \forall x\forall y(in(x,y)) conclude \neg(\exists x\exists y(\neg(in(x,y)))) {
    deny \exists x\exists y(\neg(in(x,y))) {
      some x:x, y:y such \exists x\exists y(\neg(in(x,y))) conclude \bot {
        apply \forall x\forall y(in(x,y)) for x: x, y: y conclude in(x,y)
        contradict in(x,y)
      }
    }
  }
}

theorem test22 \neg(\exists x\exists y(\neg(in(x,y))))\to\forall x\forall y(in(x,y)) {
  assume \neg(\exists x\exists y(\neg(in(x,y)))) conclude \forall x\forall y(in(x,y)) {
    any x, y conclude in(x,y) {
      deny \neg(in(x,y)) {
        lift \neg(in(x,y)) for x: x, y: y conclude \exists x\exists y(\neg(in(x,y)))
        contradict \exists x\exists y(\neg(in(x,y)))
      }
    }
  }
}

theorem test23 \forall x(in(x,x)\to\neg(in(x,x)))\to(\forall x(in(x,x))\to\forall x(\neg(in(x,x)))) {
  assume \forall x(in(x,x)\to\neg(in(x,x))) conclude \forall x(in(x,x))\to\forall x(\neg(in(x,x))) {
    assume \forall x(in(x,x)) conclude \forall x(\neg(in(x,x))) {
      any x conclude \neg(in(x,x)) {
        apply \forall x(in(x,x)\to\neg(in(x,x))) for x: x conclude in(x,x)\to\neg(in(x,x))
        apply \forall x(in(x,x)) for x: x conclude in(x,x)
        apply in(x,x)\to\neg(in(x,x)) with in(x,x) conclude \neg(in(x,x))
      }
    }
  }
}

theorem test24 \forall x\forall y(\neg(in(x,y)))\to\neg(\exists x\exists y(in(x,y))) {
  assume \forall x\forall y(\neg(in(x,y))) conclude \neg(\exists x\exists y(in(x,y))) {
    deny \exists x\exists y(in(x,y)) {
      some x:x, y:y such \exists x\exists y(in(x,y)) conclude \bot {
        apply \forall x\forall y(\neg(in(x,y))) for x: x, y: y conclude \neg(in(x,y))
        contradict in(x,y)
      }
    }
  }
}

theorem test25 \neg(\exists x\exists y(in(x,y)))\to\forall x\forall y(\neg(in(x,y))) {
  assume \neg(\exists x\exists y(in(x,y))) conclude \forall x\forall y(\neg(in(x,y))) {
    any x, y conclude \neg(in(x,y)) {
      deny in(x,y) {
        lift in(x,y) for x: x, y: y conclude \exists x\exists y(in(x,y))
        contradict \exists x\exists y(in(x,y))
      }
    }
  }
}
