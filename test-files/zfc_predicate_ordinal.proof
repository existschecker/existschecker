include "zfc_predicate_order.proof"

definition predicate cap(template \phi[1], template \chi[1], template \rho[1]) as \forall x (\rho(x) \leftrightarrow \phi(x) \wedge \chi(x))

theorem cap_is_subset_left \forall^T \phi[1] \forall^T \chi[1] \forall^T \rho[1] (cap(\phi, \chi, \rho) \to subset(\rho, \phi)) {
  any template \phi[1], template \chi[1], template \rho[1] {
    assume cap(\phi, \chi, \rho) {
      any x {
        assume \rho(x) {
          apply invoke rightward cap(\phi, \chi, \rho) for x
          split 1 \phi(x) \wedge \chi(x)
        }
      }
      fold for subset conclude subset(\rho, \phi)
    }
  }
}

theorem cap_is_subset_right \forall^T \phi[1] \forall^T \chi[1] \forall^T \rho[1] (cap(\phi, \chi, \rho) \to subset(\rho, \chi)) {
  any template \phi[1], template \chi[1], template \rho[1] {
    assume cap(\phi, \chi, \rho) {
      any x {
        assume \rho(x) {
          apply invoke rightward cap(\phi, \chi, \rho) for x
          split 2 \phi(x) \wedge \chi(x)
        }
      }
      fold for subset conclude subset(\rho, \chi)
    }
  }
}

definition predicate setminus(template \phi[1], template \chi[1], template \rho[1]) as \forall x (\rho(x) \leftrightarrow \phi(x) \wedge \neg(\chi(x)))

theorem setminus_is_subset \forall^T \phi[1] \forall^T \chi[1] \forall^T \rho[1] (setminus(\phi, \chi, \rho) \to subset(\rho, \phi)) {
  any template \phi[1], template \chi[1], template \rho[1] {
    assume setminus(\phi, \chi, \rho) {
      any x {
        assume \rho(x) {
          apply invoke rightward setminus(\phi, \chi, \rho) for x
          split 1 \phi(x) \wedge \neg(\chi(x))
        }
      }
      fold for subset conclude subset(\rho, \phi)
    }
  }
}

definition predicate trans(template \phi[1]) as \forall x \forall y (in(y, x) \wedge \phi(x) \to \phi(y))

definition predicate trans(x) as trans(lambda y. in(y, x))

theorem trans_cor1 \forall^T \phi[1] (trans(\phi) \leftrightarrow \forall x (\phi(x) \to subset(x, \phi))) {
  any template \phi[1] {
    assume trans(\phi) {
      any x {
        assume \phi(x) {
          any y {
            assume in(y, x) {
              connect in(y, x) \wedge \phi(x)
              apply invoke trans(\phi) for x, y
            }
          }
          fold for subset conclude subset(x, \phi)
        }
      }
    }
    assume \forall x (\phi(x) \to subset(x, \phi)) {
      any x, y {
        assume in(y, x) \wedge \phi(x) {
          split in(y, x) \wedge \phi(x)
          apply invoke \forall x (\phi(x) \to subset(x, \phi)) for x
          apply invoke subset(x, \phi) for y
        }
      }
      fold for trans conclude trans(\phi)
    }
    connect trans(\phi) \leftrightarrow \forall x (\phi(x) \to subset(x, \phi))
  }
}

theorem cap_of_trans_is_trans \forall^T \phi[1] \forall^T \chi[1] \forall^T \rho[1] (trans(\phi) \wedge trans(\chi) \wedge cap(\phi, \chi, \rho) \to trans(\rho)) {
  any template \phi[1], template \chi[1], template \rho[1] {
    assume trans(\phi) \wedge trans(\chi) \wedge cap(\phi, \chi, \rho) {
      split trans(\phi) \wedge trans(\chi) \wedge cap(\phi, \chi, \rho)
      any x, y {
        assume in(y, x) \wedge \rho(x) {
          split in(y, x) \wedge \rho(x)
          apply invoke rightward cap(\phi, \chi, \rho) for x
          split \phi(x) \wedge \chi(x)
          connect in(y, x) \wedge \phi(x)
          apply invoke trans(\phi) for x, y
          connect in(y, x) \wedge \chi(x)
          apply invoke trans(\chi) for x, y
          connect \phi(y) \wedge \chi(y)
          apply invoke leftward cap(\phi, \chi, \rho) for y
        }
      }
      fold for trans conclude trans(\rho)
    }
  }
}

definition predicate ordinal(template \phi[1]) as trans(\phi) \wedge irrefrelon(\phi, in) \wedge wellorder(\phi, in)

definition predicate ordinal(\alpha) as ordinal(lambda \beta. in(\beta, \alpha))

theorem element_of_ordinal_is_trans \forall^T \phi[1] (ordinal(\phi) \to \forall \alpha (\phi(\alpha) \to trans(\alpha))) {
  any template \phi[1] {
    assume ordinal(\phi) {
      any \alpha {
        assume \phi(\alpha) {
          any \beta, \gamma {
            assume in(\gamma, \beta) \wedge in(\beta, \alpha) {
              split in(\gamma, \beta) \wedge in(\beta, \alpha)
              split ordinal(\phi)
              connect in(\beta, \alpha) \wedge \phi(\alpha)
              apply invoke trans(\phi) for \alpha, \beta
              connect in(\gamma, \beta) \wedge \phi(\beta)
              apply invoke trans(\phi) for \beta, \gamma
              connect \phi(\gamma) \wedge \phi(\beta) \wedge \phi(\alpha) \wedge in(\gamma, \beta)\wedge in(\beta, \alpha)
              split 1 wellorder(\phi, in)
              split 1 orderon(\phi, in)
              apply invoke transrelon(\phi, in) for \gamma, \beta, \alpha
            }
          }
          fold for trans conclude trans(\alpha)
        }
      }
    }
  }
}

