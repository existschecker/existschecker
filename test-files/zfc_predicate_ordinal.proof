include "zfc_predicate_order.proof"

definition predicate cap(x, y, z) as \forall w (in(w, z) \leftrightarrow in(w, x) \wedge in(w, y))

definition predicate cap_predicate(predicate \phi[1], predicate \chi[1], predicate \rho[1]) as \forall x (\rho(x) \leftrightarrow \phi(x) \wedge \chi(x))

theorem cap_lambda \forall X \forall Y \forall Z (cap(X, Y, Z) \leftrightarrow cap_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y), \lambda^P z. in(z, Z))) {
  any X, Y, Z {
    assume cap(X, Y, Z) {
      expand cap(X, Y, Z) for cap
      fold for cap_predicate conclude cap_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y), \lambda^P z. in(z, Z))
    }
    assume cap_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y), \lambda^P z. in(z, Z)) {
      expand cap_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y), \lambda^P z. in(z, Z)) for cap_predicate
      fold for cap conclude cap(X, Y, Z)
    }
    connect cap(X, Y, Z) \leftrightarrow cap_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y), \lambda^P z. in(z, Z))
  }
}

theorem cap_is_subset_left_predicate \forall^P \phi[1] \forall^P \chi[1] \forall^P \rho[1] (cap_predicate(\phi, \chi, \rho) \to subset_predicate(\rho, \phi)) {
  any predicate \phi[1], predicate \chi[1], predicate \rho[1] {
    assume cap_predicate(\phi, \chi, \rho) {
      any x {
        assume \rho(x) {
          apply invoke rightward cap_predicate(\phi, \chi, \rho) for x
          split 1 \phi(x) \wedge \chi(x)
        }
      }
      fold for subset_predicate conclude subset_predicate(\rho, \phi)
    }
  }
}

theorem cap_is_subset_left \forall X \forall Y \forall Z (cap(X, Y, Z) \to subset(Z, X)) {
  any X, Y, Z {
    assume cap(X, Y, Z) {
      apply invoke rightward cap_lambda for X, Y, Z
      apply invoke cap_is_subset_left_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y), \lambda^P z. in(z, Z)
      apply invoke leftward subset_lambda for Z, X
    }
  }
}

theorem cap_is_subset_right \forall^P \phi[1] \forall^P \chi[1] \forall^P \rho[1] (cap_predicate(\phi, \chi, \rho) \to subset_predicate(\rho, \chi)) {
  any predicate \phi[1], predicate \chi[1], predicate \rho[1] {
    assume cap_predicate(\phi, \chi, \rho) {
      any x {
        assume \rho(x) {
          apply invoke rightward cap_predicate(\phi, \chi, \rho) for x
          split 2 \phi(x) \wedge \chi(x)
        }
      }
      fold for subset_predicate conclude subset_predicate(\rho, \chi)
    }
  }
}

definition predicate setminus(x, y, z) as \forall w (in(w, z) \leftrightarrow in(w, x) \wedge notin(w, y))

definition predicate setminus_predicate(predicate \phi[1], predicate \chi[1], predicate \rho[1]) as \forall x (\rho(x) \leftrightarrow \phi(x) \wedge \neg(\chi(x)))

theorem setminus_is_subset \forall^P \phi[1] \forall^P \chi[1] \forall^P \rho[1] (setminus_predicate(\phi, \chi, \rho) \to subset_predicate(\rho, \phi)) {
  any predicate \phi[1], predicate \chi[1], predicate \rho[1] {
    assume setminus_predicate(\phi, \chi, \rho) {
      any x {
        assume \rho(x) {
          apply invoke rightward setminus_predicate(\phi, \chi, \rho) for x
          split 1 \phi(x) \wedge \neg(\chi(x))
        }
      }
      fold for subset_predicate conclude subset_predicate(\rho, \phi)
    }
  }
}

definition predicate trans(x) as \forall y \forall z (in(z, y) \wedge in(y, x) \to in(z, x))

definition predicate trans_predicate(predicate \phi[1]) as \forall x \forall y (in(y, x) \wedge \phi(x) \to \phi(y))

theorem trans_lambda \forall X (trans(X) \leftrightarrow trans_predicate(\lambda^P x. in(x, X))) {
  any X {
    assume trans(X) {
      expand trans(X) for trans
      fold for trans_predicate conclude trans_predicate(\lambda^P x. in(x, X))
    }
    assume trans_predicate(\lambda^P x. in(x, X)) {
      expand trans_predicate(\lambda^P x. in(x, X)) for trans_predicate
      fold for trans conclude trans(X)
    }
    connect trans(X) \leftrightarrow trans_predicate(\lambda^P x. in(x, X))
  }
}

theorem trans_cor1 \forall x (trans(x) \leftrightarrow \forall y (in(y, x) \to subset(y, x))) {
  any x {
    assume trans(x) {
      any y {
        assume in(y, x) {
          any z {
            assume in(z, y) {
              connect in(z, y) \wedge in(y, x)
              apply invoke trans(x) for y, z
            }
          }
          fold for subset conclude subset(y, x)
        }
      }
    }
    assume \forall y (in(y, x) \to subset(y, x)) {
      any y, z {
        assume in(z, y) \wedge in(y, x) {
          split in(z, y) \wedge in(y, x)
          apply invoke \forall y (in(y, x) \to subset(y, x)) for y
          apply invoke subset(y, x) for z
        }
      }
      fold for trans conclude trans(x)
    }
    connect trans(x) \leftrightarrow \forall y (in(y, x) \to subset(y, x))
  }
}

theorem cap_of_trans_is_trans_predicate \forall^P \phi[1] \forall^P \chi[1] \forall^P \rho[1] (trans_predicate(\phi) \wedge trans_predicate(\chi) \wedge cap_predicate(\phi, \chi, \rho) \to trans_predicate(\rho)) {
  any predicate \phi[1], predicate \chi[1], predicate \rho[1] {
    assume trans_predicate(\phi) \wedge trans_predicate(\chi) \wedge cap_predicate(\phi, \chi, \rho) {
      split trans_predicate(\phi) \wedge trans_predicate(\chi) \wedge cap_predicate(\phi, \chi, \rho)
      any x, y {
        assume in(y, x) \wedge \rho(x) {
          split in(y, x) \wedge \rho(x)
          apply invoke rightward cap_predicate(\phi, \chi, \rho) for x
          split \phi(x) \wedge \chi(x)
          connect in(y, x) \wedge \phi(x)
          apply invoke trans_predicate(\phi) for x, y
          connect in(y, x) \wedge \chi(x)
          apply invoke trans_predicate(\chi) for x, y
          connect \phi(y) \wedge \chi(y)
          apply invoke leftward cap_predicate(\phi, \chi, \rho) for y
        }
      }
      fold for trans_predicate conclude trans_predicate(\rho)
    }
  }
}

theorem cap_of_trans_is_trans \forall X \forall Y \forall Z (trans(X) \wedge trans(Y) \wedge cap(X, Y, Z) \to trans(Z)) {
  any X, Y, Z {
    assume trans(X) \wedge trans(Y) \wedge cap(X, Y, Z) {
      split trans(X) \wedge trans(Y) \wedge cap(X, Y, Z)
      apply invoke rightward trans_lambda for X
      apply invoke rightward trans_lambda for Y
      apply invoke rightward cap_lambda for X, Y, Z
      connect trans_predicate(\lambda^P x. in(x, X)) \wedge trans_predicate(\lambda^P y. in(y, Y)) \wedge cap_predicate(\lambda^P x. in(x, X), \lambda^P y. in(y, Y), \lambda^P z. in(z, Z))
      apply invoke cap_of_trans_is_trans_predicate for \lambda^P x. in(x, X), \lambda^P y. in(y, Y), \lambda^P z. in(z, Z)
      apply invoke leftward trans_lambda for Z
    }
  }
}

definition predicate ordinal(x) as trans(x) \wedge irrefrelon(x, in) \wedge wellorder(x, in)

definition predicate ordinal_predicate(predicate \phi[1]) as trans_predicate(\phi) \wedge irrefrelon_predicate(\phi, in) \wedge wellorder_predicate(\phi, in)

theorem element_of_ordinal_is_trans \forall \alpha (ordinal(\alpha) \to \forall \beta (in(\beta, \alpha) \to trans(\beta))) {
  any \alpha {
    assume ordinal(\alpha) {
      any \beta {
        assume in(\beta, \alpha) {
          any \gamma, \delta {
            assume in(\delta, \gamma) \wedge in(\gamma, \beta) {
              split in(\delta, \gamma) \wedge in(\gamma, \beta)
              split ordinal(\alpha)
              connect in(\gamma, \beta) \wedge in(\beta, \alpha)
              apply invoke trans(\alpha) for \beta, \gamma
              connect in(\delta, \gamma) \wedge in(\gamma, \alpha)
              apply invoke trans(\alpha) for \gamma, \delta
              connect in(\delta, \alpha) \wedge in(\gamma, \alpha) \wedge in(\beta, \alpha) \wedge in(\delta, \gamma)\wedge in(\gamma, \beta)
              split 1 wellorder(\alpha, in)
              split 1 orderon(\alpha, in)
              apply invoke transrelon(\alpha, in) for \delta, \gamma, \beta
            }
          }
          fold for trans conclude trans(\beta)
        }
      }
    }
  }
}

theorem element_of_ordinal_is_ordinal \forall \alpha (ordinal(\alpha) \to \forall \beta (in(\beta, \alpha) \to ordinal(\beta))) {
  any \alpha {
    assume ordinal(\alpha) {
      any \beta {
        assume in(\beta, \alpha) {
          apply invoke element_of_ordinal_is_trans for \alpha
          apply invoke \forall \beta (in(\beta, \alpha) \to trans(\beta)) for \beta
          split ordinal(\alpha)
          apply invoke rightward trans_cor1 for \alpha
          apply invoke \forall \beta (in(\beta, \alpha) \to subset(\beta, \alpha)) for \beta
          connect irrefrelon(\alpha, in)\wedge subset(\beta, \alpha)
          apply invoke irrefrelon_subset for \alpha, in, \beta
          connect wellorder(\alpha, in)\wedge subset(\beta, \alpha)
          apply invoke wellorder_subset for \alpha, in, \beta
          connect trans(\beta) \wedge irrefrelon(\beta, in) \wedge wellorder(\beta, in)
          fold for ordinal conclude ordinal(\beta)
        }
      }
    }
  }
}

theorem ordinal_not_contain_itself \forall\alpha(ordinal(\alpha)\to notin(\alpha,\alpha)) {
  any \alpha {
    assume ordinal(\alpha) {
      split 2 ordinal(\alpha)
      apply irrefrelon(\alpha,in) for \alpha
      deny in(\alpha,\alpha) {
        invoke in(\alpha,\alpha)\to notin(\alpha,\alpha)
        contradict in(\alpha,\alpha)
      }
    }
  }
}

theorem ordianl_trans \forall\alpha\forall\beta\forall\gamma(ordinal(\alpha)\wedge in(\gamma,\beta)\wedge in(\beta,\alpha)\to in(\gamma,\alpha)) {
  any \alpha,\beta,\gamma {
    assume ordinal(\alpha)\wedge in(\gamma,\beta)\wedge in(\beta,\alpha) {
      split ordinal(\alpha)\wedge in(\gamma,\beta)\wedge in(\beta,\alpha)
      split 1 ordinal(\alpha)
      connect in(\gamma,\beta)\wedge in(\beta,\alpha)
      apply invoke trans(\alpha) for \beta,\gamma
    }
  }
}

theorem ordinal_subsetneq_of_ordinal_is_element \forall\alpha(ordinal(\alpha)\to\forall\beta(subsetneq(\beta,\alpha)\wedge ordinal(\beta)\to in(\beta,\alpha))) {
  any \alpha {
    assume ordinal(\alpha) {
      any \beta {
        assume subsetneq(\beta,\alpha)\wedge ordinal(\beta) {
          split subsetneq(\beta,\alpha)\wedge ordinal(\beta)
          apply invoke subsetneq_implies_exist for \beta,\alpha
          split ordinal(\alpha)
          split wellorder(\alpha,in)
          apply invoke wellorder_core(\alpha,in) for \lambda^P\gamma.notin(\gamma,\beta)
          some \gamma such \exists a(minimum(\alpha,in,\lambda^P\gamma.notin(\gamma,\beta),a)) {
            split minimum(\alpha,in,\lambda^P\gamma.notin(\gamma,\beta),\gamma)
            any \delta {
              assume in(\delta,\gamma) {
                deny notin(\delta,\beta) {
                  connect in(\delta,\gamma)\wedge in(\gamma,\alpha)
                  apply invoke trans(\alpha) for \gamma,\delta
                  connect in(\delta,\alpha)\wedge notin(\delta,\beta)
                  connect in(\delta,\gamma)\wedge in(\delta,\alpha)\wedge in(\gamma,\alpha)
                  show neq(\delta,\gamma) {
                    deny equal(\delta,\gamma) {
                      substitute in(\delta,\gamma) for \delta:\gamma
                      apply invoke irrefrelon(\alpha,in) for \gamma
                      contradict in(\gamma,\gamma)
                    }
                  }
                  connect in(\delta,\alpha)\wedge notin(\delta,\beta)\wedge neq(\delta,\gamma)
                  apply invoke minimum_core(\alpha,in,\lambda^P\gamma.notin(\gamma,\beta),\gamma) for \delta
                  split 2 orderon(\alpha,in)
                  connect in(\delta,\alpha)\wedge in(\gamma,\alpha)\wedge in(\delta,\gamma)\wedge in(\gamma,\delta)
                  apply invoke antisymrelon(\alpha,in) for \delta,\gamma
                  contradict equal(\delta,\gamma)
                }
              }
              assume in(\delta,\beta) {
                split 1 subsetneq(\beta,\alpha)
                connect in(\delta,\beta)\wedge subset(\beta,\alpha)
                apply invoke subset(\beta,\alpha) for \delta
                connect in(\delta,\alpha)\wedge in(\gamma,\alpha)
                apply invoke wellorder_implies_linorder for \alpha,in
                split 2 linorder(\alpha,in)
                apply invoke linorder_core(\alpha,in) for \delta,\gamma
                divide in(\delta,\gamma)\vee equal(\delta,\gamma)\vee in(\gamma,\delta)
                  case in(\delta,\gamma) {}
                  case equal(\delta,\gamma) {
                    substitute in(\delta,\beta) for \delta:\gamma
                    contradict in(\gamma,\beta)
                    explode in(\delta,\gamma)
                  }
                  case in(\gamma,\delta) {
                    connect in(\gamma,\delta)\wedge in(\delta,\beta)
                    split 1 ordinal(\beta)
                    apply invoke trans(\beta) for \delta,\gamma
                    contradict in(\gamma,\beta)
                    explode in(\delta,\gamma)
                  }
              }
              connect in(\delta,\gamma)\leftrightarrow in(\delta,\beta)
            }
            apply invoke axiom_of_extensionality for \gamma, \beta
            substitute in(\gamma,\alpha) for \gamma:\beta
          }
        }
      }
    }
  }
}

theorem ordinal_in_iff_subsetneq \forall\alpha\forall\beta(ordinal(\alpha)\wedge ordinal(\beta)\to(in(\alpha,\beta)\leftrightarrow subsetneq(\alpha,\beta))) {
  any \alpha,\beta {
    assume ordinal(\alpha)\wedge ordinal(\beta) {
      split ordinal(\alpha)\wedge ordinal(\beta)
      assume in(\alpha,\beta) {
        split 1 ordinal(\beta)
        apply invoke rightward trans_cor1 for \beta
        apply invoke \forall y(in(y,\beta)\to subset(y,\beta)) for \alpha
        deny equal(\alpha,\beta) {
          substitute in(\alpha,\beta) for \beta:\alpha
          apply invoke ordinal_not_contain_itself for \alpha
          contradict in(\alpha,\alpha)
        }
        connect subset(\alpha,\beta)\wedge neq(\alpha,\beta)
        fold for subsetneq conclude subsetneq(\alpha,\beta)
      }
      assume subsetneq(\alpha,\beta) {
        apply invoke ordinal_subsetneq_of_ordinal_is_element for \beta
        connect ordinal(\alpha)\wedge subsetneq(\alpha,\beta)
        apply invoke \forall\alpha(ordinal(\alpha)\wedge subsetneq(\alpha,\beta)\to in(\alpha,\beta)) for \alpha
      }
      connect in(\alpha,\beta)\leftrightarrow subsetneq(\alpha,\beta)
    }
  }
}

theorem cap_of_ordinals_is_ordinal \forall\alpha\forall\beta\forall\gamma(ordinal(\alpha)\wedge ordinal(\beta)\wedge cap(\alpha,\beta,\gamma)\to ordinal(\gamma)) {
  any \alpha,\beta,\gamma {
    assume ordinal(\alpha)\wedge ordinal(\beta)\wedge cap(\alpha,\beta,\gamma) {
      split ordinal(\alpha)\wedge ordinal(\beta)\wedge cap(\alpha,\beta,\gamma)
      split ordinal(\alpha)
      split ordinal(\beta)
      connect trans(\alpha)\wedge trans(\beta)\wedge cap(\alpha,\beta,\gamma)
      apply invoke cap_of_trans_is_trans for \alpha,\beta,\gamma
      apply invoke cap_is_subset_left for \alpha,\beta,\gamma
      connect irrefrelon(\alpha,in)\wedge subset(\gamma,\alpha)
      apply invoke irrefrelon_subset for \alpha,in,\gamma
      connect wellorder(\alpha,in)\wedge subset(\gamma,\alpha)
      apply invoke wellorder_subset for \alpha,in,\gamma
      connect trans(\gamma)\wedge irrefrelon(\gamma,in)\wedge wellorder(\gamma,in)
      fold for ordinal conclude ordinal(\gamma)
    }
  }
}

theorem ordinals_comparable_subset \forall\alpha\forall\beta(ordinal(\alpha)\wedge ordinal(\beta)\to subset(\alpha,\beta)\vee subset(\beta,\alpha)) {
  any \alpha,\beta {
    assume ordinal(\alpha)\wedge ordinal(\beta) {
      split ordinal(\alpha)\wedge ordinal(\beta)
      split ordinal(\alpha)
      split wellorder(\alpha,in)
      split orderon(\alpha,in)
      split ordinal(\beta)
      split wellorder(\beta,in)
      split orderon(\beta,in)
      deny \neg(subset(\alpha,\beta)\vee subset(\beta,\alpha)) {
        apply invoke rightward neg_or for \lambda^P.subset(\alpha,\beta),\lambda^P.subset(\beta,\alpha)
        split \neg(subset(\alpha,\beta))\wedge\neg(subset(\beta,\alpha))
        apply invoke rightward neg_subset for \alpha,\beta
        apply invoke wellorder_core(\alpha,in) for \lambda^P z.notin(z,\beta)
        apply invoke rightward neg_subset for \beta,\alpha
        apply invoke wellorder_core(\beta,in) for \lambda^P z.notin(z,\alpha)
        some \gamma such \exists\gamma(minimum(\alpha,in,\lambda^P z.notin(z,\beta),\gamma)) {
          some \delta such \exists\delta(minimum(\beta,in,\lambda^P z.notin(z,\alpha),\delta)) {
            split minimum(\alpha,in,\lambda^P z.notin(z,\beta),\gamma)
            split minimum(\beta,in,\lambda^P z.notin(z,\alpha),\delta)
            deny \neg(subset(\gamma,\delta)) {
              apply invoke rightward neg_subset for \gamma,\delta
              some \varepsilon such \exists\varepsilon(in(\varepsilon,\gamma)\wedge notin(\varepsilon,\delta)) {
                split in(\varepsilon,\gamma)\wedge notin(\varepsilon,\delta)
                connect in(\varepsilon,\gamma)\wedge in(\gamma,\alpha)
                apply invoke trans(\alpha) for \gamma,\varepsilon
                deny equal(\varepsilon,\gamma) {
                  substitute in(\varepsilon,\gamma) for \varepsilon:\gamma
                  apply invoke irrefrelon(\alpha,in) for \gamma
                  contradict in(\gamma,\gamma)
                }
                apply irrefrelon(\alpha,in) for \varepsilon
                connect antisymrelon(\alpha,in)\wedge minimum(\alpha,in,\lambda^P z.notin(z,\beta),\gamma)
                apply invoke minimum_implies_minimal for \alpha,in,\lambda^P z.notin(z,\beta),\gamma
                split minimal(\alpha,in,\lambda^P z.notin(z,\beta),\gamma)
                deny notin(\varepsilon,\beta) {
                  connect in(\varepsilon,\alpha)\wedge notin(\varepsilon,\beta)\wedge neq(\varepsilon,\gamma)
                  apply invoke minimal_core(\alpha,in,\lambda^P z.notin(z,\beta),\gamma) for \varepsilon
                  contradict in(\varepsilon,\gamma)
                }
                apply invoke wellorder_implies_linorder for \beta,in
                split linorder(\beta,in)
                connect in(\varepsilon,\beta)\wedge in(\delta,\beta)
                apply invoke linorder_core(\beta,in) for \varepsilon,\delta
                divide in(\varepsilon,\delta)\vee equal(\varepsilon,\delta)\vee in(\delta,\varepsilon)
                  case in(\varepsilon,\delta) {
                    contradict in(\varepsilon,\delta)
                  }
                  case equal(\varepsilon,\delta) {
                    substitute in(\varepsilon,\alpha) for \varepsilon:\delta
                    contradict in(\delta,\alpha)
                  }
                  case in(\delta,\varepsilon) {
                    connect in(\delta,\varepsilon)\wedge in(\varepsilon,\alpha)
                    apply invoke trans(\alpha) for \varepsilon,\delta
                    contradict in(\delta,\alpha)
                  }
              }
            }
            deny \neg(subset(\delta,\gamma)) {
              apply invoke rightward neg_subset for \delta,\gamma
              some \varepsilon such \exists\varepsilon(in(\varepsilon,\delta)\wedge notin(\varepsilon,\gamma)) {
                split in(\varepsilon,\delta)\wedge notin(\varepsilon,\gamma)
                connect in(\varepsilon,\delta)\wedge in(\delta,\beta)
                apply invoke trans(\beta) for \delta,\varepsilon
                deny equal(\varepsilon,\delta) {
                  substitute in(\varepsilon,\delta) for \varepsilon:\delta
                  apply invoke irrefrelon(\beta,in) for \delta
                  contradict in(\delta,\delta)
                }
                apply irrefrelon(\beta,in) for \varepsilon
                connect antisymrelon(\beta,in)\wedge minimum(\beta,in,\lambda^P z.notin(z,\alpha),\delta)
                apply invoke minimum_implies_minimal for \beta,in,\lambda^P z.notin(z,\alpha),\delta
                split minimal(\beta,in,\lambda^P z.notin(z,\alpha),\delta)
                deny notin(\varepsilon,\alpha) {
                  connect in(\varepsilon,\beta)\wedge notin(\varepsilon,\alpha)\wedge neq(\varepsilon,\delta)
                  apply invoke minimal_core(\beta,in,\lambda^P z.notin(z,\alpha),\delta) for \varepsilon
                  contradict in(\varepsilon,\delta)
                }
                apply invoke wellorder_implies_linorder for \alpha,in
                split linorder(\alpha,in)
                connect in(\varepsilon,\alpha)\wedge in(\gamma,\alpha)
                apply invoke linorder_core(\alpha,in) for \varepsilon,\gamma
                divide in(\varepsilon,\gamma)\vee equal(\varepsilon,\gamma)\vee in(\gamma,\varepsilon)
                  case in(\varepsilon,\gamma) {
                    contradict in(\varepsilon,\gamma)
                  }
                  case equal(\varepsilon,\gamma) {
                    substitute in(\varepsilon,\beta) for \varepsilon:\gamma
                    contradict in(\gamma,\beta)
                  }
                  case in(\gamma,\varepsilon) {
                    connect in(\gamma,\varepsilon)\wedge in(\varepsilon,\beta)
                    apply invoke trans(\beta) for \varepsilon,\gamma
                    contradict in(\gamma,\beta)
                  }
              }
            }
            connect subset(\gamma,\delta)\wedge subset(\delta,\gamma)
            apply invoke rightward subset_antisymmetry for \gamma,\delta
            substitute in(\gamma,\alpha) for \gamma:\delta
            contradict in(\delta,\alpha)
          }
        }
      }
    }
  }
}

theorem ordinals_trichotomy_subset \forall\alpha\forall\beta(ordinal(\alpha)\wedge ordinal(\beta)\to subsetneq(\alpha,\beta)\vee equal(\alpha,\beta)\vee subsetneq(\beta,\alpha)) {
  any \alpha,\beta {
    assume ordinal(\alpha)\wedge ordinal(\beta) {
      apply invoke ordinals_comparable_subset for \alpha,\beta
      divide subset(\alpha,\beta)\vee subset(\beta,\alpha)
        case subset(\alpha,\beta) {
          apply invoke rightward subset_subsetneq for \alpha,\beta
          pad subsetneq(\alpha,\beta)\vee equal(\alpha,\beta) conclude subsetneq(\alpha,\beta)\vee equal(\alpha,\beta)\vee subsetneq(\beta,\alpha)
        }
        case subset(\beta,\alpha) {
          apply invoke rightward subset_subsetneq for \beta,\alpha
          pad subsetneq(\beta,\alpha)\vee equal(\alpha,\beta) conclude subsetneq(\alpha,\beta)\vee equal(\alpha,\beta)\vee subsetneq(\beta,\alpha)
        }
    }
  }
}

theorem ordinals_trichotomy_in \forall\alpha\forall\beta(ordinal(\alpha)\wedge ordinal(\beta)\to in(\alpha,\beta)\vee equal(\alpha,\beta)\vee in(\beta,\alpha)) {
  any \alpha,\beta {
    assume ordinal(\alpha)\wedge ordinal(\beta) {
      apply invoke ordinals_trichotomy_subset for \alpha,\beta
      divide subsetneq(\alpha,\beta)\vee equal(\alpha,\beta)\vee subsetneq(\beta,\alpha)
        case subsetneq(\alpha,\beta) {
          apply invoke ordinal_in_iff_subsetneq for \alpha,\beta
          invoke leftward in(\alpha,\beta)\leftrightarrow subsetneq(\alpha,\beta)
          pad in(\alpha,\beta) conclude in(\alpha,\beta)\vee equal(\alpha,\beta)\vee in(\beta,\alpha)
        }
        case equal(\alpha,\beta) {
          pad equal(\alpha,\beta) conclude in(\alpha,\beta)\vee equal(\alpha,\beta)\vee in(\beta,\alpha)
        }
        case subsetneq(\beta,\alpha) {
          apply invoke ordinal_in_iff_subsetneq for \beta,\alpha
          invoke leftward in(\beta,\alpha)\leftrightarrow subsetneq(\beta,\alpha)
          pad in(\beta,\alpha) conclude in(\alpha,\beta)\vee equal(\alpha,\beta)\vee in(\beta,\alpha)
        }
    }
  }
}

theorem ordinal_is_trans trans_predicate(ordinal) {
  any x, y {
    assume in(y, x) \wedge ordinal(x) {
      split in(y, x) \wedge ordinal(x)
      apply invoke element_of_ordinal_is_ordinal for x
      apply invoke \forall y (in(y, x) \to ordinal(y)) for y
    }
  }
  fold for trans_predicate conclude trans_predicate(ordinal)
}

theorem ordinal_is_irrefrelon irrefrelon_predicate(ordinal, in) {
  any \alpha {
    assume ordinal(\alpha) {
      apply invoke ordinal_not_contain_itself for \alpha
    }
  }
  fold for irrefrelon_predicate conclude irrefrelon_predicate(ordinal, in)
}

theorem ordinal_is_transrelon transrelon_predicate(ordinal, in) {
  any \alpha, \beta, \gamma {
    assume ordinal(\alpha) \wedge ordinal(\beta) \wedge ordinal(\gamma) \wedge in(\alpha, \beta) \wedge in(\beta, \gamma) {
      split ordinal(\alpha) \wedge ordinal(\beta) \wedge ordinal(\gamma) \wedge in(\alpha, \beta) \wedge in(\beta, \gamma)
      split ordinal(\gamma)
      connect in(\alpha, \beta) \wedge in(\beta, \gamma)
      apply invoke trans(\gamma) for \beta, \alpha
    }
  }
  fold for transrelon_predicate conclude transrelon_predicate(ordinal, in)
}

theorem ordinal_is_orderon orderon_predicate(ordinal, in) {
  assert ordinal_is_irrefrelon
  assert ordinal_is_transrelon
  connect irrefrelon_predicate(ordinal, in) \wedge transrelon_predicate(ordinal, in)
  apply invoke irrefrelon_and_transrelon_implies_orderon_predicate for ordinal, in
}

theorem ordinal_is_linorder linorder_predicate(ordinal, in) {
  assert ordinal_is_orderon
  any \alpha, \beta {
    assume ordinal(\alpha) \wedge ordinal(\beta) {
      apply invoke ordinals_trichotomy_in for \alpha, \beta
    }
  }
  fold for linorder_core_predicate conclude linorder_core_predicate(ordinal, in)
  connect linorder_predicate(ordinal, in)
}

theorem ordinal_is_wellfounded wellfounded_predicate(ordinal, in) {
  any predicate \phi[1] {
    assume \exists \alpha (ordinal(\alpha) \wedge \phi(\alpha)) {
      some \alpha such \exists \alpha (ordinal(\alpha) \wedge \phi(\alpha)) {
        split ordinal(\alpha) \wedge \phi(\alpha)
        split ordinal(\alpha)
        apply invoke wellorder_implies_wellfounded for \alpha, in
        apply law_of_excluded_middle for \lambda^P. \exists \beta (in(\beta, \alpha) \wedge \phi(\beta))
        divide \exists \beta (in(\beta, \alpha) \wedge \phi(\beta)) \vee \neg(\exists \beta (in(\beta, \alpha) \wedge \phi(\beta)))
          case \exists \beta (in(\beta, \alpha) \wedge \phi(\beta)) {
            apply invoke wellfounded(\alpha, in) for \phi
            some \beta such \exists \beta (minimal(\alpha, in, \phi, \beta)) {
              split minimal(\alpha, in, \phi, \beta)
              apply invoke element_of_ordinal_is_ordinal for \alpha
              apply invoke \forall \beta (in(\beta, \alpha) \to ordinal(\beta)) for \beta
              deny \exists \gamma (in(\gamma, \beta) \wedge \phi(\gamma)) {
                some \gamma such \exists \gamma (in(\gamma, \beta) \wedge \phi(\gamma)) {
                  split in(\gamma, \beta) \wedge \phi(\gamma)
                  connect in(\gamma, \beta) \wedge in(\beta, \alpha)
                  apply invoke trans(\alpha) for \beta, \gamma
                  deny equal(\gamma, \beta) {
                    substitute in(\gamma, \beta) for \gamma: \beta
                    apply invoke irrefrelon(\alpha, in) for \beta
                    contradict in(\beta, \beta)
                  }
                  connect in(\gamma, \alpha) \wedge \phi(\gamma) \wedge neq(\gamma, \beta)
                  apply invoke minimal_core(\alpha, in, \phi, \beta) for \gamma
                  contradict in(\gamma, \beta)
                }
              }
              apply invoke rightward neg_exist_leftrightarrow_forall_neg for \lambda^P \gamma. (in(\gamma, \beta) \wedge \phi(\gamma))
              any \gamma {
                assume ordinal(\gamma) \wedge \phi(\gamma) \wedge neq(\gamma, \beta) {
                  split ordinal(\gamma) \wedge \phi(\gamma) \wedge neq(\gamma, \beta)
                  deny in(\gamma, \beta) {
                    connect in(\gamma, \beta) \wedge \phi(\gamma)
                    apply \forall \gamma (\neg(in(\gamma, \beta) \wedge \phi(\gamma))) for \gamma
                    contradict in(\gamma, \beta) \wedge \phi(\gamma)
                  }
                }
              }
              fold for minimal_core_predicate conclude minimal_core_predicate(ordinal, in, \phi, \beta)
              connect minimal_predicate(ordinal, in, \phi, \beta)
              lift for \beta conclude \exists \beta (minimal_predicate(ordinal, in, \phi, \beta))
            }
          }
          case \neg(\exists \beta (in(\beta, \alpha) \wedge \phi(\beta))) {
            apply invoke rightward neg_exist_leftrightarrow_forall_neg for \lambda^P \beta. (in(\beta, \alpha) \wedge \phi(\beta))
            any \beta {
              assume ordinal(\beta) \wedge \phi(\beta) \wedge neq(\beta, \alpha) {
                split ordinal(\beta) \wedge \phi(\beta) \wedge neq(\beta, \alpha)
                deny in(\beta, \alpha) {
                  connect in(\beta, \alpha) \wedge \phi(\beta)
                  apply \forall \beta (\neg(in(\beta, \alpha) \wedge \phi(\beta))) for \beta
                  contradict in(\beta, \alpha) \wedge \phi(\beta)
                }
              }
            }
            fold for minimal_core_predicate conclude minimal_core_predicate(ordinal, in, \phi, \alpha)
            connect minimal_predicate(ordinal, in, \phi, \alpha)
            lift for \alpha conclude \exists \alpha (minimal_predicate(ordinal, in, \phi, \alpha))
          }
      }
    }
  }
  fold for wellfounded_predicate conclude wellfounded_predicate(ordinal, in)
}

theorem ordinal_is_wellorder wellorder_predicate(ordinal, in) {
  assert ordinal_is_linorder
  assert ordinal_is_wellfounded
  connect linorder_predicate(ordinal, in) \wedge wellfounded_predicate(ordinal, in)
  apply invoke leftward wellorder_equivalent_linorder_and_wellfounded for ordinal, in
}

theorem ordinal_is_ordinal ordinal_predicate(ordinal) {
  assert ordinal_is_trans
  assert ordinal_is_irrefrelon
  assert ordinal_is_wellorder
  connect trans_predicate(ordinal) \wedge irrefrelon_predicate(ordinal, in) \wedge wellorder_predicate(ordinal, in)
  fold for ordinal_predicate conclude ordinal_predicate(ordinal)
}
