include "zfc_finite_size.proof"

theorem cup_is_unique \forall X \forall Y \forall Z \forall Z' (\forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)) \wedge \forall z (in(z, Z') \leftrightarrow in(z, X) \vee in(z, Y)) \to equal(Z, Z')) {
  any X, Y, Z, Z' {
    assume \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)) \wedge \forall z (in(z, Z') \leftrightarrow in(z, X) \vee in(z, Y)) {
      apply invoke set_is_unique_for_each_predicate for \lambda^P z. in(z, X) \vee in(z, Y), Z, Z'
    }
  }  
}

theorem finite_cup_exists_uniquely \forall X \forall Y (finite(X) \wedge finite(Y) \to \exists! Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)))) {
  any X, Y {
    assume finite(X) \wedge size(Y, emptyset) {
      split finite(X) \wedge size(Y, emptyset)
      apply invoke size_emptyset_implies_set_emptyset for Y
      any z {
        assume in(z, X) {
          pad in(z, X) conclude in(z, X) \vee in(z, Y)
        }
        assume in(z, X) \vee in(z, Y) {
          divide in(z, X) \vee in(z, Y)
            case in(z, X) {}
            case in(z, Y) {
              substitute in(z, Y) for Y: emptyset
              apply emptyset_existence for z
              contradict in(z, emptyset)
              explode in(z, X)
            }
        }
        connect in(z, X) \leftrightarrow in(z, X) \vee in(z, Y)
      }
      connect finite(X) \wedge \forall z (in(z, X) \leftrightarrow in(z, X) \vee in(z, Y))
      lift for X conclude \exists Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)))
    }
  }
  any n {
    assume \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)))) {
      any X, Y {
        assume finite(X) \wedge size(Y, suc(n)) {
          split finite(X) \wedge size(Y, suc(n))
          apply invoke size_suc_decomposition for Y, n
          some Y', y such \exists Y' \exists y (size(Y', n) \wedge notin(y, Y') \wedge equal(Y, adj(Y', y))) {
            split size(Y', n) \wedge notin(y, Y') \wedge equal(Y, adj(Y', y))
            connect finite(X) \wedge size(Y', n)
            apply invoke \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)))) for X, Y'
            some Z such \exists Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y'))) {
              split finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y'))
              apply invoke finite_adj for Z, y
              any z {
                assume in(z, adj(Z, y)) {
                  apply invoke rightward adj_existence for Z, y, z
                  divide in(z, Z) \vee equal(z, y)
                    case in(z, Z) {
                      apply invoke rightward \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y')) for z
                      divide in(z, X) \vee in(z, Y')
                        case in(z, X) {
                          pad in(z, X) conclude in(z, X) \vee in(z, Y)
                        }
                        case in(z, Y') {
                          apply invoke adj_cor1 for Y', y, z
                          substitute in(z, adj(Y', y)) for adj(Y', y): Y
                          pad in(z, Y) conclude in(z, X) \vee in(z, Y)
                        }
                    }
                    case equal(z, y) {
                      apply adj_cor3 for Y', y
                      substitute in(y, adj(Y', y)) for y[1]: z, adj(Y', y): Y
                      pad in(z, Y) conclude in(z, X) \vee in(z, Y)
                    }
                }
                assume in(z, X) \vee in(z, Y) {
                  divide in(z, X) \vee in(z, Y)
                    case in(z, X) {
                      pad in(z, X) conclude in(z, X) \vee in(z, Y')
                      apply invoke leftward \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y')) for z
                      apply invoke adj_cor1 for Z, y, z
                    }
                    case in(z, Y) {
                      substitute in(z, Y) for Y: adj(Y', y)
                      apply invoke rightward adj_existence for Y', y, z
                      divide in(z, Y') \vee equal(z, y)
                        case in(z, Y') {
                          pad in(z, Y') conclude in(z, X) \vee in(z, Y')
                          apply invoke leftward \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y')) for z
                          apply invoke adj_cor1 for Z, y, z
                        }
                        case equal(z, y) {
                          apply adj_cor3 for Z, y
                          substitute in(y, adj(Z, y)) for y[1]: z
                        }
                    }
                }
                connect in(z, adj(Z, y)) \leftrightarrow in(z, X) \vee in(z, Y)
              }
              connect finite(adj(Z, y)) \wedge \forall z (in(z, adj(Z, y)) \leftrightarrow in(z, X) \vee in(z, Y))
              lift for adj(Z, y) conclude \exists Z' (finite(Z') \wedge \forall z (in(z, Z') \leftrightarrow in(z, X) \vee in(z, Y)))
            }
          }
        }
      }
    }
  }
  connect inductive(\lambda^P n. \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)))))
  apply invoke natural_induction for \lambda^P n. \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y))))
  any X, Y {
    assume finite(X) \wedge finite(Y) {
      split finite(X) \wedge finite(Y)
      some n such finite(Y) {
        split 1 size(Y, n)
        apply invoke subset(natural, \lambda^P n. \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y))))) for n
        connect finite(X) \wedge size(Y, n)
        apply invoke \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)))) for X, Y
        some Z such \exists Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y))) {
          split finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y))
          any Z' {
            assume finite(Z') \wedge \forall z (in(z, Z') \leftrightarrow in(z, X) \vee in(z, Y)) {
              split finite(Z') \wedge \forall z (in(z, Z') \leftrightarrow in(z, X) \vee in(z, Y))
              connect \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)) \wedge \forall z (in(z, Z') \leftrightarrow in(z, X) \vee in(z, Y))
              apply invoke cup_is_unique for X, Y, Z, Z'
            }
          }
          connect finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)) \wedge \forall Z' (finite(Z') \wedge \forall z (in(z, Z') \leftrightarrow in(z, X) \vee in(z, Y)) \to equal(Z', Z))
          characterize for Z conclude \exists! Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)))
        }
      }
    }
  }
}

definition function cup by finite_cup_exists_uniquely
existence cup_existence \forall X \forall Y (finite(X) \wedge finite(Y) \to (finite(cup(X, Y)) \wedge \forall z (in(z, cup(X, Y)) \leftrightarrow in(z, X) \vee in(z, Y)))) by cup
uniqueness cup_uniqueness \forall X \forall Y (finite(X) \wedge finite(Y) \to \forall Z (finite(Z) \wedge \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)) \to equal(Z, cup(X, Y)))) by cup

theorem bigcup_is_unique \forall X \forall Y \forall Y' (\forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))) \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(y, x) \wedge in(x, X))) \to equal(Y, Y')) {
  any X, Y, Y' {
    assume \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))) \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(y, x) \wedge in(x, X))) {
      apply invoke set_is_unique_for_each_predicate for \lambda^P y. \exists x (in(y, x) \wedge in(x, X)), Y, Y'
    }
  }
}

theorem finite_bigcup_exists_uniquely \forall X (finite(X) \wedge \forall x (in(x, X) \to finite(x)) \to \exists! Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))))) {
  any X {
    assume size(X, emptyset) \wedge \forall x (in(x, X) \to finite(x)) {
      split 1 size(X, emptyset) \wedge \forall x (in(x, X) \to finite(x))
      apply invoke size_emptyset_implies_set_emptyset for X
      assert emptyset_is_finite
      any y {
        assume in(y, emptyset) {
          apply emptyset_existence for y
          contradict in(y, emptyset)
          explode \exists x (in(y, x) \wedge in(x, X))
        }
        assume \exists x (in(y, x) \wedge in(x, X)) {
          some x such \exists x (in(y, x) \wedge in(x, X)) {
            split 2 in(y, x) \wedge in(x, X)
            substitute in(x, X) for X: emptyset
            apply emptyset_existence for x
            contradict in(x, emptyset)
            explode in(y, emptyset)
          }
        }
        connect in(y, emptyset) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))
      }
      connect finite(emptyset) \wedge \forall y (in(y, emptyset) \leftrightarrow \exists x (in(y, x) \wedge in(x, X)))
      lift for emptyset conclude \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))))
    }
  }
  any n {
    assume \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))))) {
      any X {
        assume size(X, suc(n)) \wedge \forall x (in(x, X) \to finite(x)) {
          split size(X, suc(n)) \wedge \forall x (in(x, X) \to finite(x))
          apply invoke size_suc_decomposition for X, n
          some X', x such \exists X' \exists x (size(X', n) \wedge notin(x, X') \wedge equal(X, adj(X', x))) {
            split size(X', n) \wedge notin(x, X') \wedge equal(X, adj(X', x))
            apply adj_cor3 for X', x
            substitute in(x, adj(X', x)) for adj(X', x): X
            apply invoke \forall x (in(x, X) \to finite(x)) for x
            any x' {
              assume in(x', X') {
                apply invoke adj_cor1 for X', x, x'
                substitute in(x', adj(X', x)) for adj(X', x): X
                apply invoke \forall x (in(x, X) \to finite(x)) for x'
              }
            }
            connect size(X', n) \wedge \forall x' (in(x', X') \to finite(x'))
            apply invoke \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))))) for X'
            some Y such \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X')))) {
              split finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X')))
              connect finite(Y) \wedge finite(x)
              apply invoke cup_existence for Y, x
              split finite(cup(Y, x)) \wedge \forall y (in(y, cup(Y, x)) \leftrightarrow in(y, Y) \vee in(y, x))
              any y {
                assume in(y, cup(Y, x)) {
                  apply invoke rightward \forall y (in(y, cup(Y, x)) \leftrightarrow in(y, Y) \vee in(y, x)) for y
                  divide in(y, Y) \vee in(y, x)
                    case in(y, Y) {
                      apply invoke rightward \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X'))) for y
                      some x' such \exists x (in(y, x) \wedge in(x, X')) {
                        split in(y, x') \wedge in(x', X')
                        apply invoke adj_cor1 for X', x, x'
                        substitute in(x', adj(X', x)) for adj(X', x): X
                        connect in(y, x') \wedge in(x', X)
                        lift for x' conclude \exists x (in(y, x) \wedge in(x, X))
                      }
                    }
                    case in(y, x) {
                      connect in(y, x) \wedge in(x, X)
                      lift for x conclude \exists x (in(y, x) \wedge in(x, X))
                    }
                }
                assume \exists x (in(y, x) \wedge in(x, X)) {
                  some x' such \exists x (in(y, x) \wedge in(x, X)) {
                    split in(y, x') \wedge in(x', X)
                    substitute in(x', X) for X: adj(X', x)
                    apply invoke rightward adj_existence for X', x, x'
                    divide in(x', X') \vee equal(x', x)
                      case in(x', X') {
                        connect in(y, x') \wedge in(x', X')
                        lift for x' conclude \exists x (in(y, x) \wedge in(x, X'))
                        apply invoke leftward \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X'))) for y
                        pad in(y, Y) conclude in(y, Y) \vee in(y, x)
                        apply invoke leftward \forall y (in(y, cup(Y, x)) \leftrightarrow in(y, Y) \vee in(y, x)) for y
                      }
                      case equal(x', x) {
                        substitute in(y, x') for x': x
                        pad in(y, x) conclude in(y, Y) \vee in(y, x)
                        apply invoke leftward \forall y (in(y, cup(Y, x)) \leftrightarrow in(y, Y) \vee in(y, x)) for y
                      }
                  }
                }
                connect in(y, cup(Y, x)) \leftrightarrow \exists x' (in(y, x') \wedge in(x', X))
              }
              connect finite(cup(Y, x)) \wedge \forall y (in(y, cup(Y, x)) \leftrightarrow \exists x' (in(y, x') \wedge in(x', X)))
              lift for cup(Y, x) conclude \exists Y' (finite(Y') \wedge \forall y (in(y, Y') \leftrightarrow \exists x' (in(y, x') \wedge in(x', X))))
            }
          }
        }
      }
    }
  }
  connect inductive(\lambda^P n. \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))))))
  apply invoke natural_induction for \lambda^P n. \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X)))))
  any X {
    assume finite(X) \wedge \forall x (in(x, X) \to finite(x)) {
      split finite(X) \wedge \forall x (in(x, X) \to finite(x))
      some n such finite(X) {
        split 1 size(X, n)
        apply invoke subset(natural, \lambda^P n. \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X)))))) for n
        connect size(X, n) \wedge \forall x (in(x, X) \to finite(x))
        apply invoke \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))))) for X
        some Y such \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X)))) {
          split finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X)))
          any Y' {
            assume finite(Y') \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(y, x) \wedge in(x, X))) {
              split 2 finite(Y') \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(y, x) \wedge in(x, X)))
              connect \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))) \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(y, x) \wedge in(x, X)))
              apply invoke bigcup_is_unique for X, Y, Y'
            }
          }
          connect finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))) \wedge \forall Y' (finite(Y') \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(y, x) \wedge in(x, X))) \to equal(Y', Y))
          characterize for Y conclude \exists! Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))))
        }
      }
    }
  }
}

definition function bigcup by finite_bigcup_exists_uniquely
