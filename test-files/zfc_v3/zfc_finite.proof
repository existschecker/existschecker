include "zfc_bigcup.proof"

definition predicate equipotent(X, Y) as \exists f (bij(f, X, Y))

definition predicate size(X, n) as natural(n) \wedge equipotent(n, X)

definition predicate finite(X) as \exists n (size(X, n))

theorem size_emptyset_implies_set_emptyset \forall X (size(X, emptyset) \to equal(X, emptyset)) {
  any X {
    assume size(X, emptyset) {
      split size(X, emptyset)
      some f such equipotent(emptyset, X) {
        split bij(f, emptyset, X)
        apply invoke surj_with_dom_emptyset_implies_ran_emptyset for f, X
      }
    }
  }
}

theorem emptyset_is_equipotent_to_emptyset equipotent(emptyset, emptyset) {
  assert emptyset_is_bij_from_emptyset_to_emptyset
  lift for emptyset conclude \exists f (bij(f, emptyset, emptyset))
  fold for equipotent conclude equipotent(emptyset, emptyset)
}

theorem size_of_emptyset_is_emptyset size(emptyset, emptyset) {
  assert emptyset_is_natural
  assert emptyset_is_equipotent_to_emptyset
  connect size(emptyset, emptyset)
}

theorem emptyset_is_finite finite(emptyset) {
  assert size_of_emptyset_is_emptyset
  lift for emptyset conclude \exists n (size(emptyset, n))
  fold for finite conclude finite(emptyset)
}

theorem size_suc_decomposition \forall X \forall n (size(X, suc(n)) \to \exists X' \exists x (size(X', n) \wedge notin(x, X') \wedge equal(X, adj(X', x)))) {
  any X, n {
    assume size(X, suc(n)) {
      split size(X, suc(n))
      apply in_suc for n
      connect in(n, suc(n)) \wedge natural(suc(n))
      apply invoke element_of_natural_is_natural for suc(n), n
      apply invoke natural_is_ordinal for n
      split ordinal(n)
      some f such equipotent(suc(n), X) {
        split bij(f, suc(n), X)
        split surj(f, suc(n), X)
        apply invoke rightward dom(f, suc(n)) for n
        some x such \exists x (in(op(n, x), f)) {
          connect bij(f, suc(n), X) \wedge in(op(n, x), f)
          apply invoke removing_op_bij for f, suc(n), X, n, x
          apply invoke irrefrel_not_contain_itself for n
          apply invoke rem_suc for n
          substitute bij(rem(f, op(n, x)), rem(suc(n), n), rem(X, x)) for rem(suc(n), n): n
          lift for rem(f, op(n, x)) conclude \exists f' (bij(f', n, rem(X, x)))
          fold for equipotent conclude equipotent(n, rem(X, x))
          connect size(rem(X, x), n)
          lift for n conclude \exists n (in(op(n, x), f))
          apply invoke leftward ran(f, X) for x
          apply invoke equal_adj_rem for X, x
          deny in(x, rem(X, x)) {
            apply invoke rightward rem_existence for X, x, x
            split 2 in(x, X) \wedge neq(x, x)
            contradict equal(x, x)
          }
          connect size(rem(X, x), n) \wedge notin(x, rem(X, x)) \wedge equal(X, adj(rem(X, x), x))
          lift for rem(X, x), x conclude \exists X' \exists x (size(X', n) \wedge notin(x, X') \wedge equal(X, adj(X', x)))
        }
      }
    }
  }
}

theorem finite_adj \forall Y \forall y (finite(Y) \to finite(adj(Y, y))) {
  any Y, y {
    assume finite(Y) {
      apply law_of_excluded_middle for \lambda^P. in(y, Y)
      divide in(y, Y) \vee notin(y, Y)
        case in(y, Y) {
          any z {
            assume in(z, adj(Y, y)) {
              apply invoke rightward adj_existence for Y, y, z
              divide in(z, Y) \vee equal(z, y)
                case in(z, Y) {}
                case equal(z, y) {
                  substitute in(y, Y) for y: z
                }
            }
            assume in(z, Y) {
              apply invoke adj_cor1 for Y, y, z
            }
            connect in(z, adj(Y, y)) \leftrightarrow in(z, Y)
          }
          apply invoke axiom_of_extensionality for adj(Y, y), Y
          substitute finite(Y) for Y: adj(Y, y)
        }
        case notin(y, Y) {
          some n such finite(Y) {
            split size(Y, n)
            apply invoke natural_is_ordinal for n
            split ordinal(n)
            some f such equipotent(n, Y) {
              split bij(f, n, Y)
              split surj(f, n, Y)
              deny \exists q (in(op(n, q), f)) {
                apply invoke leftward dom(f, n) for n
                apply invoke irrefrel_not_contain_itself for n
                contradict in(n, n)
              }
              deny \exists p (in(op(p, y), f)) {
                apply invoke leftward ran(f, Y) for y
                contradict in(y, Y)
              }
              connect bij(f, n, Y) \wedge \neg(\exists q (in(op(n, q), f))) \wedge \neg(\exists p (in(op(p, y), f)))
              apply invoke adding_op_bij for f, n, Y, n, y
              fold for suc conclude bij(adj(f, op(n, y)), suc(n), adj(Y, y))
              lift for adj(f, op(n, y)) conclude \exists f' (bij(f', suc(n), adj(Y, y)))
              fold for equipotent conclude equipotent(suc(n), adj(Y, y))
              apply invoke suc_of_natural_is_natural for n
              connect size(adj(Y, y), suc(n))
              lift for suc(n) conclude \exists n' (size(adj(Y, y), n'))
              fold for finite conclude finite(adj(Y, y))
            }
          }
        }
    }
  }
}

theorem subset_of_finite_is_finite \forall x \forall y (finite(x) \wedge subset(y, x) \to finite(y)) {
  any x {
    assume size(x, emptyset) {
      apply invoke size_emptyset_implies_set_emptyset for x
      any y {
        assume subset(y, x) {
          substitute subset(y, x) for x: emptyset
          apply invoke subset_of_emptyset_is_emptyset for y
          assert emptyset_is_finite
          substitute finite(emptyset) for emptyset: y
        }
      }
    }
  }
  any n {
    assume natural(n) {
      assume \forall x (size(x, n) \to \forall y (subset(y, x) \to finite(y))) {
        any x {
          assume size(x, suc(n)) {
            apply invoke size_suc_decomposition for x, n
            some x', z such \exists x' \exists z (size(x', n) \wedge notin(z, x') \wedge equal(x, adj(x', z))) {
              split size(x', n) \wedge notin(z, x') \wedge equal(x, adj(x', z))
              any y {
                assume subset(y, x) {
                  substitute subset(y, x) for x: adj(x', z)
                  apply law_of_excluded_middle for \lambda^P. in(z, y)
                  divide in(z, y) \vee notin(z, y)
                    case in(z, y) {
                      apply invoke \forall x (size(x, n) \to \forall y (subset(y, x) \to finite(y))) for x'
                      connect in(z, y) \wedge subset(y, adj(x', z))
                      apply invoke subset_adj_in for x', z, y
                      assert subset(rem(y, z), x')
                      apply invoke \forall y (subset(y, x') \to finite(y)) for rem(y, z)
                      apply invoke finite_adj for rem(y, z), z
                      apply invoke equal_adj_rem for y, z
                      substitute finite(adj(rem(y, z), z)) for adj(rem(y, z), z): y
                    }
                    case notin(z, y) {
                      connect notin(z, y) \wedge subset(y, adj(x', z))
                      apply invoke subset_adj_notin for x', z, y
                      assert subset(y, x')
                      apply invoke \forall x (size(x, n) \to \forall y (subset(y, x) \to finite(y))) for x'
                      apply invoke \forall y (subset(y, x') \to finite(y)) for y
                    }
                }
              }
            }
          }
        }
      }
    }
  }
  connect \forall x (size(x, emptyset) \to \forall y (subset(y, x) \to finite(y))) \wedge \forall n (natural(n) \to (\forall x (size(x, n) \to \forall y (subset(y, x) \to finite(y))) \to \forall x (size(x, suc(n) ) \to \forall y (subset(y, x) \to finite(y)))))
  apply invoke natural_induction for \lambda^P n. \forall x (size(x, n) \to \forall y (subset(y, x) \to finite(y)))
  any x, y {
    assume finite(x) \wedge subset(y, x) {
      split finite(x) \wedge subset(y, x)
      some n such finite(x) {
        split 1 size(x, n)
        apply invoke \forall n (natural(n) \to \forall x (size(x, n) \to \forall y (subset(y, x) \to finite(y)))) for n
        apply invoke \forall x (size(x, n) \to \forall y (subset(y, x) \to finite(y))) for x
        apply invoke \forall y (subset(y, x) \to finite(y)) for y
      }
    }
  }
}

theorem finite_cup_exists_uniquely \forall X \forall Y (finite(X) \wedge finite(Y) \to \exists! Z (finite(Z) \wedge cup(X, Y, Z))) {
  any X, Y {
    assume finite(X) \wedge size(Y, emptyset) {
      split finite(X) \wedge size(Y, emptyset)
      apply invoke size_emptyset_implies_set_emptyset for Y
      any z {
        assume in(z, X) {
          pad in(z, X) conclude in(z, X) \vee in(z, Y)
        }
        assume in(z, X) \vee in(z, Y) {
          divide in(z, X) \vee in(z, Y)
            case in(z, X) {}
            case in(z, Y) {
              substitute in(z, Y) for Y: emptyset
              apply emptyset_existence for z
              contradict in(z, emptyset)
              explode in(z, X)
            }
        }
        connect in(z, X) \leftrightarrow in(z, X) \vee in(z, Y)
      }
      fold for cup conclude cup(X, Y, X)
      connect finite(X) \wedge cup(X, Y, X)
      lift for X conclude \exists Z (finite(Z) \wedge cup(X, Y, Z))
    }
  }
  any n {
    assume natural(n) {
      assume \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge cup(X, Y, Z))) {
        any X, Y {
          assume finite(X) \wedge size(Y, suc(n)) {
            split finite(X) \wedge size(Y, suc(n))
            apply invoke size_suc_decomposition for Y, n
            some Y', y such \exists Y' \exists y (size(Y', n) \wedge notin(y, Y') \wedge equal(Y, adj(Y', y))) {
              split size(Y', n) \wedge notin(y, Y') \wedge equal(Y, adj(Y', y))
              connect finite(X) \wedge size(Y', n)
              apply invoke \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge cup(X, Y, Z))) for X, Y'
              some Z such \exists Z (finite(Z) \wedge cup(X, Y', Z)) {
                split finite(Z) \wedge cup(X, Y', Z)
                apply invoke finite_adj for Z, y
                any z {
                  assume in(z, adj(Z, y)) {
                    apply invoke rightward adj_existence for Z, y, z
                    divide in(z, Z) \vee equal(z, y)
                      case in(z, Z) {
                        apply invoke rightward cup(X, Y', Z) for z
                        divide in(z, X) \vee in(z, Y')
                          case in(z, X) {
                            pad in(z, X) conclude in(z, X) \vee in(z, Y)
                          }
                          case in(z, Y') {
                            apply invoke adj_cor1 for Y', y, z
                            substitute in(z, adj(Y', y)) for adj(Y', y): Y
                            pad in(z, Y) conclude in(z, X) \vee in(z, Y)
                          }
                      }
                      case equal(z, y) {
                        apply adj_cor3 for Y', y
                        substitute in(y, adj(Y', y)) for y[1]: z, adj(Y', y): Y
                        pad in(z, Y) conclude in(z, X) \vee in(z, Y)
                      }
                  }
                  assume in(z, X) \vee in(z, Y) {
                    divide in(z, X) \vee in(z, Y)
                      case in(z, X) {
                        pad in(z, X) conclude in(z, X) \vee in(z, Y')
                        apply invoke leftward cup(X, Y', Z) for z
                        apply invoke adj_cor1 for Z, y, z
                      }
                      case in(z, Y) {
                        substitute in(z, Y) for Y: adj(Y', y)
                        apply invoke rightward adj_existence for Y', y, z
                        divide in(z, Y') \vee equal(z, y)
                          case in(z, Y') {
                            pad in(z, Y') conclude in(z, X) \vee in(z, Y')
                            apply invoke leftward cup(X, Y', Z) for z
                            apply invoke adj_cor1 for Z, y, z
                          }
                          case equal(z, y) {
                            apply adj_cor3 for Z, y
                            substitute in(y, adj(Z, y)) for y[1]: z
                          }
                      }
                  }
                  connect in(z, adj(Z, y)) \leftrightarrow in(z, X) \vee in(z, Y)
                }
                fold for cup conclude cup(X, Y, adj(Z, y))
                connect finite(adj(Z, y)) \wedge cup(X, Y, adj(Z, y))
                lift for adj(Z, y) conclude \exists Z' (finite(Z') \wedge cup(X, Y, Z'))
              }
            }
          }
        }
      }
    }
  }
  connect \forall X \forall Y (finite(X) \wedge size(Y, emptyset) \to \exists Z (finite(Z) \wedge cup(X, Y, Z))) \wedge \forall n (natural(n) \to (\forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge cup(X, Y, Z))) \to \forall X \forall Y (finite(X) \wedge size(Y, suc(n)) \to \exists Z (finite(Z) \wedge cup(X, Y, Z)))))
  apply invoke natural_induction for \lambda^P n. \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge cup(X, Y, Z)))
  any X, Y {
    assume finite(X) \wedge finite(Y) {
      split finite(X) \wedge finite(Y)
      some n such finite(Y) {
        split 1 size(Y, n)
        apply invoke \forall n (natural(n) \to \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge cup(X, Y, Z)))) for n
        connect finite(X) \wedge size(Y, n)
        apply invoke \forall X \forall Y (finite(X) \wedge size(Y, n) \to \exists Z (finite(Z) \wedge cup(X, Y, Z))) for X, Y
        some Z such \exists Z (finite(Z) \wedge cup(X, Y, Z)) {
          split finite(Z) \wedge cup(X, Y, Z)
          any Z' {
            assume finite(Z') \wedge cup(X, Y, Z') {
              split finite(Z') \wedge cup(X, Y, Z')
              connect cup(X, Y, Z) \wedge cup(X, Y, Z')
              apply invoke cup_is_unique for X, Y, Z, Z'
            }
          }
          connect finite(Z) \wedge cup(X, Y, Z) \wedge \forall Z' (finite(Z') \wedge cup(X, Y, Z') \to equal(Z', Z))
          characterize for Z conclude \exists! Z (finite(Z) \wedge cup(X, Y, Z))
        }
      }
    }
  }
}

theorem finite_bigcup_exists_uniquely \forall X (finite(X) \wedge \forall x (in(x, X) \to finite(x)) \to \exists! Y (finite(Y) \wedge bigcup(X, Y))) {
  any X {
    assume size(X, emptyset) \wedge \forall x (in(x, X) \to finite(x)) {
      split 1 size(X, emptyset) \wedge \forall x (in(x, X) \to finite(x))
      apply invoke size_emptyset_implies_set_emptyset for X
      assert emptyset_is_finite
      any y {
        assume in(y, emptyset) {
          apply emptyset_existence for y
          contradict in(y, emptyset)
          explode \exists x (in(y, x) \wedge in(x, X))
        }
        assume \exists x (in(y, x) \wedge in(x, X)) {
          some x such \exists x (in(y, x) \wedge in(x, X)) {
            split 2 in(y, x) \wedge in(x, X)
            substitute in(x, X) for X: emptyset
            apply emptyset_existence for x
            contradict in(x, emptyset)
            explode in(y, emptyset)
          }
        }
        connect in(y, emptyset) \leftrightarrow \exists x (in(y, x) \wedge in(x, X))
      }
      fold for bigcup conclude bigcup(X, emptyset)
      connect finite(emptyset) \wedge bigcup(X, emptyset)
      lift for emptyset conclude \exists Y (finite(Y) \wedge bigcup(X, Y))
    }
  }
  any n {
    assume natural(n) {
      assume \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge bigcup(X, Y))) {
        any X {
          assume size(X, suc(n)) \wedge \forall x (in(x, X) \to finite(x)) {
            split size(X, suc(n)) \wedge \forall x (in(x, X) \to finite(x))
            apply invoke size_suc_decomposition for X, n
            some X', x such \exists X' \exists x (size(X', n) \wedge notin(x, X') \wedge equal(X, adj(X', x))) {
              split size(X', n) \wedge notin(x, X') \wedge equal(X, adj(X', x))
              apply adj_cor3 for X', x
              substitute in(x, adj(X', x)) for adj(X', x): X
              apply invoke \forall x (in(x, X) \to finite(x)) for x
              any x' {
                assume in(x', X') {
                  apply invoke adj_cor1 for X', x, x'
                  substitute in(x', adj(X', x)) for adj(X', x): X
                  apply invoke \forall x (in(x, X) \to finite(x)) for x'
                }
              }
              connect size(X', n) \wedge \forall x' (in(x', X') \to finite(x'))
              apply invoke \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge bigcup(X, Y))) for X'
              some Y such \exists Y (finite(Y) \wedge bigcup(X', Y)) {
                split finite(Y) \wedge bigcup(X', Y)
                connect finite(Y) \wedge finite(x)
                apply invoke finite_cup_exists_uniquely for Y, x
                some Z such \exists! Z (finite(Z) \wedge cup(Y, x, Z)) {
                  split finite(Z) \wedge cup(Y, x, Z)
                  any y {
                    assume in(y, Z) {
                      apply invoke rightward cup(Y, x, Z) for y
                      divide in(y, Y) \vee in(y, x)
                        case in(y, Y) {
                          apply invoke rightward bigcup(X', Y) for y
                          some x' such \exists x (in(y, x) \wedge in(x, X')) {
                            split in(y, x') \wedge in(x', X')
                            apply invoke adj_cor1 for X', x, x'
                            substitute in(x', adj(X', x)) for adj(X', x): X
                            connect in(y, x') \wedge in(x', X)
                            lift for x' conclude \exists x (in(y, x) \wedge in(x, X))
                          }
                        }
                        case in(y, x) {
                          connect in(y, x) \wedge in(x, X)
                          lift for x conclude \exists x (in(y, x) \wedge in(x, X))
                        }
                    }
                    assume \exists x (in(y, x) \wedge in(x, X)) {
                      some x' such \exists x (in(y, x) \wedge in(x, X)) {
                        split in(y, x') \wedge in(x', X)
                        substitute in(x', X) for X: adj(X', x)
                        apply invoke rightward adj_existence for X', x, x'
                        divide in(x', X') \vee equal(x', x)
                          case in(x', X') {
                            connect in(y, x') \wedge in(x', X')
                            lift for x' conclude \exists x (in(y, x) \wedge in(x, X'))
                            apply invoke leftward bigcup(X', Y) for y
                            pad in(y, Y) conclude in(y, Y) \vee in(y, x)
                            apply invoke leftward cup(Y, x, Z) for y
                          }
                          case equal(x', x) {
                            substitute in(y, x') for x': x
                            pad in(y, x) conclude in(y, Y) \vee in(y, x)
                            apply invoke leftward cup(Y, x, Z) for y
                          }
                      }
                    }
                    connect in(y, Z) \leftrightarrow \exists x' (in(y, x') \wedge in(x', X))
                  }
                  fold for bigcup conclude bigcup(X, Z)
                  connect finite(Z) \wedge bigcup(X, Z)
                  lift for Z conclude \exists Y' (finite(Y') \wedge bigcup(X, Y'))
                }
              }
            }
          }
        }
      }
    }
  }
  connect \forall X (size(X, emptyset) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge bigcup(X, Y))) \wedge \forall n (natural(n) \to (\forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge bigcup(X, Y))) \to \forall X (size(X, suc(n) ) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge bigcup(X, Y)))))
  apply invoke natural_induction for \lambda^P n. \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge bigcup(X, Y)))
  any X {
    assume finite(X) \wedge \forall x (in(x, X) \to finite(x)) {
      split finite(X) \wedge \forall x (in(x, X) \to finite(x))
      some n such finite(X) {
        split 1 size(X, n)
        apply invoke \forall n (natural(n) \to \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge bigcup(X, Y)))) for n
        connect size(X, n) \wedge \forall x (in(x, X) \to finite(x))
        apply invoke \forall X (size(X, n) \wedge \forall x (in(x, X) \to finite(x)) \to \exists Y (finite(Y) \wedge bigcup(X, Y))) for X
        some Y such \exists Y (finite(Y) \wedge bigcup(X, Y)) {
          split finite(Y) \wedge bigcup(X, Y)
          any Y' {
            assume finite(Y') \wedge bigcup(X, Y') {
              split 2 finite(Y') \wedge bigcup(X, Y')
              connect bigcup(X, Y) \wedge bigcup(X, Y')
              apply invoke bigcup_is_unique for X, Y, Y'
            }
          }
          connect finite(Y) \wedge bigcup(X, Y) \wedge \forall Y' (finite(Y') \wedge bigcup(X, Y') \to equal(Y', Y))
          characterize for Y conclude \exists! Y (finite(Y) \wedge bigcup(X, Y))
        }
      }
    }
  }
}

theorem replacement_is_unique \forall X \forall^P \psi[2] \forall Y \forall Y' (\forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))) \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))) \to equal(Y, Y')) {
  any X, predicate \psi[2], Y, Y' {
    assume \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))) \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))) {
      apply invoke set_is_unique_for_predicate for \lambda^P y. \exists x (in(x, X) \wedge \psi(x, y)), Y, Y'
    }
  }
}

theorem finite_replacement_exists_uniquely \forall X \forall^P \psi[2] (finite(X) \wedge functional(\psi) \to \exists! Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))))) {
  any X, predicate \psi[2] {
    assume size(X, emptyset) \wedge functional(\psi) {
      split size(X, emptyset) \wedge functional(\psi)
      apply invoke size_emptyset_implies_set_emptyset for X
      assert emptyset_is_finite
      any y {
        assume in(y, emptyset) {
          apply emptyset_existence for y
          contradict in(y, emptyset)
          explode \exists x (in(x, X) \wedge \psi(x, y))
        }
        assume \exists x (in(x, X) \wedge \psi(x, y)) {
          some x such \exists x (in(x, X) \wedge \psi(x, y)) {
            split 1 in(x, X) \wedge \psi(x, y)
            substitute in(x, X) for X: emptyset
            apply emptyset_existence for x
            contradict in(x, emptyset)
            explode in(y, emptyset)
          }
        }
        connect in(y, emptyset) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))
      }
      connect finite(emptyset) \wedge \forall y (in(y, emptyset) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y)))
      lift for emptyset conclude \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))))
    }
  }
  any n {
    assume natural(n) {
      assume \forall X \forall^P \psi[2] (size(X, n) \wedge functional(\psi) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))))) {
        any X, predicate \psi[2] {
          assume size(X, suc(n)) \wedge functional(\psi) {
            split size(X, suc(n)) \wedge functional(\psi)
            apply invoke size_suc_decomposition for X, n
            some X', x such \exists X' \exists x (size(X', n) \wedge notin(x, X') \wedge equal(X, adj(X', x))) {
              split size(X', n) \wedge notin(x, X') \wedge equal(X, adj(X', x))
              connect size(X', n) \wedge functional(\psi)
              apply invoke \forall X \forall^P \psi[2] (size(X, n) \wedge functional(\psi) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))))) for X', \psi
              some Y such \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x' (in(x', X') \wedge \psi(x', y)))) {
                split finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x' (in(x', X') \wedge \psi(x', y)))
                apply adj_cor3 for X', x
                substitute in(x, adj(X', x)) for adj(X', x): X
                apply law_of_excluded_middle for \lambda^P. \exists y (\psi(x, y))
                divide \exists y (\psi(x, y)) \vee \neg(\exists y (\psi(x, y)))
                  case \exists y (\psi(x, y)) {
                    some y such \exists y (\psi(x, y)) {
                      apply invoke finite_adj for Y, y
                      any y' {
                        assume in(y', adj(Y, y)) {
                          apply invoke rightward adj_existence for Y, y, y'
                          divide in(y', Y) \vee equal(y', y)
                            case in(y', Y) {
                              apply invoke rightward \forall y (in(y, Y) \leftrightarrow \exists x' (in(x', X') \wedge \psi(x', y))) for y'
                              some x' such \exists x' (in(x', X') \wedge \psi(x', y')) {
                                split in(x', X') \wedge \psi(x', y')
                                apply invoke adj_cor1 for X', x, x'
                                substitute in(x', adj(X', x)) for adj(X', x): X
                                connect in(x', X) \wedge \psi(x', y')
                                lift for x' conclude \exists x' (in(x', X) \wedge \psi(x', y'))
                              }
                            }
                            case equal(y', y) {
                              substitute \psi(x, y) for y: y'
                              connect in(x, X) \wedge \psi(x, y')
                              lift for x conclude \exists x (in(x, X) \wedge \psi(x, y'))
                            }
                        }
                        assume \exists x' (in(x', X) \wedge \psi(x', y')) {
                          some x' such \exists x' (in(x', X) \wedge \psi(x', y')) {
                            split in(x', X) \wedge \psi(x', y')
                            substitute in(x', X) for X: adj(X', x)
                            apply invoke rightward adj_existence for X', x, x'
                            divide in(x', X') \vee equal(x', x)
                              case in(x', X') {
                                connect in(x', X') \wedge \psi(x', y')
                                lift for x' conclude \exists x' (in(x', X') \wedge \psi(x', y'))
                                apply invoke leftward \forall y (in(y, Y) \leftrightarrow \exists x' (in(x', X') \wedge \psi(x', y))) for y'
                                apply invoke adj_cor1 for Y, y, y'
                              }
                              case equal(x', x) {
                                substitute \psi(x', y') for x': x
                                connect \psi(x, y) \wedge \psi(x, y')
                                apply invoke functional(\psi) for x, y, y'
                                apply adj_cor3 for Y, y
                                substitute in(y, adj(Y, y)) for y[1]: y'
                              }
                          }
                        }
                        connect in(y', adj(Y, y)) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y'))
                      }
                      connect finite(adj(Y, y)) \wedge \forall y' (in(y', adj(Y, y)) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y')))
                      lift for adj(Y, y) conclude \exists Y' (finite(Y') \wedge \forall y' (in(y', Y') \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y'))))
                    }
                  }
                  case \neg(\exists y (\psi(x, y))) {
                    apply invoke rightward neg_exist_leftrightarrow_forall_neg for \lambda^P y. \psi(x, y)
                    any y {
                      assume in(y, Y) {
                        apply invoke rightward \forall y (in(y, Y) \leftrightarrow \exists x' (in(x', X') \wedge \psi(x', y))) for y
                        some x' such \exists x' (in(x', X') \wedge \psi(x', y)) {
                          split in(x', X') \wedge \psi(x', y)
                          apply invoke adj_cor1 for X', x, x'
                          substitute in(x', adj(X', x)) for adj(X', x): X
                          connect in(x', X) \wedge \psi(x', y)
                          lift for x' conclude \exists x' (in(x', X) \wedge \psi(x', y))
                        }
                      }
                      assume \exists x' (in(x', X) \wedge \psi(x', y)) {
                        some x' such \exists x' (in(x', X) \wedge \psi(x', y)) {
                          split in(x', X) \wedge \psi(x', y)
                          substitute in(x', X) for X: adj(X', x)
                          apply invoke rightward adj_existence for X', x, x'
                          divide in(x', X') \vee equal(x', x)
                            case in(x', X') {
                              connect in(x', X') \wedge \psi(x', y)
                              lift for x' conclude \exists x' (in(x', X') \wedge \psi(x', y))
                              apply invoke leftward \forall y (in(y, Y) \leftrightarrow \exists x' (in(x', X') \wedge \psi(x', y))) for y
                            }
                            case equal(x', x) {
                              substitute \psi(x', y) for x': x
                              apply \forall y (\neg(\psi(x, y))) for y
                              contradict \psi(x, y)
                              explode in(y, Y)
                            }
                        }
                      }
                      connect in(y, Y) \leftrightarrow \exists x' (in(x', X) \wedge \psi(x', y))
                    }
                    connect finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x' (in(x', X) \wedge \psi(x', y)))
                    lift for Y conclude \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x' (in(x', X) \wedge \psi(x', y))))
                  }
              }
            }
          }
        }
      }
    }
  }
  connect \forall X \forall^P \psi[2] (size(X, emptyset) \wedge functional(\psi) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))))) \wedge \forall n (natural(n) \to (\forall X \forall^P \psi[2] (size(X, n) \wedge functional(\psi) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))))) \to \forall X \forall^P \psi[2] (size(X, suc(n)) \wedge functional(\psi) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y)))))))
  apply invoke natural_induction for \lambda^P n. \forall X \forall^P \psi[2] (size(X, n) \wedge functional(\psi) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y)))))
  any X, n, predicate \psi[2] {
    assume size(X, n) \wedge functional(\psi) {
      split 1 size(X, n) \wedge functional(\psi)
      split 1 size(X, n)
      apply invoke \forall n (natural(n) \to \forall X \forall^P \psi[2] (size(X, n) \wedge functional(\psi) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y)))))) for n
      apply invoke \forall X \forall^P \psi[2] (size(X, n) \wedge functional(\psi) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))))) for X, \psi
    }
  }
  any X, predicate \psi[2] {
    assume finite(X) \wedge functional(\psi) {
      split finite(X) \wedge functional(\psi)
      some n such finite(X) {
        connect size(X, n) \wedge functional(\psi)
        apply invoke \forall X \forall n \forall^P \psi[2] (size(X, n) \wedge functional(\psi) \to \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))))) for X, n, \psi
        some Y such \exists Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y)))) {
          split finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y)))
          any Y' {
            assume finite(Y') \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))) {
              split finite(Y') \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y)))
              connect \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))) \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y)))
              apply invoke replacement_is_unique for X, \psi, Y, Y'
            }
          }
          connect finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))) \wedge \forall Y' (finite(Y') \wedge \forall y (in(y, Y') \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))) \to equal(Y', Y))
          characterize for Y conclude \exists! Y (finite(Y) \wedge \forall y (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge \psi(x, y))))
        }
      }
    }
  }
}
