include "zfc_logic.proof"

equality equal tex infix "="

definition predicate autoexpand neq(x, y) as \neg(equal(x, y)) tex infix "\neq"

primitive predicate in arity 2 tex infix "\in"

definition predicate autoexpand notin(x, y) as \neg(in(x, y)) tex infix "\notin"

axiom axiom_of_extensionality \forall x \forall y (\forall z (in(z, x) \leftrightarrow in(z, y)) \to equal(x, y))

theorem set_is_unique_for_predicate \forall^P \phi[1] \forall x \forall x' (\forall y (in(y, x) \leftrightarrow \phi(y)) \wedge \forall y (in(y, x') \leftrightarrow \phi(y)) \to equal(x, x')) {
  any predicate \phi[1], x, x' {
    assume \forall y (in(y, x) \leftrightarrow \phi(y)) \wedge \forall y (in(y, x') \leftrightarrow \phi(y)) {
      split \forall y (in(y, x) \leftrightarrow \phi(y)) \wedge \forall y (in(y, x') \leftrightarrow \phi(y))
      any y {
        assume in(y, x) {
          apply invoke rightward \forall y (in(y, x) \leftrightarrow \phi(y)) for y
          apply invoke leftward \forall y (in(y, x') \leftrightarrow \phi(y)) for y
        }
        assume in(y, x') {
          apply invoke rightward \forall y (in(y, x') \leftrightarrow \phi(y)) for y
          apply invoke leftward \forall y (in(y, x) \leftrightarrow \phi(y)) for y
        }
        connect in(y, x) \leftrightarrow in(y, x')
      }
      apply invoke axiom_of_extensionality for x, x'
    }
  }
}

theorem set_exists_implies_set_exists_uniquely \forall^P \phi[1] (\exists x \forall y (in(y, x) \leftrightarrow \phi(y)) \to \exists! x \forall y (in(y, x) \leftrightarrow \phi(y))) {
  any predicate \phi[1] {
    assume \exists x \forall y (in(y, x) \leftrightarrow \phi(y)) {
      some x such \exists x \forall y (in(y, x) \leftrightarrow \phi(y)) {
        any x' {
          assume \forall y (in(y, x') \leftrightarrow \phi(y)) {
            connect \forall y (in(y, x') \leftrightarrow \phi(y)) \wedge \forall y (in(y, x) \leftrightarrow \phi(y))
            apply invoke set_is_unique_for_predicate for \phi, x', x
          }
        }
        connect \forall y (in(y, x) \leftrightarrow \phi(y)) \wedge \forall x' (\forall y (in(y, x') \leftrightarrow \phi(y)) \to equal(x', x))
        characterize for x conclude \exists! x \forall y (in(y, x) \leftrightarrow \phi(y))
      }
    }
  }
}

definition predicate subset(x, y) as \forall z (in(z, x) \to in(z, y)) tex infix "\subset"

theorem subset_reflexivity \forall x (subset(x, x)) {
  any x {
    any y {
      assume in(y, x) {}
    }
    fold for subset conclude subset(x, x)
  }
}

theorem subset_transivity \forall x \forall y \forall z (subset(x, y) \wedge subset(y, z) \to subset(x, z)) {
  any x, y, z {
    assume subset(x, y) \wedge subset(y, z) {
      split subset(x, y) \wedge subset(y, z)
      any w {
        assume in(w, x) {
          apply invoke subset(x, y) for w
          apply invoke subset(y, z) for w
        }
      }
      fold for subset conclude subset(x, z)
    }
  }
}

theorem subset_antisymmetry \forall x \forall y (subset(x, y) \wedge subset(y, x) \to equal(x, y)) {
  any x, y {
    assume subset(x, y) \wedge subset(y, x) {
      split subset(x, y) \wedge subset(y, x)
      any z {
        assume in(z, x) {
          apply invoke subset(x, y) for z
        }
        assume in(z, y) {
          apply invoke subset(y, x) for z
        }
        connect in(z, x) \leftrightarrow in(z, y)
      }
      apply invoke axiom_of_extensionality for x, y
    }
  }
}
