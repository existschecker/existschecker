include "zfc_tcm.proof"

definition predicate hirrefrel(x) as \exists y (irrefrel(y, in) \wedge tcm(x, y))

theorem hirrefrel_is_irrefrel \forall x (hirrefrel(x) \to irrefrel(x, in)) {
  any x {
    assume hirrefrel(x) {
      some y such hirrefrel(x) {
        split irrefrel(y, in) \wedge tcm(x, y)
        apply invoke tcm_implies_subset for x, y
        connect irrefrel(y, in) \wedge subset(x, y)
        apply invoke subset_of_irrefrel_is_irrefrel for in, y, x
      }
    }
  }
}

theorem element_of_hirrefrel_is_hirrefrel \forall x \forall y (hirrefrel(x) \wedge in(y, x) \to hirrefrel(y)) {
  any x, y {
    assume hirrefrel(x) \wedge in(y, x) {
      split hirrefrel(x) \wedge in(y, x)
      some t such hirrefrel(x) {
        split irrefrel(t, in) \wedge tcm(x, t)
        connect tcm(x, t) \wedge in(y, x)
        apply invoke tcm_of_element_is_subset_of_tcm for x, t, y
        some s such \exists s (subset(s, t) \wedge tcm(y, s)) {
          split subset(s, t) \wedge tcm(y, s)
          connect irrefrel(t, in) \wedge subset(s, t)
          apply invoke subset_of_irrefrel_is_irrefrel for in, t, s
          connect irrefrel(s, in) \wedge tcm(y, s)
          lift for s conclude hirrefrel(y)
        }
      }
    }
  }
}

theorem set_of_hirrefrel_is_hirrefrel \forall Y \forall Z \forall W \forall V (\forall y (in(y, Y) \to hirrefrel(y)) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V) \to hirrefrel(Y)) {
  any Y, Z, W, V {
    assume \forall y (in(y, Y) \to hirrefrel(y)) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V) {
      split \forall y (in(y, Y) \to hirrefrel(y)) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
      any y {
        assume in(y, Y) {
          apply invoke \forall y (in(y, Y) \to hirrefrel(y)) for y
          some z such hirrefrel(y) {
            split irrefrel(z, in) \wedge tcm(y, z)
            lift for z conclude \exists z (tcm(y, z))
          }
        }
      }
      connect \forall y (in(y, Y) \to \exists z (tcm(y, z))) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
      apply invoke tcm_is_cup_of_itself_and_bigcup_of_tcm_of_element for Y, Z, W, V
      any y {
        assume in(y, Y) {
          apply invoke \forall y (in(y, Y) \to hirrefrel(y)) for y
          apply invoke hirrefrel_is_irrefrel for y
          apply invoke irrefrel_not_contain_itself for y
        }
      }
      fold for irrefrel conclude irrefrel(Y, in)
      any w {
        assume in(w, W) {
          apply invoke rightward bigcup(Z, W) for w
          some z such \exists z (in(w, z) \wedge in(z, Z)) {
            split in(w, z) \wedge in(z, Z)
            apply invoke rightward replacement(Y, tcm, Z) for z
            some y such \exists y (in(y, Y) \wedge tcm(y, z)) {
              split in(y, Y) \wedge tcm(y, z)
              apply invoke \forall y (in(y, Y) \to hirrefrel(y)) for y
              some z' such hirrefrel(y) {
                split irrefrel(z', in) \wedge tcm(y, z')
                connect tcm(y, z) \wedge tcm(y, z')
                apply invoke tcm_is_unique for y, z, z'
                substitute irrefrel(z', in) for z': z
                apply invoke irrefrel(z, in) for w
              }
            }
          }
        }
      }
      fold for irrefrel conclude irrefrel(W, in)
      connect irrefrel(Y, in) \wedge irrefrel(W, in) \wedge cup(Y, W, V)
      apply invoke cup_of_irrefrel_is_irrefrel for in, Y, W, V
      connect irrefrel(V, in) \wedge tcm(Y, V)
      lift for V conclude hirrefrel(Y)
    }
  }
}

definition predicate hwellfounded(x) as \exists y (wellfounded(y, in) \wedge tcm(x, y))

theorem hwellfounded_is_wellfounded \forall x (hwellfounded(x) \to wellfounded(x, in)) {
  any x {
    assume hwellfounded(x) {
      some y such hwellfounded(x) {
        split wellfounded(y, in) \wedge tcm(x, y)
        apply invoke tcm_implies_subset for x, y
        connect wellfounded(y, in) \wedge subset(x, y)
        apply invoke subset_of_wellfounded_is_wellfounded for in, y, x
      }
    }
  }
}

theorem element_of_hwellfounded_is_hwellfounded \forall x \forall y (hwellfounded(x) \wedge in(y, x) \to hwellfounded(y)) {
  any x, y {
    assume hwellfounded(x) \wedge in(y, x) {
      split hwellfounded(x) \wedge in(y, x)
      some t such hwellfounded(x) {
        split wellfounded(t, in) \wedge tcm(x, t)
        connect tcm(x, t) \wedge in(y, x)
        apply invoke tcm_of_element_is_subset_of_tcm for x, t, y
        some s such \exists s (subset(s, t) \wedge tcm(y, s)) {
          split subset(s, t) \wedge tcm(y, s)
          connect wellfounded(t, in) \wedge subset(s, t)
          apply invoke subset_of_wellfounded_is_wellfounded for in, t, s
          connect wellfounded(s, in) \wedge tcm(y, s)
          lift for s conclude hwellfounded(y)
        }
      }
    }
  }
}

theorem set_of_hwellfounded_is_hwellfounded \forall Y \forall Z \forall W \forall V (\forall y (in(y, Y) \to hwellfounded(y)) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V) \to hwellfounded(Y)) {
  any Y, Z, W, V {
    assume \forall y (in(y, Y) \to hwellfounded(y)) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V) {
      split \forall y (in(y, Y) \to hwellfounded(y)) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
      any y {
        assume in(y, Y) {
          apply invoke \forall y (in(y, Y) \to hwellfounded(y)) for y
          some z such hwellfounded(y) {
            split wellfounded(z, in) \wedge tcm(y, z)
            lift for z conclude \exists z (tcm(y, z))
          }
        }
      }
      connect \forall y (in(y, Y) \to \exists z (tcm(y, z))) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
      apply invoke tcm_is_cup_of_itself_and_bigcup_of_tcm_of_element for Y, Z, W, V
      any A {
        assume subset(A, V) \wedge neq(A, emptyset) {
          split subset(A, V) \wedge neq(A, emptyset)
          apply invoke not_emptyset_has_a_member for A
          some v such \exists v (in(v, A)) {
            apply invoke subset(A, V) for v
            apply invoke rightward cup(Y, W, V) for v
            divide in(v, Y) \vee in(v, W)
              case in(v, Y) {
                apply invoke \forall y (in(y, Y) \to hwellfounded(y)) for v
              }
              case in(v, W) {
                apply invoke rightward bigcup(Z, W) for v
                some z such \exists z (in(v, z) \wedge in(z, Z)) {
                  split in(v, z) \wedge in(z, Z)
                  apply invoke rightward replacement(Y, tcm, Z) for z
                  some y such \exists y (in(y, Y) \wedge tcm(y, z)) {
                    split in(y, Y) \wedge tcm(y, z)
                    apply invoke \forall y (in(y, Y) \to hwellfounded(y)) for y
                    some z' such hwellfounded(y) {
                      split wellfounded(z', in) \wedge tcm(y, z')
                      apply invoke tcm_is_tcm_of_itself for y, z'
                      connect wellfounded(z', in) \wedge tcm(z', z')
                      lift for z' conclude hwellfounded(z')
                      connect tcm(y, z) \wedge tcm(y, z')
                      apply invoke tcm_is_unique for y, z, z'
                      substitute hwellfounded(z') for z': z
                      connect hwellfounded(z) \wedge in(v, z)
                      apply invoke element_of_hwellfounded_is_hwellfounded for z, v
                    }
                  }
                }
              }
            some T such hwellfounded(v) {
              split wellfounded(T, in) \wedge tcm(v, T)
              apply invoke tcm_implies_subset for v, T
              apply invoke tcm_is_trans for v, T
              apply law_of_excluded_middle for \lambda^P. equal(cap(A, T), emptyset)
              divide equal(cap(A, T), emptyset) \vee neq(cap(A, T), emptyset)
                case equal(cap(A, T), emptyset) {
                  any x {
                    assume in(x, A) \wedge neq(x, v) {
                      split in(x, A) \wedge neq(x, v)
                      deny in(x, v) {
                        apply invoke subset(v, T) for x
                        apply invoke rightward tcm(v, T) for x
                        connect in(x, A) \wedge in(x, T)
                        apply invoke leftward cap_characterization for A, T, x
                        substitute in(x, cap(A, T)) for cap(A, T): emptyset
                        apply emptyset_existence for x
                        contradict in(x, emptyset)
                      }
                    }
                  }
                  fold for minimal_core conclude minimal_core(in, A, v)
                  connect minimal(in, A, v)
                  lift for v conclude \exists a (minimal(in, A, a))
                }
                case neq(cap(A, T), emptyset) {
                  apply cap_is_subset_right for A, T
                  connect subset(cap(A, T), T) \wedge neq(cap(A, T), emptyset)
                  apply invoke wellfounded(T, in) for cap(A, T)
                  some a such \exists a (minimal(in, cap(A, T), a)) {
                    split minimal(in, cap(A, T), a)
                    apply invoke rightward cap_characterization for A, T, a
                    split in(a, A) \wedge in(a, T)
                    any x {
                      assume in(x, A) \wedge neq(x, a) {
                        split in(x, A) \wedge neq(x, a)
                        deny in(x, a) {
                          connect in(x, a) \wedge in(a, T)
                          apply invoke trans(T) for a, x
                          connect in(x, A) \wedge in(x, T)
                          apply invoke leftward cap_characterization for A, T, x
                          connect in(x, cap(A, T)) \wedge neq(x, a)
                          apply invoke minimal_core(in, cap(A, T), a) for x
                          contradict in(x, a)
                        }
                      }
                    }
                    fold for minimal_core conclude minimal_core(in, A, a)
                    connect minimal(in, A, a)
                    lift for a conclude \exists a (minimal(in, A, a))
                  }
                }
            }
          }
        }
      }
      fold for wellfounded conclude wellfounded(V, in)
      connect wellfounded(V, in) \wedge tcm(Y, V)
      lift for V conclude hwellfounded(Y)
    }
  }
}

definition predicate hfcore(x) as \exists y (finite(y) \wedge tcm(x, y))

theorem hfcore_is_finite \forall x (hfcore(x) \to finite(x)) {
  any x {
    assume hfcore(x) {
      some y such hfcore(x) {
        split finite(y) \wedge tcm(x, y)
        apply invoke tcm_implies_subset for x, y
        connect finite(y) \wedge subset(x, y)
        apply invoke subset_of_finite_is_finite for y, x
      }
    }
  }
}

theorem element_of_hfcore_is_hfcore \forall x \forall y (hfcore(x) \wedge in(y, x) \to hfcore(y)) {
  any x, y {
    assume hfcore(x) \wedge in(y, x) {
      split hfcore(x) \wedge in(y, x)
      some t such hfcore(x) {
        split finite(t) \wedge tcm(x, t)
        connect tcm(x, t) \wedge in(y, x)
        apply invoke tcm_of_element_is_subset_of_tcm for x, t, y
        some s such \exists s (subset(s, t) \wedge tcm(y, s)) {
          split subset(s, t) \wedge tcm(y, s)
          connect finite(t) \wedge subset(s, t)
          apply invoke subset_of_finite_is_finite for t, s
          connect finite(s) \wedge tcm(y, s)
          lift for s conclude hfcore(y)
        }
      }
    }
  }
}

theorem finite_set_of_hfcore_is_hfcore \forall Y (finite(Y) \wedge \forall y (in(y, Y) \to hfcore(y)) \to hfcore(Y) \wedge \exists Z \exists W \exists V (replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V))) {
  any Y {
    assume finite(Y) \wedge \forall y (in(y, Y) \to hfcore(y)) {
      split finite(Y) \wedge \forall y (in(y, Y) \to hfcore(y))
      assert tcm_is_functional
      connect finite(Y) \wedge functional(tcm)
      apply invoke finite_replacement_exists_uniquely for Y, tcm
      some Z such \exists! Z (finite(Z) \wedge replacement(Y, tcm, Z)) {
        split finite(Z) \wedge replacement(Y, tcm, Z)
        any z {
          assume in(z, Z) {
            apply invoke rightward replacement(Y, tcm, Z) for z
            some y such \exists y (in(y, Y) \wedge tcm(y, z)) {
              split in(y, Y) \wedge tcm(y, z)
              apply invoke \forall y (in(y, Y) \to hfcore(y)) for y
              some z' such hfcore(y) {
                split finite(z') \wedge tcm(y, z')
                connect tcm(y, z) \wedge tcm(y, z')
                apply invoke tcm_is_unique for y, z, z'
                substitute finite(z') for z': z
              }
            }
          }
        }
        connect finite(Z) \wedge \forall z (in(z, Z) \to finite(z))
        apply invoke finite_bigcup_exists_uniquely for Z
        some W such \exists! W (finite(W) \wedge bigcup(Z, W)) {
          split finite(W) \wedge bigcup(Z, W)
          connect finite(Y) \wedge finite(W)
          apply invoke finite_cup_exists_uniquely for Y, W
          some V such \exists! V (finite(V) \wedge cup(Y, W, V)) {
            split finite(V) \wedge cup(Y, W, V)
            any y {
              assume in(y, Y) {
                apply invoke \forall y (in(y, Y) \to hfcore(y)) for y
                some z such hfcore(y) {
                  split 2 finite(z) \wedge tcm(y, z)
                  lift for z conclude \exists z (tcm(y, z))
                }
              }
            }
            connect \forall y (in(y, Y) \to \exists z (tcm(y, z))) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
            apply invoke tcm_is_cup_of_itself_and_bigcup_of_tcm_of_element for Y, Z, W, V
            connect finite(V) \wedge tcm(Y, V)
            connect replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
            lift for V conclude hfcore(Y)
            lift for Z, W, V conclude \exists Z \exists W \exists V (replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V))
            connect hfcore(Y) \wedge \exists Z \exists W \exists V (replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V))
          }
        }
      }
    }
  }
}

definition predicate hf(x) as \exists y (irrefrel(y, in) \wedge wellfounded(y, in) \wedge finite(y) \wedge tcm(x, y))

theorem hf_iff_hirrefrel_hwellfounded_hfcore \forall x (hf(x) \leftrightarrow hirrefrel(x) \wedge hwellfounded(x) \wedge hfcore(x)) {
  any x {
    assume hf(x) {
      some t such hf(x) {
        split irrefrel(t, in) \wedge wellfounded(t, in) \wedge finite(t) \wedge tcm(x, t)
        connect irrefrel(t, in) \wedge tcm(x, t)
        lift for t conclude hirrefrel(x)
        connect wellfounded(t, in) \wedge tcm(x, t)
        lift for t conclude hwellfounded(x)
        connect finite(t) \wedge tcm(x, t)
        lift for t conclude hfcore(x)
        connect hirrefrel(x) \wedge hwellfounded(x) \wedge hfcore(x)
      }
    }
    assume hirrefrel(x) \wedge hwellfounded(x) \wedge hfcore(x) {
      split hirrefrel(x) \wedge hwellfounded(x) \wedge hfcore(x)
      some t such hirrefrel(x) {
        split irrefrel(t, in) \wedge tcm(x, t)
        some t' such hwellfounded(x) {
          split wellfounded(t', in) \wedge tcm(x, t')
          connect tcm(x, t) \wedge tcm(x, t')
          apply invoke tcm_is_unique for x, t, t'
          substitute wellfounded(t', in) for t': t
        }
        some t'' such hfcore(x) {
          split finite(t'') \wedge tcm(x, t'')
          connect tcm(x, t) \wedge tcm(x, t'')
          apply invoke tcm_is_unique for x, t, t''
          substitute finite(t'') for t'': t
        }
        connect irrefrel(t, in) \wedge wellfounded(t, in) \wedge finite(t) \wedge tcm(x, t)
        lift for t conclude hf(x)
      }
    }
    connect hf(x) \leftrightarrow hirrefrel(x) \wedge hwellfounded(x) \wedge hfcore(x)
  }
}

theorem hf_is_irrefrel_wellfounded_finite \forall x (hf(x) \to irrefrel(x, in) \wedge wellfounded(x, in) \wedge finite(x)) {
  any x {
    assume hf(x) {
      apply invoke rightward hf_iff_hirrefrel_hwellfounded_hfcore for x
      split hirrefrel(x) \wedge hwellfounded(x) \wedge hfcore(x)
      apply invoke hirrefrel_is_irrefrel for x
      apply invoke hwellfounded_is_wellfounded for x
      apply invoke hfcore_is_finite for x
      connect irrefrel(x, in) \wedge wellfounded(x, in) \wedge finite(x)
    }
  }
}

theorem element_of_hf_is_hf \forall x \forall y (hf(x) \wedge in(y, x) \to hf(y)) {
  any x, y {
    assume hf(x) \wedge in(y, x) {
      split hf(x) \wedge in(y, x)
      apply invoke rightward hf_iff_hirrefrel_hwellfounded_hfcore for x
      split hirrefrel(x) \wedge hwellfounded(x) \wedge hfcore(x)
      connect hirrefrel(x) \wedge in(y, x)
      apply invoke element_of_hirrefrel_is_hirrefrel for x, y
      connect hwellfounded(x) \wedge in(y, x)
      apply invoke element_of_hwellfounded_is_hwellfounded for x, y
      connect hfcore(x) \wedge in(y, x)
      apply invoke element_of_hfcore_is_hfcore for x, y
      connect hirrefrel(y) \wedge hwellfounded(y) \wedge hfcore(y)
      apply invoke leftward hf_iff_hirrefrel_hwellfounded_hfcore for y
    }
  }
}

theorem hf_satisfies_axiom_of_extensionality \forall x \forall y (hf(x) \wedge hf(y) \to (\forall z (hf(z) \to (in(z, x) \leftrightarrow in(z, y))) \to equal(x, y))) {
  any x, y {
    assume hf(x) \wedge hf(y) {
      split hf(x) \wedge hf(y)
      assume \forall z (hf(z) \to (in(z, x) \leftrightarrow in(z, y))) {
        any z {
          assume in(z, x) {
            connect hf(x) \wedge in(z, x)
            apply invoke element_of_hf_is_hf for x, z
            apply invoke \forall z (hf(z) \to (in(z, x) \leftrightarrow in(z, y))) for z
            invoke rightward in(z, x) \leftrightarrow in(z, y)
          }
          assume in(z, y) {
            connect hf(y) \wedge in(z, y)
            apply invoke element_of_hf_is_hf for y, z
            apply invoke \forall z (hf(z) \to (in(z, x) \leftrightarrow in(z, y))) for z
            invoke leftward in(z, x) \leftrightarrow in(z, y)
          }
          connect in(z, x) \leftrightarrow in(z, y)
        }
        apply invoke axiom_of_extensionality for x, y
      }
    }
  }
}

theorem emptyset_is_hf hf(emptyset) {
  assert emptyset_is_irrefrel
  assert emptyset_is_wellfounded
  assert emptyset_is_finite
  assert emptyset_is_tcm_of_emptyset
  connect irrefrel(emptyset, in) \wedge wellfounded(emptyset, in) \wedge finite(emptyset) \wedge tcm(emptyset, emptyset)
  lift for emptyset conclude hf(emptyset)
}

theorem hf_satisfies_axiom_of_emptyset \exists x (hf(x) \wedge \forall y (hf(y) \to notin(y, x))) {
  assert emptyset_is_hf
  any y {
    assume hf(y) {
      apply emptyset_existence for y
    }
  }
  connect hf(emptyset) \wedge \forall y (hf(y) \to notin(y, emptyset))
  lift for emptyset conclude \exists x (hf(x) \wedge \forall y (hf(y) \to notin(y, x)))
}

theorem finite_set_of_hf_is_hf \forall Y (finite(Y) \wedge \forall y (in(y, Y) \to hf(y)) \to hf(Y)) {
  any Y {
    assume finite(Y) \wedge \forall y (in(y, Y) \to hf(y)) {
      split finite(Y) \wedge \forall y (in(y, Y) \to hf(y))
      any y {
        assume in(y, Y) {
          apply invoke \forall y (in(y, Y) \to hf(y)) for y
          apply invoke rightward hf_iff_hirrefrel_hwellfounded_hfcore for y
          split 1 hirrefrel(y) \wedge hwellfounded(y) \wedge hfcore(y)
        }
      }
      any y {
        assume in(y, Y) {
          apply invoke \forall y (in(y, Y) \to hf(y)) for y
          apply invoke rightward hf_iff_hirrefrel_hwellfounded_hfcore for y
          split 2 hirrefrel(y) \wedge hwellfounded(y) \wedge hfcore(y)
        }
      }
      any y {
        assume in(y, Y) {
          apply invoke \forall y (in(y, Y) \to hf(y)) for y
          apply invoke rightward hf_iff_hirrefrel_hwellfounded_hfcore for y
          split 3 hirrefrel(y) \wedge hwellfounded(y) \wedge hfcore(y)
        }
      }
      connect finite(Y) \wedge \forall y (in(y, Y) \to hfcore(y))
      apply invoke finite_set_of_hfcore_is_hfcore for Y
      split hfcore(Y) \wedge \exists Z \exists W \exists V (replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V))
      some Z, W, V such \exists Z \exists W \exists V (replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)) {
        split replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
        connect \forall y (in(y, Y) \to hirrefrel(y)) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
        apply invoke set_of_hirrefrel_is_hirrefrel for Y, Z, W, V
        connect \forall y (in(y, Y) \to hwellfounded(y)) \wedge replacement(Y, tcm, Z) \wedge bigcup(Z, W) \wedge cup(Y, W, V)
        apply invoke set_of_hwellfounded_is_hwellfounded for Y, Z, W, V
        connect hfcore(Y) \wedge hirrefrel(Y) \wedge hwellfounded(Y)
        apply invoke leftward hf_iff_hirrefrel_hwellfounded_hfcore for Y
      }
    }
  }
}

theorem subset_of_hf_is_hf \forall x \forall y (hf(x) \wedge subset(y, x) \to hf(y)) {
  any x, y {
    assume hf(x) \wedge subset(y, x) {
      split hf(x) \wedge subset(y, x)
      apply invoke hf_is_irrefrel_wellfounded_finite for x
      split 3 irrefrel(x, in) \wedge wellfounded(x, in) \wedge finite(x)
      connect finite(x) \wedge subset(y, x)
      apply invoke subset_of_finite_is_finite for x, y
      any z {
        assume in(z, y) {
          apply invoke subset(y, x) for z
          connect hf(x) \wedge in(z, x)
          apply invoke element_of_hf_is_hf for x, z
        }
      }
      connect finite(y) \wedge \forall z (in(z, y) \to hf(z))
      apply invoke finite_set_of_hf_is_hf for y
    }
  }
}

theorem hf_satisfies_axiom_of_adjunction \forall x \forall y (hf(x) \wedge hf(y) \to \exists z (hf(z) \wedge \forall w (hf(w) \to (in(w, z) \leftrightarrow in(w, x) \vee equal(w, y))))) {
  any x, y {
    assume hf(x) \wedge hf(y) {
      split hf(x) \wedge hf(y)
      apply invoke hf_is_irrefrel_wellfounded_finite for x
      split 3 irrefrel(x, in) \wedge wellfounded(x, in) \wedge finite(x)
      apply invoke finite_adj for x, y
      any p {
        assume in(p, adj(x, y)) {
          apply invoke rightward adj_existence for x, y, p
          divide in(p, x) \vee equal(p, y)
            case in(p, x) {
              connect hf(x) \wedge in(p, x)
              apply invoke element_of_hf_is_hf for x, p
            }
            case equal(p, y) {
              substitute hf(y) for y: p
            }
        }
      }
      connect finite(adj(x, y)) \wedge \forall p (in(p, adj(x, y)) \to hf(p))
      apply invoke finite_set_of_hf_is_hf for adj(x, y)
      any w {
        assume hf(w) {
          apply adj_existence for x, y, w
        }
      }
      connect hf(adj(x, y)) \wedge \forall w (hf(w) \to (in(w, adj(x, y)) \leftrightarrow in(w, x) \vee equal(w, y)))
      lift for adj(x, y) conclude \exists z (hf(z) \wedge \forall w (hf(w) \to (in(w, z) \leftrightarrow in(w, x) \vee equal(w, y))))
    }
  }
}

theorem hf_satisfies_axiom_of_separation \forall^P \phi[1] \forall x (hf(x) \to \exists y (hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow in(z, x) \wedge \phi(z))))) {
  any predicate \phi[1], x {
    assume hf(x) {
      apply invoke hf_is_irrefrel_wellfounded_finite for x
      split 3 irrefrel(x, in) \wedge wellfounded(x, in) \wedge finite(x)
      apply sep_is_subset for x, \phi
      connect finite(x) \wedge subset(sep(x, \phi), x)
      apply invoke subset_of_finite_is_finite for x, sep(x, \phi)
      any p {
        assume in(p, sep(x, \phi)) {
          apply invoke rightward sep_existence for x, \phi, p
          split 1 in(p, x) \wedge \phi(p)
          connect hf(x) \wedge in(p, x)
          apply invoke element_of_hf_is_hf for x, p
        }
      }
      connect finite(sep(x, \phi)) \wedge \forall p (in(p, sep(x, \phi)) \to hf(p))
      apply invoke finite_set_of_hf_is_hf for sep(x, \phi)
      any z {
        assume hf(z) {
          apply sep_existence for x, \phi, z
        }
      }
      connect hf(sep(x, \phi)) \wedge \forall z (hf(z) \to (in(z, sep(x, \phi)) \leftrightarrow in(z, x) \wedge \phi(z)))
      lift for sep(x, \phi) conclude \exists y (hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow in(z, x) \wedge \phi(z))))
    }
  }
}

theorem hf_satisfies_axiom_of_union \forall x (hf(x) \to \exists y (hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow \exists w (hf(w) \wedge in(z, w) \wedge in(w, x)))))) {
  any x {
    assume hf(x) {
      apply invoke hf_is_irrefrel_wellfounded_finite for x
      split 3 irrefrel(x, in) \wedge wellfounded(x, in) \wedge finite(x)
      any p {
        assume in(p, x) {
          connect hf(x) \wedge in(p, x)
          apply invoke element_of_hf_is_hf for x, p
          apply invoke hf_is_irrefrel_wellfounded_finite for p
          split 3 irrefrel(p, in) \wedge wellfounded(p, in) \wedge finite(p)
        }
      }
      connect finite(x) \wedge \forall p (in(p, x) \to finite(p))
      apply invoke finite_bigcup_exists_uniquely for x
      some y such \exists! y (finite(y) \wedge bigcup(x, y)) {
        split finite(y) \wedge bigcup(x, y)
        any p {
          assume in(p, y) {
            apply invoke rightward bigcup(x, y) for p
            some q such \exists q (in(p, q) \wedge in(q, x)) {
              split in(p, q) \wedge in(q, x)
              connect hf(x) \wedge in(q, x)
              apply invoke element_of_hf_is_hf for x, q
              connect hf(q) \wedge in(p, q)
              apply invoke element_of_hf_is_hf for q, p
            }
          }
        }
        connect finite(y) \wedge \forall p (in(p, y) \to hf(p))
        apply invoke finite_set_of_hf_is_hf for y
        any z {
          assume hf(z) {
            assume in(z, y) {
              apply invoke rightward bigcup(x, y) for z
              some w such \exists w (in(z, w) \wedge in(w, x)) {
                split in(z, w) \wedge in(w, x)
                connect hf(x) \wedge in(w, x)
                apply invoke element_of_hf_is_hf for x, w
                connect hf(w) \wedge in(z, w) \wedge in(w, x)
                lift for w conclude \exists w (hf(w) \wedge in(z, w) \wedge in(w, x))
              }
            }
            assume \exists w (hf(w) \wedge in(z, w) \wedge in(w, x)) {
              some w such \exists w (hf(w) \wedge in(z, w) \wedge in(w, x)) {
                split hf(w) \wedge in(z, w) \wedge in(w, x)
                connect in(z, w) \wedge in(w, x)
                lift for w conclude \exists w (in(z, w) \wedge in(w, x))
                apply invoke leftward bigcup(x, y) for z
              }
            }
            connect in(z, y) \leftrightarrow \exists w (hf(w) \wedge in(z, w) \wedge in(w, x))
          }
        }
        connect hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow \exists w (hf(w) \wedge in(z, w) \wedge in(w, x))))
        lift for y conclude \exists y (hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow \exists w (hf(w) \wedge in(z, w) \wedge in(w, x)))))
      }
    }
  }
}

theorem hf_satisfies_axiom_of_replacement \forall^P \psi[2] (\forall x \forall y \forall y' (hf(x) \wedge hf(y) \wedge hf(y') \to (\psi(x, y) \wedge \psi(x, y') \to equal(y, y'))) \to \forall X (hf(X) \to \exists Y (hf(Y) \wedge \forall y (hf(y) \to (in(y, Y) \leftrightarrow \exists x (hf(x) \wedge in(x, X) \wedge \psi(x, y))))))) {
  any predicate \psi[2] {
    assume \forall x \forall y \forall y' (hf(x) \wedge hf(y) \wedge hf(y') \to (\psi(x, y) \wedge \psi(x, y') \to equal(y, y'))) {
      any x, y, y' {
        assume hf(x) \wedge hf(y) \wedge \psi(x, y) \wedge hf(x) \wedge hf(y') \wedge \psi(x, y') {
          split hf(x) \wedge hf(y) \wedge \psi(x, y) \wedge hf(x) \wedge hf(y') \wedge \psi(x, y')
          connect hf(x) \wedge hf(y) \wedge hf(y')
          apply invoke \forall x \forall y \forall y' (hf(x) \wedge hf(y) \wedge hf(y') \to (\psi(x, y) \wedge \psi(x, y') \to equal(y, y'))) for x, y, y'
          connect \psi(x, y) \wedge \psi(x, y')
          invoke \psi(x, y) \wedge \psi(x, y') \to equal(y, y')
        }
      }
      fold for functional conclude functional(\lambda^P x, y. hf(x) \wedge hf(y) \wedge \psi(x, y))
      any X {
        assume hf(X) {
          apply invoke hf_is_irrefrel_wellfounded_finite for X
          split irrefrel(X, in) \wedge wellfounded(X, in) \wedge finite(X)
          connect finite(X) \wedge functional(\lambda^P x, y. hf(x) \wedge hf(y) \wedge \psi(x, y))
          apply invoke finite_replacement_exists_uniquely for X, \lambda^P x, y. hf(x) \wedge hf(y) \wedge \psi(x, y)
          some Y such \exists! Y (finite(Y) \wedge replacement(X, \lambda^P x, y. hf(x) \wedge hf(y) \wedge \psi(x, y), Y)) {
            split finite(Y) \wedge replacement(X, \lambda^P x, y. hf(x) \wedge hf(y) \wedge \psi(x, y), Y)
            any y {
              assume in(y, Y) {
                apply invoke rightward replacement(X, \lambda^P x, y. hf(x) \wedge hf(y) \wedge \psi(x, y), Y) for y
                some x such \exists x (in(x, X) \wedge hf(x) \wedge hf(y) \wedge \psi(x, y)) {
                  split 3 in(x, X) \wedge hf(x) \wedge hf(y) \wedge \psi(x, y)
                }
              }
            }
            connect finite(Y) \wedge \forall y (in(y, Y) \to hf(y))
            apply invoke finite_set_of_hf_is_hf for Y
            any y {
              assume hf(y) {
                assume in(y, Y) {
                  apply invoke rightward replacement(X, \lambda^P x, y. hf(x) \wedge hf(y) \wedge \psi(x, y), Y) for y
                  some x such \exists x (in(x, X) \wedge hf(x) \wedge hf(y) \wedge \psi(x, y)) {
                    split in(x, X) \wedge hf(x) \wedge hf(y) \wedge \psi(x, y)
                    connect in(x, X) \wedge hf(x) \wedge \psi(x, y)
                    lift for x conclude \exists x (in(x, X) \wedge hf(x) \wedge \psi(x, y))
                  }
                }
                assume \exists x (in(x, X) \wedge hf(x) \wedge \psi(x, y)) {
                  some x such \exists x (in(x, X) \wedge hf(x) \wedge \psi(x, y)) {
                    split in(x, X) \wedge hf(x) \wedge \psi(x, y)
                    connect in(x, X) \wedge hf(x) \wedge hf(y) \wedge \psi(x, y)
                    lift for x conclude \exists x (in(x, X) \wedge hf(x) \wedge hf(y) \wedge \psi(x, y))
                  }
                  apply invoke leftward replacement(X, \lambda^P x, y. hf(x) \wedge hf(y) \wedge \psi(x, y), Y) for y
                }
                connect in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge hf(x) \wedge \psi(x, y))
              }
            }
            connect hf(Y) \wedge \forall y (hf(y) \to (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge hf(x) \wedge \psi(x, y))))
            lift for Y conclude \exists Y (hf(Y) \wedge \forall y (hf(y) \to (in(y, Y) \leftrightarrow \exists x (in(x, X) \wedge hf(x) \wedge \psi(x, y)))))
          }
        }
      }
    }
  }
}

theorem hf_satisfies_axiom_of_powerset \forall x (hf(x) \to \exists y (hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow subset(z, x))))) {
  any x {
    assume hf(x) {
      apply invoke hf_is_irrefrel_wellfounded_finite for x
      split 3 irrefrel(x, in) \wedge wellfounded(x, in) \wedge finite(x)
      apply invoke finite_powerset_exists_uniquely for x
      some y such \exists! y (finite(y) \wedge powerset(x, y)) {
        split finite(y) \wedge powerset(x, y)
        any z {
          assume in(z, y) {
            apply invoke rightward powerset(x, y) for z
            connect hf(x) \wedge subset(z, x)
            apply invoke subset_of_hf_is_hf for x, z
          }
        }
        connect finite(y) \wedge \forall z (in(z, y) \to hf(z))
        apply invoke finite_set_of_hf_is_hf for y
        any z {
          assume hf(z) {
            apply powerset(x, y) for z
          }
        }
        connect hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow subset(z, x)))
        lift for y conclude \exists y (hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow subset(z, x))))
      }
    }
  }
}

theorem hf_satisfies_axiom_of_foundation \forall x (hf(x) \to (neq(x, emptyset) \to \exists y (hf(y) \wedge in(y, x) \wedge \forall z (hf(z) \to (in(z, y) \to notin(z, x)))))) {
  any A {
    assume hf(A) {
      assume neq(A, emptyset) {
        apply invoke hf_is_irrefrel_wellfounded_finite for A
        split irrefrel(A, in) \wedge wellfounded(A, in) \wedge finite(A)
        apply subset_reflexivity for A
        connect subset(A, A) \wedge neq(A, emptyset)
        apply invoke wellfounded(A, in) for A
        some y such \exists y (minimal(in, A, y)) {
          split minimal(in, A, y)
          connect hf(A) \wedge in(y, A)
          apply invoke element_of_hf_is_hf for A, y
          any z {
            assume hf(z) {
              assume in(z, y) {
                deny in(z, A) {
                  apply law_of_excluded_middle for \lambda^P. equal(z, y)
                  divide equal(z, y) \vee neq(z, y)
                    case equal(z, y) {
                      substitute in(z, y) for z: y
                      apply invoke irrefrel(A, in) for y
                      contradict in(y, y)
                    }
                    case neq(z, y) {
                      connect in(z, A) \wedge neq(z, y)
                      apply invoke minimal_core(in, A, y) for z
                      contradict in(z, y)
                    }
                }
              }
            }
          }
          connect hf(y) \wedge in(y, A) \wedge \forall z (hf(z) \to (in(z, y) \to notin(z, A)))
          lift for y conclude \exists y (hf(y) \wedge in(y, A) \wedge \forall z (hf(z) \to (in(z, y) \to notin(z, A))))
        }
      }
    }
  }
}
