include "zfc_tc.proof"

definition predicate hf(x) as \exists y (finite(y) \wedge tcm(x, y))

definition predicate ptrans(predicate \phi[1]) as \forall x \forall y (\phi(x) \wedge in(y, x) \to \phi(y))

theorem hf_is_trans ptrans(hf) {
  any x, y {
    assume hf(x) \wedge in(y, x) {
      split hf(x) \wedge in(y, x)
      some t such hf(x) {
        split finite(t) \wedge tcm(x, t)
        apply sep_is_subset for t, \lambda^P z. tc(owns, y, z)
        connect finite(t) \wedge subset(sep(t, \lambda^P z. tc(owns, y, z)), t)
        apply invoke subset_of_finite_is_finite for t, sep(t, \lambda^P z. tc(owns, y, z))
        any z {
          assume in(z, sep(t, \lambda^P z. tc(owns, y, z))) {
            apply invoke sep_satisfies_predicate for t, \lambda^P z. tc(owns, y, z), z
          }
          assume tc(owns, y, z) {
            connect in(y, x) \wedge tc(owns, y, z)
            apply invoke tc_add_first for owns, x, y, z
            apply invoke leftward tcm(x, t) for z
            connect in(z, t) \wedge tc(owns, y, z)
            apply invoke leftward sep_existence for t, \lambda^P z. tc(owns, y, z), z
          }
          connect in(z, sep(t, \lambda^P z. tc(owns, y, z))) \leftrightarrow tc(owns, y, z)
        }
        fold for tcm conclude tcm(y, sep(t, \lambda^P z. tc(owns, y, z)))
        connect finite(sep(t, \lambda^P z. tc(owns, y, z))) \wedge tcm(y, sep(t, \lambda^P z. tc(owns, y, z)))
        lift for sep(t, \lambda^P z. tc(owns, y, z)) conclude \exists s (finite(s) \wedge tcm(y, s))
      }
      fold for hf conclude hf(y)
    }
  }
  fold for ptrans conclude ptrans(hf)
}

theorem hf_satisfies_axiom_of_extensionality \forall x \forall y (hf(x) \wedge hf(y) \to (\forall z (hf(z) \to (in(z, x) \leftrightarrow in(z, y))) \to equal(x, y))) {
  assert hf_is_trans
  any x, y {
    assume hf(x) \wedge hf(y) {
      split hf(x) \wedge hf(y)
      assume \forall z (hf(z) \to (in(z, x) \leftrightarrow in(z, y))) {
        any z {
          assume in(z, x) {
            connect hf(x) \wedge in(z, x)
            apply invoke ptrans(hf) for x, z
            apply invoke \forall z (hf(z) \to (in(z, x) \leftrightarrow in(z, y))) for z
            invoke rightward in(z, x) \leftrightarrow in(z, y)
          }
          assume in(z, y) {
            connect hf(y) \wedge in(z, y)
            apply invoke ptrans(hf) for y, z
            apply invoke \forall z (hf(z) \to (in(z, x) \leftrightarrow in(z, y))) for z
            invoke leftward in(z, x) \leftrightarrow in(z, y)
          }
          connect in(z, x) \leftrightarrow in(z, y)
        }
        apply invoke axiom_of_extensionality for x, y
      }
    }
  }
}

theorem emptyset_is_hf hf(emptyset) {
  assert emptyset_is_finite
  assert emptyset_is_tcm_of_emptyset
  connect finite(emptyset) \wedge tcm(emptyset, emptyset)
  lift for emptyset conclude hf(emptyset)
}

theorem hf_satisfies_axiom_of_emptyset \exists x (hf(x) \wedge \forall y (hf(y) \to notin(y, x))) {
  assert emptyset_is_hf
  any y {
    assume hf(y) {
      apply emptyset_existence for y
    }
  }
  connect hf(emptyset) \wedge \forall y (hf(y) \to notin(y, emptyset))
  lift for emptyset conclude \exists x (hf(x) \wedge \forall y (hf(y) \to notin(y, x)))
}

theorem hf_satisfies_axiom_of_adjunction \forall x \forall y (hf(x) \wedge hf(y) \to \exists z (hf(z) \wedge \forall w (hf(w) \to (in(w, z) \leftrightarrow in(w, x) \vee equal(w, y))))) {
  any x, y {
    assume hf(x) \wedge hf(y) {
      split hf(x) \wedge hf(y)
      some p such hf(x) {
        split finite(p) \wedge tcm(x, p)
        some q such hf(y) {
          split finite(q) \wedge tcm(y, q)
          connect finite(p) \wedge finite(q)
          apply invoke finite_cup_exists_uniquely for p, q
          some r such \exists! r (finite(r) \wedge cup(p, q, r)) {
            split finite(r) \wedge cup(p, q, r)
            connect tcm(x, p) \wedge tcm(y, q) \wedge cup(p, q, r)
            apply invoke tcm_adjunction for x, y, p, q, r
            apply invoke finite_adj for r, y
            connect finite(adj(r, y)) \wedge tcm(adj(x, y), adj(r, y))
            lift for adj(r, y) conclude hf(adj(x, y))
            any w {
              assume hf(w) {
                apply adj_existence for x, y, w
              }
            }
            connect hf(adj(x, y)) \wedge (\forall w (hf(w) \to (in(w, adj(x, y)) \leftrightarrow in(w, x) \vee equal(w, y))))
            lift for adj(x, y) conclude \exists z (hf(z) \wedge \forall w (hf(w) \to (in(w, z) \leftrightarrow in(w, x) \vee equal(w, y))))
          }
        }
      }
    }
  }
}

theorem hf_satisfies_axiom_of_separation \forall^P \phi[1] \forall x (hf(x) \to \exists y (hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow in(z, x) \wedge \phi(z))))) {
  any predicate \phi[1], x {
    assume hf(x) {
      some p such hf(x) {
        split finite(p) \wedge tcm(x, p)
        apply sep_is_subset for x, \phi
        apply sep_is_subset for p, \lambda^P z. tc(owns, sep(x, \phi), z)
        connect finite(p) \wedge subset(sep(p, \lambda^P z. tc(owns, sep(x, \phi), z)), p)
        apply invoke subset_of_finite_is_finite for p, sep(p, \lambda^P z. tc(owns, sep(x, \phi), z))
        show tcm(sep(x, \phi), sep(p, \lambda^P z. tc(owns, sep(x, \phi), z))) {
          any s {
            assume in(s, sep(p, \lambda^P z. tc(owns, sep(x, \phi), z))) {
              apply invoke rightward sep_existence for p, \lambda^P z. tc(owns, sep(x, \phi), z), s
              split 2 in(s, p) \wedge tc(owns, sep(x, \phi), s)
            }
            assume tc(owns, sep(x, \phi), s) {
              connect tc(owns, sep(x, \phi), s) \wedge subset(sep(x, \phi), x)
              apply invoke tc_subset for sep(x, \phi), s, x
              apply invoke leftward tcm(x, p) for s
              connect in(s, p) \wedge tc(owns, sep(x, \phi), s)
              apply invoke leftward sep_existence for p, \lambda^P z. tc(owns, sep(x, \phi), z), s
            }
            connect in(s, sep(p, \lambda^P z. tc(owns, sep(x, \phi), z))) \leftrightarrow tc(owns, sep(x, \phi), s)
          }
          fold for tcm conclude tcm(sep(x, \phi), sep(p, \lambda^P z. tc(owns, sep(x, \phi), z)))
        }
        connect finite(sep(p, \lambda^P z. tc(owns, sep(x, \phi), z))) \wedge tcm(sep(x, \phi), sep(p, \lambda^P z. tc(owns, sep(x, \phi), z)))
        lift for sep(p, \lambda^P z. tc(owns, sep(x, \phi), z)) conclude hf(sep(x, \phi))
        any z {
          assume hf(z) {
            apply sep_existence for x, \phi
          }
        }
        connect hf(sep(x, \phi)) \wedge \forall z (hf(z) \to (in(z, sep(x, \phi)) \leftrightarrow in(z, x) \wedge \phi(z)))
        lift for sep(x, \phi) conclude \exists y (hf(y) \wedge \forall z (hf(z) \to (in(z, y) \leftrightarrow in(z, x) \wedge \phi(z))))
      }
    }
  }
}
