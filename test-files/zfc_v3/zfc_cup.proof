include "zfc_operation.proof"

definition predicate cup(X, Y, Z) as \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y))

theorem cup_is_unique \forall X \forall Y \forall Z \forall Z' (cup(X, Y, Z) \wedge cup(X, Y, Z') \to equal(Z, Z')) {
  any X, Y, Z, Z' {
    assume cup(X, Y, Z) \wedge cup(X, Y, Z') {
      split cup(X, Y, Z) \wedge cup(X, Y, Z')
      expand cup(X, Y, Z) for cup
      expand cup(X, Y, Z') for cup
      connect \forall z (in(z, Z) \leftrightarrow in(z, X) \vee in(z, Y)) \wedge \forall z (in(z, Z') \leftrightarrow in(z, X) \vee in(z, Y))
      apply invoke set_is_unique_for_predicate for \lambda^P z. in(z, X) \vee in(z, Y), Z, Z'
    }
  }
}

theorem cup_of_trans_is_trans \forall X \forall Y \forall Z (trans(X) \wedge trans(Y) \wedge cup(X, Y, Z) \to trans(Z)) {
  any X, Y, Z {
    assume trans(X) \wedge trans(Y) \wedge cup(X, Y, Z) {
      split trans(X) \wedge trans(Y) \wedge cup(X, Y, Z)
      any p, q {
        assume in(p, Z) \wedge in(q, p) {
          split in(p, Z) \wedge in(q, p)
          apply invoke rightward cup(X, Y, Z) for p
          divide in(p, X) \vee in(p, Y)
            case in(p, X) {
              connect in(p, X) \wedge in(q, p)
              apply invoke trans(X) for p, q
              pad in(q, X) conclude in(q, X) \vee in(q, Y)
            }
            case in(p, Y) {
              connect in(p, Y) \wedge in(q, p)
              apply invoke trans(Y) for p, q
              pad in(q, Y) conclude in(q, X) \vee in(q, Y)
            }
          apply invoke leftward cup(X, Y, Z) for q
        }
      }
      fold for trans conclude trans(Z)
    }
  }
}

theorem cup_of_irrefrel_is_irrefrel \forall^P \phi[2] \forall X \forall Y \forall Z (irrefrel(X, \phi) \wedge irrefrel(Y, \phi) \wedge cup(X, Y, Z) \to irrefrel(Z, \phi)) {
  any predicate \phi[2], X, Y, Z {
    assume irrefrel(X, \phi) \wedge irrefrel(Y, \phi) \wedge cup(X, Y, Z) {
      split irrefrel(X, \phi) \wedge irrefrel(Y, \phi) \wedge cup(X, Y, Z)
      any z {
        assume in(z, Z) {
          apply invoke rightward cup(X, Y, Z) for z
          divide in(z, X) \vee in(z, Y)
            case in(z, X) {
              apply invoke irrefrel(X, \phi) for z
            }
            case in(z, Y) {
              apply invoke irrefrel(Y, \phi) for z
            }
        }
      }
      fold for irrefrel conclude irrefrel(Z, \phi)
    }
  }
}

theorem subset_of_cup_disjoint_left_is_subset_of_right \forall X \forall Y \forall Z \forall A (cup(X, Y, Z) \wedge subset(A, Z) \wedge equal(cap(A, X), emptyset) \to subset(A, Y)) {
  any X, Y, Z, A {
    assume cup(X, Y, Z) \wedge subset(A, Z) \wedge equal(cap(A, X), emptyset) {
      split cup(X, Y, Z) \wedge subset(A, Z) \wedge equal(cap(A, X), emptyset)
      any y {
        assume in(y, A) {
          apply invoke subset(A, Z) for y
          apply invoke rightward cup(X, Y, Z) for y
          divide in(y, X) \vee in(y, Y)
            case in(y, X) {
              connect in(y, A) \wedge in(y, X)
              apply invoke leftward cap_characterization for A, X, y
              substitute in(y, cap(A, X)) for cap(A, X): emptyset
              apply emptyset_existence for y
              contradict in(y, emptyset)
              explode in(y, Y)
            }
            case in(y, Y) {}
        }
      }
      fold for subset conclude subset(A, Y)
    }
  }
}

theorem cup_of_trans_wellfounded_is_wellfounded_left \forall X \forall Y \forall Z (trans(X) \wedge wellfounded(X, in) \wedge wellfounded(Y, in) \wedge cup(X, Y, Z) \to wellfounded(Z, in)) {
  any X, Y, Z {
    assume trans(X) \wedge wellfounded(X, in) \wedge wellfounded(Y, in) \wedge cup(X, Y, Z) {
      split trans(X) \wedge wellfounded(X, in) \wedge wellfounded(Y, in) \wedge cup(X, Y, Z)
      any A {
        assume subset(A, Z) \wedge neq(A, emptyset) {
          split subset(A, Z) \wedge neq(A, emptyset)
          apply law_of_excluded_middle for \lambda^P. equal(cap(A, X), emptyset)
          divide equal(cap(A, X), emptyset) \vee neq(cap(A, X), emptyset)
            case equal(cap(A, X), emptyset) {
              connect cup(X, Y, Z) \wedge subset (A, Z) \wedge equal(cap(A, X), emptyset)
              apply invoke subset_of_cup_disjoint_left_is_subset_of_right for X, Y, Z, A
              connect subset(A, Y) \wedge neq(A, emptyset)
              apply invoke wellfounded(Y, in) for A
            }
            case neq(cap(A, X), emptyset) {
              apply cap_is_subset_right for A, X
              connect subset(cap(A, X), X) \wedge neq(cap(A, X), emptyset)
              apply invoke wellfounded(X, in) for cap(A, X)
              some a such \exists a (minimal(in, cap(A, X), a)) {
                split minimal(in, cap(A, X), a)
                apply invoke rightward cap_characterization for A, X, a
                split in(a, A) \wedge in(a, X)
                any x {
                  assume in(x, A) \wedge neq(x, a) {
                    split in(x, A) \wedge neq(x, a)
                    deny in(x, a) {
                      connect in(a, X) \wedge in(x, a)
                      apply invoke trans(X) for a, x
                      connect in(x, A) \wedge in(x, X)
                      apply invoke leftward cap_characterization for A, X, x
                      connect in(x, cap(A, X)) \wedge neq(x, a)
                      apply invoke minimal_core(in, cap(A, X), a) for x
                      contradict in(x, a)
                    }
                  }
                }
                fold for minimal_core conclude minimal_core(in, A, a)
                connect minimal(in, A, a)
                lift for a conclude \exists a (minimal(in, A, a))
              }
            }
        }
      }
      fold for wellfounded conclude wellfounded(Z, in)
    }
  }
}
