include "zfc_piterate.proof"

definition predicate fiterate(function f[1], n, c, x) as piterate(\lambda^P p, q. equal(f(p), q), n, c, x)

theorem fiterate_exists_base_step \forall^F f[1] \forall c (fiterate(f, emptyset, c, c)) {
  any function f[1], c {
    apply piterate_base_step for \lambda^P p, q. equal(f(p), q), c
    fold for fiterate conclude fiterate(f, emptyset, c, c)
  }
}

theorem fiterate_exists_induction_step \forall^F f[1] \forall n \forall c \forall x (natural(n) \wedge fiterate(f, n, c, x) \to fiterate(f, suc(n), c, f(x))) {
  any function f[1], n, c, x {
    assume natural(n) \wedge fiterate(f, n, c, x) {
      split natural(n) \wedge fiterate(f, n, c, x)
      expand fiterate(f, n, c, x) for fiterate
      connect natural(n) \wedge piterate(\lambda^P p, q. equal(f(p), q), n, c, x) \wedge equal(f(x), f(x))
      apply invoke piterate_induction_step for \lambda^P p, q. equal(f(p), q), n, c, x, f(x)
      fold for fiterate conclude fiterate(f, suc(n), c, f(x))
    }
  }
}

theorem fiterate_is_unique_base_step \forall^F f[1] \forall c \forall x (fiterate(f, emptyset, c, x) \to equal(x, c)) {
  any function f[1], c, x {
    assume fiterate(f, emptyset, c, x) {
      expand fiterate(f, emptyset, c, x) for fiterate
      some g such piterate(\lambda^P p, q. equal(f(p), q), emptyset, c, x) {
        split trace(\lambda^P p, q. equal(f(p), q), emptyset, g) \wedge in(op(emptyset, c), g) \wedge in(op(emptyset, x), g)
        split trace(\lambda^P p, q. equal(f(p), q), emptyset, g)
        connect in(op(emptyset, x), g) \wedge in(op(emptyset, c), g)
        split fun(g)
        apply invoke \forall x \forall y \forall y' (in(op(x, y), g) \wedge in(op(x, y'), g) \to equal(y, y')) for emptyset, x, c
      }
    }
  }
}

theorem fiterate_is_unique_induction_step \forall^F f[1] \forall n \forall c \forall x (natural(n) \wedge \forall x' (fiterate(f, n, c, x') \to equal(x', x)) \to \forall y (fiterate(f, suc(n), c, y) \to equal(y, f(x)))) {
  any function f[1], n, c, x {
    assume natural(n) \wedge \forall x' (fiterate(f, n, c, x') \to equal(x', x)) {
      any y {
        assume fiterate(f, suc(n), c, y) {
          split natural(n) \wedge \forall x' (fiterate(f, n, c, x') \to equal(x', x))
          apply invoke natural_is_ordinal for n
          split ordinal(n)
          apply invoke suc_of_natural_is_natural for n
          apply invoke natural_is_ordinal for suc(n)
          split ordinal(suc(n))
          expand fiterate(f, suc(n), c, y) for fiterate
          some h' such piterate(\lambda^P p, q. equal(f(p), q), suc(n), c, y) {
            split trace(\lambda^P p, q. equal(f(p), q), suc(n), h') \wedge in(op(emptyset, c), h') \wedge in(op(suc(n), y), h')
            split trace(\lambda^P p, q. equal(f(p), q), suc(n), h')
            apply in_suc for n
            apply invoke \forall k (in(k, suc(n)) \to \exists p \exists q (in(op(k, p), h') \wedge in(op(suc(k), q), h') \wedge equal(f(p), q))) for n
            some p, q such \exists p \exists q (in(op(n, p), h') \wedge in(op(suc(n), q), h') \wedge equal(f(p), q)) {
              split in(op(n, p), h') \wedge in(op(suc(n), q), h') \wedge equal(f(p), q)
              connect in(op(suc(n), q), h') \wedge in(op(suc(n), y), h')
              split 2 fun(h')
              apply invoke \forall x \forall y \forall y' (in(op(x, y), h') \wedge in(op(x, y'), h') \to equal(y, y')) for suc(n), q, y
              apply invoke removing_op_fun for h', suc(n), y
              connect fun(h') \wedge dom(h', suc(suc(n))) \wedge in(op(suc(n), y), h')
              apply invoke removing_op_dom for h', suc(suc(n)), suc(n), y
              apply invoke irrefrel_not_contain_itself for suc(n)
              apply invoke rem_suc for suc(n)
              substitute dom(rem(h', op(suc(n), y)), rem(suc(suc(n)), suc(n))) for rem(suc(suc(n)), suc(n)): suc(n)
              apply suc_is_not_emptyset for n
              connect in(op(emptyset, c), h') \wedge neq(suc(n), emptyset)
              apply invoke removing_op_lem1 for h', emptyset, c, suc(n), y
              any k {
                assume in(k, n) {
                  pad in(k, n) conclude in(k, n) \vee equal(k, n)
                  apply invoke leftward suc_characterization for n, k
                  apply invoke \forall k (in(k, suc(n)) \to \exists p \exists q (in(op(k, p), h') \wedge in(op(suc(k), q), h') \wedge equal(f(p), q))) for k
                  some p', q' such \exists p \exists q (in(op(k, p), h') \wedge in(op(suc(k), q), h') \wedge equal(f(p), q)) {
                    split in(op(k, p'), h') \wedge in(op(suc(k), q'), h') \wedge equal(q', f(p'))
                    deny equal(k, suc(n)) {
                      substitute in(k, suc(n)) for k: suc(n)
                      apply invoke irrefrel_not_contain_itself for suc(n)
                      contradict in(suc(n), suc(n))
                    }
                    connect in(op(k, p'), h') \wedge neq(k, suc(n))
                    apply invoke removing_op_lem1 for h', k, p', suc(n), y
                    deny equal(k, n) {
                      substitute in(k, n) for k: n
                      apply invoke irrefrel_not_contain_itself for n
                      contradict in(n, n)
                    }
                    connect natural(n) \wedge neq(k, n)
                    apply invoke natural_implies_suc_is_injection_contrapositive for n, k
                    connect in(op(suc(k), q'), h') \wedge neq(suc(k), suc(n))
                    apply invoke removing_op_lem1 for h', suc(k), q', suc(n), y
                    connect in(op(k, p'), rem(h', op(suc(n), y))) \wedge in(op(suc(k), q'), rem(h', op(suc(n), y))) \wedge equal(q', f(p'))
                    lift for p', q' conclude \exists p' \exists q' (in(op(k, p'), rem(h', op(suc(n), y))) \wedge in(op(suc(k), q'), rem(h', op(suc(n), y))) \wedge equal(q', f(p')))
                  }
                }
              }
              connect trace(\lambda^P p, q. equal(f(p), q), n, rem(h', op(suc(n), y)))
              deny equal(n, suc(n)) {
                substitute in(n, suc(n)) for suc(n): n
                apply invoke irrefrel_not_contain_itself for n
                contradict in(n, n)
              }
              connect in(op(n, p), h') \wedge neq(n, suc(n))
              apply invoke removing_op_lem1 for h', n, p, suc(n), y
              connect trace(\lambda^P p, q. equal(f(p), q), n, rem(h', op(suc(n), y))) \wedge in(op(emptyset, c), rem(h', op(suc(n), y))) \wedge in(op(n, p), rem(h', op(suc(n), y)))
              lift for rem(h', op(suc(n), y)) conclude piterate(\lambda^P p', q'. equal(q', f(p')), n, c, p)
              fold for fiterate conclude fiterate(f, n, c, p)
              apply invoke \forall x' (fiterate(f, n, c, x') \to equal(x', x)) for p
              substitute equal(f(p), q) for p: x, q: y
            }
          }          
        }
      }
    }
  }  
}

theorem fiterate_exists_uniquely_base_step \forall^F f[1] \forall c \exists! x (fiterate(f, emptyset, c, x)) {
  any function f[1], c {
    apply fiterate_exists_base_step for f, c
    any x {
      apply fiterate_is_unique_base_step for f, c, x
    }
    connect fiterate(f, emptyset, c, c) \wedge \forall x (fiterate(f, emptyset, c, x) \to equal(x, c))
    characterize for c conclude \exists! x (fiterate(f, emptyset, c, x))
  }
}

theorem recursion_exists_uniquely_induction_step \forall^F f[1] \forall n \forall c (natural(n) \wedge \exists! x (fiterate(f, n, c, x)) \to \exists! x (fiterate(f, suc(n), c, x))) {
  any function f[1], n, c {
    assume natural(n) \wedge \exists! x (fiterate(f, n, c, x)) {
      split natural(n) \wedge \exists! x (fiterate(f, n, c, x))
      apply invoke natural_is_ordinal for n
      split ordinal(n)
      some x such \exists! x (fiterate(f, n, c, x)) {
        connect natural(n) \wedge fiterate(f, n, c, x)
        apply invoke fiterate_exists_induction_step for f, n, c, x
        connect natural(n) \wedge \forall x' (fiterate(f, n, c, x') \to equal(x', x))
        apply invoke fiterate_is_unique_induction_step for f, n, c, x
        connect fiterate(f, suc(n), c, f(x)) \wedge \forall y' (fiterate(f, suc(n), c, y') \to equal(y', f(x)))
        characterize for f(x) conclude \exists! x (fiterate(f, suc(n), c, x))
      }
    }
  }
}

theorem recursion_exists_uniquely \forall^F f[1] \forall n \forall c (natural(n) \to \exists! x (fiterate(f, n, c, x))) {
  any function f[1], c {
    apply fiterate_exists_uniquely_base_step for f, c
    any n {
      assume natural(n) {
        assume \exists! x (fiterate(f, n, c, x)) {
          connect natural(n) \wedge \exists! x (fiterate(f, n, c, x))
          apply invoke recursion_exists_uniquely_induction_step for f, n, c
        }
      }
    }
    connect \exists! x (fiterate(f, emptyset, c, x)) \wedge \forall n (natural(n) \to (\exists! x (fiterate(f, n, c, x)) \to \exists! x (fiterate(f, suc(n), c, x))))
    apply invoke natural_induction for \lambda^P n. \exists! x (fiterate(f, n, c, x))
  }
}

definition function iterate by recursion_exists_uniquely
existence iterate_existence \forall^F f[1] \forall n \forall c (natural(n) \to fiterate(f, n, c, iterate(f, n, c))) by iterate
uniqueness iterate_uniqueness \forall^F f[1] \forall n \forall c (natural(n) \to \forall x (fiterate(f, n, c, x) \to equal(x, iterate(f, n, c)))) by iterate

theorem iterate_characterization \forall^F f[1] \forall c (equal(iterate(f, emptyset, c), c) \wedge \forall n (natural(n) \to equal(iterate(f, suc(n), c), f(iterate(f, n, c))))) {
  any function f[1], c {
    assert emptyset_is_natural
    apply invoke iterate_existence for f, emptyset, c
    apply fiterate_exists_base_step for f, c
    apply invoke iterate_uniqueness for f, emptyset, c
    apply invoke \forall x (fiterate(f, emptyset, c, x) \to equal(x, iterate(f, emptyset, c))) for c
    any n {
      assume natural(n) {
        apply invoke suc_of_natural_is_natural for n
        apply invoke iterate_existence for f, n, c
        connect natural(n) \wedge fiterate(f, n, c, iterate(f, n, c))
        apply invoke fiterate_exists_induction_step for f, n, c, iterate(f, n, c)
        apply invoke iterate_uniqueness for f, suc(n), c
        apply invoke \forall x (fiterate(f, suc(n), c, x) \to equal(x, iterate(f, suc(n), c))) for f(iterate(f, n, c))
      }
    }
    connect equal(iterate(f, emptyset, c), c) \wedge \forall n (natural(n) \to equal(iterate(f, suc(n), c), f(iterate(f, n, c))))
  }
}

theorem natural_is_constructed_by_emptyset_and_suc \forall n (natural(n) \to equal(iterate(suc, n, emptyset), n)) {
  apply iterate_characterization for suc, emptyset
  split equal(iterate(suc, emptyset, emptyset), emptyset) \wedge \forall n (natural(n) \to equal(iterate(suc, suc(n), emptyset), suc(iterate(suc, n, emptyset))))
  any n {
    assume natural(n) {
      apply invoke \forall n (natural(n) \to equal(iterate(suc, suc(n), emptyset), suc(iterate(suc, n, emptyset)))) for n
      assume equal(iterate(suc, n, emptyset), n) {
        substitute equal(iterate(suc, suc(n), emptyset), suc(iterate(suc, n, emptyset))) for iterate(suc, n, emptyset): n
      }
    }
  }
  connect equal(iterate(suc, emptyset, emptyset), emptyset) \wedge \forall n (natural(n) \to (equal(iterate(suc, n, emptyset), n) \to equal(iterate(suc, suc(n), emptyset), suc(n))))
  apply invoke natural_induction for \lambda^P n. equal(iterate(suc, n, emptyset), n)
}
