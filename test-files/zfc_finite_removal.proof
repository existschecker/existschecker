include "zfc_finite_recursion.proof"

axiom axiom_of_removal \forall x \forall y \exists z \forall w (in(w, z) \leftrightarrow in(w, x) \wedge neq(w, y))

theorem removal_exists_uniquely \forall x \forall y \exists! z \forall w (in(w, z) \leftrightarrow in(w, x) \wedge neq(w, y)) {
  any x, y {
    apply axiom_of_removal for x, y
    some z such \exists z \forall w (in(w, z) \leftrightarrow in(w, x) \wedge neq(w, y)) {
      any z' {
        assume \forall w (in(w, z') \leftrightarrow in(w, x) \wedge neq(w, y)) {
          connect \forall w (in(w, z') \leftrightarrow in(w, x) \wedge neq(w, y)) \wedge \forall w (in(w, z) \leftrightarrow in(w, x) \wedge neq(w, y))
          apply invoke set_is_unique_for_each_predicate for lambda w. in(w, x) \wedge neq(w, y), z', z
        }
      }
      connect \forall w (in(w, z) \leftrightarrow in(w, x) \wedge neq(w, y)) \wedge \forall z' (\forall w (in(w, z') \leftrightarrow in(w, x) \wedge neq(w, y)) \to equal(z', z))
      characterize for z conclude \exists! z \forall w (in(w, z) \leftrightarrow in(w, x) \wedge neq(w, y))
    }
  }
}

definition function rem by removal_exists_uniquely
existence rem_existence \forall x \forall y \forall w (in(w, rem(x, y)) \leftrightarrow in(w, x) \wedge neq(w, y)) by rem
uniqueness rem_uniqueness \forall x \forall y \forall z (\forall w (in(w, z) \leftrightarrow in(w, x) \wedge neq(w, y)) \to equal(z, rem(x, y))) by rem

theorem rem_suc \forall x (notin(x, x) \to equal(rem(suc(x), x), x)) {
  any x {
    assume notin(x, x) {
      any y {
        assume in(y, rem(suc(x), x)) {
          apply invoke rightward rem_existence for suc(x), x, y
          split in(y, suc(x)) \wedge neq(y, x)
          apply invoke rightward suc_characterization for x, y
          divide in(y, x) \vee equal(y, x)
            case in(y, x) {}
            case equal(y, x) {
              contradict equal(y, x)
              explode in(y, x)
            }
        }
        assume in(y, x) {
          pad in(y, x) conclude in(y, x) \vee equal(y, x)
          apply invoke leftward suc_characterization for x, y
          deny equal(y, x) {
            substitute in(y, x) for y: x
            contradict in(x, x)
          }
          connect in(y, suc(x)) \wedge neq(y, x)
          apply invoke leftward rem_existence for suc(x), x, y
        }
        connect in(y, rem(suc(x), x)) \leftrightarrow in(y, x)
      }
      fold for equal conclude equal(rem(suc(x), x), x)
    }
  }
}

theorem removing_op_rel \forall R \forall x \forall y (rel(R) \to rel(rem(R, op(x, y)))) {
  any R, x, y {
    assume rel(R) {
      any z {
        assume in(z, rem(R, op(x, y))) {
          apply invoke rightward rem_existence for R, op(x, y), z
          split 1 in(z, R) \wedge neq(z, op(x, y))
          apply invoke rel(R) for z
        }
      }
      fold for rel conclude rel(rem(R, op(x, y)))
    }
  }
}

theorem removing_op_dom \forall f \forall X \forall x \forall y (fun(f) \wedge dom(f, X) \wedge in(op(x, y), f) \to dom(rem(f, op(x, y)), rem(X, x))) {
  any f, X, x, y {
    assume fun(f) \wedge dom(f, X) \wedge in(op(x, y), f) {
      split fun(f) \wedge dom(f, X) \wedge in(op(x, y), f)
      split fun(f)
      any p {
        assume in(p, rem(X, x)) {
          apply invoke rightward rem_existence for X, x, p
          split in(p, X) \wedge neq(p, x)
          apply invoke rightward dom(f, X) for p
          some q such \exists q (in(op(p, q), f)) {
            deny equal(op(p, q), op(x, y)) {
              apply invoke op_characterization for p, q, x, y
              split 1 equal(p, x) \wedge equal(q, y)
              contradict equal(p, x)
            }
            connect in(op(p, q), f) \wedge neq(op(p, q), op(x, y))
            apply invoke leftward rem_existence for f, op(x, y), op(p, q)
            lift for q conclude \exists q (in(op(p, q), rem(f, op(x, y))))
          }
        }
        assume \exists q (in(op(p, q), rem(f, op(x, y)))) {
          some q such \exists q (in(op(p, q), rem(f, op(x, y)))) {
            apply invoke rightward rem_existence for f, op(x, y), op(p, q)
            split in(op(p, q), f) \wedge neq(op(p, q), op(x, y))
            lift for q conclude \exists q (in(op(p, q), f))
            apply invoke leftward dom(f, X) for p
            apply law_of_excluded_middle for lambda. in(op(x, y), f)
            deny equal(p, x) {
              substitute in(op(x, y), f) for x: p
              connect in(op(p, q), f) \wedge in(op(p, y), f)
              apply invoke \forall x \forall y \forall y' (in(op(x, y), f) \wedge in(op(x, y'), f) \to equal(y, y')) for p, q, y
              substitute neq(op(p, q), op(x, y)) for x: p, y: q
              contradict equal(op(p, q), op(p, q))
            }
            connect in(p, X) \wedge neq(p, x)
            apply invoke leftward rem_existence for X, x, p
          }
        }
        connect in(p, rem(X, x)) \leftrightarrow \exists q (in(op(p, q), rem(f, op(x, y))))
      }
      fold for dom conclude dom(rem(f, op(x, y)), rem(X, x))
    }
  }
}

theorem removing_op_fun \forall f \forall x \forall y (fun(f) \to fun(rem(f, op(x, y)))) {
  any f, x, y {
    assume fun(f) {
      split fun(f)
      apply invoke removing_op_rel for f, x, y
      any p, q, q' {
        assume in(op(p, q), rem(f, op(x, y))) \wedge in(op(p, q'), rem(f, op(x, y))) {
          split in(op(p, q), rem(f, op(x, y))) \wedge in(op(p, q'), rem(f, op(x, y)))
          apply invoke rightward rem_existence for f, op(x, y), op(p, q)
          apply invoke rightward rem_existence for f, op(x, y), op(p, q')
          split 1 in(op(p, q), f) \wedge neq(op(p, q), op(x, y))
          split 1 in(op(p, q'), f) \wedge neq(op(p, q'), op(x, y))
          connect in(op(p, q), f) \wedge in(op(p, q'), f)
          apply invoke \forall x \forall y \forall y' (in(op(x, y), f) \wedge in(op(x, y'), f) \to equal(y, y')) for p, q, q'
        }
      }
      connect fun(rem(f, op(x, y)))
    }
  }
}

theorem removing_op_lem1 \forall R \forall x \forall y \forall p \forall q (in(op(x, y), R) \wedge neq(x, p) \to in(op(x, y), rem(R, op(p, q)))) {
  any R, x, y, p, q {
    assume in(op(x, y), R) \wedge neq(x, p) {
      split in(op(x, y), R) \wedge neq(x, p)
      deny equal(op(x, y), op(p, q)) {
        apply invoke op_characterization for x, y, p, q
        split 1 equal(x, p) \wedge equal(y, q)
        contradict equal(x, p)
      }
      connect in(op(x, y), R) \wedge neq(op(x, y), op(p, q))
      apply invoke leftward rem_existence for R, op(p, q), op(x, y)
    }
  }
}

theorem recursion_is_unique \forall c \forall^F g[1] \forall n (natural(n) \to \exists! x (recursion(lambda a. equal(a, c), lambda p, q. equal(q, g(p)))(n, x))) {
  any c, function f[1] {
    show \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(emptyset, x)) {
      assert emptyset_is_natural
      apply singleton_op_is_fun for emptyset, c
      apply singleton_op_dom for emptyset, c
      assert suc_emptyset_is_singleton_emptyset
      substitute dom(singleton(op(emptyset, c)), singleton(emptyset)) for singleton(emptyset): suc(emptyset)
      apply singleton_cor1 for op(emptyset, c)
      connect in(op(emptyset, c), singleton(op(emptyset, c))) \wedge equal(c, c)
      lift for c conclude \exists a (in(op(emptyset, a), singleton(op(emptyset, c))) \wedge equal(c, a))
      any k {
        assume in(k, emptyset) {
          apply emptyset_existence for k
          contradict in(k, emptyset)
          explode \exists p \exists q (in(op(k, p), singleton(op(emptyset, c))) \wedge in(op(suc(k), q), singleton(op(emptyset, c))) \wedge equal(q, f(p)))
        }
      }
      connect approx(singleton(op(emptyset, c)), emptyset, lambda a. equal(c, a), lambda p, q. equal(q, f(p)))
      connect approx(singleton(op(emptyset, c)), emptyset, lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(emptyset, c), singleton(op(emptyset, c)))
      lift for singleton(op(emptyset, c)) conclude \exists g (approx(g, emptyset, lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(emptyset, c), g))
      connect natural(emptyset) \wedge \exists g (approx(g, emptyset, lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(emptyset, c), g))
      fold for recursion conclude recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(emptyset, c)
      any x {
        assume recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(emptyset, x) {
          split 2 recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(emptyset, x)
          some g such \exists g (approx(g, emptyset, lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(emptyset, x), g)) {
            split approx(g, emptyset, lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(emptyset, x), g)
            split approx(g, emptyset, lambda a. equal(c, a), lambda p, q. equal(q, f(p)))
            some a' such \exists a' (in(op(emptyset, a'), g) \wedge equal(c, a')) {
              split in(op(emptyset, a'), g) \wedge equal(c, a')
              substitute in(op(emptyset, a'), g) for a': c
            }
            connect in(op(emptyset, x), g) \wedge in(op(emptyset, c), g)
            split 2 fun(g)
            apply invoke \forall x \forall y \forall y' (in(op(x, y), g) \wedge in(op(x, y'), g) \to equal(y, y')) for emptyset, x, c
          }
        }
      }
      connect recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(emptyset, c) \wedge \forall x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(emptyset, x) \to equal(x, c))
      characterize for c conclude \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(emptyset, x))
    }
    any n {
      apply law_of_excluded_middle for lambda. natural(n)
      divide natural(n) \vee \neg(natural(n))
        case natural(n) {
          assume \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x)) {
            some x such \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x)) {
              split 2 recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x)
              apply invoke rightward suc_of_natural_is_natural_and_vice_versa for n
              some g such \exists g (approx(g, n, lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(n, x), g)) {
                split approx(g, n, lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(n, x), g)
                split approx(g, n, lambda a. equal(c, a), lambda p, q. equal(q, f(p)))
                deny \exists q (in(op(suc(n), q), g)) {
                  some q such \exists q (in(op(suc(n), q), g)) {
                    apply invoke leftward dom(g, suc(n)) for suc(n)
                    apply invoke natural_is_irrefrelon for suc(n)
                    contradict in(suc(n), suc(n))
                  }
                }
                connect fun(g) \wedge \neg(\exists q (in(op(suc(n), q), g)))
                apply invoke adding_op_fun for g, suc(n), f(x)
                apply invoke adding_op_dom for g, suc(n), suc(n), f(x)
                fold for suc[2] conclude dom(adj(g, op(suc(n), f(x))), suc(suc(n)))
                some a such \exists a (in(op(emptyset, a), g) \wedge equal(c, a)) {
                  split in(op(emptyset, a), g) \wedge equal(c, a)
                  pad in(op(emptyset, a), g) conclude in(op(emptyset, a), g) \vee equal(op(emptyset, a), op(suc(n), f(x)))
                  apply invoke leftward adj_existence for g, op(suc(n), f(x)), op(emptyset, a)
                  connect in(op(emptyset, a), adj(g, op(suc(n), f(x)))) \wedge equal(c, a)
                  lift for a conclude \exists a (in(op(emptyset, a), adj(g, op(suc(n), f(x)))) \wedge equal(c, a))
                }
                pad equal(op(suc(n), f(x)), op(suc(n), f(x))) conclude in(op(suc(n), f(x)), g) \vee equal(op(suc(n), f(x)), op(suc(n), f(x)))
                apply invoke leftward adj_existence for g, op(suc(n), f(x)), op(suc(n), f(x))
                any k {
                  assume in(k, suc(n)) {
                    apply invoke rightward suc_characterization for n, k
                    divide in(k, n) \vee equal(k, n)
                      case in(k, n) {
                        apply invoke \forall k (in(k, n) \to \exists p \exists q (in(op(k, p), g) \wedge in(op(suc(k), q), g) \wedge equal(q, f(p)))) for k
                        some p, q such \exists p \exists q (in(op(k, p), g) \wedge in(op(suc(k), q), g) \wedge equal(q, f(p))) {
                          split in(op(k, p), g) \wedge in(op(suc(k), q), g) \wedge equal(q, f(p))
                          pad in(op(k, p), g) conclude in(op(k, p), g) \vee equal(op(k, p), op(suc(n), f(x)))
                          apply invoke leftward adj_existence for g, op(suc(n), f(x)), op(k, p)
                          pad in(op(suc(k), q), g) conclude in(op(suc(k), q), g) \vee equal(op(suc(k), q), op(suc(n), f(x)))
                          apply invoke leftward adj_existence for g, op(suc(n), f(x)), op(suc(k), q)
                          connect in(op(k, p), adj(g, op(suc(n), f(x)))) \wedge in(op(suc(k), q), adj(g, op(suc(n), f(x)))) \wedge equal(q, f(p))
                          lift for p, q conclude \exists p \exists q (in(op(k, p), adj(g, op(suc(n), f(x)))) \wedge in(op(suc(k), q), adj(g, op(suc(n), f(x)))) \wedge equal(q, f(p)))
                        }
                      }
                      case equal(k, n) {
                        pad in(op(n, x), g) conclude in(op(n, x), g) \vee equal(op(n, x), op(suc(n), f(x)))
                        apply invoke leftward adj_existence for g, op(suc(n), f(x)), op(n, x)
                        substitute in(op(n, x), adj(g, op(suc(n), f(x)))) for n[1]: k
                        substitute in(op(suc(n), f(x)), adj(g, op(suc(n), f(x)))) for n[1]: k
                        connect in(op(k, x), adj(g, op(suc(n), f(x)))) \wedge in(op(suc(k), f(x)), adj(g, op(suc(n), f(x)))) \wedge equal(f(x), f(x))
                        lift for x, f(x) conclude \exists p \exists q (in(op(k, p), adj(g, op(suc(n), f(x)))) \wedge in(op(suc(k), q), adj(g, op(suc(n), f(x)))) \wedge equal(q, f(p)))
                      }
                  }
                }
                connect approx(adj(g, op(suc(n), f(x))), suc(n), lambda a. equal(c, a), lambda p, q. equal(q, f(p)))
                connect approx(adj(g, op(suc(n), f(x))), suc(n), lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(suc(n), f(x)), adj(g, op(suc(n), f(x))))
                lift for adj(g, op(suc(n), f(x))) conclude \exists h (approx(h, suc(n), lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(suc(n), f(x)), h))
              }
              connect natural(suc(n)) \wedge \exists h (approx(h, suc(n), lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(suc(n), f(x)), h))
              fold for recursion conclude recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(suc(n), f(x))
              any y' {
                assume recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(suc(n), y') {
                  split 2 recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(suc(n), y')
                  some h' such \exists h' (approx(h', suc(n), lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(suc(n), y'), h')) {
                    split approx(h', suc(n), lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(suc(n), y'), h')
                    split approx(h', suc(n), lambda a. equal(c, a), lambda p, q. equal(q, f(p)))
                    apply suc_implies_in for n
                    apply invoke \forall k (in(k, suc(n)) \to \exists p \exists q (in(op(k, p), h') \wedge in(op(suc(k), q), h') \wedge equal(q, f(p)))) for n
                    some p, q such \exists p \exists q (in(op(n, p), h') \wedge in(op(suc(n), q), h') \wedge equal(q, f(p))) {
                      split in(op(n, p), h') \wedge in(op(suc(n), q), h') \wedge equal(q, f(p))
                      connect in(op(suc(n), q), h') \wedge in(op(suc(n), y'), h')
                      split 2 fun(h')
                      apply invoke \forall x \forall y \forall y' (in(op(x, y), h') \wedge in(op(x, y'), h') \to equal(y, y')) for suc(n), q, y'
                      substitute equal(q, f(p)) for q: y'
                      apply invoke removing_op_fun for h', suc(n), y'
                      connect fun(h') \wedge dom(h', suc(suc(n))) \wedge in(op(suc(n), y'), h')
                      apply invoke removing_op_dom for h', suc(suc(n)), suc(n), y'
                      apply invoke natural_is_irrefrelon for suc(n)
                      apply invoke rem_suc for suc(n)
                      substitute dom(rem(h', op(suc(n), y')), rem(suc(suc(n)), suc(n))) for rem(suc(suc(n)), suc(n)): suc(n)
                      some a such \exists a (in(op(emptyset, a), h') \wedge equal(c, a)) {
                        split in(op(emptyset, a), h') \wedge equal(c, a)
                        apply suc_neq_emptyset for n
                        connect in(op(emptyset, a), h') \wedge neq(suc(n), emptyset)
                        apply invoke removing_op_lem1 for h', emptyset, a, suc(n), y'
                        connect in(op(emptyset, a), rem(h', op(suc(n), y'))) \wedge equal(c, a)
                        lift for a conclude \exists a (in(op(emptyset, a), rem(h', op(suc(n), y'))) \wedge equal(c, a))
                      }
                      any k {
                        assume in(k, n) {
                          pad in(k, n) conclude in(k, n) \vee equal(k, n)
                          apply invoke leftward suc_characterization for n, k
                          apply invoke \forall k (in(k, suc(n)) \to \exists p \exists q (in(op(k, p), h') \wedge in(op(suc(k), q), h') \wedge equal(q, f(p)))) for k
                          some p', q' such \exists p \exists q (in(op(k, p), h') \wedge in(op(suc(k), q), h') \wedge equal(q, f(p))) {
                            split in(op(k, p'), h') \wedge in(op(suc(k), q'), h') \wedge equal(q', f(p'))
                            deny equal(k, suc(n)) {
                              substitute in(k, suc(n)) for k: suc(n)
                              apply invoke natural_is_irrefrelon for suc(n)
                              contradict in(suc(n), suc(n))
                            }
                            connect in(op(k, p'), h') \wedge neq(k, suc(n))
                            apply invoke removing_op_lem1 for h', k, p', suc(n), y'
                            connect in(k, n) \wedge natural(n)
                            apply invoke natural_is_trans for n, k
                            deny equal(k, n) {
                              substitute in(k, n) for k: n
                              apply invoke natural_is_irrefrelon for n
                              contradict in(n, n)
                            }
                            connect natural(k) \wedge natural(n) \wedge neq(k, n)
                            apply invoke suc_is_injection_cor1 for k, n
                            connect in(op(suc(k), q'), h') \wedge neq(suc(k), suc(n))
                            apply invoke removing_op_lem1 for h', suc(k), q', suc(n), y'
                            connect in(op(k, p'), rem(h', op(suc(n), y'))) \wedge in(op(suc(k), q'), rem(h', op(suc(n), y'))) \wedge equal(q', f(p'))
                            lift for p', q' conclude \exists p' \exists q' (in(op(k, p'), rem(h', op(suc(n), y'))) \wedge in(op(suc(k), q'), rem(h', op(suc(n), y'))) \wedge equal(q', f(p')))
                          }
                        }
                      }
                      connect approx(rem(h', op(suc(n), y')), n, lambda a. equal(c, a), lambda p, q. equal(q, f(p)))
                      deny equal(n, suc(n)) {
                        substitute in(n, suc(n)) for suc(n): n
                        apply invoke natural_is_irrefrelon for n
                        contradict in(n, n)
                      }
                      connect in(op(n, p), h') \wedge neq(n, suc(n))
                      apply invoke removing_op_lem1 for h', n, p, suc(n), y'
                      connect approx(rem(h', op(suc(n), y')), n, lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(n, p), rem(h', op(suc(n), y')))
                      lift for rem(h', op(suc(n), y')) conclude \exists g (approx(g, n, lambda a. equal(c, a), lambda p', q'. equal(q', f(p'))) \wedge in(op(n, p), g))
                      connect natural(n) \wedge \exists g (approx(g, n, lambda a. equal(c, a), lambda p, q. equal(q, f(p))) \wedge in(op(n, p), g))
                      fold for recursion conclude recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, p)
                      apply invoke \forall x' (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x') \to equal(x', x)) for p
                      substitute equal(y', f(p)) for p: x
                    }
                  }
                }
              }
              connect recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(suc(n), f(x)) \wedge \forall y' (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(suc(n), y') \to equal(y', f(x)))
              characterize for f(x) conclude \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(suc(n), x))
            }
          }
        }
        case \neg(natural(n)) {
          assume \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x)) {
            some x such \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x)) {
              split 1 recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x)
              contradict natural(n)
              explode \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(suc(n), x))
            }
          }
        }
    }
    connect inductive(lambda n. \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x)))
    apply invoke natural_induction for lambda n. \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x))
    any n {
      assume natural(n) {
        apply invoke subset(natural, lambda n. \exists! x (recursion(lambda a. equal(c, a), lambda p, q. equal(q, f(p)))(n, x))) for n
      }
    }
  }
}

definition function iterate by recursion_is_unique
existence iterate_existence \forall c \forall^F f[1] \forall n (natural(n) \to recursion(lambda a. equal(a, c), lambda p, q. equal(q, f(p)))(n, iterate(c, f, n))) by iterate
uniqueness iterate_uniqueness \forall c \forall^F f[1] \forall n (natural(n) \to \forall x (recursion(lambda a. equal(a, c), lambda p, q. equal(q, f(p)))(n, x) \to equal(x, iterate(c, f, n)))) by iterate

/* theorem iterate_characterization \forall c \forall^F f[1] (equal(iterate(c, f, emptyset), c) \wedge \forall n (natural(n) \to equal(iterate(c, f, suc(n)), f(iterate(c, f, n))))) */
