{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Proof",
	"patterns": [
		{
			"include": "#declarations"
		},
		{
			"include": "#controls"
		},
		{
			"include": "#formulas"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#comments"
		}
	],
	"repository": {
		"declarations": {
			"name": "keyword.declaration.proof",
			"match": "\\b(primitive|axiom|theorem|definition|equality|existence|uniqueness)\\b"
		},
		"controls": {
			"name": "keyword.control.proof",
			"match": "\\b(any|assume|conclude|divide|case|some|such|deny|contradict|explode|apply|for|with|lift|predicate|arity|invoke|expand|constant|by|pad|split|connect|autoexpand|function|reflection|replacement|substitute|characterize|show|tex|as|leftward|rightward|include|assert|fold|infix)\\b"
		},
		"formulas": {
			"name": "entity.name.type.proof",
			"match": "\\\\exists!|\\\\(lambda\\^P|lambda\\^F|forall\\^P|forall\\^F|forall|exists|wedge|vee|neg|to|leftrightarrow|bot)\\b"
		},
		"numbers": {
			"name": "constant.numeric.proof",
			"match": "\\b\\d+\\b"
		},
		"strings": {
			"name": "string.quoted.double.proof",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.proof",
					"match": "\\\\."
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.block.proof",
					"begin": "/\\*",
					"end": "\\*/"
				},
				{
					"name": "comment.line.double-slash.proof",
					"match": "//.*"
				}
			]
		}
	},
	"scopeName": "source.proof"
}