{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Proof",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#definitions"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.proof",
				"match": "\\b(any|assume|conclude|divide|case|some|such|deny|contradict|explode|apply|for|with|check|lift|predicate|arity|invoke|expand|constant|by|identify|pad|split|connect)\\b"
			}]
		},
		"definitions": {
			"patterns": [
				{
					"match": "\\b(atom|axiom|theorem|definition)\\s+(\\w+)",
					"captures": {
						"1": { "name": "keyword.declaration.proof"},
						"2": { "name": "entity.name.function.proof" }
					}
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.proof",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.proof",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.proof"
}